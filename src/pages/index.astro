---
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseCard from '../components/CaseCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allCases = await getCollection('cases');
const featuredCases = allCases
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

// Case images (Unsplash)
const caseImages: Record<string, string> = {
  'email-task':       'https://images.unsplash.com/photo-1596526131083-e8c633c948d2?auto=format&fit=crop&w=800&q=80',
  'dashboard':        'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80',
  'supplier-quality': 'https://images.unsplash.com/photo-1565514020179-026b92b84bb6?auto=format&fit=crop&w=800&q=80',
};
---

<BaseLayout title="TOP" description="製造業DX実行事例・AI活用・業務自動化の実践知見を発信するNaNi Execution Labの公式サイト。ETO製造業専門。">

  <!-- ═══ HERO ═══ -->
  <section style="position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;">

    <!-- Background image -->
    <div style="position:absolute;inset:0;z-index:0;">
      <img
        src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1920&q=80"
        alt="Technology background"
        style="width:100%;height:100%;object-fit:cover;opacity:0.18;"
      />
      <div style="position:absolute;inset:0;background:linear-gradient(160deg,#0c0c0e 0%,rgba(12,12,14,0.7) 50%,#0c0c0e 100%);"></div>
    </div>

    <!-- Decorative horizontal line -->
    <div style="position:absolute;top:50%;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,rgba(200,169,110,0.08),transparent);pointer-events:none;z-index:1;"></div>

    <!-- Hero content -->
    <div style="position:relative;z-index:10;max-width:56rem;margin:0 auto;padding:0 1.5rem;text-align:center;">
      <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;margin-bottom:2rem;text-transform:uppercase;">
        Manufacturing DX · AI Integration · Process Design
      </p>
      <h1 style="font-size:clamp(3rem,9vw,6rem);font-weight:100;letter-spacing:0.15em;color:#edede8;line-height:1.1;margin-bottom:1.5rem;">
        NaNi
      </h1>
      <p style="font-size:clamp(0.8rem,2vw,1rem);font-weight:300;letter-spacing:0.35em;color:rgba(255,255,255,0.35);margin-bottom:2.5rem;text-transform:uppercase;">
        Execution Lab
      </p>
      <p style="color:rgba(255,255,255,0.45);font-size:clamp(0.9rem,2.5vw,1.1rem);font-weight:300;line-height:1.9;margin-bottom:3rem;max-width:36rem;margin-left:auto;margin-right:auto;">
        データでプロセスを再設計し、<br/>価値を生む自律型仕組みを実現する。
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;">
        <a href={`${base}/cases`} style="display:inline-block;border:1px solid #c8a96e;color:#c8a96e;font-size:0.7rem;letter-spacing:0.3em;padding:1rem 2.5rem;transition:all 0.3s;" onmouseover="this.style.background='#c8a96e';this.style.color='#000'" onmouseout="this.style.background='transparent';this.style.color='#c8a96e'">
          実行事例を見る
        </a>
        <a href={`${base}/about`} style="display:inline-block;border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.5);font-size:0.7rem;letter-spacing:0.3em;padding:1rem 2.5rem;transition:all 0.3s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.6)';this.style.color='rgba(255,255,255,0.9)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='rgba(255,255,255,0.5)'">
          ABOUT
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div style="position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:0.5rem;color:rgba(255,255,255,0.15);z-index:10;">
      <span style="font-size:0.6rem;letter-spacing:0.3em;">SCROLL</span>
      <div style="width:1px;height:2rem;background:linear-gradient(to bottom,rgba(255,255,255,0.15),transparent);animation:pulse 2s infinite;"></div>
    </div>
  </section>

  <!-- ═══ TOOLS HUB (NEW) ═══ -->
  <section style="padding:5rem 1.5rem;background:linear-gradient(180deg,#0c0c0e 0%,#14100a 50%,#0c0c0e 100%);border-top:1px solid rgba(200,169,110,0.08);border-bottom:1px solid rgba(200,169,110,0.08);">
    <div style="max-width:1280px;margin:0 auto;">
      <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2.5rem;flex-wrap:wrap;gap:1rem;">
        <div>
          <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;margin-bottom:0.75rem;">🛠 TOOLS · NEW</p>
          <h2 style="font-size:clamp(1.5rem,4vw,2rem);font-weight:300;letter-spacing:0.1em;color:#edede8;margin-bottom:0.5rem;">便利ツール集</h2>
          <p style="color:rgba(255,255,255,0.4);font-size:0.85rem;">ブラウザで完結・登録不要・100% クライアントサイド処理</p>
        </div>
        <a href={`${base}/tools`} style="color:rgba(255,255,255,0.3);font-size:0.7rem;letter-spacing:0.2em;transition:color 0.2s;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">ALL TOOLS →</a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.75rem;">
        {[
          { icon:'📋', name:'役員提案書', desc:'A4一枚を5分で', href:`${base}/tools/proposal`, badge:'NEW' },
          { icon:'🔗', name:'Mermaid編集', desc:'双方向フロー図', href:`${base}/mermaid-tool`, badge:'NEW' },
          { icon:'📊', name:'JSON/CSV変換', desc:'整形・相互変換', href:`${base}/tools/json`, badge:'NEW' },
          { icon:'📱', name:'QRコード生成', desc:'URL/WiFi/連絡先', href:`${base}/tools/qr`, badge:'NEW' },
          { icon:'🔍', name:'正規表現テスター', desc:'マッチ・置換', href:`${base}/tools/regex`, badge:'NEW' },
          { icon:'⏰', name:'タイムスタンプ変換', desc:'Unix ⇄ 日時', href:`${base}/tools/timestamp`, badge:'NEW' },
          { icon:'🕐', name:'Cron式ビルダー', desc:'cron自動生成', href:`${base}/tools/cron`, badge:'NEW' },
          { icon:'💰', name:'ROI計算', desc:'投資対効果', href:`${base}/roi-calculator` },
          { icon:'📋', name:'DX成熟度診断', desc:'20問自己評価', href:`${base}/assessment` },
          { icon:'⚖️', name:'ツール比較', desc:'MES/ERP/PLM', href:`${base}/tools-comparison` },
        ].map(t => (
          <a href={t.href} style="background:rgba(17,17,20,0.7);border:1px solid rgba(255,255,255,0.07);padding:1.1rem 1.2rem;text-decoration:none;transition:all 0.2s;position:relative;display:block;" onmouseover="this.style.borderColor='rgba(200,169,110,0.5)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.07)';this.style.transform='translateY(0)'">
            {t.badge && <span style="position:absolute;top:0.5rem;right:0.5rem;color:#c8a96e;font-size:0.55rem;letter-spacing:0.2em;border:1px solid rgba(200,169,110,0.5);padding:0.1rem 0.35rem;">{t.badge}</span>}
            <div style="font-size:1.6rem;margin-bottom:0.5rem;">{t.icon}</div>
            <div style="color:#edede8;font-size:0.85rem;font-weight:400;letter-spacing:0.03em;margin-bottom:0.25rem;">{t.name}</div>
            <div style="color:rgba(255,255,255,0.45);font-size:0.7rem;">{t.desc}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CASE STUDIES ═══ -->
  <section style="padding:6rem 1.5rem;max-width:1280px;margin:0 auto;">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:4rem;flex-wrap:wrap;gap:1rem;">
      <div>
        <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:0.75rem;">CASE STUDIES</p>
        <h2 style="font-size:clamp(1.5rem,4vw,2rem);font-weight:300;letter-spacing:0.1em;color:#edede8;">実行事例</h2>
      </div>
      <a href={`${base}/cases`} style="color:rgba(255,255,255,0.3);font-size:0.7rem;letter-spacing:0.2em;transition:color 0.2s;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">ALL CASES →</a>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1px;background:rgba(255,255,255,0.04);">
      {featuredCases.map(c => (
        <CaseCard
          title={c.data.title}
          description={c.data.description}
          category={c.data.category}
          slug={c.id.replace(/\.md$/, '')}
          tags={c.data.tags}
          image={caseImages[c.id.replace(/\.md$/, '')]}
        />
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;">
    <div style="height:1px;background:linear-gradient(to right,transparent,rgba(255,255,255,0.08),transparent);"></div>
  </div>

  <!-- ═══ LEARNING SECTION FEATURE ═══ -->
  <section style="padding:5rem 1.5rem;background:linear-gradient(180deg,#0c0c0e 0%,#0d1520 50%,#0c0c0e 100%);">
    <div style="max-width:1280px;margin:0 auto;">

      <!-- Section header -->
      <div style="text-align:center;margin-bottom:3.5rem;">
        <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;margin-bottom:0.75rem;text-transform:uppercase;">Learning Roadmap</p>
        <h2 style="font-size:clamp(1.5rem,4vw,2rem);font-weight:300;letter-spacing:0.1em;color:#edede8;margin-bottom:1rem;">製造DX 学習ロードマップ</h2>
        <p style="color:rgba(255,255,255,0.4);font-size:0.875rem;font-weight:300;max-width:36rem;margin:0 auto;line-height:1.9;">
          ETO製造業のDX推進担当者向けに設計した16週間・4フェーズのカリキュラム。<br/>TPS・ECM・SPC・AI・OEEまで実務に直結した知識を体系的に学ぶ。
        </p>
      </div>

      <!-- Stats row -->
      <div style="display:flex;justify-content:center;gap:3rem;margin-bottom:3.5rem;flex-wrap:wrap;">
        {[
          { num: '16週', label: 'カリキュラム期間' },
          { num: '16テーマ', label: '学習コンテンツ' },
          { num: '約23〜24時間', label: '総学習時間' },
          { num: '4フェーズ', label: '段階的構成' },
        ].map(stat => (
          <div style="text-align:center;">
            <div style="font-size:clamp(1.5rem,4vw,2rem);font-weight:200;color:#c8a96e;letter-spacing:0.1em;margin-bottom:0.25rem;">{stat.num}</div>
            <div style="font-size:0.65rem;letter-spacing:0.2em;color:rgba(255,255,255,0.3);">{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- 4 Phase cards -->
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1rem;margin-bottom:3rem;">
        {[
          {
            num: '01',
            label: 'Phase 1',
            title: 'ビジネス基盤',
            weeks: 'Week 1–4',
            color: '#4a9eff',
            desc: '製造業のビジネスモデル・ETO/MTO・業務プロセス設計・設計変更管理（ECM）の基礎を習得する。',
            topics: ['ETOビジネスモデル', '業務フロー設計', 'ECM基礎', '設計変更台帳'],
          },
          {
            num: '02',
            label: 'Phase 2',
            title: '製造技術基盤',
            weeks: 'Week 5–9',
            color: '#4ec97a',
            desc: '製造展開・生産技術・品質統計（SPC）・設備管理・調達管理の実務知識を深める。',
            topics: ['OEE・TPM', 'SPC・管理図', 'FMEA', '調達管理'],
          },
          {
            num: '03',
            label: 'Phase 3',
            title: 'DX実装基盤',
            weeks: 'Week 10–12',
            color: '#e8a84a',
            desc: 'データ収集設計・IT基盤・AI活用・PoC設計・ダッシュボード構築の実践スキルを身につける。',
            topics: ['記録情報設計', 'ITインフラ設計', 'AI活用', '標準化'],
          },
          {
            num: '04',
            label: 'Phase 4',
            title: '高度化・推進',
            weeks: 'Week 13–16',
            color: '#c8a96e',
            desc: '標準化・KPI管理・経営報告・推進体制の構築。DX推進担当者として組織を動かす力を養う。',
            topics: ['KPI設計', '効果測定', '経営報告', '推進体制'],
          },
        ].map(phase => (
          <div style={`background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-top:2px solid ${phase.color};padding:1.75rem;transition:border-color 0.2s;`}
               onmouseover={`this.style.borderColor='${phase.color}';this.style.borderTopColor='${phase.color}'`}
               onmouseout="this.style.borderColor='rgba(255,255,255,0.06)';this.style.borderTopColor=this.style.borderTopColor">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1rem;">
              <div>
                <span style={`color:${phase.color};font-size:0.65rem;letter-spacing:0.3em;`}>{phase.label}</span>
                <h3 style="font-size:1.1rem;font-weight:300;color:#edede8;margin-top:0.25rem;letter-spacing:0.05em;">{phase.title}</h3>
              </div>
              <span style="color:rgba(255,255,255,0.2);font-size:0.65rem;letter-spacing:0.15em;white-space:nowrap;">{phase.weeks}</span>
            </div>
            <p style="color:rgba(255,255,255,0.5);font-size:0.8rem;line-height:1.8;margin-bottom:1.25rem;">{phase.desc}</p>
            <div style="display:flex;flex-wrap:wrap;gap:0.375rem;">
              {phase.topics.map(topic => (
                <span style={`font-size:0.65rem;padding:0.2rem 0.6rem;border:1px solid ${phase.color}30;color:${phase.color}99;letter-spacing:0.05em;`}>{topic}</span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div style="text-align:center;">
        <a
          href={`${base}/learning`}
          style="display:inline-block;background:linear-gradient(135deg,rgba(200,169,110,0.12) 0%,rgba(200,169,110,0.06) 100%);border:1px solid #c8a96e;color:#c8a96e;font-size:0.7rem;letter-spacing:0.35em;padding:1rem 3rem;transition:all 0.3s;text-transform:uppercase;"
          onmouseover="this.style.background='#c8a96e';this.style.color='#000'"
          onmouseout="this.style.background='linear-gradient(135deg,rgba(200,169,110,0.12) 0%,rgba(200,169,110,0.06) 100%)';this.style.color='#c8a96e'"
        >
          学習ロードマップを見る →
        </a>
      </div>

    </div>
  </section>

  <!-- ═══ VISUAL BANNER ═══ -->
  <section style="position:relative;height:28rem;overflow:hidden;margin:0;">
    <img
      src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=1920&q=80"
      alt="Smart manufacturing"
      style="width:100%;height:100%;object-fit:cover;opacity:0.25;"
    />
    <div style="position:absolute;inset:0;background:linear-gradient(to right,#0c0c0e 30%,transparent 70%);"></div>
    <div style="position:absolute;inset:0;display:flex;align-items:center;padding:0 8vw;">
      <div style="max-width:32rem;">
        <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;margin-bottom:1.5rem;">APPROACH</p>
        <h2 style="font-size:clamp(1.5rem,4vw,2.5rem);font-weight:100;color:#edede8;letter-spacing:0.08em;line-height:1.5;margin-bottom:1.5rem;">
          現場の課題を、<br/>データで解く。
        </h2>
        <p style="color:rgba(255,255,255,0.4);font-size:0.875rem;line-height:1.9;">
          製造業特有の複雑な業務フローを分析し、<br/>再現性ある仕組みへと変換する。
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ NEWS ═══ -->
  <section style="padding:6rem 1.5rem;max-width:1280px;margin:0 auto;">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:4rem;flex-wrap:wrap;gap:1rem;">
      <div>
        <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:0.75rem;">LATEST NEWS</p>
        <h2 style="font-size:clamp(1.5rem,4vw,2rem);font-weight:300;letter-spacing:0.1em;color:#edede8;">ニュース</h2>
      </div>
      <a href={`${base}/news`} style="color:rgba(255,255,255,0.3);font-size:0.7rem;letter-spacing:0.2em;transition:color 0.2s;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">ALL NEWS →</a>
    </div>
    <div style="max-width:48rem;">
      {latestNews.map(n => (
        <BlogCard
          title={n.data.title}
          date={n.data.date}
          slug={n.id.replace(/\.md$/, '')}
          type="news"
          category={n.data.category}
        />
      ))}
    </div>
  </section>

  <!-- ═══ CONCEPT ═══ -->
  <section style="position:relative;padding:8rem 1.5rem;overflow:hidden;">
    <img
      src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1920&q=80"
      alt="Data center"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.08;"
    />
    <div style="position:absolute;inset:0;background:#0f0f14;opacity:0.85;"></div>
    <div style="position:relative;z-index:1;max-width:48rem;margin:0 auto;text-align:center;">
      <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;margin-bottom:2rem;">CONCEPT</p>
      <blockquote style="font-size:clamp(1.25rem,3.5vw,1.75rem);font-weight:100;color:#edede8;line-height:1.8;letter-spacing:0.05em;margin-bottom:2rem;">
        「データでプロセスを再設計し、<br/>
        価値を生む自律型仕組みを実現する。」
      </blockquote>
      <p style="color:rgba(255,255,255,0.35);font-size:0.875rem;line-height:1.9;max-width:32rem;margin:0 auto;">
        製造業の現場で積み上げたDX経験とAIを活用した業務自動化の実践事例を発信しています。
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }
</style>
