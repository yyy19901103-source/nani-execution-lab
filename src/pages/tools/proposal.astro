---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="役員提案書ジェネレーター — 製造部長向け"
  description="製造部門の部長が経営会議・役員承認を得るためのA4一枚エグゼクティブサマリー作成ツール。投資提案・DXプロジェクト・改善施策のプレゼン資料を5分で生成。"
>

  <!-- ═══════════════ HERO (CINEMATIC) ═══════════════ -->
  <div class="cinema-hero">
    <div class="hero-bg-gradient"></div>
    <div class="hero-bg-grid"></div>
    <div class="hero-spotlight"></div>

    <div class="hero-content">
      <p class="hero-marquee" data-reveal="fade-up" data-delay="400">
        <span class="reel-dot"></span>
        <span>REEL 01 · EXECUTIVE PROPOSAL</span>
        <span class="reel-dot"></span>
      </p>

      <h1 class="hero-title" id="hero-title" data-reveal="letters" data-delay="700">役員提案書ジェネレーター</h1>

      <div class="hero-rule" data-reveal="draw" data-delay="1600"></div>

      <p class="hero-sub" data-reveal="fade-up" data-delay="1900">
        製造部長が <span class="hero-accent">5 分</span> で作る A4 一枚のエグゼクティブサマリー
      </p>

      <div class="hero-credits" data-reveal="fade-up" data-delay="2200">
        <span>DIRECTED BY YOU</span>
        <span class="hero-credits-sep">·</span>
        <span>PRESENTED TO THE BOARD</span>
      </div>
    </div>
  </div>

  <div style="max-width:1500px;margin:0 auto;padding:1.5rem 1rem 4rem;">

    <!-- Toolbar -->
    <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:0.75rem 1rem;margin-bottom:0.75rem;display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;">
      <span style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.3em;">TEMPLATE</span>
      <select id="template-select" class="m-select">
        <option value="investment">💰 投資提案</option>
        <option value="dx">🚀 DXプロジェクト</option>
        <option value="quality">✅ 品質改善</option>
        <option value="kpi">📊 KPI報告</option>
        <option value="risk">⚠️ リスク対応</option>
        <option value="blank">📝 ブランク</option>
      </select>

      <span style="color:rgba(255,255,255,0.15);margin:0 0.25rem;">|</span>

      <span style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.3em;">PREVIEW</span>
      <button class="m-btn-ghost theme-btn active" data-theme="print">印刷用（白）</button>
      <button class="m-btn-ghost theme-btn" data-theme="dark">ダーク</button>

      <span style="flex:1;"></span>

      <button id="btn-reset" class="m-btn-ghost">🔄 リセット</button>
      <button id="btn-print" class="m-btn">🖨 印刷 / PDF</button>
      <button id="btn-png" class="m-btn">⬇ PNG</button>
      <button id="btn-md" class="m-btn-ghost">📋 Markdown</button>
    </div>

    <!-- Main Grid -->
    <div style="display:grid;grid-template-columns:420px 1fr;gap:0.75rem;" id="main-grid">

      <!-- Form -->
      <div style="display:flex;flex-direction:column;gap:0.75rem;max-height:calc(100vh - 2rem);overflow:auto;padding-right:0.25rem;">

        <div class="form-section">
          <p class="section-label">① タイトル・対象</p>
          <label class="field-label">議題タイトル</label>
          <input id="f-title" class="m-input" placeholder="例: ライン3 MES導入による工程管理高度化">

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;margin-top:0.6rem;">
            <div>
              <label class="field-label">対象会議</label>
              <input id="f-meeting" class="m-input" placeholder="例: 経営会議">
            </div>
            <div>
              <label class="field-label">日付</label>
              <input id="f-date" type="date" class="m-input">
            </div>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;margin-top:0.6rem;">
            <div>
              <label class="field-label">提案者</label>
              <input id="f-author" class="m-input" placeholder="例: 製造部長 山田">
            </div>
            <div>
              <label class="field-label">決裁者</label>
              <input id="f-approver" class="m-input" placeholder="例: 工場長">
            </div>
          </div>
        </div>

        <div class="form-section">
          <p class="section-label">② 結論（ワンライン）</p>
          <textarea id="f-conclusion" class="m-input m-area" rows="2" placeholder="一言で: 何に・いくら投資・どれだけの効果"></textarea>
          <label class="field-label" style="margin-top:0.6rem;">意思決定を求める事項</label>
          <input id="f-ask" class="m-input" placeholder="例: XX万円の予算承認">
        </div>

        <div class="form-section">
          <p class="section-label">③ 背景・課題</p>
          <textarea id="f-problem" class="m-input m-area" rows="4" placeholder="・現状の問題&#10;・定量的な影響&#10;・このまま放置した場合のリスク"></textarea>
        </div>

        <div class="form-section">
          <p class="section-label">④ 解決策</p>
          <textarea id="f-solution" class="m-input m-area" rows="4" placeholder="・具体的な施策&#10;・なぜこれが有効か&#10;・代替案を検討した結果"></textarea>
        </div>

        <div class="form-section">
          <p class="section-label">⑤ 期待効果</p>
          <label class="field-label">定量効果（1行1項目）</label>
          <textarea id="f-effect-q" class="m-input m-area" rows="3" placeholder="工数削減: 年間 XXX 時間 (約 XXX 万円)&#10;不良率: X.X% → X.X%&#10;リードタイム: X日 → X日"></textarea>
          <label class="field-label" style="margin-top:0.5rem;">定性効果</label>
          <textarea id="f-effect-n" class="m-input m-area" rows="2" placeholder="・属人化の解消&#10;・顧客満足度向上&#10;・他ラインへの横展開可能"></textarea>
        </div>

        <div class="form-section">
          <p class="section-label">⑥ 投資額</p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
            <div>
              <label class="field-label">初期投資（万円）</label>
              <input id="f-cost-init" type="number" class="m-input" min="0" placeholder="1500">
            </div>
            <div>
              <label class="field-label">年間運用費（万円）</label>
              <input id="f-cost-run" type="number" class="m-input" min="0" placeholder="300">
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;margin-top:0.5rem;">
            <div>
              <label class="field-label">年間効果額（万円）</label>
              <input id="f-benefit" type="number" class="m-input" min="0" placeholder="1200">
            </div>
            <div>
              <label class="field-label">評価期間（年）</label>
              <input id="f-years" type="number" class="m-input" min="1" max="10" value="3">
            </div>
          </div>
          <div style="margin-top:0.6rem;padding:0.6rem 0.8rem;background:#0a0a0c;border-left:2px solid #c8a96e;font-size:0.75rem;color:rgba(255,255,255,0.7);">
            <div id="calc-payback">回収期間: —</div>
            <div id="calc-roi">累積効果: —</div>
          </div>
        </div>

        <div class="form-section">
          <p class="section-label">⑦ スケジュール</p>
          <textarea id="f-schedule" class="m-input m-area" rows="4" placeholder="1Q: 要件定義・ベンダー選定&#10;2Q: 設計・PoC&#10;3Q: 実装・試運用&#10;4Q: 本格運用"></textarea>
        </div>

        <div class="form-section">
          <p class="section-label">⑧ リスクと対策</p>
          <textarea id="f-risk" class="m-input m-area" rows="3" placeholder="リスクA → 対策&#10;リスクB → 対策"></textarea>
        </div>

      </div>

      <!-- Preview -->
      <div id="preview-wrap" style="background:#0a0a0c;border:1px solid rgba(255,255,255,0.07);padding:1.25rem;overflow:auto;">
        <div id="preview" class="preview-print"></div>
      </div>

    </div>

  </div>

  <style>
    /* ═══════════════ PAGE CINEMATIC EFFECTS ═══════════════ */
    /* Global overlays are in BaseLayout. This page adds hero-specific effects only. */

    /* Hero */
    .cinema-hero {
      position: relative;
      height: 28rem;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #08080a;
    }
    .hero-bg-gradient {
      position: absolute; inset: 0;
      background:
        radial-gradient(circle at 30% 40%, rgba(200,169,110,0.15), transparent 50%),
        radial-gradient(circle at 70% 60%, rgba(200,169,110,0.08), transparent 55%),
        linear-gradient(135deg, #0c0c0e 0%, #1a1409 60%, #0c0c0e 100%);
      animation: bgDrift 18s ease-in-out infinite alternate;
    }
    @keyframes bgDrift {
      0% { transform: scale(1) translate(0,0); filter: hue-rotate(0deg); }
      100% { transform: scale(1.15) translate(-2%,-1%); filter: hue-rotate(-8deg); }
    }
    .hero-bg-grid {
      position: absolute; inset: 0; opacity: 0.05;
      background-image:
        repeating-linear-gradient(0deg,transparent,transparent 60px,rgba(200,169,110,0.5) 60px,rgba(200,169,110,0.5) 61px),
        repeating-linear-gradient(90deg,transparent,transparent 60px,rgba(200,169,110,0.5) 60px,rgba(200,169,110,0.5) 61px);
    }
    .hero-spotlight {
      position: absolute;
      top: 50%; left: 50%;
      width: 120vmax; height: 120vmax;
      transform: translate(-50%,-50%);
      background: radial-gradient(circle, rgba(200,169,110,0.1) 0%, transparent 35%);
      animation: spotlightPulse 6s ease-in-out infinite alternate;
    }
    @keyframes spotlightPulse {
      0% { opacity: 0.7; transform: translate(-50%,-50%) scale(1); }
      100% { opacity: 1; transform: translate(-50%,-50%) scale(1.2); }
    }

    .hero-content {
      position: relative; z-index: 2; text-align: center; padding: 0 2rem;
    }
    .hero-marquee {
      display: inline-flex; align-items: center; gap: 0.9rem;
      color: #c8a96e;
      font-size: 0.6rem; letter-spacing: 0.6em;
      text-transform: uppercase;
      margin-bottom: 1.8rem;
      font-weight: 500;
    }
    .reel-dot {
      width: 6px; height: 6px; border-radius: 50%; background: #c8a96e;
      box-shadow: 0 0 12px rgba(200,169,110,0.8);
      animation: reelPulse 2s ease-in-out infinite;
    }
    .reel-dot:nth-child(3) { animation-delay: 1s; }
    @keyframes reelPulse {
      0%,100% { opacity: 0.3; transform: scale(0.8); }
      50% { opacity: 1; transform: scale(1); }
    }

    .hero-title {
      font-size: clamp(2rem, 6vw, 3.5rem);
      font-weight: 200;
      letter-spacing: 0.22em;
      color: #edede8;
      margin-bottom: 1.3rem;
      line-height: 1.15;
      text-shadow:
        0 0 40px rgba(200,169,110,0.2),
        0 2px 20px rgba(0,0,0,0.6);
    }
    .hero-title .char {
      display: inline-block;
      opacity: 0;
      transform: translateY(20px) scale(0.9);
      filter: blur(8px);
    }
    .hero-title.revealed .char {
      animation: charReveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes charReveal {
      0% { opacity: 0; transform: translateY(20px) scale(0.9); filter: blur(8px); }
      100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
    }

    .hero-rule {
      width: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, #c8a96e 20%, #c8a96e 80%, transparent);
      margin: 0 auto 1.5rem;
      box-shadow: 0 0 12px rgba(200,169,110,0.5);
    }
    .hero-rule.revealed {
      animation: ruleDraw 1.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes ruleDraw {
      0% { width: 0; }
      100% { width: 340px; }
    }

    .hero-sub {
      color: rgba(255,255,255,0.55);
      font-size: clamp(0.88rem, 1.6vw, 1.05rem);
      font-weight: 300;
      letter-spacing: 0.08em;
      margin-bottom: 1.6rem;
    }
    .hero-accent {
      color: #c8a96e;
      font-weight: 500;
      position: relative;
      padding: 0 0.2em;
    }
    .hero-accent::after {
      content: '';
      position: absolute; left: 0; bottom: -2px; right: 0; height: 1px;
      background: #c8a96e;
      transform: scaleX(0); transform-origin: left;
      animation: accentUnderline 0.8s 2.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes accentUnderline { to { transform: scaleX(1); } }

    .hero-credits {
      color: rgba(200,169,110,0.5);
      font-size: 0.6rem; letter-spacing: 0.5em;
      text-transform: uppercase;
    }
    .hero-credits-sep {
      margin: 0 0.7em; opacity: 0.5;
    }

    /* Reveal animations (scroll) */
    [data-reveal] {
      opacity: 0;
      transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1), transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }
    [data-reveal="fade-up"] { transform: translateY(24px); }
    [data-reveal].revealed { opacity: 1; transform: translateY(0); }

    /* Form sections stagger */
    .form-section {
      transition: transform 0.25s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .form-section:hover {
      border-color: rgba(200,169,110,0.22);
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }

    /* Counter text (numbers that tick up) */
    .counter { font-variant-numeric: tabular-nums; }

    /* Preview 3D tilt */
    #preview-wrap {
      perspective: 1800px;
      transition: box-shadow 0.4s ease;
    }
    #preview {
      transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
      will-change: transform;
    }
    #preview.template-switch {
      animation: dissolve 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @keyframes dissolve {
      0% { opacity: 1; filter: blur(0); transform: translateY(0) scale(1); }
      40% { opacity: 0; filter: blur(10px); transform: translateY(-6px) scale(0.985); }
      60% { opacity: 0; filter: blur(10px); transform: translateY(6px) scale(1.015); }
      100% { opacity: 1; filter: blur(0); transform: translateY(0) scale(1); }
    }

    /* KPI cards in preview — dramatic entrance */
    .p-box {
      position: relative; overflow: hidden;
    }
    .p-box::before {
      content: '';
      position: absolute;
      top: 0; left: -100%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(200,169,110,0.15), transparent);
      animation: shimmer 3s ease-in-out infinite;
    }
    @keyframes shimmer {
      0% { left: -100%; }
      60%, 100% { left: 200%; }
    }

    /* Gold shimmer buttons */
    .m-btn {
      position: relative; overflow: hidden;
    }
    .m-btn::before {
      content: '';
      position: absolute; top: 0; left: -100%;
      width: 60%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.35), transparent);
      transition: left 0.6s ease;
    }
    .m-btn:hover::before { left: 120%; }

    /* Input focus glow */
    .m-input:focus {
      box-shadow: 0 0 0 1px rgba(200,169,110,0.4), 0 0 16px rgba(200,169,110,0.15);
    }

    /* Template select with subtle cinematic flair */
    #template-select {
      background-image: linear-gradient(135deg, rgba(200,169,110,0.08), transparent);
    }

    /* Counter badge ASK */
    [class*="p-highlight"] {
      position: relative;
    }

    /* Scrollbar */
    .form-section + .form-section { }

    /* Disable cinematic animations for reduced-motion users */
    @media (prefers-reduced-motion: reduce) {
      #cinema-curtain, .letterbox, #film-grain, .hero-bg-gradient, .hero-spotlight,
      .reel-dot, .p-box::before, .m-btn::before {
        animation: none !important;
      }
      .hero-title .char, .hero-rule, [data-reveal] {
        opacity: 1 !important; transform: none !important; filter: none !important;
        width: 340px !important;
      }
      .hero-title.revealed .char { animation: none; }
    }

    /* ═══════════════ ORIGINAL STYLES (unchanged) ═══════════════ */
    .m-select, .m-btn, .m-btn-ghost, .m-input {
      background:#0a0a0c;color:#edede8;border:1px solid rgba(255,255,255,0.1);
      padding:0.48rem 0.75rem;font-size:0.78rem;cursor:pointer;font-family:inherit;letter-spacing:0.03em;transition:all 0.15s;
      outline:none;
    }
    .m-btn-ghost:hover,.m-select:hover { border-color:#c8a96e;color:#c8a96e; }
    .m-btn-ghost.active { background:rgba(200,169,110,0.15);border-color:#c8a96e;color:#c8a96e; }
    .m-btn { background:#c8a96e;color:#0c0c0e;border-color:#c8a96e;font-weight:600; }
    .m-btn:hover { background:#d4b87b; }
    .m-input { width:100%;cursor:text;font-size:0.82rem; }
    .m-input:focus { border-color:#c8a96e; }
    .m-area { resize:vertical;font-family:inherit;line-height:1.5; }
    .form-section {
      background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1rem 1.1rem;
    }
    .section-label {
      color:#c8a96e;font-size:0.62rem;letter-spacing:0.3em;margin-bottom:0.75rem;
    }
    .field-label {
      display:block;color:rgba(255,255,255,0.55);font-size:0.66rem;letter-spacing:0.06em;margin-bottom:0.28rem;
    }

    /* --- Preview A4 page --- */
    #preview {
      max-width:880px;margin:0 auto;padding:2.2rem 2.5rem;min-height:1150px;
      box-shadow:0 4px 24px rgba(0,0,0,0.4);
      font-family:'Hiragino Kaku Gothic ProN', 'Yu Gothic', sans-serif;
    }
    .preview-print { background:#ffffff;color:#1a1a1a; }
    .preview-dark { background:#0f0f12;color:#edede8; }

    .preview-print .p-title { color:#0a0a0c; }
    .preview-print .p-sub { color:#555; }
    .preview-print .p-accent { color:#a48344; }
    .preview-print .p-section { border-left:3px solid #a48344; }
    .preview-print .p-box { background:#f9f6ef;border:1px solid #e4d9b8; }
    .preview-print .p-highlight { background:#fdf6e3;border-left:4px solid #a48344; }
    .preview-print .p-table th { background:#f0eadc;color:#333; }
    .preview-print .p-table td,.preview-print .p-table th { border-color:#ddd;color:#333; }
    .preview-print .p-label { color:#888; }
    .preview-print .p-divider { border-color:#e0e0e0; }

    .preview-dark .p-title { color:#edede8; }
    .preview-dark .p-sub { color:rgba(255,255,255,0.5); }
    .preview-dark .p-accent { color:#c8a96e; }
    .preview-dark .p-section { border-left:3px solid #c8a96e; }
    .preview-dark .p-box { background:#161618;border:1px solid rgba(200,169,110,0.3); }
    .preview-dark .p-highlight { background:rgba(200,169,110,0.08);border-left:4px solid #c8a96e; }
    .preview-dark .p-table th { background:#1c1c22;color:#c8a96e; }
    .preview-dark .p-table td,.preview-dark .p-table th { border-color:rgba(255,255,255,0.1);color:#edede8; }
    .preview-dark .p-label { color:rgba(255,255,255,0.4); }
    .preview-dark .p-divider { border-color:rgba(255,255,255,0.08); }

    @media(max-width:1100px){ #main-grid { grid-template-columns:1fr !important; } }

    @media print {
      body > * { visibility:hidden !important; }
      #preview-wrap, #preview-wrap * { visibility:visible !important; }
      #preview-wrap {
        position:absolute;left:0;top:0;padding:0;border:none;background:white;width:100%;
      }
      #preview {
        box-shadow:none;min-height:auto;background:white !important;color:black !important;
      }
    }
  </style>

  <script is:inline src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.min.js"></script>

  <script is:inline>
    const TEMPLATES = {
      investment: {
        title: 'ライン3 MES導入による工程管理高度化',
        meeting: '経営会議',
        author: '製造部長',
        approver: '工場長',
        conclusion: 'MES導入により工程可視化と品質トレーサビリティを実現し、年間1,200万円の効果を創出。1.8年で投資回収見込み。',
        ask: 'MES導入に関する初期投資 1,500万円の承認',
        problem: '・紙ベースの工程管理で実績収集に1日/週の工数が発生\n・不適合時の原因究明に平均3日要し、再発防止サイクルが遅い\n・品質記録の保管・検索コストが年々増加',
        solution: '・オープン系MESを基幹系ERPとAPI連携\n・IoTゲートウェイで設備データを自動収集\n・ダッシュボード・アラートを現場タブレットに配信\n・ベンダー3社比較の結果、B社を選定（ライフサイクルコスト最小）',
        effectQ: '工数削減: 年間 1,800時間 (900万円相当)\n不良率: 1.2% → 0.6%\nリードタイム: 平均7日 → 4日',
