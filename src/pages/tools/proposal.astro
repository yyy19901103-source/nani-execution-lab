      const text = $title.textContent;
      $title.textContent = '';
      [...text].forEach((c, i) => {
        const span = document.createElement('span');
        span.className = 'char';
        span.textContent = c === ' ' ? '\u00A0' : c;
        span.style.animationDelay = (0.7 + i * 0.05) + 's';
        $title.appendChild(span);
      });
      setTimeout(() => $title.classList.add('revealed'), 100);
    })();

    // 2. Reveal animations for data-reveal elements
    (function setupReveals() {
      const elements = document.querySelectorAll('[data-reveal]');
      elements.forEach(el => {
        const delay = Number(el.dataset.delay) || 0;
        setTimeout(() => el.classList.add('revealed'), delay);
      });

      // Also reveal form sections when scrolled into view
      const formSections = document.querySelectorAll('.form-section');
      if ('IntersectionObserver' in window && !reduceMotion) {
        formSections.forEach((s, i) => {
          s.style.opacity = '0';
          s.style.transform = 'translateY(18px)';
          s.style.transition = 'opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1)';
          s.style.transitionDelay = (i * 0.06) + 's';
        });
        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.style.opacity = '';
              e.target.style.transform = '';
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.05 });
        setTimeout(() => formSections.forEach(s => io.observe(s)), 2500);
      }
    })();

    // 3. Counter animation (number tick-up)
    const counterCache = new WeakMap();
    function animateCounter(el, to) {
      if (reduceMotion) { el.textContent = to.toLocaleString(); return; }
      const from = counterCache.get(el) || 0;
      const duration = 900;
      const t0 = performance.now();
      function step(now) {
        const t = Math.min(1, (now - t0) / duration);
        const eased = 1 - Math.pow(1 - t, 3);
        const val = Math.round(from + (to - from) * eased);
        el.textContent = val.toLocaleString();
        if (t < 1) requestAnimationFrame(step);
        else counterCache.set(el, to);
      }
      requestAnimationFrame(step);
    }

    // Patch render function to animate numbers
    const origRender = render;
    render = function() {
      origRender();
      requestAnimationFrame(() => {
        const cards = $preview.querySelectorAll('[data-counter]');
        cards.forEach(c => {
          const target = Number(c.dataset.counter);
          if (!isNaN(target)) animateCounter(c, target);
        });
      });
    };

    // 4. Template switch dissolve
    const $templateSel = document.getElementById('template-select');
    const origChange = $templateSel.onchange;
    $templateSel.addEventListener('change', () => {
      if (reduceMotion) return;
      $preview.classList.remove('template-switch');
      void $preview.offsetWidth;
      $preview.classList.add('template-switch');
    });

    // 5. 3D tilt effect on preview
    (function setupTilt() {
      if (reduceMotion) return;
      const $wrap = document.getElementById('preview-wrap');
      let rect = null;
      let rafId = null;
      function onMove(e) {
        if (!rect) rect = $wrap.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width;
        const y = (e.clientY - rect.top) / rect.height;
        const rx = (0.5 - y) * 4;
        const ry = (x - 0.5) * 4;
        if (rafId) cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(() => {
          $preview.style.transform = 'rotateX(' + rx.toFixed(2) + 'deg) rotateY(' + ry.toFixed(2) + 'deg) translateZ(0)';
        });
      }
      function onLeave() {
        rect = null;
        if (rafId) cancelAnimationFrame(rafId);
        $preview.style.transform = '';
      }
      $wrap.addEventListener('mousemove', onMove);
      $wrap.addEventListener('mouseleave', onLeave);
      window.addEventListener('resize', () => { rect = null; });
    })();

    // 6. Form focus -> subtle hero dim (ambient cinema effect)
    (function setupAmbientFocus() {
      const $hero = document.querySelector('.cinema-hero');
      if (!$hero) return;
      let focused = 0;
      document.addEventListener('focusin', (e) => {
        if (e.target.closest('.form-section')) {
          focused++;
          $hero.style.transition = 'filter 0.6s ease';
          $hero.style.filter = 'brightness(0.7) saturate(0.85)';
        }
      });
      document.addEventListener('focusout', (e) => {
        if (e.target.closest('.form-section')) {
          focused--;
          if (focused <= 0) {
            focused = 0;
            $hero.style.filter = '';
          }
        }
      });
    })();

    // 7. KPI cards counter markup injection (enhance render output)
    // Re-inject counter data attributes after each render
    const kpiObserver = new MutationObserver(() => {
      const boxes = $preview.querySelectorAll('.p-box');
      if (boxes.length !== 4) return;
      const vals = [
        { el: boxes[0].querySelector('.p-accent'), get: () => Number(document.getElementById('f-cost-init').value) || 0 },
        { el: boxes[1].querySelector('.p-accent'), get: () => Number(document.getElementById('f-benefit').value) || 0 },
        { el: boxes[2].querySelector('.p-accent'), get: () => null }, // payback is text like "1.8年"
        { el: boxes[3].querySelector('.p-accent'), get: () => null }  // cumulative has +/- sign, handled separately
      ];
      vals.forEach(v => {
        if (!v.el) return;
        const n = v.get();
        if (n == null) return;
        // Find the first number-like run of digits in the current text
        const match = v.el.textContent.match(/-?[\d,]+/);
        if (!match) return;
        const current = Number(match[0].replace(/,/g, ''));
        if (current !== n) return;
        // Set up animation by replacing the number span
        const prefix = v.el.innerHTML.split(match[0])[0];
        const suffix = v.el.innerHTML.split(match[0])[1] || '';
        v.el.innerHTML = prefix + '<span class="counter" data-to="' + n + '">0</span>' + suffix;
        const ce = v.el.querySelector('.counter');
        if (ce) animateCounter(ce, n);
      });
    });
    kpiObserver.observe($preview, { childList: true, subtree: false });

  </script>

</BaseLayout>
