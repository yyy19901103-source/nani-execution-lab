      return '<ul style="margin:0;padding-left:1.1rem;font-size:0.82rem;line-height:1.7;">' +
             lines.map(l => '<li>' + escHtml(l) + '</li>').join('') + '</ul>';
    }

    function quantLines(text) {
      const lines = text.split(/\r?\n/).map(l => l.trim()).filter(Boolean);
      if (!lines.length) return '<p class="p-label" style="font-size:0.78rem;">（未記入）</p>';
      return '<div style="display:flex;flex-direction:column;gap:0.35rem;">' + lines.map(l => {
        const [k, v] = l.includes(':') ? [l.split(':')[0], l.split(':').slice(1).join(':').trim()] :
                       l.includes('：') ? [l.split('：')[0], l.split('：').slice(1).join('：').trim()] :
                       [l, ''];
        return '<div style="display:flex;gap:0.75rem;font-size:0.82rem;">' +
               '<span class="p-label" style="min-width:140px;">' + escHtml(k) + '</span>' +
               '<strong class="p-accent">' + escHtml(v) + '</strong></div>';
      }).join('') + '</div>';
