---
import BaseLayout from '../layouts/BaseLayout.astro';

const email = 'yyy19901103@gmail.com';
---

<BaseLayout title="CONTACT" description="NaNi Execution Lab へのお問い合わせ。製造業DX・AI活用のご相談はこちら。">
  <div style="padding-top:8rem;padding-bottom:3rem;max-width:1280px;margin:0 auto;padding-left:1.5rem;padding-right:1.5rem;">
    <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:1rem;">CONTACT</p>
    <h1 style="font-size:clamp(2rem,6vw,3.5rem);font-weight:100;letter-spacing:0.15em;color:#edede8;margin-bottom:1rem;">Contact</h1>
    <p style="color:rgba(255,255,255,0.35);font-size:0.875rem;line-height:1.8;max-width:32rem;">
      事例に関するご質問、取り組みへの連携、技術相談などお気軽にご連絡ください。
    </p>
  </div>

  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem 8rem;">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:4rem;max-width:56rem;">

      <!-- Email -->
      <div>
        <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:1.5rem;">EMAIL</p>
        <p style="color:rgba(255,255,255,0.45);font-size:0.875rem;line-height:1.9;margin-bottom:2rem;">
          以下のメールアドレスへ直接ご連絡ください。<br/>
          通常2〜3営業日以内に返信いたします。
        </p>
        <a
          href={`mailto:${email}`}
          style="display:inline-flex;align-items:center;gap:0.75rem;border:1px solid #c8a96e;color:#c8a96e;font-size:0.75rem;letter-spacing:0.2em;padding:1rem 2rem;transition:all 0.3s;text-decoration:none;"
          onmouseover="this.style.background='#c8a96e';this.style.color='#000'"
          onmouseout="this.style.background='transparent';this.style.color='#c8a96e'"
        >
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <span>メールを送る</span>
        </a>
        <p style="color:rgba(255,255,255,0.2);font-size:0.7rem;margin-top:0.875rem;letter-spacing:0.05em;">{email}</p>
      </div>

      <!-- Guidelines -->
      <div>
        <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:1.5rem;">GUIDELINES</p>
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          {[
            { title: 'ご相談歓迎', body: '製造業DX・業務自動化に関するご相談はお気軽にどうぞ。' },
            { title: '取材・登壇', body: '事例の取材・勉強会・セミナーへの登壇依頼も受け付けています。' },
            { title: '技術コラボ', body: '同じ課題に取り組む方との情報交換・コラボレーションも歓迎します。' },
          ].map(item => (
            <div style="border-left:1px solid rgba(255,255,255,0.1);padding-left:1rem;">
              <div style="color:#edede8;font-size:0.85rem;font-weight:400;margin-bottom:0.375rem;">{item.title}</div>
              <div style="color:rgba(255,255,255,0.4);font-size:0.78rem;line-height:1.8;">{item.body}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
