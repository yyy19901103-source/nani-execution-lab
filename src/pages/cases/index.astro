---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';
import { getCollection } from 'astro:content';

const cases = await getCollection('cases');
const sorted = cases.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="事例一覧" description="製造業DXの実行事例。メール自動化・ダッシュボード統合・サプライヤー品質管理。">
  <div style="padding-top:8rem;padding-bottom:3rem;max-width:1280px;margin:0 auto;padding-left:1.5rem;padding-right:1.5rem;">
    <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:1rem;">CASE STUDIES</p>
    <h1 style="font-size:clamp(2rem,6vw,3.5rem);font-weight:100;letter-spacing:0.15em;color:#edede8;margin-bottom:1rem;">実行事例</h1>
    <p style="color:rgba(255,255,255,0.35);font-size:0.875rem;line-height:1.8;max-width:32rem;">
      実際に現場で導入・運用した仕組みの記録。背景から成果まで詳細に公開しています。
    </p>
  </div>

  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem 8rem;">
    {sorted.length > 0 ? (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1px;background:rgba(255,255,255,0.04);">
        {sorted.map(c => (
          <CaseCard
            title={c.data.title}
            description={c.data.description}
            category={c.data.category}
            slug={c.id.replace(/\.md$/, '')}
            tags={c.data.tags}
          />
        ))}
      </div>
    ) : (
      <p style="color:rgba(255,255,255,0.2);text-align:center;padding:6rem 0;font-size:0.875rem;letter-spacing:0.2em;">準備中</p>
    )}
  </div>
</BaseLayout>
