---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';
import { getCollection } from 'astro:content';

const cases = await getCollection('cases');
const sorted = cases.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const caseImages: Record<string, string> = {
  'email-task':       'https://images.unsplash.com/photo-1596526131083-e8c633c948d2?auto=format&fit=crop&w=800&q=80',
  'dashboard':        'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80',
  'supplier-quality': 'https://images.unsplash.com/photo-1565514020179-026b92b84bb6?auto=format&fit=crop&w=800&q=80',
};

// Collect all categories
const allCategories = [...new Set(sorted.map(c => c.data.category).filter(Boolean))].sort();
---

<BaseLayout title="事例一覧" description="製造DX実行事例一覧。設計変更自動化・OEE監視・トレーサビリティデジタル化など実務事例を公開。">

  <!-- Page Hero -->
  <div style="position:relative;height:22rem;overflow:hidden;">
    <img
      src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=1920&q=80"
      alt="Manufacturing cases"
      style="width:100%;height:100%;object-fit:cover;opacity:0.2;"
    />
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom,#0c0c0e 0%,transparent 30%,rgba(12,12,14,0.9) 100%);"></div>
    <div style="position:absolute;bottom:3rem;left:0;right:0;max-width:1280px;margin:0 auto;padding:0 1.5rem;">
      <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:1rem;">CASE STUDIES</p>
      <h1 style="font-size:clamp(2rem,6vw,3.5rem);font-weight:100;letter-spacing:0.15em;color:#edede8;margin-bottom:0.75rem;">実行事例</h1>
      <p style="color:rgba(255,255,255,0.45);font-size:0.9rem;line-height:1.8;max-width:40rem;">
        ETO製造業における実装事例。設計から運用まで、実際に動いている仕組みを公開します。
      </p>
    </div>
  </div>

  <div style="max-width:1280px;margin:0 auto;padding:3rem 1.5rem 8rem;">

    {sorted.length > 0 ? (
      <>
        <!-- Category filter + count -->
        <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:2rem;">
          <div style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;">
            <span style="font-size:0.65rem;color:rgba(255,255,255,0.25);letter-spacing:0.1em;margin-right:0.25rem;">カテゴリ：</span>
            <button
              data-cat="all"
              onclick="filterByCat('all')"
              style="font-size:0.62rem;letter-spacing:0.1em;padding:0.3rem 0.75rem;border:1px solid #c8a96e;background:rgba(200,169,110,0.12);color:#c8a96e;cursor:pointer;transition:all 0.15s;"
              class="cat-btn active-cat"
            >
              すべて
            </button>
            {allCategories.map(cat => (
              <button
                data-cat={cat}
                onclick={`filterByCat('${cat}')`}
                style="font-size:0.62rem;letter-spacing:0.05em;padding:0.3rem 0.75rem;border:1px solid rgba(255,255,255,0.1);background:transparent;color:rgba(255,255,255,0.4);cursor:pointer;transition:all 0.15s;"
                class="cat-btn"
              >
                {cat}
              </button>
            ))}
          </div>
          <p id="case-count" style="color:rgba(255,255,255,0.2);font-size:0.72rem;letter-spacing:0.08em;white-space:nowrap;">{sorted.length}件の事例</p>
        </div>

        <!-- Cases grid -->
        <div id="cases-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1px;background:rgba(255,255,255,0.04);">
          {sorted.map(c => (
            <div
              class="case-item"
              data-category={c.data.category ?? ''}
            >
              <CaseCard
                title={c.data.title}
                description={c.data.description}
                category={c.data.category}
                slug={c.id.replace(/\.md$/, '')}
                tags={c.data.tags}
                image={caseImages[c.id.replace(/\.md$/, '')]}
              />
            </div>
          ))}
        </div>
      </>
    ) : (
      <p style="color:rgba(255,255,255,0.2);text-align:center;padding:6rem 0;font-size:0.875rem;letter-spacing:0.2em;">準備中</p>
    )}
  </div>
</BaseLayout>

<style>
  .cat-btn.active-cat {
    border-color: #c8a96e !important;
    background: rgba(200,169,110,0.12) !important;
    color: #c8a96e !important;
  }
</style>

<script is:inline>
  function filterByCat(cat) {
    const items = document.querySelectorAll('.case-item');
    const buttons = document.querySelectorAll('.cat-btn');
    const countEl = document.getElementById('case-count');
    const grid = document.getElementById('cases-grid');
    let visible = 0;

    buttons.forEach(btn => {
      if (btn.dataset.cat === cat) {
        btn.classList.add('active-cat');
        btn.style.borderColor = '#c8a96e';
        btn.style.background = 'rgba(200,169,110,0.12)';
        btn.style.color = '#c8a96e';
      } else {
        btn.classList.remove('active-cat');
        btn.style.borderColor = 'rgba(255,255,255,0.1)';
        btn.style.background = 'transparent';
        btn.style.color = 'rgba(255,255,255,0.4)';
      }
    });

    items.forEach(item => {
      const itemCat = item.dataset.category || '';
      const show = cat === 'all' || itemCat === cat;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (countEl) {
      countEl.textContent = cat === 'all'
        ? `${items.length}件の事例`
        : `${visible}件の事例（${cat}）`;
    }
  }
</script>
