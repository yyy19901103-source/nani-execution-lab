---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map(c => ({
    params: { slug: c.id.replace(/\.md$/, '') },
    props: { entry: c },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={entry.data.title} description={entry.data.description}>

  <!-- Breadcrumb -->
  <div style="padding-top:5.5rem;max-width:1280px;margin:0 auto;padding-left:1.5rem;padding-right:1.5rem;">
    <div style="display:flex;align-items:center;gap:0.5rem;color:rgba(255,255,255,0.25);font-size:0.7rem;letter-spacing:0.08em;padding-top:1rem;">
      <a href={`${base}/`} style="transition:color 0.2s;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='rgba(255,255,255,0.25)'">TOP</a>
      <span>/</span>
      <a href={`${base}/cases`} style="transition:color 0.2s;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='rgba(255,255,255,0.25)'">事例</a>
      <span>/</span>
      <span style="color:rgba(255,255,255,0.5);">{entry.data.title}</span>
    </div>
  </div>

  <!-- Article Header -->
  <header style="padding:3rem 1.5rem 2.5rem;max-width:1280px;margin:0 auto;border-bottom:1px solid rgba(255,255,255,0.06);">
    <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:1rem;text-transform:uppercase;">{entry.data.category}</p>
    <h1 style="font-size:clamp(1.5rem,4vw,2.75rem);font-weight:300;letter-spacing:0.05em;color:#edede8;line-height:1.4;margin-bottom:1rem;">{entry.data.title}</h1>
    <p style="color:rgba(255,255,255,0.45);font-size:0.9rem;line-height:1.8;max-width:48rem;">{entry.data.description}</p>
    {entry.data.tags && entry.data.tags.length > 0 && (
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:1.25rem;">
        {entry.data.tags.map((tag: string) => (
          <span style="font-size:0.65rem;color:rgba(255,255,255,0.25);border:1px solid rgba(255,255,255,0.1);padding:0.15rem 0.6rem;">{tag}</span>
        ))}
      </div>
    )}
  </header>

  <!-- Article Body -->
  <article class="prose-custom" style="max-width:56rem;margin:0 auto;padding:3rem 1.5rem;">
    <Content />
  </article>

  <!-- Back link -->
  <div style="max-width:56rem;margin:0 auto;padding:0 1.5rem 6rem;">
    <a href={`${base}/cases`} style="display:inline-flex;align-items:center;gap:0.5rem;color:rgba(255,255,255,0.3);font-size:0.7rem;letter-spacing:0.2em;transition:color 0.2s;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
      <span>←</span><span>事例一覧へ戻る</span>
    </a>
  </div>

</BaseLayout>
