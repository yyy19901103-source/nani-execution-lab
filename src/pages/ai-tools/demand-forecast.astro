---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="需要予測（AI時系列分析）" description="Holt-Winters三重指数平滑化による月次需要予測。トレンド・季節性を自動検出し、95%信頼区間つきで3〜12ヶ月先を予測。ブラウザ完結型。">

  <!-- Security Banner -->
  <div style="background:rgba(200,169,110,0.08);border-left:3px solid #c8a96e;padding:0.85rem 1.25rem;font-size:0.78rem;color:#edede8;letter-spacing:0.03em;display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;justify-content:space-between;">
    <div>🔒 <strong>機密保護: 全処理ブラウザ完結</strong> — 入力データは外部送信されません</div>
    <button id="verify-privacy" style="background:transparent;border:1px solid rgba(200,169,110,0.3);color:#c8a96e;padding:0.3rem 0.75rem;font-size:0.7rem;cursor:pointer;font-family:inherit;letter-spacing:0.05em;border-radius:0;transition:all 0.15s;">検証方法を見る ▼</button>
  </div>
  <div id="privacy-detail" style="display:none;background:#0a0a0c;border-left:3px solid #c8a96e;border-bottom:1px solid rgba(200,169,110,0.15);padding:1.25rem 1.75rem;font-size:0.78rem;color:rgba(237,237,232,0.75);line-height:1.7;">
    <p style="color:#c8a96e;font-size:0.7rem;letter-spacing:0.2em;margin-bottom:0.6rem;">VERIFY YOURSELF</p>
    <ol style="margin:0;padding-left:1.25rem;">
      <li>ブラウザの DevTools を開く（F12 / Ctrl+Shift+I）</li>
      <li><code style="background:#111114;padding:0.1em 0.4em;color:#c8a96e;">Network</code> タブを選択</li>
      <li>このページで計算を実行</li>
      <li>新規ネットワーク通信が <strong>発生しないこと</strong> を確認</li>
    </ol>
    <p style="margin-top:0.8rem;color:rgba(255,255,255,0.5);font-size:0.72rem;">通信は CDN ライブラリ初回読込のみ（Chart.js / TF.js）。データを入れた後は完全ローカル処理です。</p>
  </div>

  <!-- Hero -->
  <div style="position:relative;height:12rem;overflow:hidden;display:flex;align-items:center;justify-content:center;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#0c0c0e 0%,#0d1a12 60%,#0c0c0e 100%);"></div>
    <div style="position:relative;z-index:1;text-align:center;padding:0 1.5rem;">
      <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;margin-bottom:0.85rem;text-transform:uppercase;">AI Time-Series Analysis</p>
      <h1 style="font-size:clamp(1.5rem,4vw,2.1rem);font-weight:200;letter-spacing:0.15em;color:#edede8;">需要予測</h1>
      <p style="color:rgba(237,237,232,0.5);font-size:0.78rem;margin-top:0.6rem;letter-spacing:0.05em;">Holt-Winters 三重指数平滑化 · トレンド + 季節性 · 95% 信頼区間</p>
    </div>
  </div>

  <div style="max-width:1100px;margin:0 auto;padding:1.5rem 1rem 4rem;">

    <!-- Parameters & Controls -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;" id="ctrl-grid">

      <!-- Parameters -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">PARAMETERS</p>
        <div style="display:flex;flex-direction:column;gap:0.85rem;">
          <div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
              <label class="field-label">α (レベル平滑化)</label>
              <span id="alpha-val" style="color:#c8a96e;font-size:0.75rem;font-variant-numeric:tabular-nums;">0.30</span>
            </div>
            <input id="alpha" type="range" min="0.05" max="0.95" step="0.05" value="0.3" class="slider">
          </div>
          <div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
              <label class="field-label">β (トレンド平滑化)</label>
              <span id="beta-val" style="color:#c8a96e;font-size:0.75rem;font-variant-numeric:tabular-nums;">0.10</span>
            </div>
            <input id="beta" type="range" min="0.01" max="0.5" step="0.01" value="0.1" class="slider">
          </div>
          <div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
              <label class="field-label">γ (季節性平滑化)</label>
              <span id="gamma-val" style="color:#c8a96e;font-size:0.75rem;font-variant-numeric:tabular-nums;">0.20</span>
            </div>
            <input id="gamma" type="range" min="0.01" max="0.5" step="0.01" value="0.2" class="slider">
          </div>
          <div>
            <label class="field-label" style="margin-bottom:0.35rem;">予測期間</label>
            <div style="display:flex;gap:0.5rem;">
              <button class="period-btn active" data-period="3">3ヶ月</button>
              <button class="period-btn" data-period="6">6ヶ月</button>
              <button class="period-btn" data-period="12">12ヶ月</button>
            </div>
          </div>
          <div>
            <label class="field-label" style="margin-bottom:0.35rem;">予測モデル</label>
            <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
              <button class="model-btn active" data-model="hw">Holt-Winters</button>
              <button class="model-btn" data-model="sma">季節MA</button>
              <button class="model-btn" data-model="linseason">線形+季節</button>
              <button class="model-btn" data-model="ensemble">アンサンブル</button>
              <button class="model-btn" data-model="best">自動ベスト</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Data input -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">DATA</p>
        <div style="display:flex;flex-direction:column;gap:0.65rem;">
          <p style="color:rgba(255,255,255,0.5);font-size:0.72rem;line-height:1.6;">
            CSV形式: <code style="background:#0a0a0c;padding:0.1em 0.4em;color:#c8a96e;">year_month,quantity</code><br>
            例: <code style="background:#0a0a0c;padding:0.1em 0.4em;color:rgba(255,255,255,0.6);">2024-01,820</code>（最低14ヶ月必要）
          </p>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
            <button id="btn-sample" class="m-btn-ghost">サンプルデータ読込</button>
            <label class="m-btn-ghost" style="cursor:pointer;">
              CSV アップロード
              <input id="csv-upload" type="file" accept=".csv,text/csv" style="display:none;">
            </label>
          </div>
          <div id="data-status" style="color:rgba(255,255,255,0.4);font-size:0.7rem;min-height:1.2em;"></div>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
            <button id="btn-run" class="m-btn" disabled>予測実行</button>
            <button id="btn-autotune" class="m-btn-ghost" disabled>自動最適化</button>
            <button id="btn-reset" class="m-btn-ghost">リセット</button>
          </div>
          <div id="autotune-progress" style="display:none;">
            <div id="autotune-label" style="color:#c8a96e;font-size:0.7rem;margin-bottom:0.3rem;">グリッド探索中…</div>
            <div style="background:#1a1a1d;height:6px;border-radius:3px;overflow:hidden;">
              <div id="autotune-bar" style="background:#c8a96e;height:100%;width:0%;transition:width 0.1s;"></div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Data Preview -->
    <div id="preview-section" style="display:none;background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-bottom:1rem;">
      <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:0.8rem;">DATA PREVIEW</p>
      <div style="position:relative;height:120px;">
        <canvas id="preview-chart"></canvas>
      </div>
    </div>

    <!-- Chart -->
    <div id="chart-section" style="display:none;">
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.5rem;margin-bottom:1rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">FORECAST CHART</p>
        <div style="position:relative;height:320px;">
          <canvas id="forecast-chart"></canvas>
        </div>
      </div>

      <!-- Metrics -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1rem;" id="metrics-grid">
        <div class="metric-card">
          <div class="metric-label">MAPE</div>
          <div class="metric-value" id="mape-val">—</div>
          <div class="metric-sub">平均絶対パーセント誤差</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">MAE</div>
          <div class="metric-value" id="mae-val">—</div>
          <div class="metric-sub">平均絶対誤差</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">データ数</div>
          <div class="metric-value" id="data-count">—</div>
          <div class="metric-sub">実績データ月数</div>
        </div>
      </div>

      <!-- Model comparison -->
      <div id="model-compare-section" style="display:none;background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.5rem;margin-bottom:1rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">MODEL COMPARISON</p>
        <div style="overflow-x:auto;">
          <table id="model-compare-table" style="width:100%;border-collapse:collapse;font-size:0.78rem;"></table>
        </div>
      </div>

      <!-- Forecast table -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">FORECAST SUMMARY</p>
        <div style="overflow-x:auto;">
          <table id="forecast-table" style="width:100%;border-collapse:collapse;font-size:0.78rem;"></table>
        </div>
      </div>
      <div style="margin-top:1rem;text-align:right;">
        <button id="btn-download" class="m-btn-ghost" style="font-size:0.7rem;">📥 結果をCSVでダウンロード</button>
      </div>
    </div>

  </div>

  <style>
    .m-btn, .m-btn-ghost, .period-btn, .model-btn {
      background:#0a0a0c;color:#edede8;border:1px solid rgba(255,255,255,0.1);
      padding:0.42rem 0.75rem;font-size:0.72rem;cursor:pointer;font-family:inherit;letter-spacing:0.05em;transition:all 0.15s;
    }
    .m-btn-ghost:hover, .period-btn:hover, .model-btn:hover { border-color:#c8a96e;color:#c8a96e; }
    .period-btn.active, .model-btn.active { background:rgba(200,169,110,0.15);border-color:#c8a96e;color:#c8a96e; }
    .slider:disabled { opacity:0.35;cursor:not-allowed; }
    .m-btn { background:#c8a96e;color:#0c0c0e;border-color:#c8a96e;font-weight:600; }
    .m-btn:hover:not(:disabled) { background:#d4b87b; }
    .m-btn:disabled { opacity:0.4;cursor:not-allowed; }
    .field-label { display:block;color:rgba(255,255,255,0.55);font-size:0.68rem;letter-spacing:0.08em; }
    .slider { width:100%;accent-color:#c8a96e;cursor:pointer; }
    .metric-card { background:#0f0f12;border:1px solid rgba(255,255,255,0.07);padding:1.25rem;text-align:center; }
    .metric-label { color:#c8a96e;font-size:0.6rem;letter-spacing:0.35em;margin-bottom:0.5rem; }
    .metric-value { color:#edede8;font-size:1.6rem;font-weight:200;letter-spacing:0.05em;margin-bottom:0.3rem; }
    .metric-sub { color:rgba(255,255,255,0.4);font-size:0.65rem; }
    table th { color:#c8a96e;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;padding:0.5rem 1rem;border-bottom:1px solid rgba(255,255,255,0.07);text-align:left;font-weight:400; }
    table td { color:#edede8;font-size:0.78rem;padding:0.5rem 1rem;border-bottom:1px solid rgba(255,255,255,0.04); }
    table tr:last-child td { border-bottom:none; }
    table td.gold { color:#c8a96e; }
    @media(max-width:700px){
      #ctrl-grid { grid-template-columns:1fr !important; }
      #metrics-grid { grid-template-columns:1fr !important; }
    }
  </style>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

  <script is:inline>
    // ---- Performance helpers ----
    function debounce(fn, wait) {
      let t;
      return function(...args) {
        clearTimeout(t);
        t = setTimeout(() => fn.apply(this, args), wait);
      };
    }
    function throttleRAF(fn) {
      let scheduled = false;
      return function(...args) {
        if (scheduled) return;
        scheduled = true;
        requestAnimationFrame(() => {
          scheduled = false;
          fn.apply(this, args);
        });
      };
    }
    // Dynamic point radius based on dataset size
    function dynPointRadius(n) {
      if (n <= 50) return 3;
      if (n <= 200) return 1.5;
      if (n <= 500) return 0.5;
      return 0;
    }

    // ---- LRU Cache ----
    function createLRU(maxSize) {
      const map = new Map();
      return {
        get(key) {
          if (!map.has(key)) return undefined;
          const v = map.get(key);
          map.delete(key);
          map.set(key, v);
          return v;
        },
        set(key, value) {
          if (map.has(key)) map.delete(key);
          else if (map.size >= maxSize) {
            const firstKey = map.keys().next().value;
            map.delete(firstKey);
          }
          map.set(key, value);
        },
        clear() { map.clear(); },
        size() { return map.size; }
      };
    }
    function _dataHash(data) {
      return data.slice(0, 5).join(',') + ':' + data.slice(-5).join(',') + ':' + data.length;
    }
    const _hwCache = createLRU(50);
    const _smaCache = createLRU(50);
    const _lsCache = createLRU(50);

    // ---- Sample data ----
    const sampleData = {
      labels: ['2024-01','2024-02','2024-03','2024-04','2024-05','2024-06',
               '2024-07','2024-08','2024-09','2024-10','2024-11','2024-12',
               '2025-01','2025-02','2025-03','2025-04','2025-05','2025-06',
               '2025-07','2025-08','2025-09','2025-10','2025-11','2025-12'],
      values: [820, 760, 890, 950, 1020, 1150, 1280, 1350, 1100, 980, 850, 920,
               870, 810, 950, 1010, 1090, 1220, 1360, 1430, 1180, 1050, 920, 990]
    };

    // ---- Holt-Winters ----
    function holtWinters(data, alpha, beta, gamma, season, forecastPeriods) {
      if (data.length < season + 2) return null;
      let level = data[0];
      let trend = (data[season] - data[0]) / season;
      let seasonals = Array.from({length: season}, (_, i) => data[i] / (level + i * trend));

      let fitted = [];
      for (let i = 0; i < data.length; i++) {
        let s = seasonals[i % season];
        let prevLevel = level;
        let prevTrend = trend;
        level = alpha * (data[i] / s) + (1 - alpha) * (prevLevel + prevTrend);
        trend = beta * (level - prevLevel) + (1 - beta) * prevTrend;
        seasonals[i % season] = gamma * (data[i] / level) + (1 - gamma) * s;
        fitted.push((level + trend) * seasonals[i % season]);
      }

      let forecast = [];
      for (let h = 1; h <= forecastPeriods; h++) {
        forecast.push((level + h * trend) * seasonals[(data.length + h - 1) % season]);
      }

      let mape = fitted.slice(season).reduce((sum, f, i) =>
        sum + Math.abs((data[i + season] - f) / data[i + season]), 0) / (data.length - season) * 100;

      let mae = fitted.slice(season).reduce((sum, f, i) =>
        sum + Math.abs(data[i + season] - f), 0) / (data.length - season);

      return { fitted, forecast, mape, mae };
    }

    // ---- Seasonal Moving Average ----
    function seasonalMA(data, season, forecastPeriods) {
      try {
        if (data.length < season + 1) return null;
        const seasonals = Array(season).fill(0);
        const counts = Array(season).fill(0);
        const overallMean = data.reduce((a,b) => a+b, 0) / data.length;
        if (overallMean === 0) return null;
        for (let i = 0; i < data.length; i++) {
          seasonals[i % season] += data[i] / overallMean;
          counts[i % season]++;
        }
        for (let i = 0; i < season; i++) {
          seasonals[i] = counts[i] > 0 ? seasonals[i] / counts[i] : 1;
        }
        const earlyMean = data.slice(0, season).reduce((a,b) => a+b, 0) / season;
        const lateMean = data.slice(-season).reduce((a,b) => a+b, 0) / season;
        const trendPerPeriod = (lateMean - earlyMean) / Math.max(1, data.length - season);

        const fitted = data.map((_, i) => {
          if (i < season) return data[i];
          return overallMean * seasonals[i % season] + trendPerPeriod * (i - season/2);
        });

        const forecast = [];
        const baseRatio = lateMean / overallMean;
        for (let h = 1; h <= forecastPeriods; h++) {
          const seasIdx = (data.length + h - 1) % season;
          const v = (lateMean + trendPerPeriod * h) * (baseRatio === 0 ? 1 : seasonals[seasIdx] / baseRatio);
          forecast.push(v);
        }

        const tail = fitted.slice(season);
        const denom = data.length - season;
        let mape = denom > 0 ? tail.reduce((sum, f, i) =>
          sum + (data[i+season] !== 0 ? Math.abs((data[i+season] - f) / data[i+season]) : 0), 0) / denom * 100 : NaN;
        let mae = denom > 0 ? tail.reduce((sum, f, i) =>
          sum + Math.abs(data[i+season] - f), 0) / denom : NaN;
        return { fitted, forecast, mape, mae };
      } catch (e) { console.error('seasonalMA', e); return null; }
    }

    // ---- Linear Trend + Seasonal ----
    function linearSeasonal(data, season, forecastPeriods) {
      try {
        if (data.length < season + 2) return null;
        const n = data.length;
        const overallMean = data.reduce((a,b) => a+b, 0) / n;
        if (overallMean === 0) return null;
        const seasonals = Array(season).fill(0);
        const counts = Array(season).fill(0);
        for (let i = 0; i < n; i++) {
          seasonals[i % season] += data[i];
          counts[i % season]++;
        }
        for (let i = 0; i < season; i++) {
          seasonals[i] = counts[i] > 0 ? (seasonals[i] / counts[i]) / overallMean : 1;
        }
        let sumX = 0, sumY = 0, sumXY = 0, sumXX = 0;
        for (let i = 0; i < n; i++) {
          sumX += i; sumY += data[i]; sumXY += i * data[i]; sumXX += i * i;
        }
        const denomR = (n * sumXX - sumX * sumX);
        const slope = denomR === 0 ? 0 : (n * sumXY - sumX * sumY) / denomR;
        const intercept = (sumY - slope * sumX) / n;
        const fitted = data.map((_, i) => (intercept + slope * i) * seasonals[i % season]);
        const forecast = [];
        for (let h = 1; h <= forecastPeriods; h++) {
          forecast.push((intercept + slope * (n + h - 1)) * seasonals[(n + h - 1) % season]);
        }
        let mape = fitted.reduce((sum, f, i) =>
          sum + (data[i] !== 0 ? Math.abs((data[i] - f) / data[i]) : 0), 0) / n * 100;
        let mae = fitted.reduce((sum, f, i) => sum + Math.abs(data[i] - f), 0) / n;
        return { fitted, forecast, mape, mae };
      } catch (e) { console.error('linearSeasonal', e); return null; }
    }

    // ---- Memoize forecast functions ----
    const _hwOrig = holtWinters;
    holtWinters = function(data, alpha, beta, gamma, season, fp) {
      const key = data.length + ':' + alpha + ':' + beta + ':' + gamma + ':' + season + ':' + fp + ':' + _dataHash(data);
      const c = _hwCache.get(key);
      if (c !== undefined) return c;
      const r = _hwOrig(data, alpha, beta, gamma, season, fp);
      if (r) _hwCache.set(key, r);
      return r;
    };
    const _smaOrig = seasonalMA;
    seasonalMA = function(data, season, fp) {
      const key = data.length + ':' + season + ':' + fp + ':' + _dataHash(data);
      const c = _smaCache.get(key);
      if (c !== undefined) return c;
      const r = _smaOrig(data, season, fp);
      if (r) _smaCache.set(key, r);
      return r;
    };
    const _lsOrig = linearSeasonal;
    linearSeasonal = function(data, season, fp) {
      const key = data.length + ':' + season + ':' + fp + ':' + _dataHash(data);
      const c = _lsCache.get(key);
      if (c !== undefined) return c;
      const r = _lsOrig(data, season, fp);
      if (r) _lsCache.set(key, r);
      return r;
    };

    function confidenceInterval(data, fitted, forecast, z) {
      z = z || 1.96;
      let errors = fitted.slice(12).map((f, i) => data[i + 12] - f);
      let std = Math.sqrt(errors.reduce((s, e) => s + e * e, 0) / errors.length);
      return forecast.map((f, h) => ({
        lower: f - z * std * Math.sqrt(h + 1),
        upper: f + z * std * Math.sqrt(h + 1)
      }));
    }

    // ---- State ----
    let currentData = null;
    let forecastPeriods = 3;
    let chartInstance = null;
    let previewInstance = null;
    let lastForecastResult = null;
    let lastForecastLabels = null;
    let lastCI = null;
    let selectedModel = 'hw';     // 'hw' | 'sma' | 'linseason' | 'ensemble' | 'best'
    let lastModelComparison = null;
    let lastSelectedLabel = 'Holt-Winters';

    // ---- DOM refs ----
    const statusEl = document.getElementById('data-status');
    const btnRun = document.getElementById('btn-run');
    const chartSection = document.getElementById('chart-section');

    // ---- Sliders ----
    ['alpha','beta','gamma'].forEach(id => {
      const slider = document.getElementById(id);
      const display = document.getElementById(id + '-val');
      slider.addEventListener('input', () => {
        display.textContent = parseFloat(slider.value).toFixed(2);
      });
    });

    // ---- Period buttons ----
    document.querySelectorAll('.period-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        forecastPeriods = parseInt(btn.dataset.period, 10);
      });
    });

    // ---- Model buttons ----
    function updateSliderEnabled() {
      const enabled = (selectedModel === 'hw' || selectedModel === 'ensemble' || selectedModel === 'best');
      ['alpha','beta','gamma'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.disabled = !enabled;
      });
      const at = document.getElementById('btn-autotune');
      if (at) at.disabled = !enabled || !currentData;
    }
    document.querySelectorAll('.model-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.model-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        selectedModel = btn.dataset.model;
        updateSliderEnabled();
      });
    });

    // ---- Sample load ----
    document.getElementById('btn-sample').addEventListener('click', () => {
      currentData = { labels: sampleData.labels.slice(), values: sampleData.values.slice() };
      statusEl.textContent = 'サンプルデータ読込完了: ' + currentData.values.length + ' ヶ月分';
      btnRun.disabled = false;
      const at = document.getElementById('btn-autotune'); if (at) at.disabled = false;
      drawPreview();
    });

    // ---- CSV upload ----
    document.getElementById('csv-upload').addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function(ev) {
        const text = ev.target.result;
        const lines = text.trim().split(/\r?\n/).filter(l => l.trim());
        const labels = [], values = [];
        let skipped = 0;
        for (const line of lines) {
          const parts = line.split(',');
          if (parts.length < 2) { skipped++; continue; }
          const label = parts[0].trim();
          const val = parseFloat(parts[1].trim());
          if (isNaN(val)) { skipped++; continue; }
          labels.push(label);
          values.push(val);
        }
        if (values.length < 14) {
          statusEl.textContent = 'エラー: 最低14ヶ月分のデータが必要です（現在: ' + values.length + '）';
          btnRun.disabled = true;
          return;
        }
        currentData = { labels, values };
        statusEl.textContent = 'CSV読込完了: ' + values.length + ' ヶ月分' + (skipped ? '（' + skipped + '行スキップ）' : '');
        btnRun.disabled = false;
        const at = document.getElementById('btn-autotune'); if (at) at.disabled = false;
        drawPreview();
      };
      reader.readAsText(file);
    });

    // ---- Run forecast ----
    document.getElementById('btn-run').addEventListener('click', runForecast);

    function nextMonthLabel(label, n) {
      // label like "2025-12"
      try {
        const [y, m] = label.split('-').map(Number);
        let date = new Date(y, m - 1 + n);
        return date.getFullYear() + '-' + String(date.getMonth() + 1).padStart(2, '0');
      } catch(e) {
        return 'F+' + n;
      }
    }

    function runForecast() {
      if (!currentData) return;
      const alpha = parseFloat(document.getElementById('alpha').value);
      const beta = parseFloat(document.getElementById('beta').value);
      const gamma = parseFloat(document.getElementById('gamma').value);

      // Compute all candidate models for comparison
      const vals = currentData.values;
      const candidates = {};
      try {
        candidates.hw = holtWinters(vals, alpha, beta, gamma, 12, forecastPeriods);
      } catch (e) { console.error(e); candidates.hw = null; }
      try { candidates.sma = seasonalMA(vals, 12, forecastPeriods); } catch (e) { console.error(e); candidates.sma = null; }
      try { candidates.linseason = linearSeasonal(vals, 12, forecastPeriods); } catch (e) { console.error(e); candidates.linseason = null; }

      const modelLabels = { hw: 'Holt-Winters', sma: '季節MA', linseason: '線形+季節', ensemble: 'アンサンブル平均', best: '自動ベスト選択' };
      let result = null;
      let chosenKey = selectedModel;

      if (selectedModel === 'hw') {
        result = candidates.hw;
      } else if (selectedModel === 'sma') {
        result = candidates.sma;
      } else if (selectedModel === 'linseason') {
        result = candidates.linseason;
      } else if (selectedModel === 'ensemble') {
        const avail = ['hw','sma','linseason'].map(k => candidates[k]).filter(r => r && r.fitted && r.forecast);
        if (avail.length > 0) {
          const fLen = avail[0].fitted.length;
          const fcLen = avail[0].forecast.length;
          const fitted = Array(fLen).fill(0);
          const forecast = Array(fcLen).fill(0);
          for (const r of avail) {
            for (let i = 0; i < fLen; i++) fitted[i] += r.fitted[i] / avail.length;
            for (let i = 0; i < fcLen; i++) forecast[i] += r.forecast[i] / avail.length;
          }
          let mape = fitted.slice(12).reduce((s, f, i) =>
            s + (vals[i+12] !== 0 ? Math.abs((vals[i+12] - f) / vals[i+12]) : 0), 0) / Math.max(1, vals.length - 12) * 100;
          let mae = fitted.slice(12).reduce((s, f, i) =>
            s + Math.abs(vals[i+12] - f), 0) / Math.max(1, vals.length - 12);
          result = { fitted, forecast, mape, mae };
        }
      } else if (selectedModel === 'best') {
        let bestKey = null, bestMape = Infinity;
        ['hw','sma','linseason'].forEach(k => {
          const r = candidates[k];
          if (r && isFinite(r.mape) && r.mape < bestMape) { bestMape = r.mape; bestKey = k; }
        });
        if (bestKey) { result = candidates[bestKey]; chosenKey = bestKey; }
      }

      if (!result) {
        statusEl.textContent = 'エラー: データが不足しています（最低14ヶ月必要）または選択モデルで計算失敗';
        return;
      }
      lastSelectedLabel = modelLabels[selectedModel] + (selectedModel === 'best' && chosenKey !== 'best' ? ' (' + modelLabels[chosenKey] + ')' : '');
      lastModelComparison = { candidates, chosenKey, selectedMode: selectedModel };

      const ci = currentData.values.length > 12
        ? confidenceInterval(currentData.values, result.fitted, result.forecast, 1.96)
        : result.forecast.map(() => ({ lower: 0, upper: 0 }));
      lastCI = ci;

      // Forecast labels
      const lastLabel = currentData.labels[currentData.labels.length - 1];
      const forecastLabels = Array.from({length: forecastPeriods}, (_, i) => nextMonthLabel(lastLabel, i + 1));
      lastForecastResult = result;
      lastForecastLabels = forecastLabels;

      // Update metrics
      document.getElementById('mape-val').textContent = result.mape.toFixed(1) + '%';
      document.getElementById('mae-val').textContent = Math.round(result.mae).toLocaleString();
      document.getElementById('data-count').textContent = currentData.values.length;

      // Build chart
      const allLabels = [...currentData.labels, ...forecastLabels];

      const actualData = currentData.values.map((v, i) => ({ x: currentData.labels[i], y: v }));
      const fittedData = result.fitted.map((v, i) => ({ x: currentData.labels[i], y: Math.round(v) }));

      const forecastDataPts = result.forecast.map((v, i) => ({ x: forecastLabels[i], y: Math.round(v) }));
      // Connect last actual to first forecast
      const forecastLine = [
        { x: currentData.labels[currentData.labels.length - 1], y: currentData.values[currentData.values.length - 1] },
        ...forecastDataPts
      ];

      const ciUpperData = [
        { x: currentData.labels[currentData.labels.length - 1], y: currentData.values[currentData.values.length - 1] },
        ...ci.map((c, i) => ({ x: forecastLabels[i], y: Math.round(c.upper) }))
      ];
      const ciLowerData = [
        { x: currentData.labels[currentData.labels.length - 1], y: currentData.values[currentData.values.length - 1] },
        ...ci.map((c, i) => ({ x: forecastLabels[i], y: Math.round(c.lower) }))
      ];

      if (chartInstance) chartInstance.destroy();

      const ctx = document.getElementById('forecast-chart').getContext('2d');
      const _actualPR = dynPointRadius(actualData.length);
      chartInstance = new Chart(ctx, {
        type: 'line',
        data: {
          labels: allLabels,
          datasets: [
            {
              label: '信頼区間 上限',
              data: ciUpperData,
              borderColor: 'transparent',
              backgroundColor: 'rgba(200,169,110,0.15)',
              fill: '+1',
              pointRadius: 0,
              tension: 0.3,
              spanGaps: true
            },
            {
              label: '信頼区間 下限',
              data: ciLowerData,
              borderColor: 'transparent',
              backgroundColor: 'rgba(200,169,110,0.15)',
              fill: false,
              pointRadius: 0,
              tension: 0.3,
              spanGaps: true
            },
            {
              label: '実績',
              data: actualData,
              borderColor: '#c8a96e',
              backgroundColor: 'transparent',
              borderWidth: 2,
              pointRadius: _actualPR,
              pointBackgroundColor: '#c8a96e',
              tension: 0.2,
              spanGaps: true
            },
            {
              label: 'フィッティング',
              data: fittedData,
              borderColor: 'rgba(200,169,110,0.45)',
              backgroundColor: 'transparent',
              borderWidth: 1,
              pointRadius: 0,
              tension: 0.3,
              borderDash: [4, 3],
              spanGaps: true
            },
            {
              label: '予測',
              data: forecastLine,
              borderColor: '#edede8',
              backgroundColor: 'transparent',
              borderWidth: 2,
              pointRadius: Math.max(2, Math.min(4, _actualPR + 1)),
              pointBackgroundColor: '#edede8',
              tension: 0.2,
              borderDash: [6, 4],
              spanGaps: true
            }
          ]
        },
        options: {
          responsive: true,
          resizeDelay: 100,
          maintainAspectRatio: false,
          animation: false,
          animations: { colors: false, x: false },
          transitions: { active: { animation: { duration: 0 } } },
          interaction: { mode: 'index', intersect: false },
          plugins: {
            decimation: {
              enabled: true,
              algorithm: 'lttb',
              samples: 200,
              threshold: 300
            },
            legend: {
              labels: { color: 'rgba(237,237,232,0.6)', font: { size: 11 }, boxWidth: 18 }
            },
            tooltip: {
              backgroundColor: '#111114',
              borderColor: 'rgba(255,255,255,0.07)',
              borderWidth: 1,
              titleColor: '#c8a96e',
              bodyColor: '#edede8'
            }
          },
          scales: {
            x: {
              ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 10 }, maxRotation: 45 },
              grid: { color: 'rgba(255,255,255,0.04)' }
            },
            y: {
              ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 11 } },
              grid: { color: 'rgba(255,255,255,0.04)' }
            }
          }
        }
      });

      // Build forecast table
      const table = document.getElementById('forecast-table');
      table.innerHTML = '<thead><tr><th>年月</th><th>予測値</th><th>下限 (95%)</th><th>上限 (95%)</th></tr></thead>';
      const tbody = document.createElement('tbody');
      const frag = document.createDocumentFragment();
      result.forecast.forEach((v, i) => {
        const tr = document.createElement('tr');
        tr.innerHTML = '<td class="gold">' + forecastLabels[i] + '</td>' +
          '<td>' + Math.round(v).toLocaleString() + '</td>' +
          '<td style="color:rgba(237,237,232,0.5);">' + Math.round(ci[i].lower).toLocaleString() + '</td>' +
          '<td style="color:rgba(237,237,232,0.5);">' + Math.round(ci[i].upper).toLocaleString() + '</td>';
        frag.appendChild(tr);
      });
      tbody.appendChild(frag);
      table.appendChild(tbody);

      // Build model comparison table
      try {
        const compareSec = document.getElementById('model-compare-section');
        const compareTbl = document.getElementById('model-compare-table');
        if (compareSec && compareTbl && lastModelComparison) {
          const rows = [['hw','Holt-Winters'],['sma','季節MA'],['linseason','線形+季節']];
          let html = '<thead><tr><th>モデル</th><th>MAPE</th><th>MAE</th><th>状態</th></tr></thead><tbody>';
          rows.forEach(([k, name]) => {
            const r = lastModelComparison.candidates[k];
            const isChosen = (lastModelComparison.chosenKey === k) ||
                             (lastModelComparison.selectedMode === 'ensemble');
            const mape = (r && isFinite(r.mape)) ? r.mape.toFixed(2) + '%' : '—';
            const mae = (r && isFinite(r.mae)) ? Math.round(r.mae).toLocaleString() : '—';
            let status = '';
            if (lastModelComparison.selectedMode === 'ensemble') {
              status = '✓ 平均化';
            } else if (lastModelComparison.chosenKey === k) {
              status = '✓ 選択中';
            }
            html += '<tr><td' + (isChosen ? ' class="gold"' : '') + '>' + name + '</td>' +
              '<td>' + mape + '</td><td>' + mae + '</td>' +
              '<td style="color:#c8a96e;">' + status + '</td></tr>';
          });
          html += '</tbody>';
          compareTbl.innerHTML = html;
          compareSec.style.display = 'block';
        }
      } catch (e) { console.error('compare table', e); }

      chartSection.style.display = 'block';
      chartSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // ---- Data Preview (mini-chart) ----
    function drawPreview() {
      try {
        if (!currentData) return;
        const sec = document.getElementById('preview-section');
        const cv = document.getElementById('preview-chart');
        if (!cv || !sec) return;
        sec.style.display = 'block';
        if (previewInstance) previewInstance.destroy();
        previewInstance = new Chart(cv.getContext('2d'), {
          type: 'line',
          data: {
            labels: currentData.labels,
            datasets: [{
              label: '実績',
              data: currentData.values,
              borderColor: '#c8a96e',
              backgroundColor: 'rgba(200,169,110,0.1)',
              borderWidth: 1.5,
              pointRadius: dynPointRadius(currentData.values.length),
              pointBackgroundColor: '#c8a96e',
              tension: 0.25,
              fill: true,
              spanGaps: true
            }]
          },
          options: {
            responsive: true,
            resizeDelay: 100,
            maintainAspectRatio: false,
            animation: false,
            animations: { colors: false, x: false },
            transitions: { active: { animation: { duration: 0 } } },
            plugins: {
              decimation: { enabled: true, algorithm: 'lttb', samples: 200, threshold: 300 },
              legend: { display: false },
              tooltip: { backgroundColor: '#111114', titleColor: '#c8a96e', bodyColor: '#edede8' }
            },
            scales: {
              x: { ticks: { color: 'rgba(255,255,255,0.35)', font: { size: 9 }, maxRotation: 0, autoSkip: true, maxTicksLimit: 8 }, grid: { display: false } },
              y: { ticks: { color: 'rgba(255,255,255,0.35)', font: { size: 9 } }, grid: { color: 'rgba(255,255,255,0.04)' } }
            }
          }
        });
      } catch (e) { console.error(e); }
    }

    // ---- Auto-tune (grid search) ----
    document.getElementById('btn-autotune')?.addEventListener('click', () => {
      if (!currentData) return;
      const alphas = [0.1, 0.3, 0.5, 0.7];
      const betas  = [0.05, 0.1, 0.2, 0.3];
      const gammas = [0.1, 0.2, 0.3, 0.4];
      const total = alphas.length * betas.length * gammas.length;
      const wrap = document.getElementById('autotune-progress');
      const bar = document.getElementById('autotune-bar');
      const lbl = document.getElementById('autotune-label');
      wrap.style.display = 'block';
      bar.style.width = '0%';
      lbl.textContent = 'グリッド探索中… 0 / ' + total;

      let best = { mape: Infinity, a: 0.3, b: 0.1, g: 0.2 };
      let count = 0;
      const combos = [];
      for (const a of alphas) for (const b of betas) for (const g of gammas) combos.push([a, b, g]);

      function step() {
        try {
          const chunk = Math.min(8, combos.length - count);
          for (let k = 0; k < chunk; k++) {
            const [a, b, g] = combos[count];
            const r = holtWinters(currentData.values, a, b, g, 12, forecastPeriods);
            if (r && isFinite(r.mape) && r.mape < best.mape) { best = { mape: r.mape, a, b, g }; }
            count++;
          }
          const pct = Math.round(count / total * 100);
          bar.style.width = pct + '%';
          lbl.textContent = 'グリッド探索中… ' + count + ' / ' + total + ' (最良 MAPE: ' + best.mape.toFixed(2) + '%)';
          if (count < total) {
            requestAnimationFrame(step);
          } else {
            // セット
            document.getElementById('alpha').value = best.a;
            document.getElementById('beta').value = best.b;
            document.getElementById('gamma').value = best.g;
            document.getElementById('alpha-val').textContent = best.a.toFixed(2);
            document.getElementById('beta-val').textContent = best.b.toFixed(2);
            document.getElementById('gamma-val').textContent = best.g.toFixed(2);
            lbl.textContent = '完了 — 最適 α=' + best.a + ', β=' + best.b + ', γ=' + best.g + ' (MAPE ' + best.mape.toFixed(2) + '%)';
            setTimeout(() => { wrap.style.display = 'none'; runForecast(); }, 600);
          }
        } catch (e) {
          console.error(e);
          lbl.textContent = 'エラー: ' + e.message;
        }
      }
      requestAnimationFrame(step);
    });

    // ---- Reset ----
    document.getElementById('btn-reset')?.addEventListener('click', () => {
      try {
        if (chartInstance) { chartInstance.destroy(); chartInstance = null; }
        if (previewInstance) { previewInstance.destroy(); previewInstance = null; }
        currentData = null;
        lastForecastResult = null; lastForecastLabels = null; lastCI = null;
        chartSection.style.display = 'none';
        const cmp = document.getElementById('model-compare-section');
        if (cmp) cmp.style.display = 'none';
        document.getElementById('preview-section').style.display = 'none';
        statusEl.textContent = '';
        btnRun.disabled = true;
        const at = document.getElementById('btn-autotune'); if (at) at.disabled = true;
      } catch (e) { console.error(e); }
    });

    // ---- CSV Download ----
    document.getElementById('btn-download')?.addEventListener('click', () => {
      try {
        if (!lastForecastResult || !currentData) { alert('結果がありません。先に予測を実行してください。'); return; }
        const lines = ['year_month,actual,fitted,forecast,ci_lower,ci_upper'];
        currentData.labels.forEach((lab, i) => {
          const fitted = lastForecastResult.fitted[i];
          lines.push([lab, currentData.values[i], (fitted != null ? Math.round(fitted) : ''), '', '', ''].join(','));
        });
        lastForecastLabels.forEach((lab, i) => {
          const fc = Math.round(lastForecastResult.forecast[i]);
          const lo = lastCI ? Math.round(lastCI[i].lower) : '';
          const hi = lastCI ? Math.round(lastCI[i].upper) : '';
          lines.push([lab, '', '', fc, lo, hi].join(','));
        });
        const blob = new Blob([lines.join('\n')], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url; a.download = 'demand-forecast.csv';
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
        URL.revokeObjectURL(url);
      } catch (e) { console.error(e); alert('ダウンロード失敗: ' + e.message); }
    });

    // ---- Privacy verify toggle ----
    document.getElementById('verify-privacy')?.addEventListener('click', () => {
      const d = document.getElementById('privacy-detail');
      d.style.display = d.style.display === 'none' ? 'block' : 'none';
    });
  </script>

</BaseLayout>
