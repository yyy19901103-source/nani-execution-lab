        while (improved && iter < maxIter) {
          improved = false;
          for (let i = 0; i < best.length - 1; i++) {
            for (let j = i + 1; j < best.length; j++) {
              const candidate = best.slice();
              const sliced = candidate.slice(i, j + 1).reverse();
              for (let k = 0; k < sliced.length; k++) {
                candidate[i + k] = sliced[k];
              }
              const candEval = evaluate(candidate, jobsData, MACHINE_COUNT);
              if (candEval.fitness < bestEval.fitness) {
                best = candidate;
                bestEval = candEval;
                improved = true;
              }
            }
          }
          iter++;
        }
        return { ind: best, makespan: bestEval.makespan, latePenalty: bestEval.latePenalty, fitness: bestEval.fitness, jobEnd: bestEval.jobEnd };
      }
      self.addEventListener('message', function(e) {
        const params = e.data;
        const jobsData = params.jobsData;
        const MACHINE_COUNT = params.MACHINE_COUNT;
        const POP_SIZE = params.POP_SIZE;
        const MAX_GEN = params.MAX_GEN;
        const CROSSOVER_RATE = params.CROSSOVER_RATE;
        const MUTATION_RATE = params.MUTATION_RATE;
        const EARLY_STOP = params.EARLY_STOP;
        const n = jobsData.length;
        let pop = Array.from({ length: POP_SIZE }, function() { return randomPermutation(n); });
        let bestFit = Infinity, bestIndiv = null, stagnation = 0;
        let currentMutationRate = MUTATION_RATE;
        for (let gen = 0; gen < MAX_GEN; gen++) {
          const evaluated = pop.map(function(ind) {
            const r = evaluate(ind, jobsData, MACHINE_COUNT);
            return { ind: ind, makespan: r.makespan, latePenalty: r.latePenalty, fitness: r.fitness, jobEnd: r.jobEnd };
          });
          evaluated.sort(function(a,b){return a.fitness - b.fitness;});
          if (evaluated[0].fitness < bestFit) {
            bestFit = evaluated[0].fitness;
            bestIndiv = evaluated[0];
            stagnation = 0;
            currentMutationRate = MUTATION_RATE;
          } else {
            stagnation++;
          }
          // 適応的突然変異率
          if (stagnation > 20) currentMutationRate = Math.min(0.5, MUTATION_RATE * 4);
          else if (stagnation > 10) currentMutationRate = Math.min(0.3, MUTATION_RATE * 2);
          else currentMutationRate = MUTATION_RATE;

          if (gen % 5 === 0 || gen === MAX_GEN - 1) {
            self.postMessage({ type: 'progress', gen: gen + 1, total: MAX_GEN, bestFit: bestFit, stagnation: stagnation, mutationRate: currentMutationRate });
          }
          if (stagnation >= EARLY_STOP) {
            self.postMessage({ type: 'progress', gen: gen + 1, total: MAX_GEN, bestFit: bestFit, stagnation: stagnation, mutationRate: currentMutationRate, earlyStop: true });
            break;
          }
          const eliteN = Math.max(2, Math.floor(POP_SIZE * 0.2));
          const newPop = evaluated.slice(0, eliteN).map(function(e){return e.ind;});
          while (newPop.length < POP_SIZE) {
            const pa = evaluated[Math.floor(Math.random() * eliteN)].ind;
            const pb = evaluated[Math.floor(Math.random() * eliteN)].ind;
            let child = Math.random() < CROSSOVER_RATE ? crossover(pa, pb) : pa.slice();
            if (Math.random() < currentMutationRate) child = mutate(child);
            newPop.push(child);
          }
          pop = newPop;
        }
        // 2-opt 局所探索
        const gaFitness = bestIndiv ? bestIndiv.fitness : Infinity;
        if (bestIndiv) {
          self.postMessage({ type: 'progress', gen: MAX_GEN, total: MAX_GEN, bestFit: bestFit, stagnation: 0, mutationRate: MUTATION_RATE, localSearch: true });
          const refined = twoOptImprove(bestIndiv.ind, jobsData, MACHINE_COUNT);
          if (refined.fitness < bestIndiv.fitness) {
            bestIndiv = refined;
          }
        }
        self.postMessage({ type: 'done', best: bestIndiv, gaFitness: gaFitness });
      });
    `;
    let workerBlobUrl = null;
    try {
      const workerBlob = new Blob([workerCode], { type: 'application/javascript' });
      workerBlobUrl = URL.createObjectURL(workerBlob);
    } catch (e) { console.warn('Worker setup failed, falling back:', e); }

    // ============================================================
    // 実行ボタン
    // ============================================================
    // 状態保持（CSVダウンロード/リセット用）
    let lastGanttTasks = null;
    let lastJobsData = null;
    let cancelFlag = false;
    let currentWorker = null;

    // Round 9: PNG export button
    document.getElementById('btn-png-gantt').addEventListener('click', () => downloadChartPNG('gantt-canvas', 'production-schedule-chart.png'));

    // Round 9: Keyboard shortcuts
    document.addEventListener('keydown', e => {
      if (e.ctrlKey && e.key === 'Enter') {
        const btn = document.getElementById('btn-run');
        if (btn && !btn.disabled) btn.click();
      }
      if (e.key === 'Escape') {
        const stopBtn = document.getElementById('btn-cancel');
        if (stopBtn && stopBtn.style.display !== 'none') stopBtn.click();
      }
    });

    document.getElementById('btn-run').addEventListener('click', () => {
      const jobsData = getJobs();
      if (jobsData.length < 2) {
        alert('ジョブを2件以上入力してください。');
        return;
      }

      const algoVal = document.querySelector('input[name="algo"]:checked')?.value || 'ga';

      // NEH mode: immediate calculation, no Worker needed
      if (algoVal === 'neh') {
        const _t0 = performance.now();
        const fifoResult = fifoSchedule(jobsData);
        const nehResult = nehSchedule(jobsData);
        document.getElementById('compare-table').style.display = 'none';
        const ganttTasks = buildGanttData(nehResult.ind, jobsData);
        drawGantt(ganttTasks, jobsData, nehResult.makespan);
        renderMetrics(nehResult, fifoResult, jobsData, ganttTasks, null);
        lastGanttTasks = ganttTasks;
        lastJobsData = jobsData;
        document.getElementById('result-area').style.display = 'block';
        showPerfStats(performance.now() - _t0);
        return;
      }

      // Compare mode: run GA + NEH + FIFO and show comparison table
      if (algoVal === 'compare') {
        const _t0 = performance.now();
        const fifoResult = fifoSchedule(jobsData);
        const nehResult = nehSchedule(jobsData);
        // Quick GA (reduced generations for speed in compare mode)
        const n = jobsData.length;
        const quickPopSize = Math.min(50, POP_SIZE);
        const quickMaxGen = Math.min(100, MAX_GEN);
        let pop = Array.from({ length: quickPopSize }, () => randomPermutation(n));
        let gaResult = null; let gaFit = Infinity;
        for (let gen = 0; gen < quickMaxGen; gen++) {
          const evaluated = pop.map(ind => { const r = evaluate(ind, jobsData); return { ind, ...r }; });
          evaluated.sort((a, b) => a.fitness - b.fitness);
          if (evaluated[0].fitness < gaFit) { gaFit = evaluated[0].fitness; gaResult = evaluated[0]; }
          const eliteN = Math.max(2, Math.floor(quickPopSize * 0.2));
          const newPop = evaluated.slice(0, eliteN).map(e => e.ind);
          while (newPop.length < quickPopSize) {
            const pa = evaluated[Math.floor(Math.random() * eliteN)].ind;
            const pb = evaluated[Math.floor(Math.random() * eliteN)].ind;
            let child = Math.random() < CROSSOVER_RATE ? crossover(pa, pb) : [...pa];
            if (Math.random() < MUTATION_RATE) child = mutate(child);
            newPop.push(child);
          }
          pop = newPop;
        }
        const elapsed = performance.now() - _t0;

        // Build compare table
        const tbody = document.getElementById('compare-tbody');
        tbody.innerHTML = '';
        const results = [
          { name: '遺伝的アルゴリズム (GA)', res: gaResult },
          { name: 'NEH法', res: nehResult },
          { name: 'FIFO（投入順）', res: fifoResult }
        ];
        const bestMs = Math.min(...results.map(r => r.res ? r.res.makespan : Infinity));
        results.forEach(({ name, res }) => {
          if (!res) return;
          let onTime = 0;
          jobsData.forEach((job, i) => { if (res.jobEnd[i] <= job.deadline) onTime++; });
          const adherence = Math.round(onTime / jobsData.length * 100);
          const isBest = res.makespan === bestMs;
          const tr = document.createElement('tr');
          tr.innerHTML = `<td style="padding:0.4rem 0.75rem;border-bottom:1px solid rgba(255,255,255,0.04);${isBest ? 'color:#c8a96e;' : 'color:#edede8;'}">${name}${isBest ? ' ✓' : ''}</td>
            <td style="padding:0.4rem 0.75rem;border-bottom:1px solid rgba(255,255,255,0.04);text-align:right;${isBest ? 'color:#c8a96e;' : ''}">${res.makespan.toFixed(1)} h</td>
            <td style="padding:0.4rem 0.75rem;border-bottom:1px solid rgba(255,255,255,0.04);text-align:right;">${adherence}%</td>
            <td style="padding:0.4rem 0.75rem;border-bottom:1px solid rgba(255,255,255,0.04);text-align:right;color:rgba(255,255,255,0.4);">${name.includes('GA') ? fmtMs(elapsed) : '< 1ms'}</td>`;
          tbody.appendChild(tr);
        });
        document.getElementById('compare-table').style.display = 'block';

        // Show best result (NEH or GA, whichever is better) in Gantt
        const best = (nehResult.makespan <= (gaResult ? gaResult.makespan : Infinity)) ? nehResult : gaResult;
        if (best) {
          const ganttTasks = buildGanttData(best.ind, jobsData);
          drawGantt(ganttTasks, jobsData, best.makespan);
          renderMetrics(best, fifoResult, jobsData, ganttTasks, null);
          lastGanttTasks = ganttTasks;
          lastJobsData = jobsData;
          document.getElementById('result-area').style.display = 'block';
          showPerfStats(elapsed);
        }
        return;
      }

      // Default: GA mode
      const btn = document.getElementById('btn-run');
      const cancelBtn = document.getElementById('btn-cancel');
      btn.disabled = true;
      cancelBtn.style.display = 'inline-block';
      cancelFlag = false;
      const _t0 = performance.now();
      const progressWrap = document.getElementById('progress-wrap');
      const progressBar = document.getElementById('progress-bar');
      const progressLabel = document.getElementById('progress-label');
      progressWrap.style.display = 'flex';
      progressWrap.style.flexDirection = 'column';
      progressWrap.style.gap = '0.3rem';
      progressWrap.style.flex = '1';
      document.getElementById('result-area').style.display = 'none';

      // FIFO naive（入力順）
      const fifoOrder = jobsData.map((_, i) => i);
      const naiveResult = evaluate(fifoOrder, jobsData);

      // 規模に応じてパラメータをスケール
      const nJobs = jobsData.length;
      const dynPopSize = nJobs <= 10 ? 50 : (nJobs <= 20 ? 80 : 100);
      const dynMaxGen = nJobs <= 10 ? 200 : (nJobs <= 20 ? 300 : 400);
      const STAGNATION_LIMIT = 30;

      function finalize(bestIndiv, reasonLabel, gaFitness) {
        progressBar.style.width = '100%';
        progressLabel.textContent = (reasonLabel || '完了') + ' 最適解を描画中…';
        setTimeout(() => {
          progressWrap.style.display = 'none';
          btn.disabled = false;
          cancelBtn.style.display = 'none';
          if (!bestIndiv) return;
          try {
            const ganttTasks = buildGanttData(bestIndiv.ind, jobsData);
            drawGantt(ganttTasks, jobsData, bestIndiv.makespan);
            renderMetrics(bestIndiv, naiveResult, jobsData, ganttTasks, gaFitness);
            lastGanttTasks = ganttTasks;
            lastJobsData = jobsData;
            document.getElementById('result-area').style.display = 'block';
            showPerfStats(performance.now() - _t0);
          } catch (e) {
            console.error(e);
            alert('描画中にエラーが発生しました: ' + e.message);
          }
        }, 80);
      }

      // Worker優先 (Blob URL対応ブラウザ)
      if (workerBlobUrl && typeof Worker !== 'undefined') {
        try {
          const worker = new Worker(workerBlobUrl);
          currentWorker = worker;
          worker.onmessage = (e) => {
            const msg = e.data;
            if (msg.type === 'progress') {
              const pct = Math.round(msg.gen / msg.total * 100);
              progressBar.style.width = pct + '%';
              if (msg.localSearch) {
                progressLabel.textContent = `2-opt 局所探索中… (GA最良 fitness: ${msg.bestFit.toFixed(1)})`;
              } else {
                const mr = typeof msg.mutationRate === 'number' ? `, 突然変異率: ${(msg.mutationRate*100).toFixed(1)}%` : '';
                progressLabel.textContent = `計算中… ${msg.gen} / ${msg.total} 世代 (最良 fitness: ${msg.bestFit.toFixed(1)}, 停滞: ${msg.stagnation}${mr})`;
              }
            } else if (msg.type === 'done') {
              try { worker.terminate(); } catch (_) {}
              currentWorker = null;
              finalize(msg.best, '完了！', msg.gaFitness);
            }
          };
          worker.onerror = (err) => {
            console.error('Worker error:', err);
            try { worker.terminate(); } catch (_) {}
            currentWorker = null;
            alert('Workerエラー: ' + (err.message || 'unknown'));
            btn.disabled = false;
            cancelBtn.style.display = 'none';
            progressWrap.style.display = 'none';
          };
          worker.postMessage({
            jobsData, MACHINE_COUNT,
            POP_SIZE: dynPopSize, MAX_GEN: dynMaxGen,
            CROSSOVER_RATE, MUTATION_RATE, EARLY_STOP: STAGNATION_LIMIT
          });
          return;
        } catch (e) {
          console.warn('Worker dispatch failed, falling back to main thread:', e);
        }
      }

      // フォールバック: メインスレッドでチャンク実行
      let gen = 0;
      const n = jobsData.length;
      let pop = Array.from({ length: dynPopSize }, () => randomPermutation(n));
      let bestFit = Infinity;
      let bestIndiv = null;
      let stagnation = 0;
      let currentMutationRate = MUTATION_RATE;
      const workerBadge = document.getElementById('worker-badge');
      if (workerBadge) workerBadge.textContent = '⚙ メインスレッド計算';

      function finalizeWithLocalSearch(bestIndivLocal, reasonLabel) {
        const gaFitness = bestIndivLocal ? bestIndivLocal.fitness : Infinity;
        let finalBest = bestIndivLocal;
        if (bestIndivLocal) {
          progressLabel.textContent = '2-opt 局所探索中…';
          const refined = twoOptImproveMain(bestIndivLocal.ind, jobsData);
          if (refined.fitness < bestIndivLocal.fitness) {
            finalBest = refined;
          }
        }
        finalize(finalBest, reasonLabel, gaFitness);
      }

      function step() {
        if (cancelFlag) { finalizeWithLocalSearch(bestIndiv, '中断 —'); return; }
        if (gen >= dynMaxGen) { finalizeWithLocalSearch(bestIndiv, '完了！'); return; }
        if (stagnation >= STAGNATION_LIMIT) { finalizeWithLocalSearch(bestIndiv, '早期停止（' + STAGNATION_LIMIT + '世代改善なし） —'); return; }

        const chunk = Math.min(10, dynMaxGen - gen);
        for (let c = 0; c < chunk; c++) {
          const evaluated = pop.map(ind => {
            const r = evaluate(ind, jobsData);
            return { ind, ...r };
          });
          evaluated.sort((a, b) => a.fitness - b.fitness);
          if (evaluated[0].fitness < bestFit) {
            bestFit = evaluated[0].fitness;
            bestIndiv = evaluated[0];
            stagnation = 0;
            currentMutationRate = MUTATION_RATE;
          } else {
            stagnation++;
          }
          // 適応的突然変異率
          if (stagnation > 20) currentMutationRate = Math.min(0.5, MUTATION_RATE * 4);
          else if (stagnation > 10) currentMutationRate = Math.min(0.3, MUTATION_RATE * 2);
          else currentMutationRate = MUTATION_RATE;

          const eliteN = Math.max(2, Math.floor(dynPopSize * 0.2));
          const newPop = evaluated.slice(0, eliteN).map(e => e.ind);
          while (newPop.length < dynPopSize) {
            const pa = evaluated[Math.floor(Math.random() * eliteN)].ind;
            const pb = evaluated[Math.floor(Math.random() * eliteN)].ind;
            let child = Math.random() < CROSSOVER_RATE ? crossover(pa, pb) : [...pa];
            if (Math.random() < currentMutationRate) child = mutate(child);
            newPop.push(child);
          }
          pop = newPop;
          gen++;
          if (stagnation >= STAGNATION_LIMIT) break;
        }

        const pct = Math.round(gen / dynMaxGen * 100);
        progressBar.style.width = pct + '%';
        progressLabel.textContent = `計算中… ${gen} / ${dynMaxGen} 世代 (最良 fitness: ${bestFit.toFixed(1)}, 停滞: ${stagnation}, 突然変異率: ${(currentMutationRate*100).toFixed(1)}%)`;
        requestAnimationFrame(step);
      }

      requestAnimationFrame(step);
    });

    // 中断ボタン
    document.getElementById('btn-cancel').addEventListener('click', () => {
      cancelFlag = true;
      if (currentWorker) {
        try { currentWorker.terminate(); } catch (_) {}
        currentWorker = null;
        // Worker中断時はUIを片付けて結果は破棄
        document.getElementById('progress-wrap').style.display = 'none';
        document.getElementById('btn-run').disabled = false;
        document.getElementById('btn-cancel').style.display = 'none';
        const lbl = document.getElementById('progress-label');
        if (lbl) lbl.textContent = '中断 —';
      }
    });

    // リセットボタン
    document.getElementById('btn-reset').addEventListener('click', () => {
      try {
        cancelFlag = true;
        if (currentWorker) { try { currentWorker.terminate(); } catch (_) {} currentWorker = null; }
        document.getElementById('result-area').style.display = 'none';
        document.getElementById('progress-wrap').style.display = 'none';
        document.getElementById('btn-cancel').style.display = 'none';
        document.getElementById('compare-table').style.display = 'none';
        document.getElementById('btn-run').disabled = false;
        const canvas = document.getElementById('gantt-canvas');
        if (canvas) {
          const ctx = canvas.getContext('2d');
          ctx && ctx.clearRect(0, 0, canvas.width, canvas.height);
        }
        lastGanttTasks = null;
        lastJobsData = null;
        renderTable(SAMPLE_JOBS);
      } catch (e) { console.error(e); }
    });

    // CSVダウンロード
    document.getElementById('btn-download').addEventListener('click', () => {
      try {
        if (!lastGanttTasks || !lastJobsData) { alert('結果がありません。先に最適化を実行してください。'); return; }
        const lines = ['job_name,machine,start_h,end_h,is_late'];
        for (const t of lastGanttTasks) {
          const job = lastJobsData[t.jobIdx];
          const isLast = t.machine === MACHINE_COUNT - 1;
          const isLate = isLast && t.end > job.deadline ? 1 : 0;
          lines.push([job.name, 'M' + (t.machine + 1), t.start.toFixed(2), t.end.toFixed(2), isLate].join(','));
        }
        const blob = new Blob([lines.join('\n')], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url; a.download = 'production-schedule.csv';
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
        URL.revokeObjectURL(url);
      } catch (e) { console.error(e); alert('ダウンロード失敗: ' + e.message); }
    });

    // 機密保護検証トグル
    document.getElementById('verify-privacy')?.addEventListener('click', () => {
      const d = document.getElementById('privacy-detail');
      d.style.display = d.style.display === 'none' ? 'block' : 'none';
    });

    // ============================================================
    // 初期表示
    // ============================================================
    renderTable(SAMPLE_JOBS);
  </script>


<section style="max-width:1100px;margin:0 auto;padding:4rem 1rem 5rem;">
  <h2 style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;text-transform:uppercase;margin-bottom:2rem;">このツールについて</h2>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem;">
    <div style="background:#111114;border:1px solid rgba(255,255,255,0.05);padding:1.5rem;border-radius:0;">
      <div style="color:#c8a96e;font-size:0.82rem;font-weight:500;margin-bottom:0.85rem;">🧬 遺伝的アルゴリズム (GA)</div>
      <p style="color:rgba(255,255,255,0.5);font-size:0.8rem;line-height:1.7;margin:0;">自然の「進化」を模倣した最適化手法。多数の解候補（個体）を世代ごとに交叉・突然変異させ、より良い順列を探索します。時間はかかりますが、複雑な問題でも高品質な解が得られます。</p>
    </div>
    <div style="background:#111114;border:1px solid rgba(255,255,255,0.05);padding:1.5rem;border-radius:0;">
      <div style="color:#c8a96e;font-size:0.82rem;font-weight:500;margin-bottom:0.85rem;">⚡ NEH法</div>
      <p style="color:rgba(255,255,255,0.5);font-size:0.8rem;line-height:1.7;margin:0;">Nawaz・Enscore・Ham が考案した決定論的ヒューリスティック。処理時間合計の長いジョブから順に、最もMakespanが短くなる位置に挿入していきます。GAより高速で、実用上十分な品質です。</p>
    </div>
    <div style="background:#111114;border:1px solid rgba(255,255,255,0.05);padding:1.5rem;border-radius:0;">
      <div style="color:#c8a96e;font-size:0.82rem;font-weight:500;margin-bottom:0.85rem;">📊 結果の見方</div>
      <p style="color:rgba(255,255,255,0.5);font-size:0.8rem;line-height:1.7;margin:0;"><strong style="color:rgba(237,237,232,0.75);">Makespan</strong>: 全ジョブ完了までの総時間（短いほど良い）。<strong style="color:rgba(237,237,232,0.75);">納期遵守率</strong>: 期限内に完了したジョブの割合。<strong style="color:rgba(237,237,232,0.75);">FIFO改善率</strong>: 投入順と比較してどれだけ短縮できたか。</p>
    </div>
  </div>
</section>

