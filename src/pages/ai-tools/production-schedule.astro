---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="生産スケジュール最適化" description="遺伝的アルゴリズムによる生産スケジュール最適化ツール。ジョブ・機械割り当てを自動最適化し、ガントチャートで可視化。ブラウザ完結型。">

  <!-- 機密保護バナー -->
  <div style="background:rgba(200,169,110,0.08);border-left:3px solid #c8a96e;padding:0.85rem 1.25rem;font-size:0.78rem;color:#edede8;letter-spacing:0.03em;display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;justify-content:space-between;">
    <div>🔒 <strong>機密保護: 全処理ブラウザ完結</strong> — 入力データは外部送信されません</div>
    <button id="verify-privacy" style="background:transparent;border:1px solid rgba(200,169,110,0.3);color:#c8a96e;padding:0.3rem 0.75rem;font-size:0.7rem;cursor:pointer;font-family:inherit;letter-spacing:0.05em;border-radius:0;transition:all 0.15s;">検証方法を見る ▼</button>
  </div>
  <div id="privacy-detail" style="display:none;background:#0a0a0c;border-left:3px solid #c8a96e;border-bottom:1px solid rgba(200,169,110,0.15);padding:1.25rem 1.75rem;font-size:0.78rem;color:rgba(237,237,232,0.75);line-height:1.7;">
    <p style="color:#c8a96e;font-size:0.7rem;letter-spacing:0.2em;margin-bottom:0.6rem;">VERIFY YOURSELF</p>
    <ol style="margin:0;padding-left:1.25rem;">
      <li>ブラウザの DevTools を開く（F12 / Ctrl+Shift+I）</li>
      <li><code style="background:#111114;padding:0.1em 0.4em;color:#c8a96e;">Network</code> タブを選択</li>
      <li>このページで計算を実行</li>
      <li>新規ネットワーク通信が <strong>発生しないこと</strong> を確認</li>
    </ol>
    <p style="margin-top:0.8rem;color:rgba(255,255,255,0.5);font-size:0.72rem;">通信は CDN ライブラリ初回読込のみ（Chart.js / TF.js）。データを入れた後は完全ローカル処理です。</p>
  </div>

  <!-- ヒーロー -->
  <div style="position:relative;height:12rem;overflow:hidden;display:flex;align-items:center;justify-content:center;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#0c0c0e 0%,#0d1a12 60%,#0c0c0e 100%);"></div>
    <div style="position:relative;z-index:1;text-align:center;padding:0 1.5rem;">
      <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;margin-bottom:0.85rem;text-transform:uppercase;">Genetic Algorithm · Production Scheduling</p>
      <h1 style="font-size:clamp(1.5rem,4vw,2.1rem);font-weight:200;letter-spacing:0.15em;color:#edede8;">生産スケジュール最適化</h1>
    </div>
  </div>

  <!-- USE CASES -->
  <div style="max-width:1100px;margin:0 auto;padding:1rem 1rem 0;">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:0.75rem;">
      <div style="background:#111114;border:1px solid rgba(200,169,110,0.15);border-left:3px solid #c8a96e;padding:0.85rem 1.1rem;">
        <div style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.4rem;">USE CASE 1</div>
        <div style="color:#edede8;font-size:0.82rem;font-weight:500;margin-bottom:0.3rem;">多品種少量ライン</div>
        <div style="color:rgba(237,237,232,0.55);font-size:0.72rem;line-height:1.5;">ジョブ順序決定で総生産時間20-30%短縮</div>
      </div>
      <div style="background:#111114;border:1px solid rgba(200,169,110,0.15);border-left:3px solid #c8a96e;padding:0.85rem 1.1rem;">
        <div style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.4rem;">USE CASE 2</div>
        <div style="color:#edede8;font-size:0.82rem;font-weight:500;margin-bottom:0.3rem;">受注生産・納期管理</div>
        <div style="color:rgba(237,237,232,0.55);font-size:0.72rem;line-height:1.5;">納期遵守率を55%→90%に改善</div>
      </div>
      <div style="background:#111114;border:1px solid rgba(200,169,110,0.15);border-left:3px solid #c8a96e;padding:0.85rem 1.1rem;">
        <div style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.4rem;">USE CASE 3</div>
        <div style="color:#edede8;font-size:0.82rem;font-weight:500;margin-bottom:0.3rem;">設備稼働率改善</div>
        <div style="color:rgba(237,237,232,0.55);font-size:0.72rem;line-height:1.5;">機械待ち時間を可視化し、稼働率15%向上</div>
      </div>
    </div>
  </div>

  <div style="max-width:1100px;margin:0 auto;padding:1.5rem 1rem 4rem;">

    <!-- 業界プリセットバー -->
    <div style="background:#0a0a0c;border:1px solid rgba(200,169,110,0.1);padding:0.7rem 1rem;display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;margin-bottom:0.6rem;">
      <span style="color:rgba(200,169,110,0.7);font-size:0.62rem;letter-spacing:0.2em;">PRESET</span>
      <button class="preset-btn" data-preset="auto" style="background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(237,237,232,0.7);padding:0.3rem 0.85rem;font-size:0.72rem;cursor:pointer;font-family:inherit;">🚗 自動車部品</button>
      <button class="preset-btn" data-preset="elec" style="background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(237,237,232,0.7);padding:0.3rem 0.85rem;font-size:0.72rem;cursor:pointer;font-family:inherit;">⚙ 電子機器</button>
      <button class="preset-btn" data-preset="food" style="background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(237,237,232,0.7);padding:0.3rem 0.85rem;font-size:0.72rem;cursor:pointer;font-family:inherit;">🥫 食品工場</button>
      <button id="btn-template-csv" style="background:transparent;border:1px solid rgba(110,200,151,0.3);color:rgba(110,200,151,0.85);padding:0.3rem 0.85rem;font-size:0.72rem;cursor:pointer;font-family:inherit;margin-left:auto;">📥 CSVテンプレートDL</button>
    </div>

    <!-- コントロールバー -->
    <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:0.85rem 1rem;display:flex;flex-wrap:wrap;gap:0.75rem;align-items:center;margin-bottom:1rem;">
      <button id="btn-sample" class="m-btn-ghost">サンプルデータを読み込む</button>
      <label class="m-btn-ghost" style="cursor:pointer;">
        CSVアップロード
        <input id="csv-upload" type="file" accept=".csv" style="display:none;">
      </label>
      <span style="color:rgba(255,255,255,0.3);font-size:0.7rem;flex:1;">CSV形式: job_name,m1_time,m2_time,m3_time,deadline</span>
      <div id="csv-progress" class="hidden mt-2" style="display:none;margin-top:0.5rem;width:100%;">
        <div style="color:rgba(255,255,255,0.5);font-size:0.7rem;margin-bottom:0.3rem;">CSVを解析中...</div>
        <div style="width:100%;background:#1a1a1d;border-radius:9999px;height:6px;">
          <div id="csv-progress-bar" style="background:#c8a96e;height:6px;border-radius:9999px;transition:width 0.1s;width:0%;"></div>
        </div>
      </div>
    </div>

    <!-- ジョブテーブル -->
    <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-bottom:1rem;overflow-x:auto;">
      <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">JOBS</p>
      <table id="job-table" style="width:100%;border-collapse:collapse;font-size:0.82rem;">
        <thead>
          <tr>
              <th class="th">ジョブ名</th>
            <th class="th">M1 (h)</th>
            <th class="th">M2 (h)</th>
            <th class="th">M3 (h)</th>
            <th class="th">納期 (h)</th>
            <th class="th"></th>
          </tr>
        </thead>
        <tbody id="job-tbody"></tbody>
      </table>
      <button id="btn-add-row" class="m-btn-ghost" style="margin-top:0.75rem;font-size:0.72rem;">+ 行を追加</button>
    </div>

    <!-- アルゴリズム選択 -->
    <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:0.85rem 1rem;display:flex;flex-wrap:wrap;gap:1.25rem;align-items:center;margin-bottom:1rem;">
      <span style="color:rgba(255,255,255,0.4);font-size:0.65rem;letter-spacing:0.15em;">ALGORITHM</span>
      <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
        <input type="radio" name="algo" value="ga" id="algo-ga" checked style="accent-color:#c8a96e;">
        <span style="font-size:0.8rem;color:rgba(237,237,232,0.75);">遺伝的アルゴリズム (GA)</span>
      </label>
      <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
        <input type="radio" name="algo" value="neh" id="algo-neh" style="accent-color:#c8a96e;">
        <span style="font-size:0.8rem;color:rgba(237,237,232,0.75);">NEH法（高速）</span>
      </label>
      <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
        <input type="radio" name="algo" value="compare" id="algo-compare" style="accent-color:#c8a96e;">
        <span style="font-size:0.8rem;color:rgba(237,237,232,0.75);">3手法比較</span>
      </label>
    </div>

    <!-- 比較結果テーブル（compare モード時のみ表示） -->
    <div id="compare-table" style="display:none;background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-bottom:1rem;">
      <div style="color:rgba(255,255,255,0.4);font-size:0.62rem;letter-spacing:0.35em;margin-bottom:0.75rem;">ALGORITHM COMPARISON</div>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:0.82rem;">
          <thead><tr style="border-bottom:1px solid rgba(255,255,255,0.07);">
            <th style="text-align:left;padding:0.4rem 0.75rem;color:rgba(255,255,255,0.4);font-size:0.65rem;letter-spacing:0.1em;font-weight:400;">手法</th>
            <th style="text-align:right;padding:0.4rem 0.75rem;color:rgba(255,255,255,0.4);font-size:0.65rem;letter-spacing:0.1em;font-weight:400;">Makespan</th>
            <th style="text-align:right;padding:0.4rem 0.75rem;color:rgba(255,255,255,0.4);font-size:0.65rem;letter-spacing:0.1em;font-weight:400;">納期遵守率</th>
            <th style="text-align:right;padding:0.4rem 0.75rem;color:rgba(255,255,255,0.4);font-size:0.65rem;letter-spacing:0.1em;font-weight:400;">計算時間</th>
          </tr></thead>
          <tbody id="compare-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- 実行ボタン -->
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;">
      <button id="btn-run" class="m-btn">最適化実行</button>
      <span style="color:rgba(255,255,255,0.35);font-size:0.72rem;">Ctrl+Enter で実行</span>
      <button id="btn-cancel" class="m-btn-ghost" style="display:none;">⏸ 中断</button>
      <button id="btn-reset" class="m-btn-ghost" style="margin-left:0.5rem;">リセット</button>
      <div id="progress-wrap" style="display:none;flex:1;min-width:200px;">
        <div style="font-size:0.7rem;color:#c8a96e;margin-bottom:0.3rem;display:flex;justify-content:space-between;gap:0.5rem;">
          <span id="progress-label">計算中… 0 / 200 世代</span>
          <span id="worker-badge" style="color:rgba(110,200,151,0.85);font-size:0.65rem;letter-spacing:0.05em;">⚙ Web Worker（別スレッド）で計算中</span>
        </div>
        <div style="background:#1a1a1d;height:6px;border-radius:3px;overflow:hidden;">
          <div id="progress-bar" style="background:#c8a96e;height:100%;width:0%;transition:width 0.1s;"></div>
        </div>
      </div>
    </div>

    <!-- 結果エリア -->
    <div id="result-area" style="display:none;">
      <!-- メトリクス -->
      <div id="metrics-row" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:0.75rem;margin-bottom:1.25rem;"></div>
      <!-- ガントチャート -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">GANTT CHART</p>
        <div style="overflow-x:auto;">
          <canvas id="gantt-canvas" style="display:block;"></canvas>
        </div>
        <div style="margin-top:0.75rem;display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;" id="legend-area"></div>
        <button id="btn-png-gantt" class="m-btn-ghost" style="margin-top:0.5rem;font-size:0.72rem;">📷 PNG保存</button>
      </div>
      <div id="perf-stats" style="display:none;margin-top:0.5rem;font-size:0.72rem;color:rgba(255,255,255,0.4);font-family:ui-monospace,monospace;"></div>
      <div style="margin-top:1rem;text-align:right;">
        <button id="btn-download" class="m-btn-ghost" style="font-size:0.7rem;">📥 結果をCSVでダウンロード</button>
      </div>

      <!-- NEXT ACTIONS -->
      <div id="action-hints" style="background:linear-gradient(135deg,rgba(200,169,110,0.05) 0%,rgba(110,200,151,0.05) 100%);border-left:3px solid #6ec897;padding:1.25rem 1.5rem;margin-top:1.5rem;">
        <div style="color:#6ec897;font-size:0.62rem;letter-spacing:0.3em;margin-bottom:0.75rem;">✓ NEXT ACTIONS — 現場で次にすべきこと</div>
        <ol style="margin:0;padding-left:1.5rem;color:rgba(237,237,232,0.85);font-size:0.85rem;line-height:1.8;">
          <li>上記順序でジョブ投入計画を更新（作業指示書・かんばん書き換え）</li>
          <li>ボトルネック機械（M2想定）に予防保全を集中、段取り短縮SMEDを企画</li>
          <li>納期遅延ジョブを再交渉対象として営業へエスカレーション</li>
        </ol>
      </div>
    </div>

  </div>

  <style>
    .m-btn, .m-btn-ghost {
      background:#0a0a0c;color:#edede8;border:1px solid rgba(255,255,255,0.1);
      padding:0.5rem 1rem;font-size:0.75rem;cursor:pointer;font-family:inherit;letter-spacing:0.05em;transition:all 0.15s;
    }
    .m-btn-ghost:hover { border-color:#c8a96e;color:#c8a96e; }
    .m-btn { background:#c8a96e;color:#0c0c0e;border-color:#c8a96e;font-weight:700; }
    .m-btn:hover { background:#d4b87b; }
    .m-btn:disabled { background:#555;border-color:#555;color:#999;cursor:not-allowed; }
    .th {
      text-align:left;color:rgba(255,255,255,0.4);font-size:0.65rem;letter-spacing:0.1em;
      padding:0.4rem 0.5rem;border-bottom:1px solid rgba(255,255,255,0.07);font-weight:400;
    }
    .td {
      padding:0.3rem 0.5rem;border-bottom:1px solid rgba(255,255,255,0.04);
    }
    .cell-input {
      background:#0a0a0c;color:#edede8;border:1px solid rgba(255,255,255,0.08);
      padding:0.3rem 0.5rem;font-size:0.8rem;font-family:inherit;width:100%;outline:none;
    }
    .cell-input:focus { border-color:#c8a96e; }
    .del-btn {
      background:none;border:none;color:rgba(255,80,80,0.5);cursor:pointer;font-size:1rem;line-height:1;padding:0.1rem 0.3rem;
    }
    .del-btn:hover { color:rgba(255,80,80,1); }
    .metric-card {
      background:#0f0f12;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;
    }
    .metric-label { color:rgba(255,255,255,0.4);font-size:0.62rem;letter-spacing:0.2em;margin-bottom:0.4rem; }
    .metric-value { color:#edede8;font-size:1.6rem;font-weight:200;letter-spacing:0.05em; }
    .metric-sub { color:rgba(255,255,255,0.3);font-size:0.68rem;margin-top:0.25rem; }
  </style>

  <script>
    // ============================================================
    // Round 8: Chunked CSV Parser (canonical version)
    // ============================================================
    const CHUNK_ROWS = 1000;
    async function parseCSVChunkedNew(file, onProgress) {
      const text = await file.text();
      const lines = text.split('\n').filter(l => l.trim());
      const headers = lines[0].split(',').map(h => h.trim());
      const rows = [];
      const total = lines.length - 1;
      for (let i = 1; i < lines.length; i++) {
        const cols = lines[i].split(',').map(c => c.trim());
        const obj = {};
        headers.forEach((h, j) => { obj[h] = cols[j] ?? ''; });
        rows.push(obj);
        if (i % CHUNK_ROWS === 0) {
          if (onProgress) onProgress(Math.round(i / total * 100));
          await new Promise(r => setTimeout(r, 0));
        }
      }
      if (onProgress) onProgress(100);
      return { headers, rows };
    }

    // Round 9: PNG export
    function downloadChartPNG(canvasId, filename) {
      const canvas = document.getElementById(canvasId);
      if (!canvas) return;
      const link = document.createElement('a');
      link.download = filename;
      link.href = canvas.toDataURL('image/png');
      link.click();
    }

    // Round 10: Performance stats
    function fmtMs(ms) { return ms < 1000 ? ms.toFixed(0)+'ms' : (ms/1000).toFixed(2)+'s'; }
    function showPerfStats(ms, tfMemory) {
      const el = document.getElementById('perf-stats');
      if (!el) return;
      let html = `⏱ 計算時間: ${fmtMs(ms)}`;
      if (tfMemory) html += ` | 🧠 TF.jsメモリ: ${(tfMemory.numBytes/1024/1024).toFixed(1)}MB (テンソル${tfMemory.numTensors}個)`;
      el.textContent = html;
      el.style.display = 'block';
    }

    // ============================================================
    // Performance helpers
    // ============================================================
    function debounce(fn, wait) {
      let t;
      return function(...args) {
        clearTimeout(t);
        t = setTimeout(() => fn.apply(this, args), wait);
      };
    }
    function throttleRAF(fn) {
      let scheduled = false;
      return function(...args) {
        if (scheduled) return;
        scheduled = true;
        requestAnimationFrame(() => {
          scheduled = false;
          fn.apply(this, args);
        });
      };
    }

    // ============================================================
    // データ
    // ============================================================
    const SAMPLE_JOBS = [
      { name: 'Job A', times: [3, 2, 4], deadline: 12 },
      { name: 'Job B', times: [2, 5, 1], deadline: 10 },
      { name: 'Job C', times: [4, 1, 3], deadline: 15 },
      { name: 'Job D', times: [1, 3, 5], deadline: 11 },
      { name: 'Job E', times: [5, 2, 2], deadline: 14 },
    ];
    const MACHINE_COUNT = 3;

    const JOB_COLORS = [
      '#c8a96e','#6ea8c8','#6ec897','#c86e6e','#a96ec8',
      '#c8b86e','#6e7fc8','#6ec8b8','#c89a6e','#8ec86e',
    ];

    let jobs = [];

    // ============================================================
    // テーブル管理
    // ============================================================
    function getJobs() {
      const rows = document.querySelectorAll('#job-tbody tr');
      const result = [];
      rows.forEach(row => {
        const inputs = row.querySelectorAll('input');
        const name = inputs[0].value.trim();
        const t1 = parseFloat(inputs[1].value) || 0;
        const t2 = parseFloat(inputs[2].value) || 0;
        const t3 = parseFloat(inputs[3].value) || 0;
        const dl = parseFloat(inputs[4].value) || 999;
        if (name) result.push({ name, times: [t1, t2, t3], deadline: dl });
      });
      return result;
    }

    function buildRow(job = null) {
      const tr = document.createElement('tr');
      const vals = job
        ? [job.name, job.times[0], job.times[1], job.times[2], job.deadline]
        : ['新規ジョブ', 1, 1, 1, 10];
      const tds = vals.map((v, ci) => {
        const td = document.createElement('td');
        td.className = 'td';
        const inp = document.createElement('input');
        inp.className = 'cell-input';
        inp.value = v;
        inp.type = ci === 0 ? 'text' : 'number';
        if (ci > 0) { inp.min = '0'; inp.step = '0.5'; }
        td.appendChild(inp);
        return td;
      });
      tds.forEach(td => tr.appendChild(td));
      const delTd = document.createElement('td');
      delTd.className = 'td';
      const delBtn = document.createElement('button');
      delBtn.className = 'del-btn';
      delBtn.textContent = '✕';
      delBtn.addEventListener('click', () => tr.remove());
      delTd.appendChild(delBtn);
      tr.appendChild(delTd);
      return tr;
    }

    function renderTable(data) {
      const tbody = document.getElementById('job-tbody');
      tbody.innerHTML = '';
      const frag = document.createDocumentFragment();
      data.forEach(job => frag.appendChild(buildRow(job)));
      tbody.appendChild(frag);
    }

    function addRow(job = null) {
      const tbody = document.getElementById('job-tbody');
      tbody.appendChild(buildRow(job));
    }

    document.getElementById('btn-sample').addEventListener('click', () => {
      renderTable(SAMPLE_JOBS);
    });
    document.getElementById('btn-add-row').addEventListener('click', () => addRow());

    // 業界プリセット
    const INDUSTRY_PRESETS = {
      auto: [
        { name:'シリンダーヘッド加工', times:[8,5,3], deadline:24 },
        { name:'バルブ穴加工', times:[4,7,2], deadline:20 },
