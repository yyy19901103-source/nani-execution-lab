---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="株式AI予測ダッシュボード — NaNi Execution Lab"
  description="LightGBM+69エージェントによる米国株AI予測。推奨銘柄・上昇確率・過去の的中率をリアルタイム公開。"
>

<style is:global>
  /* ========== レイアウト基本 ========== */
  .sp-wrap { max-width: 1100px; margin: 0 auto; padding: 1.5rem 1rem 4rem; }
  .sp-head { display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 1rem; padding: 1.5rem 0 0.8rem; border-bottom: 1px solid rgba(200,169,110,0.15); margin-bottom: 1.2rem; }
  .sp-title { font-size: clamp(1.2rem, 3vw, 1.6rem); font-weight: 300; letter-spacing: 0.08em; color: #edede8; margin: 0; }
  .sp-title-icon { color: #c8a96e; margin-right: 0.4rem; }
  .sp-meta { font-size: 0.7rem; color: #666; }

  /* ========== 鮮度ピル ========== */
  .fresh-pill { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.25rem 0.7rem; border-radius: 999px; font-size: 0.7rem; font-weight: 500; }
  .fresh-ok   { background: rgba(110,200,110,0.12); color: #88c888; border: 1px solid rgba(110,200,110,0.3); }
  .fresh-warn { background: rgba(200,150,80,0.12); color: #c8a96e; border: 1px solid rgba(200,150,80,0.4); }
  .fresh-bad  { background: rgba(200,80,80,0.12); color: #c87e6e; border: 1px solid rgba(200,80,80,0.4); }
  .fresh-detail { font-size: 0.65rem; color: #666; margin-left: 0.5rem; }

  /* ========== HERO: 今日のおすすめ ========== */
  .hero { background: linear-gradient(135deg, #0d0d0d 0%, #161616 50%, #0d0d0d 100%); border: 1px solid rgba(200,169,110,0.25); padding: 1.5rem; margin-bottom: 1.5rem; position: relative; overflow: hidden; }
  .hero::before { content: ''; position: absolute; top: -50%; right: -10%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(200,169,110,0.08) 0%, transparent 70%); pointer-events: none; }
  .hero-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 1.5rem; position: relative; }
  @media (max-width: 720px) { .hero-grid { grid-template-columns: 1fr; } }
  .hero-eyebrow { font-size: 0.62rem; letter-spacing: 0.25em; color: #c8a96e; text-transform: uppercase; margin-bottom: 0.6rem; }
  .hero-headline { font-size: clamp(1.1rem, 2.6vw, 1.5rem); color: #edede8; line-height: 1.5; margin-bottom: 0.8rem; font-weight: 400; }
  .hero-cta-list { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1rem; }
  .hero-cta { display: flex; align-items: center; gap: 0.7rem; padding: 0.7rem 1rem; background: rgba(200,169,110,0.06); border: 1px solid rgba(200,169,110,0.2); border-radius: 4px; font-size: 0.85rem; color: #ddd; transition: all 0.2s; cursor: pointer; }
  .hero-cta:hover { background: rgba(200,169,110,0.12); border-color: rgba(200,169,110,0.5); transform: translateX(4px); }
  .hero-cta-rank { padding: 0.15rem 0.5rem; border-radius: 3px; font-size: 0.7rem; font-weight: 600; }
  .hero-cta-info { flex: 1; font-size: 0.78rem; color: #999; }
  .hero-side { display: flex; flex-direction: column; gap: 0.6rem; }
  .hero-stat { background: rgba(0,0,0,0.4); border: 1px solid #1a1a1a; padding: 0.7rem 0.9rem; border-radius: 4px; }
  .hero-stat-label { font-size: 0.6rem; letter-spacing: 0.18em; color: #888; text-transform: uppercase; }
  .hero-stat-value { font-size: 1.4rem; font-weight: 300; color: #edede8; margin-top: 0.2rem; }
  .hero-stat-sub { font-size: 0.7rem; color: #666; margin-top: 0.1rem; }

  /* ========== タブナビゲーション ========== */
  .tabs { display: flex; gap: 0; border-bottom: 1px solid #1f1f1f; margin-bottom: 1.5rem; overflow-x: auto; }
  .tab-btn { padding: 0.85rem 1.5rem; background: transparent; border: 0; color: #888; cursor: pointer; font-size: 0.85rem; letter-spacing: 0.05em; border-bottom: 2px solid transparent; transition: all 0.2s; white-space: nowrap; font-family: inherit; }
  .tab-btn:hover { color: #c8a96e; }
  .tab-btn.active { color: #c8a96e; border-bottom-color: #c8a96e; background: rgba(200,169,110,0.04); }
  .tab-content { display: none; animation: fadeIn 0.4s ease; }
  .tab-content.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  /* ========== セクションタイトル ========== */
  .sec-title { font-size: 0.65rem; letter-spacing: 0.25em; color: #c8a96e; text-transform: uppercase; padding-bottom: 0.5rem; margin: 1.8rem 0 1rem; border-bottom: 1px solid rgba(200,169,110,0.2); display: flex; align-items: center; gap: 0.5rem; }
  .sec-title-count { font-size: 0.6rem; color: #555; letter-spacing: 0.1em; margin-left: auto; text-transform: none; }

  /* ========== KPI ========== */
  .kpi-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px,1fr)); gap: 0.8rem; margin-bottom: 1.5rem; }
  .kpi { background: #0f0f0f; border: 1px solid #1d1d1d; padding: 1rem; text-align: center; border-radius: 4px; transition: all 0.25s; }
  .kpi:hover { border-color: rgba(200,169,110,0.4); transform: translateY(-2px); }
  .kpi-label { font-size: 0.6rem; letter-spacing: 0.2em; color: #888; margin-bottom: 0.3rem; }
  .kpi-val { font-size: 1.7rem; font-weight: 300; color: #c8a96e; }
  .kpi-sub { font-size: 0.65rem; color: #555; margin-top: 0.15rem; }

  /* ========== ランキングテーブル（強化版） ========== */
  .rank-grid { display: flex; flex-direction: column; gap: 0.5rem; }
  .rank-row { display: grid; grid-template-columns: 60px 110px 1fr 1fr 90px 80px; gap: 0.8rem; align-items: center; padding: 0.8rem 1rem; background: #0f0f0f; border: 1px solid #1a1a1a; border-radius: 4px; transition: all 0.2s; cursor: pointer; }
  .rank-row:hover { background: #141414; border-color: rgba(200,169,110,0.4); transform: translateX(3px); }
  @media (max-width: 720px) { .rank-row { grid-template-columns: 50px 90px 1fr 80px; gap: 0.5rem; padding: 0.6rem; } .rank-row .rank-col-er, .rank-row .rank-col-time { display: none; } }
  .rank-ticker { font-weight: 600; font-size: 1rem; color: #edede8; }
  .rank-bar-wrap { background: #1a1a1a; height: 8px; border-radius: 4px; overflow: hidden; position: relative; }
  .rank-bar-fill { height: 100%; transition: width 0.6s ease; border-radius: 4px; }
  .rank-bar-text { font-size: 0.7rem; color: #aaa; margin-top: 0.2rem; }
  .rank-score-num { font-size: 1.1rem; color: #edede8; font-weight: 500; text-align: right; }
  .rank-er { font-size: 0.85rem; }
  .rank-time { font-size: 0.65rem; color: #555; text-align: right; }

  /* ========== バッジ ========== */
  .badge { display: inline-block; padding: 0.2rem 0.55rem; font-size: 0.65rem; letter-spacing: 0.05em; border-radius: 3px; font-weight: 500; white-space: nowrap; }
  .badge-sb { background: rgba(80,200,80,0.25);  color: #88e088; border: 1px solid rgba(80,200,80,0.4); }
  .badge-b  { background: rgba(80,200,80,0.15); color: #6ec86e; border: 1px solid rgba(80,200,80,0.3); }
  .badge-wb { background: rgba(200,200,80,0.15);color: #d8d878; border: 1px solid rgba(200,200,80,0.3); }
  .badge-w  { background: rgba(150,150,150,0.1);color: #999;    border: 1px solid #2a2a2a; }
  .badge-ws { background: rgba(200,100,80,0.15);color: #d8896e; border: 1px solid rgba(200,100,80,0.3); }
  .badge-s  { background: rgba(200,80,80,0.18); color: #d87878; border: 1px solid rgba(200,80,80,0.3); }
  .badge-ss { background: rgba(200,50,50,0.25); color: #e07878; border: 1px solid rgba(200,50,50,0.4); }

  /* ========== マクロボード ========== */
  .macro-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 0.9rem; margin-bottom: 1rem; }
  @media (max-width: 720px) { .macro-grid { grid-template-columns: 1fr 1fr; } }
  .macro-tile { background: linear-gradient(135deg, #0f0f0f 0%, #181818 100%); border: 1px solid #222; padding: 1rem; border-radius: 4px; position: relative; overflow: hidden; transition: all 0.25s; }
  .macro-tile:hover { transform: translateY(-2px); border-color: rgba(200,169,110,0.3); }
  .macro-label { font-size: 0.6rem; letter-spacing: 0.18em; color: #888; }
  .macro-val { font-size: 1.7rem; font-weight: 300; color: #edede8; margin: 0.3rem 0 0.1rem; }
  .macro-chg { font-size: 0.72rem; }
  .vix-meter { position: relative; height: 70px; margin-top: 0.5rem; background: linear-gradient(90deg, #6ec86e 0%, #c8a96e 40%, #c87e6e 70%, #c84e4e 100%); border-radius: 4px; overflow: hidden; }
  .vix-needle { position: absolute; top: -6px; width: 3px; height: 82px; background: #fff; box-shadow: 0 0 10px rgba(255,255,255,0.8); transition: left 1s cubic-bezier(0.34, 1.3, 0.64, 1); }
  .vix-scale { display: flex; justify-content: space-between; font-size: 0.55rem; color: #666; padding: 0 4px; margin-top: 0.2rem; }

  /* ========== 類似日カード ========== */
  .similar-today { background: rgba(200,169,110,0.06); border: 1px solid rgba(200,169,110,0.25); padding: 0.8rem 1rem; margin-bottom: 0.8rem; border-radius: 4px; font-size: 0.82rem; color: #ddd; }
  .similar-card { background: #0f0f0f; border: 1px solid #1f1f1f; border-left: 3px solid #c8a96e; padding: 0.9rem 1.1rem; margin-bottom: 0.6rem; border-radius: 0 4px 4px 0; transition: all 0.2s; }
  .similar-card:hover { background: #141414; transform: translateX(3px); }
  .similar-date { font-size: 0.95rem; color: #c8a96e; font-weight: 500; }
  .similar-context { display: inline-block; padding: 0.1rem 0.5rem; font-size: 0.65rem; background: rgba(200,169,110,0.18); color: #c8a96e; margin-left: 0.5rem; border-radius: 2px; letter-spacing: 0.05em; }
  .similar-stats { font-size: 0.75rem; color: #888; margin-top: 0.3rem; }
  .similar-fwd { font-size: 0.85rem; margin-top: 0.4rem; font-weight: 500; }
  .similar-fwd.pos { color: #6ec86e; }
  .similar-fwd.neg { color: #c86e6e; }

  /* ========== 振り返りカード ========== */
  .pm-summary { display: flex; gap: 1.2rem; flex-wrap: wrap; padding: 1rem 1.2rem; background: #0f0f0f; border: 1px solid #1f1f1f; border-radius: 4px; margin-bottom: 1rem; }
  .pm-stat { font-size: 0.78rem; color: #888; display: flex; align-items: baseline; gap: 0.4rem; }
  .pm-stat-num { font-size: 1.5rem; font-weight: 300; color: #c8a96e; }
  .pm-card { background: #0f0f0f; border: 1px solid #1f1f1f; border-left: 3px solid #c8a96e; padding: 1rem 1.1rem; margin-bottom: 0.7rem; border-radius: 0 4px 4px 0; }
  .pm-card.hit  { border-left-color: #6ec86e; }
  .pm-card.miss { border-left-color: #c86e6e; }
  .pm-head { display: flex; align-items: baseline; gap: 0.6rem; margin-bottom: 0.4rem; flex-wrap: wrap; }
  .pm-tk { font-size: 1rem; color: #edede8; font-weight: 600; }
  .pm-verdict { font-size: 0.78rem; font-weight: 500; }
  .pm-verdict.hit  { color: #6ec86e; }
  .pm-verdict.miss { color: #c86e6e; }
  .pm-meta-mini { font-size: 0.66rem; color: #555; margin-left: auto; }
  .pm-stats-line { color: #aaa; font-size: 0.78rem; margin: 0.4rem 0; }
  .pm-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; margin-top: 0.5rem; }
  @media (max-width: 600px) { .pm-grid2 { grid-template-columns: 1fr; } }
  .pm-block-label { font-size: 0.62rem; color: #c8a96e; letter-spacing: 0.12em; margin-bottom: 0.3rem; text-transform: uppercase; }
  .pm-agent { padding: 0.28rem 0.4rem; font-size: 0.72rem; color: #888; border-bottom: 1px solid #181818; transition: background 0.15s; }
  .pm-agent:hover { background: rgba(200,169,110,0.04); }
  .pm-agent-name { color: #ddd; font-weight: 500; }
  .pm-agent-score { display: inline-block; min-width: 26px; padding: 0.05rem 0.3rem; border-radius: 2px; font-size: 0.65rem; font-weight: 600; text-align: center; margin-right: 0.4rem; }
  .pm-suggest { background: rgba(200,169,110,0.06); border: 1px dashed rgba(200,169,110,0.3); padding: 0.5rem 0.7rem; margin-top: 0.6rem; font-size: 0.72rem; color: #c8a96e; border-radius: 3px; }

  /* ========== チャート系 ========== */
  .chart-card { background: #0d0d0d; border: 1px solid #1e1e1e; padding: 1.2rem; border-radius: 4px; margin-bottom: 1.2rem; }
  canvas { max-height: 280px; }
  .scatter-legend { display: flex; gap: 1rem; font-size: 0.7rem; color: #888; margin-top: 0.5rem; flex-wrap: wrap; }
  .scatter-legend-dot { display: inline-block; width: 9px; height: 9px; border-radius: 50%; margin-right: 0.3rem; vertical-align: middle; }

  /* ========== 過去履歴 ========== */
  .hist-table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  .hist-table th { font-size: 0.58rem; letter-spacing: 0.12em; color: #666; padding: 0.4rem 0.6rem; border-bottom: 1px solid #1e1e1e; text-align: left; }
  .hist-table td { padding: 0.5rem 0.6rem; border-bottom: 1px solid #141414; color: #aaa; }
  .hist-table tr:hover td { background: #131313; }
  .r-hit { color: #6ec86e; }
  .r-miss { color: #c86e6e; }
  .r-pending { color: #555; }

  /* ========== モーダル ========== */
  .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.85); display: none; z-index: 1000; overflow-y: auto; backdrop-filter: blur(4px); }
  .modal-backdrop.open { display: block; animation: fadeIn 0.25s ease; }
  .modal-card { max-width: 920px; margin: 3rem auto; background: #0d0d0d; border: 1px solid #2a2418; padding: 1.8rem; color: #ddd; border-radius: 6px; }
  .modal-close { float: right; cursor: pointer; color: #888; font-size: 1.6rem; line-height: 1; transition: color 0.15s; }
  .modal-close:hover { color: #fff; }
  .modal-title { font-size: 1.3rem; color: #c8a96e; margin: 0 0 0.4rem; }
  .modal-sub { font-size: 0.7rem; color: #666; margin-bottom: 1.5rem; }
  .detail-section { margin: 1.5rem 0; }
  .detail-section h3 { font-size: 0.65rem; letter-spacing: 0.18em; color: #c8a96e; border-bottom: 1px solid rgba(200,169,110,0.2); padding-bottom: 0.4rem; margin-bottom: 0.8rem; text-transform: uppercase; }
  .grid3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
  @media (max-width: 600px) { .grid3 { grid-template-columns: 1fr 1fr; } }
  .stat-cell { background: #141414; padding: 0.65rem; border: 1px solid #1f1f1f; border-radius: 3px; }
  .stat-label { font-size: 0.58rem; color: #888; letter-spacing: 0.12em; text-transform: uppercase; }
  .stat-value { font-size: 1rem; color: #edede8; margin-top: 0.2rem; }
  .agent-list { font-size: 0.75rem; }
  .agent-item { padding: 0.45rem 0.5rem; border-bottom: 1px solid #1a1a1a; display: flex; align-items: center; gap: 0.5rem; }
  .agent-score { display: inline-block; min-width: 32px; padding: 0.1rem 0.35rem; border-radius: 2px; font-weight: 600; text-align: center; font-size: 0.7rem; }
  .agent-buy { background: rgba(80,200,80,0.18); color: #88e088; }
  .agent-sell { background: rgba(200,80,80,0.18); color: #e07878; }
  .agent-hold { background: rgba(150,150,150,0.12); color: #888; }
  .agent-name { color: #aaa; min-width: 130px; font-size: 0.7rem; }
  .agent-reason { color: #777; font-size: 0.7rem; flex: 1; }
  .news-item { font-size: 0.75rem; padding: 0.4rem 0; border-bottom: 1px solid #1a1a1a; }
  .news-meta { font-size: 0.62rem; color: #555; margin-top: 0.15rem; }
  .verdict-box { background: #141414; padding: 0.9rem 1rem; border-left: 3px solid #c8a96e; font-size: 0.78rem; white-space: pre-wrap; line-height: 1.55; color: #ccc; border-radius: 0 3px 3px 0; }
  .cat-bar-wrap { display: flex; gap: 0.5rem; align-items: center; font-size: 0.7rem; color: #aaa; padding: 0.25rem 0; }
  .cat-bar { flex: 1; height: 7px; background: #1a1a1a; border-radius: 2px; overflow: hidden; display: flex; }
  .cat-bar-buy  { background: #6ec86e; }
  .cat-bar-hold { background: #555; }
  .cat-bar-sell { background: #c86e6e; }

  /* ========== 🆕 エージェントネットワーク（近未来UI） ========== */
  .ag-stage { background: radial-gradient(ellipse at center, #0a0a0f 0%, #050508 100%); border: 1px solid rgba(108,200,224,0.15); padding: 1.2rem; border-radius: 4px; margin-bottom: 1.2rem; position: relative; overflow: hidden; }
  .ag-stage::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(0deg, transparent 0px, transparent 39px, rgba(108,200,224,0.04) 40px), repeating-linear-gradient(90deg, transparent 0px, transparent 39px, rgba(108,200,224,0.04) 40px); pointer-events: none; }
  .ag-stage > * { position: relative; z-index: 1; }

  /* 統計サマリ */
  .ag-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.8rem; margin-bottom: 1.5rem; }
  .ag-stat { background: rgba(0,0,0,0.5); border: 1px solid rgba(108,200,224,0.25); padding: 0.8rem 1rem; border-radius: 3px; position: relative; overflow: hidden; transition: all 0.3s; }
  .ag-stat::after { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 1px; background: linear-gradient(90deg, transparent, rgba(108,200,224,0.6), transparent); animation: scan 4s ease-in-out infinite; }
  @keyframes scan { 0%, 100% { left: -100%; } 50% { left: 100%; } }
  .ag-stat-label { font-size: 0.6rem; letter-spacing: 0.2em; color: #6c8a9a; text-transform: uppercase; }
  .ag-stat-val { font-size: 1.7rem; font-weight: 200; color: #6ec8e0; margin-top: 0.2rem; font-family: 'Courier New', monospace; text-shadow: 0 0 12px rgba(108,200,224,0.4); }
  .ag-stat-sub { font-size: 0.62rem; color: #5a7080; margin-top: 0.1rem; }

  /* カテゴリフィルタ */
  .ag-filter { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .ag-cat-btn { padding: 0.35rem 0.8rem; background: rgba(0,0,0,0.4); border: 1px solid #2a2a35; color: #888; cursor: pointer; font-size: 0.7rem; letter-spacing: 0.05em; border-radius: 3px; transition: all 0.2s; font-family: inherit; }
  .ag-cat-btn:hover { color: #edede8; border-color: rgba(108,200,224,0.5); }
  .ag-cat-btn.active { color: #0a0a0f; background: var(--cat-color, #6ec8e0); border-color: var(--cat-color, #6ec8e0); font-weight: 600; box-shadow: 0 0 10px var(--cat-glow, rgba(108,200,224,0.5)); }

  /* エージェントカテゴリブロック */
  .ag-category { margin-bottom: 1.5rem; }
  .ag-cat-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--cat-color, #2a2a35); }
  .ag-cat-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--cat-color, #888); box-shadow: 0 0 8px var(--cat-color, #888); animation: pulse-dot 2s ease-in-out infinite; }
  @keyframes pulse-dot { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(1.3); } }
  .ag-cat-name { font-size: 0.85rem; color: var(--cat-color, #ddd); letter-spacing: 0.05em; font-weight: 500; }
  .ag-cat-count { font-size: 0.65rem; color: #555; margin-left: auto; font-family: 'Courier New', monospace; }

  /* エージェントグリッド */
  .ag-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.6rem; }
  .ag-card { background: linear-gradient(135deg, rgba(20,20,28,0.9) 0%, rgba(10,10,16,0.9) 100%); border: 1px solid var(--cat-color, #2a2a35); border-left: 3px solid var(--cat-color, #6ec8e0); padding: 0.7rem 0.85rem; border-radius: 2px; position: relative; overflow: hidden; transition: all 0.25s; cursor: help; }
  .ag-card:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.4), 0 0 0 1px var(--cat-color, #6ec8e0); }
  .ag-card.has-math::before { content: '🔬'; position: absolute; top: 6px; right: 8px; font-size: 0.7rem; opacity: 0.7; }
  .ag-card.evolved::after { content: ''; position: absolute; top: 6px; right: 6px; width: 8px; height: 8px; border-radius: 50%; background: #c8a96e; box-shadow: 0 0 8px #c8a96e; animation: pulse-evolved 1.5s ease-in-out infinite; }
  @keyframes pulse-evolved { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }
  .ag-name { font-size: 0.78rem; color: #edede8; font-weight: 600; font-family: 'Courier New', monospace; letter-spacing: -0.02em; margin-bottom: 0.2rem; }
  .ag-desc { font-size: 0.66rem; color: #888; line-height: 1.4; min-height: 2.4em; margin-bottom: 0.5rem; }
