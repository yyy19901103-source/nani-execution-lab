---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="株式AI予測ダッシュボード — NaNi Execution Lab"
  description="LightGBM+69エージェントによる米国株AI予測。推奨銘柄・上昇確率・過去の的中率をリアルタイム公開。"
>

<style>
  .sp-wrap { max-width: 960px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
  .sp-header { text-align: center; padding: 2.5rem 0 2rem; border-bottom: 1px solid rgba(200,169,110,0.2); margin-bottom: 2rem; }
  .sp-header h1 { font-size: clamp(1.4rem,4vw,2rem); font-weight: 300; letter-spacing: 0.1em; color: #edede8; margin-bottom: 0.5rem; }
  .sp-header p  { color: #888; font-size: 0.85rem; }
  .sp-updated   { font-size: 0.72rem; color: #555; margin-top: 0.4rem; }

  .kpi-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px,1fr)); gap: 1rem; margin-bottom: 2rem; }
  .kpi { background: #111; border: 1px solid #222; padding: 1.1rem; text-align: center; }
  .kpi-label { font-size: 0.62rem; letter-spacing: 0.2em; color: #888; margin-bottom: 0.4rem; }
  .kpi-val   { font-size: 1.6rem; font-weight: 300; color: #c8a96e; }
  .kpi-sub   { font-size: 0.68rem; color: #555; margin-top: 0.2rem; }

  .section-title { font-size: 0.65rem; letter-spacing: 0.25em; color: #c8a96e; border-bottom: 1px solid rgba(200,169,110,0.3); padding-bottom: 0.4rem; margin: 2rem 0 1rem; }

  .rank-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .rank-table th { font-size: 0.6rem; letter-spacing: 0.15em; color: #888; padding: 0.5rem 0.75rem; border-bottom: 1px solid #222; text-align: left; }
  .rank-table td { padding: 0.65rem 0.75rem; border-bottom: 1px solid #1a1a1a; color: #ddd; }
  .rank-table tr:hover td { background: #141414; }

  .badge { display: inline-block; padding: 0.15rem 0.5rem; font-size: 0.65rem; letter-spacing: 0.1em; border-radius: 2px; }
  .badge-sb { background: rgba(80,200,80,0.2);  color: #6ec86e; border: 1px solid rgba(80,200,80,0.3); }
  .badge-b  { background: rgba(80,200,80,0.12); color: #6ec86e; border: 1px solid rgba(80,200,80,0.2); }
  .badge-wb { background: rgba(200,200,80,0.15);color: #c8c86e; border: 1px solid rgba(200,200,80,0.2); }
  .badge-w  { background: rgba(150,150,150,0.1);color: #888;    border: 1px solid #333; }
  .badge-ws { background: rgba(200,100,80,0.12);color: #c87e6e; border: 1px solid rgba(200,100,80,0.2); }
  .badge-s  { background: rgba(200,80,80,0.15); color: #c86e6e; border: 1px solid rgba(200,80,80,0.2); }
  .badge-ss { background: rgba(200,50,50,0.2);  color: #c86e6e; border: 1px solid rgba(200,50,50,0.3); }

  .prob-bar { display: inline-block; width: 60px; height: 6px; background: #222; border-radius: 3px; vertical-align: middle; margin-right: 0.4rem; }
  .prob-fill { height: 100%; border-radius: 3px; background: #c8a96e; }

  .chart-wrap { background: #0d0d0d; border: 1px solid #1e1e1e; padding: 1.25rem; margin-bottom: 1.5rem; }
  canvas { max-height: 220px; }

  .history-table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  .history-table th { font-size: 0.58rem; letter-spacing: 0.12em; color: #666; padding: 0.4rem 0.6rem; border-bottom: 1px solid #1e1e1e; }
  .history-table td { padding: 0.5rem 0.6rem; border-bottom: 1px solid #141414; color: #aaa; }
  .r-hit     { color: #6ec86e; }
  .r-miss    { color: #c86e6e; }
  .r-pending { color: #555; }

  .disclaimer { font-size: 0.7rem; color: #444; background: #0a0a0a; border: 1px solid #1a1a1a; padding: 1rem 1.25rem; margin-top: 2.5rem; line-height: 1.7; }

  /* 🆕 マクロボード */
  .macro-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
  @media (max-width: 720px) { .macro-grid { grid-template-columns: 1fr 1fr; } }
  .macro-tile { background: linear-gradient(135deg, #0f0f0f 0%, #181818 100%); border: 1px solid #222; padding: 1rem; position: relative; overflow: hidden; }
  .macro-tile-label { font-size: 0.6rem; letter-spacing: 0.2em; color: #888; }
  .macro-tile-value { font-size: 1.8rem; font-weight: 300; color: #edede8; margin: 0.4rem 0; }
  .macro-tile-change { font-size: 0.75rem; }
  .vix-meter { position: relative; height: 80px; margin-top: 0.6rem; background: linear-gradient(90deg, #6ec86e 0%, #c8a96e 40%, #c87e6e 70%, #c84e4e 100%); border-radius: 4px; overflow: hidden; }
  .vix-needle { position: absolute; top: -8px; width: 3px; height: 96px; background: #fff; box-shadow: 0 0 8px rgba(255,255,255,0.7); transition: left 0.8s ease; }
  .vix-scale { display: flex; justify-content: space-between; font-size: 0.55rem; color: #555; padding: 0 4px; margin-top: 0.2rem; }

  /* 🆕 類似日マッチング */
  .similar-card { background: #0d0d0d; border: 1px solid #1f1f1f; padding: 1rem 1.2rem; margin-bottom: 0.8rem; border-left: 3px solid #c8a96e; }
  .similar-date { font-size: 1rem; color: #c8a96e; font-weight: 500; }
  .similar-context { display: inline-block; padding: 0.1rem 0.5rem; font-size: 0.65rem; background: rgba(200,169,110,0.15); color: #c8a96e; margin-left: 0.5rem; border-radius: 2px; }
  .similar-stats { font-size: 0.78rem; color: #aaa; margin-top: 0.4rem; }
  .similar-fwd { font-size: 0.85rem; color: #6ec86e; margin-top: 0.4rem; font-weight: 500; }
  .similar-fwd.neg { color: #c86e6e; }
  .today-tile { background: rgba(200,169,110,0.08); border: 1px solid rgba(200,169,110,0.3); padding: 0.8rem 1rem; margin-bottom: 1rem; font-size: 0.85rem; color: #ddd; }

  /* 🆕 ポジショニングマップ */
  .scatter-wrap { background: #0d0d0d; border: 1px solid #1e1e1e; padding: 1.25rem; margin-bottom: 1.5rem; }
  #scatter-chart { max-height: 380px; }
  .scatter-legend { display: flex; gap: 1.2rem; font-size: 0.7rem; color: #888; margin-top: 0.6rem; flex-wrap: wrap; }
  .scatter-legend-item { display: flex; align-items: center; gap: 0.3rem; }
  .scatter-legend-dot { width: 10px; height: 10px; border-radius: 50%; }

  /* 銘柄詳細モーダル */
  .ticker-link { cursor: pointer; color: #c8a96e; text-decoration: underline dotted; }
  .ticker-link:hover { color: #e0c08a; }
  .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.85); display: none; z-index: 1000; overflow-y: auto; }
  .modal-backdrop.open { display: block; }
  .modal-card { max-width: 920px; margin: 3rem auto; background: #0d0d0d; border: 1px solid #2a2418; padding: 2rem; color: #ddd; }
  .modal-close { float: right; cursor: pointer; color: #888; font-size: 1.4rem; line-height: 1; }
  .modal-close:hover { color: #fff; }
  .modal-title { font-size: 1.3rem; color: #c8a96e; margin: 0 0 0.5rem; }
  .modal-sub   { font-size: 0.75rem; color: #666; margin-bottom: 1.5rem; }
  .detail-section { margin: 1.5rem 0; }
  .detail-section h3 { font-size: 0.7rem; letter-spacing: 0.2em; color: #c8a96e; border-bottom: 1px solid rgba(200,169,110,0.2); padding-bottom: 0.4rem; margin-bottom: 0.8rem; }
  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .grid3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.6rem; }
  .stat-cell { background: #141414; padding: 0.7rem; border: 1px solid #1f1f1f; }
  .stat-label { font-size: 0.6rem; color: #888; letter-spacing: 0.15em; }
  .stat-value { font-size: 1rem; color: #edede8; margin-top: 0.2rem; }
  .agent-list { font-size: 0.75rem; }
  .agent-item { padding: 0.5rem 0.7rem; border-bottom: 1px solid #1a1a1a; display: flex; align-items: center; gap: 0.5rem; }
  .agent-score { display: inline-block; min-width: 32px; padding: 0.1rem 0.35rem; border-radius: 2px; font-weight: 600; text-align: center; }
  .agent-buy  { background: rgba(80,200,80,0.15); color: #6ec86e; }
  .agent-sell { background: rgba(200,80,80,0.15); color: #c86e6e; }
  .agent-hold { background: rgba(150,150,150,0.1); color: #888; }
  .agent-name { color: #aaa; min-width: 130px; font-size: 0.7rem; }
  .agent-reason { color: #888; font-size: 0.7rem; flex: 1; }
  .news-item { font-size: 0.75rem; padding: 0.4rem 0; border-bottom: 1px solid #1a1a1a; }
  .news-meta { font-size: 0.65rem; color: #555; }
  .verdict-box { background: #141414; padding: 1rem; border-left: 3px solid #c8a96e; font-size: 0.8rem; white-space: pre-wrap; line-height: 1.6; color: #ccc; }
  .cat-bar-wrap { display: flex; gap: 0.5rem; align-items: center; font-size: 0.7rem; color: #aaa; padding: 0.3rem 0; }
  .cat-bar { flex: 1; height: 8px; background: #1a1a1a; border-radius: 2px; overflow: hidden; display: flex; }
  .cat-bar-buy  { background: #6ec86e; }
  .cat-bar-hold { background: #555; }
  .cat-bar-sell { background: #c86e6e; }
</style>

<div class="sp-wrap">
  <div class="sp-header">
    <h1>📈 株式AI予測ダッシュボード</h1>
    <p>LightGBM + 69エージェントによる米国株予測を公開しています</p>
    <p class="sp-updated" id="updated-at">データ読み込み中…</p>
  </div>

  <!-- KPI -->
  <div class="kpi-row" id="kpi-row">
    <div class="kpi"><div class="kpi-label">MONITORED</div><div class="kpi-val" id="kpi-stocks">—</div><div class="kpi-sub">監視銘柄数</div></div>
    <div class="kpi"><div class="kpi-label">ACCURACY</div><div class="kpi-val" id="kpi-acc">—</div><div class="kpi-sub">5日後的中率</div></div>
    <div class="kpi"><div class="kpi-label">JUDGED</div><div class="kpi-val" id="kpi-judged">—</div><div class="kpi-sub">判定済み予測</div></div>
    <div class="kpi"><div class="kpi-label">PENDING</div><div class="kpi-val" id="kpi-pending">—</div><div class="kpi-sub">判定待ち</div></div>
  </div>

  <!-- 🆕 マクロボード -->
  <div class="section-title">市場恐怖メーター + マクロ環境</div>
  <div class="macro-grid">
    <div class="macro-tile">
      <div class="macro-tile-label">VIX 恐怖指数</div>
      <div class="macro-tile-value" id="m-vix-val">—</div>
      <div class="macro-tile-change" id="m-vix-chg">—</div>
      <div class="vix-meter"><div class="vix-needle" id="vix-needle" style="left:50%"></div></div>
      <div class="vix-scale"><span>0</span><span>15</span><span>25</span><span>35</span><span>50+</span></div>
    </div>
    <div class="macro-tile">
      <div class="macro-tile-label">米10年金利</div>
      <div class="macro-tile-value" id="m-10y-val">—</div>
      <div class="macro-tile-change" id="m-10y-chg">—</div>
    </div>
    <div class="macro-tile">
      <div class="macro-tile-label">S&amp;P 500</div>
      <div class="macro-tile-value" id="m-sp-val">—</div>
      <div class="macro-tile-change" id="m-sp-chg">—</div>
    </div>
    <div class="macro-tile">
      <div class="macro-tile-label">USDJPY</div>
      <div class="macro-tile-value" id="m-jpy-val">—</div>
      <div class="macro-tile-change" id="m-jpy-chg">—</div>
    </div>
  </div>

  <!-- 🆕 過去類似日マッチング -->
  <div class="section-title">過去36年DBから類似日マッチング</div>
  <div id="similar-today" class="today-tile">読み込み中…</div>
  <div id="similar-list"></div>

  <!-- 🆕 ポジショニングマップ -->
  <div class="section-title">ポジショニングマップ（リスク × 期待値）</div>
  <div class="scatter-wrap">
    <canvas id="scatter-chart"></canvas>
    <div class="scatter-legend">
      <div class="scatter-legend-item"><span class="scatter-legend-dot" style="background:#6ec86e"></span> 買い系</div>
      <div class="scatter-legend-item"><span class="scatter-legend-dot" style="background:#c8a96e"></span> 様子見</div>
      <div class="scatter-legend-item"><span class="scatter-legend-dot" style="background:#c86e6e"></span> 売り系</div>
      <div class="scatter-legend-item">X軸: 期待リターン% / Y軸: 5%下落確率% / サイズ: AIスコア</div>
    </div>
  </div>

  <!-- 的中率グラフ -->
  <div class="section-title">月別的中率</div>
  <div class="chart-wrap">
    <canvas id="acc-chart"></canvas>
  </div>

  <!-- 現在のランキング -->
  <div class="section-title">現在のAIランキング</div>
  <table class="rank-table">
    <thead>
      <tr>
        <th>銘柄</th><th>ランク</th><th>AIスコア</th><th>5日上昇確率</th><th>期待リターン</th><th>更新日時</th>
      </tr>
    </thead>
    <tbody id="ranking-tbody"></tbody>
  </table>

  <!-- 過去予測履歴 -->
  <div class="section-title">過去の予測履歴</div>
  <table class="history-table">
    <thead>
      <tr>
        <th>日付</th><th>銘柄</th><th>ランク</th><th>上昇確率</th><th>実績</th><th>判定</th>
      </tr>
    </thead>
    <tbody id="history-tbody"></tbody>
  </table>

  <!-- 銘柄詳細モーダル -->
  <div class="modal-backdrop" id="modal" role="dialog" aria-hidden="true">
    <div class="modal-card" id="modal-card">
      <span class="modal-close" id="modal-close">×</span>
      <h2 class="modal-title" id="m-title">—</h2>
      <p class="modal-sub" id="m-sub">—</p>

      <div class="detail-section">
        <h3>判定サマリー</h3>
        <div class="grid3">
          <div class="stat-cell"><div class="stat-label">RANK</div><div class="stat-value" id="m-rank">—</div></div>
          <div class="stat-cell"><div class="stat-label">SCORE</div><div class="stat-value" id="m-score">—</div></div>
          <div class="stat-cell"><div class="stat-label">RR</div><div class="stat-value" id="m-rr">—</div></div>
          <div class="stat-cell"><div class="stat-label">5日上昇確率</div><div class="stat-value" id="m-pup">—</div></div>
          <div class="stat-cell"><div class="stat-label">5%下落確率</div><div class="stat-value" id="m-pdown">—</div></div>
          <div class="stat-cell"><div class="stat-label">期待値</div><div class="stat-value" id="m-er">—</div></div>
        </div>
        <div class="verdict-box" id="m-verdict" style="margin-top:0.8rem">—</div>
      </div>

      <div class="detail-section">
        <h3>69エージェント シグナル分布</h3>
        <div id="m-cats"></div>
      </div>

      <div class="detail-section">
        <h3>過去ドローダウン分析（DB保有期間全体）</h3>
        <p class="modal-sub" id="m-hist-span">—</p>
        <div class="grid3" id="m-hist"></div>
      </div>

      <div class="detail-section">
        <h3>バックテスト的中率（ルールベース戦略）</h3>
        <div class="grid3" id="m-bt"></div>
        <p class="modal-sub" id="m-bt-period" style="margin-top:0.5rem">—</p>
      </div>

      <div class="detail-section">
        <h3>主要ファンダメンタル</h3>
        <div class="grid3" id="m-fund"></div>
      </div>

      <div class="detail-section">
        <h3>BUYシグナル根拠（上位）</h3>
        <div class="agent-list" id="m-buys"></div>
      </div>

      <div class="detail-section">
        <h3>リスク警告（上位）</h3>
        <div class="agent-list" id="m-risks"></div>
      </div>

      <div class="detail-section">
        <h3>関連ニュース（72h）</h3>
        <div id="m-news"></div>
      </div>
    </div>
  </div>

  <!-- 免責事項 -->
  <div class="disclaimer">
    ⚠️ 本ページの情報は個人の学習・研究目的で公開しています。投資判断の根拠としないでください。<br>
    予測はLightGBM（機械学習モデル）と独自エージェントによるものであり、将来の結果を保証するものではありません。<br>
    保有株数・購入単価・損益金額は一切公開していません。
  </div>
</div>

<script>
  const BASE = import.meta.env.BASE_URL?.replace(/\/$/, '') || '';

  const BADGE_CLASS = {
    strong_buy:'badge-sb', buy:'badge-b', weak_buy:'badge-wb',
    watch:'badge-w', neutral:'badge-w',
    weak_sell:'badge-ws', sell:'badge-s', strong_sell:'badge-ss', avoid:'badge-ss'
  };

  async function load() {
    let data;
    try {
      const res = await fetch(`${BASE}/data/stock.json`);
      data = await res.json();
    } catch(e) {
      document.getElementById('updated-at').textContent = 'データ読み込みエラー';
      return;
    }

    document.getElementById('updated-at').textContent = `最終更新: ${data.generated_at}`;
    const acc = data.accuracy;

    document.getElementById('kpi-stocks').textContent  = data.rankings.length;
    document.getElementById('kpi-acc').textContent     = acc.rate != null ? (acc.rate*100).toFixed(1)+'%' : '—';
    document.getElementById('kpi-judged').textContent  = acc.total;
    document.getElementById('kpi-pending').textContent = acc.pending;

    // 月別グラフ（Chart.js）
    if (acc.monthly && acc.monthly.length > 0) {
      const labels = acc.monthly.map(m => m.month);
      const rates  = acc.monthly.map(m => m.rate != null ? (m.rate*100).toFixed(1) : null);
      const totals = acc.monthly.map(m => m.total);

      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js';
      script.onload = () => {
        const ctx = document.getElementById('acc-chart').getContext('2d');
        new Chart(ctx, {
          type: 'bar',
          data: {
            labels,
            datasets: [
              {
                label: '的中率(%)',
                data: rates,
                backgroundColor: rates.map(r => r >= 60 ? 'rgba(110,200,110,0.5)' : r >= 50 ? 'rgba(200,169,110,0.5)' : 'rgba(200,110,110,0.5)'),
                borderColor:     rates.map(r => r >= 60 ? '#6ec86e' : r >= 50 ? '#c8a96e' : '#c86e6e'),
                borderWidth: 1,
                yAxisID: 'y',
              },
              {
                label: '判定数',
                data: totals,
                type: 'line',
                borderColor: '#444',
                backgroundColor: 'transparent',
                pointRadius: 3,
                yAxisID: 'y2',
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: { legend: { labels: { color:'#888', font:{size:11} } } },
            scales: {
              x:  { ticks:{color:'#666'}, grid:{color:'#1a1a1a'} },
              y:  { ticks:{color:'#888',callback:v=>v+'%'}, grid:{color:'#1a1a1a'}, min:0, max:100 },
              y2: { position:'right', ticks:{color:'#444'}, grid:{display:false} },
            }
          }
        });
      };
      document.head.appendChild(script);
    } else {
      document.querySelector('.chart-wrap').innerHTML =
        '<p style="color:#444;text-align:center;padding:2rem;">判定データ蓄積後に表示されます（予測から5営業日後）</p>';
    }

    // ランキングテーブル
    const tbody = document.getElementById('ranking-tbody');
    data.rankings.forEach(r => {
      const badgeClass = BADGE_CLASS[r.rank] || 'badge-w';
      const prob = r.prob_up_5d != null ? r.prob_up_5d : 0;
      const probPct = (prob*100).toFixed(0);
      const er = r.expected_return != null ? (r.expected_return > 0 ? '+' : '') + r.expected_return.toFixed(1)+'%' : '—';
      const updAt = r.updated_at ? r.updated_at.slice(0,16) : '—';
      tbody.insertAdjacentHTML('beforeend', `
        <tr>
          <td><span class="ticker-link" data-ticker="${r.ticker}"><strong>${r.ticker}</strong></span></td>
          <td><span class="badge ${badgeClass}">${r.rank_ja || r.rank || '—'}</span></td>
          <td>${r.score != null ? r.score : '—'}</td>
          <td>
            <span class="prob-bar"><span class="prob-fill" style="width:${probPct}%"></span></span>
            ${probPct}%
          </td>
          <td style="color:${r.expected_return>0?'#6ec86e':r.expected_return<0?'#c86e6e':'#888'}">${er}</td>
          <td style="color:#555;font-size:0.7rem">${updAt}</td>
        </tr>
      `);
    });

    // 銘柄リンクのクリックイベント
    document.querySelectorAll('.ticker-link').forEach(el => {
      el.addEventListener('click', () => openTickerDetail(el.dataset.ticker));
    });

    // 履歴テーブル
    const hbody = document.getElementById('history-tbody');
    data.history.forEach(h => {
      const badgeClass = BADGE_CLASS[h.rank] || 'badge-w';
      const prob = h.prob_up_5d != null ? (h.prob_up_5d*100).toFixed(0)+'%' : '—';
      const ret  = h.actual_ret != null ? (h.actual_ret>0?'+':'')+h.actual_ret.toFixed(1)+'%' : '—';
      const resultLabel = h.result==='hit' ? '✅ 当たり' : h.result==='miss' ? '❌ 外れ' : '⏳ 待ち';
      const resultClass = h.result==='hit' ? 'r-hit' : h.result==='miss' ? 'r-miss' : 'r-pending';
      hbody.insertAdjacentHTML('beforeend', `
        <tr>
          <td style="color:#555">${h.date}</td>
          <td><strong style="color:#ddd">${h.ticker}</strong></td>
          <td><span class="badge ${badgeClass}" style="font-size:0.6rem">${h.rank||'—'}</span></td>
          <td>${prob}</td>
          <td style="color:${h.actual_ret>0?'#6ec86e':h.actual_ret<0?'#c86e6e':'#888'}">${ret}</td>
          <td class="${resultClass}">${resultLabel}</td>
        </tr>
      `);
    });
  }

  load();

  // ============ 🆕 マクロボード ============
  async function loadMacro() {
    try {
      const res = await fetch(`${BASE}/data/stock-macro.json`);
      const m = await res.json();
      const setTile = (id, obj, suffix='') => {
        if (!obj) return;
        document.getElementById(`m-${id}-val`).textContent = obj.value + suffix;
        const chg = obj.change_pct;
        const el = document.getElementById(`m-${id}-chg`);
        if (chg != null) {
          const sign = chg > 0 ? '▲ +' : chg < 0 ? '▼ ' : '― ';
          el.textContent = `${sign}${chg.toFixed(2)}% (${obj.date})`;
          el.style.color = chg > 0 ? '#6ec86e' : chg < 0 ? '#c86e6e' : '#888';
        }
      };
      setTile('vix', m.vix);
      setTile('10y', m.us10y, '%');
      setTile('sp', m.sp500);
      setTile('jpy', m.usdjpy);
      // VIX needle 位置（0-50を100%にマッピング）
      if (m.vix) {
        const pct = Math.min(100, Math.max(0, m.vix.value / 50 * 100));
        document.getElementById('vix-needle').style.left = `${pct}%`;
      }
    } catch (e) {
      console.error('macro load error', e);
    }
  }
  loadMacro();

  // ============ 🆕 過去類似日マッチング ============
  async function loadSimilarDays() {
    try {
      const res = await fetch(`${BASE}/data/stock-similar-days.json`);
      const s = await res.json();
      const todayEl = document.getElementById('similar-today');
      if (s.today) {
        todayEl.innerHTML = `📅 <strong>今日（${s.today.date}）</strong>: VIX <strong>${s.today.vix}</strong> / 10年金利 <strong>${s.today.us10y}%</strong> / SP500 20日リターン <strong>${s.today.sp500_ret_20d_pct}%</strong>`;
      }
      const listEl = document.getElementById('similar-list');
      listEl.innerHTML = '';
      (s.similar_days || []).forEach((d, i) => {
        const fwd = d.next_30d_return_pct;
        const fwdClass = fwd != null && fwd < 0 ? 'similar-fwd neg' : 'similar-fwd';
        const fwdText = fwd != null ? `→ その後30営業日: ${fwd > 0 ? '+' : ''}${fwd}%` : '→ 30日後データなし';
        listEl.insertAdjacentHTML('beforeend', `
          <div class="similar-card">
            <span class="similar-date">#${i+1}: ${d.date}</span>
            <span class="similar-context">${d.context}</span>
            <div class="similar-stats">VIX ${d.vix} / 10Y ${d.us10y}% / SP500 20日 ${d.sp500_ret_20d_pct}% (類似度 ${d.distance})</div>
            <div class="${fwdClass}">${fwdText}</div>
          </div>
        `);
      });
    } catch (e) {
      console.error('similar days load error', e);
    }
  }
  loadSimilarDays();

  // ============ 🆕 ポジショニングマップ ============
  async function loadScatter() {
    try {
      const res = await fetch(`${BASE}/data/stock.json`);
      const data = await res.json();
      // Chart.js が既にロードされていない場合があるので動的ロード
      const ensureChart = () => new Promise(resolve => {
        if (window.Chart) return resolve();
        const sc = document.createElement('script');
        sc.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js';
        sc.onload = resolve;
        document.head.appendChild(sc);
      });
      await ensureChart();

      const colorOf = (rank) => {
        if (['strong_buy','buy','weak_buy'].includes(rank)) return 'rgba(110,200,110,0.8)';
        if (['weak_sell','sell','strong_sell','avoid'].includes(rank)) return 'rgba(200,110,110,0.8)';
        return 'rgba(200,169,110,0.8)';
      };

      // 各銘柄の (期待値, 下落確率%, スコア)
      const points = [];
      for (const r of data.rankings) {
        try {
          const dRes = await fetch(`${BASE}/data/stock-detail/${r.ticker}.json`);
          const dd = await dRes.json();
          const er = r.expected_return ?? 0;
          const pdown = (dd.summary?.prob_down_5pct ?? 0.05) * 100;
          const score = r.score ?? 50;
          points.push({
            x: er, y: pdown,
            r: Math.max(6, score / 5),
            ticker: r.ticker,
            rank: r.rank,
            color: colorOf(r.rank),
          });
        } catch {}
      }

      const ctx = document.getElementById('scatter-chart').getContext('2d');
      new Chart(ctx, {
        type: 'bubble',
        data: {
          datasets: [{
            data: points,
            backgroundColor: points.map(p => p.color),
            borderColor: points.map(p => p.color.replace('0.8','1')),
            borderWidth: 1.5,
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: (ctx) => {
                  const p = ctx.raw;
                  return `${p.ticker} (${p.rank}): 期待値${p.x.toFixed(2)}% / 下落${p.y.toFixed(0)}% / スコア${(p.r * 5).toFixed(0)}`;
                }
              }
            }
          },
          scales: {
            x: { title: { display: true, text: '期待リターン (%)', color: '#888' }, ticks: { color: '#888' }, grid: { color: '#1a1a1a' }},
            y: { title: { display: true, text: '5%下落確率 (%)', color: '#888' }, ticks: { color: '#888' }, grid: { color: '#1a1a1a' }, reverse: true },
          },
          animation: { duration: 1200, easing: 'easeOutCubic' },
        },
        plugins: [{
          afterDatasetsDraw: (chart) => {
            const {ctx} = chart;
            chart.data.datasets[0].data.forEach((p, i) => {
              const meta = chart.getDatasetMeta(0).data[i];
              ctx.font = '10px sans-serif';
              ctx.fillStyle = '#edede8';
              ctx.textAlign = 'center';
              ctx.fillText(p.ticker, meta.x, meta.y - meta.options.radius - 4);
            });
          }
        }]
      });
    } catch (e) {
      console.error('scatter load error', e);
    }
  }
  loadScatter();

  // ============ 銘柄詳細モーダル ============
  const RANK_LABEL = {
    strong_buy:'強い買い', buy:'買い', weak_buy:'やや買い',
    watch:'様子見', neutral:'中立',
    weak_sell:'やや売り', sell:'売り', strong_sell:'強い売り', avoid:'回避'
  };

  async function openTickerDetail(ticker) {
    const modal = document.getElementById('modal');
    modal.classList.add('open');
    document.getElementById('m-title').textContent = `📊 ${ticker} — 判断根拠`;
    document.getElementById('m-sub').textContent   = 'データ読み込み中…';

    let d;
    try {
      const res = await fetch(`${BASE}/data/stock-detail/${ticker}.json`);
      d = await res.json();
    } catch(e) {
      document.getElementById('m-sub').textContent = `読み込みエラー: ${e.message}`;
      return;
    }

    const s = d.summary || {};
    document.getElementById('m-sub').textContent = `更新: ${d.generated_at} / 予測日: ${s.prediction_date || '—'}`;
    document.getElementById('m-rank').textContent  = RANK_LABEL[s.rank] || s.rank || '—';
    document.getElementById('m-score').textContent = s.score != null ? s.score : '—';
    document.getElementById('m-rr').textContent    = s.risk_reward != null ? s.risk_reward.toFixed(2) : '—';
    document.getElementById('m-pup').textContent   = s.prob_up_5d != null ? (s.prob_up_5d*100).toFixed(0)+'%' : '—';
    document.getElementById('m-pdown').textContent = s.prob_down_5pct != null ? (s.prob_down_5pct*100).toFixed(0)+'%' : '—';
    document.getElementById('m-er').textContent    = s.expected_return != null ? (s.expected_return>0?'+':'')+s.expected_return.toFixed(2)+'%' : '—';
    document.getElementById('m-verdict').textContent = s.verdict || '—';

    // カテゴリ別シグナル
    const catWrap = document.getElementById('m-cats');
    catWrap.innerHTML = '';
    const cats = (d.agent_summary && d.agent_summary.category_stats) || {};
    Object.entries(cats).forEach(([cat, v]) => {
      const tot = v.count;
      const buyW  = (v.buy /tot*100).toFixed(0);
      const sellW = (v.sell/tot*100).toFixed(0);
      const holdW = 100 - buyW - sellW;
      catWrap.insertAdjacentHTML('beforeend', `
        <div class="cat-bar-wrap">
          <span style="min-width:120px">${cat}</span>
          <span class="cat-bar">
            <span class="cat-bar-buy"  style="width:${buyW}%"></span>
            <span class="cat-bar-hold" style="width:${holdW}%"></span>
            <span class="cat-bar-sell" style="width:${sellW}%"></span>
          </span>
          <span style="min-width:120px;text-align:right">BUY ${v.buy} / HOLD ${v.hold} / SELL ${v.sell} (avg ${v.avg_score})</span>
        </div>
      `);
    });

    // 過去DD分析
    const histWrap = document.getElementById('m-hist');
    const histSpan = document.getElementById('m-hist-span');
    const h = d.historical || d.historical_50y; // 互換性
    if (h) {
      histSpan.textContent = h.data_span_label || `${h.first_data_date}〜 (${h.total_days}日 = 約${(h.total_days/252).toFixed(1)}年)`;
      histWrap.innerHTML = `
        <div class="stat-cell"><div class="stat-label">最大DD</div><div class="stat-value" style="color:#c86e6e">${h.max_drawdown_pct}%</div></div>
        <div class="stat-cell"><div class="stat-label">現在DD</div><div class="stat-value" style="color:${h.current_drawdown_pct < -20 ? '#c86e6e' : '#c8a96e'}">${h.current_drawdown_pct}%</div></div>
        <div class="stat-cell"><div class="stat-label">最高値からの位置</div><div class="stat-value">${h.current_pct_of_ath}%</div></div>
        <div class="stat-cell"><div class="stat-label">-30%以下日数</div><div class="stat-value">${h.days_below_30pct_dd} / ${h.total_days}</div></div>
        <div class="stat-cell"><div class="stat-label">-30%以下の比率</div><div class="stat-value">${h.pct_time_below_30pct}%</div></div>
        <div class="stat-cell"><div class="stat-label">対象期間</div><div class="stat-value" style="font-size:0.85rem">約${h.approx_years || (h.total_days/252).toFixed(1)}年</div></div>
      `;
    } else {
      histSpan.textContent = '';
      histWrap.innerHTML = '<div style="color:#666">過去価格データなし</div>';
    }

    // バックテスト
    const btWrap = document.getElementById('m-bt');
    const bt = d.backtest;
    if (bt) {
      btWrap.innerHTML = `
        <div class="stat-cell"><div class="stat-label">勝率</div><div class="stat-value" style="color:${bt.win_rate_pct >= 55 ? '#6ec86e' : '#c8a96e'}">${bt.win_rate_pct}%</div></div>
        <div class="stat-cell"><div class="stat-label">CAGR</div><div class="stat-value">${bt.cagr_pct}%</div></div>
        <div class="stat-cell"><div class="stat-label">Sharpe</div><div class="stat-value">${bt.sharpe_ratio}</div></div>
        <div class="stat-cell"><div class="stat-label">最大DD</div><div class="stat-value" style="color:#c86e6e">${bt.max_drawdown_pct}%</div></div>
        <div class="stat-cell"><div class="stat-label">PF</div><div class="stat-value">${bt.profit_factor}</div></div>
        <div class="stat-cell"><div class="stat-label">取引数</div><div class="stat-value">${bt.total_trades}</div></div>
      `;
      document.getElementById('m-bt-period').textContent = `${bt.strategy} / 期間: ${bt.period}`;
    } else {
      btWrap.innerHTML = '<div style="color:#666">バックテスト結果なし</div>';
      document.getElementById('m-bt-period').textContent = '';
    }

    // ファンダメンタル
    const fundWrap = document.getElementById('m-fund');
    const f = d.fundamentals;
    if (f) {
      fundWrap.innerHTML = `
        <div class="stat-cell"><div class="stat-label">PER</div><div class="stat-value">${f.PER ?? '—'}</div></div>
        <div class="stat-cell"><div class="stat-label">PBR</div><div class="stat-value">${f.PBR ?? '—'}</div></div>
        <div class="stat-cell"><div class="stat-label">ROE</div><div class="stat-value">${f.ROE != null ? (f.ROE*100).toFixed(1)+'%' : '—'}</div></div>
        <div class="stat-cell"><div class="stat-label">営業利益率</div><div class="stat-value">${f.operating_margin != null ? (f.operating_margin*100).toFixed(1)+'%' : '—'}</div></div>
        <div class="stat-cell"><div class="stat-label">売上成長</div><div class="stat-value">${f.revenue_growth != null ? (f.revenue_growth*100).toFixed(1)+'%' : '—'}</div></div>
        <div class="stat-cell"><div class="stat-label">EPS成長</div><div class="stat-value">${f.eps_growth != null ? (f.eps_growth*100).toFixed(1)+'%' : '—'}</div></div>
      `;
    } else {
      fundWrap.innerHTML = '<div style="color:#666">ファンダデータなし</div>';
    }

    // BUYシグナル
    const buysWrap = document.getElementById('m-buys');
    buysWrap.innerHTML = (d.top_buys || []).map(a => `
      <div class="agent-item">
        <span class="agent-score agent-buy">${a.score}</span>
        <span class="agent-name">${a.agent}</span>
        <span class="agent-reason">${a.reason || '—'}</span>
      </div>
    `).join('') || '<div style="color:#666;padding:0.5rem">買いシグナル該当なし</div>';

    // リスク
    const risksWrap = document.getElementById('m-risks');
    risksWrap.innerHTML = (d.top_risks || []).map(a => `
      <div class="agent-item">
        <span class="agent-score ${a.judgment === 'SELL' || a.judgment === 'STRONG_SELL' ? 'agent-sell' : 'agent-hold'}">${a.score}</span>
        <span class="agent-name">${a.agent}</span>
        <span class="agent-reason">${a.reason || '—'}</span>
      </div>
    `).join('') || '<div style="color:#666;padding:0.5rem">リスク警告なし</div>';

    // ニュース
    const newsWrap = document.getElementById('m-news');
    newsWrap.innerHTML = (d.news || []).map(n => `
      <div class="news-item">
        <div>${n.headline}</div>
        <div class="news-meta">${n.published_at?.slice(0,16) || ''} / ${n.source || ''} / 重要度${n.importance ?? '—'} / 感情${n.sentiment != null ? (n.sentiment > 0 ? '+' : '') + n.sentiment.toFixed(2) : '—'}</div>
      </div>
    `).join('') || '<div style="color:#666">関連ニュースなし</div>';
  }

  document.getElementById('modal-close').addEventListener('click', () => {
    document.getElementById('modal').classList.remove('open');
  });
  document.getElementById('modal').addEventListener('click', (e) => {
    if (e.target.id === 'modal') document.getElementById('modal').classList.remove('open');
  });
</script>

</BaseLayout>
