<script>
  const BASE = import.meta.env.BASE_URL?.replace(/\/$/, '') || '';

  const BADGE_CLASS = {
    strong_buy:'badge-sb', buy:'badge-b', weak_buy:'badge-wb',
    watch:'badge-w', neutral:'badge-w',
    weak_sell:'badge-ws', sell:'badge-s', strong_sell:'badge-ss', avoid:'badge-ss'
  };
  const RANK_LABEL = {
    strong_buy:'強い買い', buy:'買い', weak_buy:'やや買い',
    watch:'様子見', neutral:'中立',
    weak_sell:'やや売り', sell:'売り', strong_sell:'強い売り', avoid:'回避'
  };
  const RANK_COLOR = {
    strong_buy:'#88e088', buy:'#6ec86e', weak_buy:'#d8d878',
    watch:'#999', neutral:'#888',
    weak_sell:'#d8896e', sell:'#d87878', strong_sell:'#e07878', avoid:'#e07878'
  };

  // ========== タブ切替 ==========
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(`tab-${btn.dataset.tab}`).classList.add('active');
    });
  });

  // ========== メイン ==========
  let stockData = null;

  async function loadAll() {
    try {
      const res = await fetch(`${BASE}/data/stock.json`);
      stockData = await res.json();
    } catch(e) {
      document.getElementById('sp-meta').textContent = 'データ読み込みエラー';
      return;
    }

    renderHeader(stockData);
    renderHero(stockData);
    renderKPI(stockData);
    renderRanking(stockData);
    renderHistory(stockData);
    renderAccChart(stockData);
    loadMacro();
    loadSimilarDays();
    loadPostmortem();
    loadScatter();
    loadAgents();
  }

  function renderHeader(data) {
    document.getElementById('sp-meta').textContent = `更新: ${data.generated_at}`;
  }

  function renderHero(data) {
    const f = data.freshness || {};
    const since = f.days_since_last;
    const gapN = f.gap_count || 0;
    let cls = 'fresh-ok', icon = '✅', label = '最新';
    if (gapN >= 3 || (since || 0) >= 3) { cls='fresh-bad'; icon='⚠'; label=`${since}日経過`; }
    else if (gapN >= 1 || (since || 0) >= 1) { cls='fresh-warn'; icon='📅'; label=`${since}日経過`; }

    document.getElementById('hero-fresh').textContent = f.last_analyzed_date || '未実行';
    document.getElementById('hero-fresh-sub').innerHTML = `<span class="fresh-pill ${cls}">${icon} ${label}</span>` + (gapN>0?`<span class="fresh-detail">欠落${gapN}日</span>`:'');

    // 今日のおすすめ: weak_buy 以上の上位2銘柄をピックアップ
    const recs = (data.rankings || []).filter(r => ['strong_buy','buy','weak_buy'].includes(r.rank)).slice(0,2);
    let headline;
    if (recs.length === 0) {
      headline = `本日は<strong style="color:#c8a96e">買いシグナル該当なし</strong>。様子見継続を推奨します。`;
    } else {
      headline = `本日の買い候補は <strong style="color:#88e088">${recs.length}銘柄</strong>。クリックで根拠を確認してください。`;
    }
    document.getElementById('hero-headline').innerHTML = headline;

    const ctaList = document.getElementById('hero-cta-list');
    ctaList.innerHTML = '';
    if (recs.length > 0) {
      recs.forEach(r => {
        const cls = BADGE_CLASS[r.rank] || 'badge-w';
        ctaList.insertAdjacentHTML('beforeend', `
          <div class="hero-cta" data-ticker="${r.ticker}">
            <span class="hero-cta-rank badge ${cls}">${RANK_LABEL[r.rank]}</span>
            <strong style="color:#edede8">${r.ticker}</strong>
            <span class="hero-cta-info">スコア${r.score} / 上昇${(r.prob_up_5d*100).toFixed(0)}% / 期待${r.expected_return>0?'+':''}${r.expected_return}%</span>
            <span style="color:#666">→</span>
          </div>
        `);
      });
    } else {
      // 様子見でもランキング1位を表示
      const top = (data.rankings || [])[0];
      if (top) {
        ctaList.insertAdjacentHTML('beforeend', `
          <div class="hero-cta" data-ticker="${top.ticker}">
            <span class="hero-cta-rank badge ${BADGE_CLASS[top.rank]||'badge-w'}">${RANK_LABEL[top.rank]||top.rank}</span>
            <strong style="color:#edede8">${top.ticker}</strong>
            <span class="hero-cta-info">スコア${top.score}（最上位） / 上昇${(top.prob_up_5d*100).toFixed(0)}%</span>
            <span style="color:#666">→</span>
          </div>
        `);
      }
    }
    document.querySelectorAll('.hero-cta').forEach(el => {
      el.addEventListener('click', () => openTickerDetail(el.dataset.ticker));
    });
  }

  function renderKPI(data) {
    const acc = data.accuracy || {};
    document.getElementById('kpi-stocks').textContent = (data.rankings || []).length;
    document.getElementById('kpi-acc').textContent = acc.rate != null ? (acc.rate*100).toFixed(0)+'%' : '—';
    document.getElementById('kpi-judged').textContent = acc.total ?? 0;
    document.getElementById('kpi-pending').textContent = acc.pending ?? 0;
  }

  function renderRanking(data) {
    const grid = document.getElementById('ranking-grid');
    grid.innerHTML = '';
    document.getElementById('ranking-count').textContent = `${(data.rankings || []).length}銘柄`;
    (data.rankings || []).forEach(r => {
      const badgeClass = BADGE_CLASS[r.rank] || 'badge-w';
      const probPct = r.prob_up_5d != null ? (r.prob_up_5d*100).toFixed(0) : '—';
      const er = r.expected_return != null ? (r.expected_return>0?'+':'')+r.expected_return.toFixed(1)+'%' : '—';
      const erColor = r.expected_return>0?'#6ec86e':r.expected_return<0?'#c86e6e':'#888';
      const updAt = r.updated_at ? r.updated_at.slice(5,16) : '—';
      const fillColor = RANK_COLOR[r.rank] || '#c8a96e';
      grid.insertAdjacentHTML('beforeend', `
        <div class="rank-row" data-ticker="${r.ticker}">
          <div class="rank-ticker">${r.ticker}</div>
          <div><span class="badge ${badgeClass}">${RANK_LABEL[r.rank] || r.rank}</span></div>
          <div>
            <div class="rank-bar-wrap"><div class="rank-bar-fill" style="width:${probPct}%;background:${fillColor}"></div></div>
            <div class="rank-bar-text">5日上昇 ${probPct}%</div>
          </div>
          <div class="rank-score-num">${r.score ?? '—'}</div>
          <div class="rank-er rank-col-er" style="color:${erColor}">${er}</div>
          <div class="rank-time rank-col-time">${updAt}</div>
        </div>
      `);
    });
    document.querySelectorAll('.rank-row').forEach(el => {
      el.addEventListener('click', () => openTickerDetail(el.dataset.ticker));
    });
  }

  function renderHistory(data) {
    const tbody = document.getElementById('history-tbody');
    tbody.innerHTML = '';
    document.getElementById('history-count').textContent = `${(data.history || []).length}件`;
    (data.history || []).forEach(h => {
      const badgeClass = BADGE_CLASS[h.rank] || 'badge-w';
      const prob = h.prob_up_5d != null ? (h.prob_up_5d*100).toFixed(0)+'%' : '—';
      const ret = h.actual_ret != null ? (h.actual_ret>0?'+':'')+h.actual_ret.toFixed(1)+'%' : '—';
      const resLabel = h.result==='hit' ? '✅' : h.result==='miss' ? '❌' : '⏳';
      const resCls = h.result==='hit' ? 'r-hit' : h.result==='miss' ? 'r-miss' : 'r-pending';
      tbody.insertAdjacentHTML('beforeend', `
        <tr>
          <td style="color:#555">${h.date}</td>
          <td><strong style="color:#ddd">${h.ticker}</strong></td>
          <td><span class="badge ${badgeClass}" style="font-size:0.6rem">${RANK_LABEL[h.rank]||h.rank||'—'}</span></td>
          <td>${prob}</td>
          <td style="color:${h.actual_ret>0?'#6ec86e':h.actual_ret<0?'#c86e6e':'#888'}">${ret}</td>
          <td class="${resCls}">${resLabel}</td>
        </tr>
      `);
    });
  }

  function renderAccChart(data) {
    const acc = data.accuracy || {};
    const monthly = acc.monthly || [];
    const wrap = document.querySelector('#tab-review .chart-card:last-of-type, #tab-review .chart-card');
    // 月別がなければ案内
    const targetCanvasId = 'acc-chart';
    if (monthly.length === 0) {
      const c = document.getElementById(targetCanvasId);
      if (c) c.parentElement.innerHTML = '<p style="color:#555;text-align:center;padding:1.5rem">⏳ 月別データ蓄積後に表示（5/13以降から）</p>';
      return;
    }
    ensureChart().then(() => {
      const labels = monthly.map(m => m.month);
      const rates = monthly.map(m => m.rate != null ? (m.rate*100).toFixed(1) : null);
      const totals = monthly.map(m => m.total);
      const ctx = document.getElementById(targetCanvasId).getContext('2d');
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels,
          datasets: [
            { label: '的中率(%)', data: rates,
              backgroundColor: rates.map(r => r>=60?'rgba(110,200,110,0.6)':r>=50?'rgba(200,169,110,0.6)':'rgba(200,110,110,0.6)'),
              borderColor: rates.map(r => r>=60?'#6ec86e':r>=50?'#c8a96e':'#c86e6e'),
              borderWidth: 1, yAxisID: 'y' },
            { label: '判定数', data: totals, type: 'line',
              borderColor: '#444', backgroundColor: 'transparent', pointRadius: 3, yAxisID: 'y2' }
          ]
        },
        options: {
          responsive: true, maintainAspectRatio: true,
          plugins: { legend: { labels: { color:'#888', font:{size:11} } } },
          scales: {
            x: { ticks:{color:'#666'}, grid:{color:'#1a1a1a'} },
            y: { ticks:{color:'#888',callback:v=>v+'%'}, grid:{color:'#1a1a1a'}, min:0, max:100 },
            y2: { position:'right', ticks:{color:'#444'}, grid:{display:false} }
          }
        }
      });
    });
  }

  // ========== マクロボード ==========
  async function loadMacro() {
    try {
      const res = await fetch(`${BASE}/data/stock-macro.json`);
      const m = await res.json();
      const setTile = (id, obj, suffix='') => {
        if (!obj) return;
        document.getElementById(`m-${id}-val`).textContent = obj.value + suffix;
        const chg = obj.change_pct;
        const el = document.getElementById(`m-${id}-chg`);
        if (chg != null) {
          const sign = chg > 0 ? '▲ +' : chg < 0 ? '▼ ' : '― ';
          el.textContent = `${sign}${chg.toFixed(2)}% (${obj.date})`;
          el.style.color = chg>0?'#6ec86e':chg<0?'#c86e6e':'#888';
        }
      };
      setTile('vix', m.vix);
      setTile('10y', m.us10y, '%');
      setTile('sp', m.sp500);
      setTile('jpy', m.usdjpy);
      if (m.vix) {
        const pct = Math.min(100, Math.max(0, m.vix.value / 50 * 100));
        document.getElementById('vix-needle').style.left = `${pct}%`;
        // ヒーローのVIXタイル
        document.getElementById('hero-vix').textContent = m.vix.value;
        const vchg = m.vix.change_pct;
        const vsub = vchg!=null ? `${vchg>0?'+':''}${vchg.toFixed(1)}% (${m.vix.date})` : '—';
        document.getElementById('hero-vix-sub').textContent = vsub;
      }
    } catch(e) { console.error('macro', e); }
  }

  // ========== 類似日 ==========
  async function loadSimilarDays() {
    try {
      const res = await fetch(`${BASE}/data/stock-similar-days.json`);
      const s = await res.json();
      const todayEl = document.getElementById('similar-today');
      if (s.today) {
        todayEl.innerHTML = `📅 <strong>今日（${s.today.date}）</strong>: VIX <strong>${s.today.vix}</strong> / 10年金利 <strong>${s.today.us10y}%</strong> / SP500 20日リターン <strong>${s.today.sp500_ret_20d_pct}%</strong>`;
      }
      const listEl = document.getElementById('similar-list');
      listEl.innerHTML = '';
      (s.similar_days || []).forEach((d, i) => {
        const fwd = d.next_30d_return_pct;
        const fwdCls = fwd!=null && fwd<0 ? 'similar-fwd neg' : 'similar-fwd pos';
        const fwdText = fwd!=null ? `→ その後30営業日: ${fwd>0?'+':''}${fwd}%` : '→ 30日後データなし';
        listEl.insertAdjacentHTML('beforeend', `
          <div class="similar-card">
            <span class="similar-date">#${i+1}: ${d.date}</span>
            <span class="similar-context">${d.context}</span>
            <div class="similar-stats">VIX ${d.vix} / 10Y ${d.us10y}% / SP500 20日 ${d.sp500_ret_20d_pct}% (類似度 ${d.distance})</div>
            <div class="${fwdCls}">${fwdText}</div>
          </div>
        `);
      });
    } catch(e) { console.error('similar', e); }
  }

  // ========== 振り返り ==========
  async function loadPostmortem() {
    try {
      const res = await fetch(`${BASE}/data/stock-postmortem.json`);
      const pm = await res.json();
      const sum = pm.summary || {};
      const sumEl = document.getElementById('pm-summary');
      if ((sum.evaluable_count || 0) === 0) {
        sumEl.innerHTML = '<div style="color:#666">⏳ 5営業日経過分の判定可能予測がまだありません</div>';
        return;
      }
      sumEl.innerHTML = `
        <div class="pm-stat"><span class="pm-stat-num">${sum.evaluable_count}</span>判定済み</div>
        <div class="pm-stat"><span class="pm-stat-num" style="color:#6ec86e">${sum.hits}</span>当たり</div>
        <div class="pm-stat"><span class="pm-stat-num" style="color:#c86e6e">${sum.misses}</span>外し</div>
        <div class="pm-stat"><span class="pm-stat-num">${sum.hit_rate!=null?(sum.hit_rate*100).toFixed(0)+'%':'—'}</span>方向的中率</div>
      `;
      const list = document.getElementById('pm-list');
      list.innerHTML = '';
      (pm.recent_results || []).slice(0, 10).forEach(r => {
        const cls = r.hit ? 'hit' : 'miss';
        const verdictCls = r.hit ? 'pm-verdict hit' : 'pm-verdict miss';
        const culprits = (r.culprits||[]).map(c =>
          `<div class="pm-agent"><span class="pm-agent-score agent-sell">${c.score}</span><span class="pm-agent-name">${c.agent}</span> <span style="color:#666">${c.reason}</span></div>`
        ).join('') || '<div class="pm-agent" style="color:#555">該当なし</div>';
        const heroes = (r.heroes||[]).map(h =>
          `<div class="pm-agent"><span class="pm-agent-score agent-buy">${h.score}</span><span class="pm-agent-name">${h.agent}</span> <span style="color:#666">${h.reason}</span></div>`
        ).join('') || '<div class="pm-agent" style="color:#555">該当なし</div>';
        const sugg = (r.suggestions||[]).map(s => `<div>💡 ${s}</div>`).join('');
        list.insertAdjacentHTML('beforeend', `
          <div class="pm-card ${cls}">
            <div class="pm-head">
              <span class="pm-tk">${r.ticker}</span>
              <span class="${verdictCls}">${r.verdict}</span>
              <span class="pm-meta-mini">予測日: ${r.prediction_date}</span>
            </div>
            <div class="pm-stats-line">
              予測 prob_up=<strong>${(r.prob_up_5d_predicted*100).toFixed(0)}%</strong> / 期待<strong>${r.expected_return_pct>=0?'+':''}${r.expected_return_pct}%</strong>
              　|　実績 <strong style="color:${r.actual_return_pct>=0?'#6ec86e':'#c86e6e'}">${r.actual_return_pct>=0?'+':''}${r.actual_return_pct}%</strong>
              　|　誤差 ${r.magnitude_error_pct}pt
            </div>
            <div class="pm-grid2">
              <div><div class="pm-block-label">⚠ 反省すべきエージェント</div>${culprits}</div>
              <div><div class="pm-block-label">🏆 的確だったエージェント</div>${heroes}</div>
            </div>
            ${sugg ? `<div class="pm-suggest">${sugg}</div>` : ''}
          </div>
        `);
      });

      const wh = pm.weight_history || [];
      const whEl = document.getElementById('pm-weight-hist');
      if (wh.length > 0) {
        whEl.innerHTML = `
          <div class="sec-title" style="margin-top:1.5rem">エージェント重み調整履歴（自動進化）</div>
          <div>${wh.map(w => `<div style="display:flex;justify-content:space-between;padding:0.4rem 0.6rem;border-bottom:1px solid #181818;font-size:0.75rem;color:#aaa"><span>${w.agent}</span><span>weight=${w.current_weight}</span><span style="color:#555">${w.updated_at}</span></div>`).join('')}</div>`;
      } else {
        whEl.innerHTML = `<div style="color:#666;font-size:0.75rem;margin-top:0.5rem">⏳ 重み調整未実施（n>=20件 蓄積後に自動発動）</div>`;
      }
    } catch(e) { console.error('postmortem', e); }
  }

  // ========== ポジショニングマップ ==========
  async function loadScatter() {
    try {
      await ensureChart();
      const points = [];
      for (const r of stockData.rankings) {
        try {
          const dRes = await fetch(`${BASE}/data/stock-detail/${r.ticker}.json`);
          const dd = await dRes.json();
          const er = r.expected_return ?? 0;
          const pdown = (dd.summary?.prob_down_5pct ?? 0.05) * 100;
          const score = r.score ?? 50;
          const cls = BADGE_CLASS[r.rank];
          const color = cls?.includes('-b')||cls?.includes('-sb')||cls?.includes('-wb') ? 'rgba(110,200,110,0.8)'
                      : cls?.includes('-s')||cls?.includes('-ss')||cls?.includes('-ws') ? 'rgba(200,110,110,0.8)'
                      : 'rgba(200,169,110,0.8)';
          points.push({ x: er, y: pdown, r: Math.max(6, score/5), ticker: r.ticker, rank: r.rank, color });
        } catch {}
      }
      const ctx = document.getElementById('scatter-chart').getContext('2d');
      new Chart(ctx, {
        type: 'bubble',
        data: { datasets: [{ data: points, backgroundColor: points.map(p=>p.color), borderColor: points.map(p=>p.color.replace('0.8','1')), borderWidth: 1.5 }] },
        options: {
          responsive: true, maintainAspectRatio: true,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: (c) => { const p=c.raw; return `${p.ticker} (${RANK_LABEL[p.rank]||p.rank}): 期待値${p.x.toFixed(2)}% / 下落${p.y.toFixed(0)}% / スコア${(p.r*5).toFixed(0)}`; }}}
          },
          scales: {
            x: { title:{display:true,text:'期待リターン (%)',color:'#888'}, ticks:{color:'#888'}, grid:{color:'#1a1a1a'} },
            y: { title:{display:true,text:'5%下落確率 (%)',color:'#888'}, ticks:{color:'#888'}, grid:{color:'#1a1a1a'}, reverse:true }
          },
          animation: { duration: 1000, easing: 'easeOutCubic' }
        },
        plugins: [{
          afterDatasetsDraw: (chart) => {
            const {ctx} = chart;
            chart.data.datasets[0].data.forEach((p, i) => {
              const meta = chart.getDatasetMeta(0).data[i];
              ctx.font = '10px sans-serif';
              ctx.fillStyle = '#edede8';
              ctx.textAlign = 'center';
              ctx.fillText(p.ticker, meta.x, meta.y - meta.options.radius - 4);
            });
          }
        }]
      });
    } catch(e) { console.error('scatter', e); }
  }

  // ========== 🆕 エージェントネットワーク ==========
  async function loadAgents() {
    let data;
    try {
      const res = await fetch(`${BASE}/data/stock-agents.json`);
      data = await res.json();
    } catch(e) { console.error('agents', e); return; }

    // サマリ
    const s = data.summary || {};
    document.getElementById('ag-stats').innerHTML = `
      <div class="ag-stat"><div class="ag-stat-label">TOTAL AGENTS</div><div class="ag-stat-val">${s.total_agents}</div><div class="ag-stat-sub">稼働中エージェント</div></div>
      <div class="ag-stat"><div class="ag-stat-label">CATEGORIES</div><div class="ag-stat-val">${s.categories}</div><div class="ag-stat-sub">専門分野</div></div>
      <div class="ag-stat"><div class="ag-stat-label">MATH MODEL</div><div class="ag-stat-val">${s.agents_using_math_model}</div><div class="ag-stat-sub">数理予測参照</div></div>
      <div class="ag-stat"><div class="ag-stat-label">EVOLVED</div><div class="ag-stat-val">${s.agents_evolved}</div><div class="ag-stat-sub">重み進化済み</div></div>
      <div class="ag-stat"><div class="ag-stat-label">EVALUATED</div><div class="ag-stat-val">${s.agents_with_performance}</div><div class="ag-stat-sub">的中率データあり</div></div>
    `;

    // カテゴリフィルタ
    const filterEl = document.getElementById('ag-filter');
    const allBtn = `<button class="ag-cat-btn active" data-cat="ALL" style="--cat-color:#6ec8e0; --cat-glow:rgba(108,200,224,0.5)">ALL ${s.total_agents}</button>`;
    const catBtns = data.categories.map(c => `
      <button class="ag-cat-btn" data-cat="${c.category_id}" style="--cat-color:${c.color}; --cat-glow:${c.color}88">${c.category_jp} ${c.agents.length}</button>
    `).join('');
    filterEl.innerHTML = allBtn + catBtns;

    // カテゴリブロック描画
    const renderCategories = (filter='ALL') => {
      const listEl = document.getElementById('ag-list');
      listEl.innerHTML = '';
      data.categories.filter(c => filter === 'ALL' || c.category_id === filter).forEach(cat => {
        const block = document.createElement('div');
        block.className = 'ag-category';
        block.style.setProperty('--cat-color', cat.color);

        const cardsHtml = cat.agents.map(a => {
          // 重み表示
          const wDiff = a.weight - 1.0;
          const wCls = Math.abs(wDiff) < 0.001 ? 'weight-neutral' : (wDiff > 0 ? 'weight-up' : 'weight-down');
          const wTxt = a.weight.toFixed(2);
          // 的中率表示
          let hitTxt = '—', hitCls = 'hit-mid';
          if (a.hit_rate != null) {
            hitTxt = (a.hit_rate*100).toFixed(0) + '%';
            hitCls = a.hit_rate >= 0.55 ? 'hit-good' : a.hit_rate < 0.45 ? 'hit-bad' : 'hit-mid';
          }
          // 今日のシグナル分布バー
          const tot = (a.buy_today + a.neutral_today + a.sell_today) || 1;
          const buyPct = (a.buy_today/tot*100).toFixed(0);
          const neuPct = (a.neutral_today/tot*100).toFixed(0);
          const selPct = 100 - buyPct - neuPct;
          // バッジクラス
          const cls = ['ag-card'];
          if (a.uses_math_model) cls.push('has-math');
          if (Math.abs(wDiff) >= 0.001) cls.push('evolved');

          return `
            <div class="${cls.join(' ')}" style="--cat-color:${cat.color}" title="${a.description}">
              <div class="ag-name">${a.name}</div>
              <div class="ag-desc">${a.description || '—'}</div>
              <div class="ag-metrics">
                <span class="ag-metric"><span class="ag-metric-label">W:</span><span class="ag-metric-val ${wCls}">${wTxt}</span></span>
                <span class="ag-metric"><span class="ag-metric-label">HIT:</span><span class="ag-metric-val ${hitCls}">${hitTxt}</span></span>
                <span class="ag-metric"><span class="ag-metric-label">N:</span><span class="ag-metric-val">${a.samples}</span></span>
              </div>
              <div class="ag-signal-bar" title="今日のシグナル: BUY ${a.buy_today} / 中立 ${a.neutral_today} / SELL ${a.sell_today}">
                <span class="ag-signal-buy" style="width:${buyPct}%"></span>
                <span class="ag-signal-neu" style="width:${neuPct}%"></span>
                <span class="ag-signal-sell" style="width:${selPct}%"></span>
              </div>
            </div>
          `;
        }).join('');

        block.innerHTML = `
          <div class="ag-cat-head">
            <span class="ag-cat-dot"></span>
            <span class="ag-cat-name">${cat.category_jp}</span>
            <span class="ag-cat-count">// ${cat.agents.length} agents</span>
          </div>
          <div class="ag-grid">${cardsHtml}</div>
        `;
        listEl.appendChild(block);
      });
    };
    renderCategories();

    // フィルタクリック
    filterEl.querySelectorAll('.ag-cat-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        filterEl.querySelectorAll('.ag-cat-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderCategories(btn.dataset.cat);
      });
    });
  }

  function ensureChart() {
    return new Promise(resolve => {
      if (window.Chart) return resolve();
      const sc = document.createElement('script');
      sc.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js';
      sc.onload = resolve;
      document.head.appendChild(sc);
    });
  }

  // ========== 銘柄詳細モーダル ==========
  async function openTickerDetail(ticker) {
    const modal = document.getElementById('modal');
    modal.classList.add('open');
    document.getElementById('m-title').textContent = `📊 ${ticker} — 判断根拠`;
    document.getElementById('m-sub').textContent = 'データ読み込み中…';

    let d;
    try {
      const res = await fetch(`${BASE}/data/stock-detail/${ticker}.json`);
      d = await res.json();
    } catch(e) {
      document.getElementById('m-sub').textContent = `読み込みエラー: ${e.message}`;
      return;
    }

    const s = d.summary || {};
    document.getElementById('m-sub').textContent = `更新: ${d.generated_at} / 予測日: ${s.prediction_date || '—'}`;
    document.getElementById('m-rank').textContent = RANK_LABEL[s.rank] || s.rank || '—';
    document.getElementById('m-score').textContent = s.score != null ? s.score : '—';
    document.getElementById('m-rr').textContent = s.risk_reward != null ? s.risk_reward.toFixed(2) : '—';
    document.getElementById('m-pup').textContent = s.prob_up_5d != null ? (s.prob_up_5d*100).toFixed(0)+'%' : '—';
    document.getElementById('m-pdown').textContent = s.prob_down_5pct != null ? (s.prob_down_5pct*100).toFixed(0)+'%' : '—';
    document.getElementById('m-er').textContent = s.expected_return != null ? (s.expected_return>0?'+':'')+s.expected_return.toFixed(2)+'%' : '—';
    document.getElementById('m-verdict').textContent = s.verdict || '—';

    const catWrap = document.getElementById('m-cats');
    catWrap.innerHTML = '';
    const cats = (d.agent_summary && d.agent_summary.category_stats) || {};
    Object.entries(cats).forEach(([cat, v]) => {
      const tot = v.count;
      const buyW = (v.buy/tot*100).toFixed(0);
      const sellW = (v.sell/tot*100).toFixed(0);
      const holdW = 100 - buyW - sellW;
      catWrap.insertAdjacentHTML('beforeend', `
        <div class="cat-bar-wrap">
          <span style="min-width:120px">${cat}</span>
          <span class="cat-bar">
            <span class="cat-bar-buy" style="width:${buyW}%"></span>
            <span class="cat-bar-hold" style="width:${holdW}%"></span>
            <span class="cat-bar-sell" style="width:${sellW}%"></span>
          </span>
          <span style="min-width:120px;text-align:right">BUY ${v.buy} / HOLD ${v.hold} / SELL ${v.sell} (avg ${v.avg_score})</span>
        </div>`);
    });

    const histWrap = document.getElementById('m-hist');
    const histSpan = document.getElementById('m-hist-span');
    const h = d.historical || d.historical_50y;
    if (h) {
      histSpan.textContent = h.data_span_label || `${h.first_data_date}〜 (${h.total_days}日)`;
      histWrap.innerHTML = `
        <div class="stat-cell"><div class="stat-label">最大DD</div><div class="stat-value" style="color:#c86e6e">${h.max_drawdown_pct}%</div></div>
        <div class="stat-cell"><div class="stat-label">現在DD</div><div class="stat-value" style="color:${h.current_drawdown_pct<-20?'#c86e6e':'#c8a96e'}">${h.current_drawdown_pct}%</div></div>
        <div class="stat-cell"><div class="stat-label">最高値からの位置</div><div class="stat-value">${h.current_pct_of_ath}%</div></div>
        <div class="stat-cell"><div class="stat-label">-30%以下日数</div><div class="stat-value">${h.days_below_30pct_dd} / ${h.total_days}</div></div>
        <div class="stat-cell"><div class="stat-label">-30%以下の比率</div><div class="stat-value">${h.pct_time_below_30pct}%</div></div>
        <div class="stat-cell"><div class="stat-label">対象期間</div><div class="stat-value" style="font-size:0.8rem">約${h.approx_years}年</div></div>`;
    } else {
      histSpan.textContent = ''; histWrap.innerHTML = '<div style="color:#666">データなし</div>';
    }

    const btWrap = document.getElementById('m-bt');
    const bt = d.backtest;
    if (bt) {
      btWrap.innerHTML = `
        <div class="stat-cell"><div class="stat-label">勝率</div><div class="stat-value" style="color:${bt.win_rate_pct>=55?'#6ec86e':'#c8a96e'}">${bt.win_rate_pct}%</div></div>
        <div class="stat-cell"><div class="stat-label">CAGR</div><div class="stat-value">${bt.cagr_pct}%</div></div>
        <div class="stat-cell"><div class="stat-label">Sharpe</div><div class="stat-value">${bt.sharpe_ratio}</div></div>
        <div class="stat-cell"><div class="stat-label">最大DD</div><div class="stat-value" style="color:#c86e6e">${bt.max_drawdown_pct}%</div></div>
        <div class="stat-cell"><div class="stat-label">PF</div><div class="stat-value">${bt.profit_factor}</div></div>
        <div class="stat-cell"><div class="stat-label">取引数</div><div class="stat-value">${bt.total_trades}</div></div>`;
      document.getElementById('m-bt-period').textContent = `${bt.strategy} / 期間: ${bt.period}`;
    } else {
      btWrap.innerHTML = '<div style="color:#666">バックテストなし</div>';
      document.getElementById('m-bt-period').textContent = '';
    }

    const fundWrap = document.getElementById('m-fund');
    const f = d.fundamentals;
    if (f) {
      fundWrap.innerHTML = `
        <div class="stat-cell"><div class="stat-label">PER</div><div class="stat-value">${f.PER ?? '—'}</div></div>
        <div class="stat-cell"><div class="stat-label">PBR</div><div class="stat-value">${f.PBR ?? '—'}</div></div>
        <div class="stat-cell"><div class="stat-label">ROE</div><div class="stat-value">${f.ROE!=null?(f.ROE*100).toFixed(1)+'%':'—'}</div></div>
        <div class="stat-cell"><div class="stat-label">営業利益率</div><div class="stat-value">${f.operating_margin!=null?(f.operating_margin*100).toFixed(1)+'%':'—'}</div></div>
        <div class="stat-cell"><div class="stat-label">売上成長</div><div class="stat-value">${f.revenue_growth!=null?(f.revenue_growth*100).toFixed(1)+'%':'—'}</div></div>
        <div class="stat-cell"><div class="stat-label">EPS成長</div><div class="stat-value">${f.eps_growth!=null?(f.eps_growth*100).toFixed(1)+'%':'—'}</div></div>`;
    } else {
      fundWrap.innerHTML = '<div style="color:#666">ETF/データなし</div>';
    }

    document.getElementById('m-buys').innerHTML = (d.top_buys || []).map(a => `
      <div class="agent-item">
        <span class="agent-score agent-buy">${a.score}</span>
        <span class="agent-name">${a.agent}</span>
        <span class="agent-reason">${a.reason || '—'}</span>
      </div>`).join('') || '<div style="color:#666;padding:0.5rem">買いシグナルなし</div>';

    document.getElementById('m-risks').innerHTML = (d.top_risks || []).map(a => `
      <div class="agent-item">
        <span class="agent-score ${a.judgment==='SELL'||a.judgment==='STRONG_SELL'?'agent-sell':'agent-hold'}">${a.score}</span>
        <span class="agent-name">${a.agent}</span>
        <span class="agent-reason">${a.reason || '—'}</span>
      </div>`).join('') || '<div style="color:#666;padding:0.5rem">リスク警告なし</div>';

    document.getElementById('m-news').innerHTML = (d.news || []).map(n => `
      <div class="news-item">
        <div>${n.headline}</div>
        <div class="news-meta">${n.published_at?.slice(0,16) || ''} / ${n.source || ''} / 重要度${n.importance ?? '—'} / 感情${n.sentiment != null ? (n.sentiment > 0 ? '+' : '') + n.sentiment.toFixed(2) : '—'}</div>
      </div>`).join('') || '<div style="color:#666">関連ニュースなし</div>';
  }

  document.getElementById('modal-close').addEventListener('click', () => {
    document.getElementById('modal').classList.remove('open');
  });
  document.getElementById('modal').addEventListener('click', (e) => {
    if (e.target.id === 'modal') document.getElementById('modal').classList.remove('open');
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') document.getElementById('modal').classList.remove('open');
  });

  loadAll();
</script>

</BaseLayout>
