        });

        // Anomaly score chart - color bars by anomaly
        const anomalies = errors.map(e => e > threshold);
        const barColors = errors.map(e => e > threshold ? 'rgba(232,112,112,0.85)' : 'rgba(200,169,110,0.5)');

        if (scoreChart) scoreChart.destroy();
        const aCtx = document.getElementById('score-chart').getContext('2d');
        scoreChart = new Chart(aCtx, {
          type: 'bar',
          data: {
            labels,
            datasets: [
              {
                label: '異常スコア',
                data: errors,
                backgroundColor: barColors,
                borderColor: 'transparent',
                borderWidth: 0
              },
              {
                label: '閾値 (μ+' + kappa.toFixed(1) + 'σ)',
                data: Array(n).fill(threshold),
                type: 'line',
                borderColor: '#e87070',
                backgroundColor: 'transparent',
                borderWidth: 1.5,
                borderDash: [5, 4],
                pointRadius: 0
              }
            ]
          },
          options: {
            responsive: true,
            resizeDelay: 100,
            maintainAspectRatio: false,
            animation: false,
            animations: { colors: false, x: false },
            transitions: { active: { animation: { duration: 0 } } },
            plugins: {
              decimation: { enabled: true, algorithm: 'lttb', samples: 200, threshold: 300 },
              legend: { labels: { color: 'rgba(237,237,232,0.6)', font: { size: 11 }, boxWidth: 14 } },
              tooltip: {
                backgroundColor: '#111114', borderColor: 'rgba(255,255,255,0.07)', borderWidth: 1, titleColor: '#c8a96e', bodyColor: '#edede8',
                callbacks: {
                  label: function(ctx) {
                    if (ctx.dataset.type === 'line') return '閾値: ' + threshold.toFixed(4);
                    const isAnom = ctx.raw > threshold;
                    return 'スコア: ' + ctx.raw.toFixed(4) + (isAnom ? ' ⚠ 異常' : '');
                  }
                }
              }
            },
            scales: {
              x: { ticks: { color: 'rgba(255,255,255,0.35)', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
              y: { ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 11 } }, grid: { color: 'rgba(255,255,255,0.04)' } }
            }
          }
        });

        // Summary
        const anomalyCount = anomalies.filter(Boolean).length;
        const maxScore = Math.max(...errors);
        document.getElementById('anomaly-count').textContent = anomalyCount;
        document.getElementById('anomaly-rate').textContent = (anomalyCount / n * 100).toFixed(1) + '%';
        document.getElementById('max-score').textContent = maxScore.toFixed(4);
        document.getElementById('mean-score').textContent = meanErr.toFixed(4);
        document.getElementById('threshold-val').textContent = threshold.toFixed(4);

        if (stopped) {
          document.getElementById('loss-text').textContent += ' (早期停止)';
        }

        resultSection.style.display = 'block';
        const tfMem = (typeof tf !== 'undefined') ? tf.memory() : null;
        showPerfStats(performance.now() - _t0, tfMem);
        resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

      } catch (err) {
        statusEl.textContent = 'エラー: ' + (err.message || '学習に失敗しました');
        console.error(err);
      } finally {
        btnRun.disabled = false;
      }
    });

    // ---- CSV Download ----
    document.getElementById('btn-download').addEventListener('click', () => {
      if (!lastErrors || !currentData) return;
      const kappa = parseFloat(document.getElementById('kappa').value);
      const mean = lastNormalErrors.reduce((a, b) => a + b, 0) / lastNormalErrors.length;
      const std = Math.sqrt(lastNormalErrors.reduce((s, e) => s + (e - mean) * (e - mean), 0) / lastNormalErrors.length);
      const threshold = mean + kappa * std;
      const header = ['timestamp', ...sensorLabels, 'reconstruction_error', 'is_anomaly'].join(',');
      const lines = [header];
      for (let i = 0; i < currentData.length; i++) {
        const row = currentData[i];
        const vals = sensorKeys.map(k => row[k] != null ? row[k] : '');
        const err = lastErrors[i];
        lines.push([row.t, ...vals, err.toFixed(6), err > threshold ? '1' : '0'].join(','));
      }
      const blob = new Blob([lines.join('\n')], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'anomaly_detection_result.csv';
      a.click();
      URL.revokeObjectURL(url);
    });

    // ---- Streaming ----
    const streamIntervalEl = document.getElementById('stream-interval');
    const streamIntervalVal = document.getElementById('stream-interval-val');
    const streamAnomProbEl = document.getElementById('stream-anom-prob');
    const streamAnomProbVal = document.getElementById('stream-anom-prob-val');
    if (streamIntervalEl) {
      // Mobile auto-adjust default
      if (window.innerWidth < 700) {
        streamIntervalEl.value = 1000;
        streamIntervalVal.textContent = '1000';
      }
      streamIntervalEl.addEventListener('input', () => {
        streamIntervalVal.textContent = streamIntervalEl.value;
        // Live update interval if running
        if (streamTimer) {
          clearInterval(streamTimer);
          streamTimer = setInterval(streamStep, parseInt(streamIntervalEl.value, 10));
        }
      });
    }
    if (streamAnomProbEl) {
      streamAnomProbEl.addEventListener('input', () => {
        streamAnomProbVal.textContent = streamAnomProbEl.value;
      });
    }

    function generateStreamPoint(t, anomaly) {
      const point = { t };
      // Generate based on number of sensors trained on
      const nSensors = sensorKeys.length;
      // Use sample-data-style generators for v1..v3, fallback random
      if (nSensors >= 1) point.v1 = 50 + 5 * Math.sin(t * 0.3) + (anomaly ? 25 : 0) + (Math.random() - 0.5) * 3;
      if (nSensors >= 2) point.v2 = 30 + 3 * Math.cos(t * 0.2) + (anomaly ? -15 : 0) + (Math.random() - 0.5) * 2;
      if (nSensors >= 3) point.v3 = 20 + 2 * Math.sin(t * 0.5) + (anomaly ? 20 : 0) + (Math.random() - 0.5) * 1.5;
      // Extra sensors: random walk based on training mins/maxs
      for (let i = 3; i < nSensors; i++) {
        const k = 'v' + (i + 1);
        const lo = streamStats ? streamStats.mins[i] : 0;
        const hi = streamStats ? streamStats.maxs[i] : 1;
        const mid = (lo + hi) / 2;
        const span = (hi - lo) / 4;
        point[k] = mid + (Math.random() - 0.5) * span * 2 + (anomaly ? span * 3 : 0);
      }
      return point;
    }

    function ensureStreamChart() {
      if (streamChart) return;
      const cv = document.getElementById('stream-chart');
      if (!cv) return;
      const ctx = cv.getContext('2d');
      streamChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: [],
          datasets: [
            {
              label: '異常スコア',
              data: [],
              borderColor: '#c8a96e',
              backgroundColor: 'rgba(200,169,110,0.08)',
              borderWidth: 1.5,
              pointRadius: (ctx2) => {
                const d = streamData[ctx2.dataIndex];
                return (d && d.detected) ? 5 : 1;
              },
              pointBackgroundColor: (ctx2) => {
                const d = streamData[ctx2.dataIndex];
                return (d && d.detected) ? '#e87070' : '#c8a96e';
              },
              tension: 0.25,
              fill: true,
              spanGaps: true
            },
            {
              label: '閾値',
              data: [],
              borderColor: '#e87070',
              borderWidth: 1,
              borderDash: [5, 4],
