          const anomalyCount2 = anomalies2.filter(Boolean).length;
          document.getElementById('anomaly-count').textContent = anomalyCount2;
          document.getElementById('anomaly-rate').textContent = (anomalyCount2 / n * 100).toFixed(1) + '%';
          document.getElementById('max-score').textContent = Math.max.apply(null, errors).toFixed(4);
          document.getElementById('mean-score').textContent = mean.toFixed(4);
          document.getElementById('threshold-val').textContent = threshold.toFixed(4);

          resultSection.style.display = 'block';
          showPerfStats(performance.now() - _t0);
          resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (err) {
          statusEl.textContent = 'エラー: ' + (err.message || 'Isolation Forest 実行失敗');
          console.error(err);
        } finally {
          btnRun.disabled = false;
        }
        return;
      }

      // ---- Autoencoder path (original) ----
      try {
        // Dispose previous stream model if exists
        if (streamModel) { try { streamModel.dispose(); } catch (_) {} streamModel = null; }
        const { errors, threshold, mean: meanErr, normalErrors, stopped, model: trainedModel } = await trainAndDetect(normalData, normalizedMatrix, epochs, kappa, useEarlyStop);
        lastErrors = errors;
        lastNormalErrors = normalErrors;
        lastTrainSplit = nTrain;
        streamModel = trainedModel;
        streamThreshold = threshold;
        // Show stream section
        const streamSec = document.getElementById('stream-section');
        if (streamSec) streamSec.style.display = 'block';

        // Sensor chart
        const labels = currentData.map(d => d.t.toString());
        const sensorColors = ['#c8a96e', '#7eb8c8', '#a8c87e'];

        // Vertical line plugin for train/test boundary
        const trainBoundaryPlugin = {
          id: 'trainBoundary',
          afterDraw(chart) {
            const xScale = chart.scales.x;
            const yScale = chart.scales.y;
            if (!xScale || !yScale || lastTrainSplit <= 0) return;
            const xPos = xScale.getPixelForValue(lastTrainSplit - 1);
            const ctx = chart.ctx;
            ctx.save();
            ctx.strokeStyle = 'rgba(232,112,112,0.6)';
            ctx.lineWidth = 1;
            ctx.setLineDash([4, 3]);
            ctx.beginPath();
            ctx.moveTo(xPos, yScale.top);
            ctx.lineTo(xPos, yScale.bottom);
            ctx.stroke();
            ctx.setLineDash([]);
            ctx.fillStyle = 'rgba(232,112,112,0.85)';
            ctx.font = '10px sans-serif';
            ctx.fillText('train | eval', xPos + 4, yScale.top + 12);
