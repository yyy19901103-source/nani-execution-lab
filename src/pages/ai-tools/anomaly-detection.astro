    // ---- CSV upload (大規模対応・チャンク処理) ----
    document.getElementById('csv-upload').addEventListener('change', async function(e) {
      const file = e.target.files[0];
      if (!file) return;
      const csvProgress = document.getElementById('csv-progress');
      const csvProgressBar = document.getElementById('csv-progress-bar');
      try {
        csvProgress.style.display = 'block';
        csvProgressBar.style.width = '0%';
        const text = await file.text();
        const lines = text.split(/\r?\n/);
        while (lines.length && !lines[lines.length - 1].trim()) lines.pop();
        if (lines.length < 2) { csvProgress.style.display = 'none'; statusEl.textContent = 'エラー: データ行が不足しています'; return; }

        const firstParts = lines[0].split(',').map(s => s.trim());
        let startIdx = 0;
        let headerNames = null;
        if (isNaN(parseFloat(firstParts[1]))) {
          startIdx = 1;
          headerNames = firstParts.slice(1, 6);
        }

        const rows = [];
        let cols = 0;
        const total = lines.length;
        const CHUNK_SIZE = CHUNK_ROWS;
        for (let i = startIdx; i < total; i += CHUNK_SIZE) {
          const end = Math.min(i + CHUNK_SIZE, total);
          for (let k = i; k < end; k++) {
            const line = lines[k];
            if (!line || !line.trim()) continue;
            const parts = line.split(',').map(s => s.trim());
            if (parts.length < 2) continue;
            const t = k - startIdx;
            const vals = {};
            const numCols = Math.min(parts.length - 1, 5);
            cols = Math.max(cols, numCols);
            for (let j = 0; j < numCols; j++) {
              vals['v' + (j + 1)] = parseFloat(parts[j + 1]);
            }
            rows.push({ t, ...vals });
          }
          csvProgressBar.style.width = Math.round(end / total * 100) + '%';
          if (total > 5000) {
            statusEl.textContent = `読込中... ${end.toLocaleString()} / ${total.toLocaleString()} 行`;
          }
          await new Promise(resolve => setTimeout(resolve, 0));
        }
        csvProgress.style.display = 'none';

        if (rows.length < 10) {
          statusEl.textContent = 'エラー: データが少なすぎます（最低10行必要）';
          return;
        }

        sensorKeys = Array.from({length: cols}, (_, i) => 'v' + (i + 1));
        if (headerNames && headerNames.length >= cols) {
          sensorLabels = headerNames.slice(0, cols);
        } else {
          sensorLabels = Array.from({length: cols}, (_, i) => 'Sensor ' + (i + 1));
        }
        currentData = rows;
        statusEl.textContent = 'CSV読込完了: ' + rows.length + ' サンプル・' + cols + ' 特徴量 (' + sensorLabels.join(' / ') + ')';
