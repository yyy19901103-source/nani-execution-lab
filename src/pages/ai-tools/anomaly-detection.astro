          const anomalies2 = errors.map(e => e > threshold);
          const barColors2 = errors.map(e => e > threshold ? 'rgba(232,112,112,0.85)' : 'rgba(200,169,110,0.5)');
          if (scoreChart) scoreChart.destroy();
          const aCtx2 = document.getElementById('score-chart').getContext('2d');
          scoreChart = new Chart(aCtx2, {
            type: 'bar',
