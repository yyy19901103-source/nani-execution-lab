---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="異常検知デモ（AIオートエンコーダー）" description="TensorFlow.js オートエンコーダーによる工場センサー異常検知。完全ブラウザ内AI学習。再構成誤差で異常点を自動判定。">

  <!-- Security Banner -->
  <div style="background:rgba(200,169,110,0.08);border-left:3px solid #c8a96e;padding:0.85rem 1.25rem;font-size:0.78rem;color:#edede8;letter-spacing:0.03em;display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;justify-content:space-between;">
    <div>🔒 <strong>機密保護: 全処理ブラウザ完結</strong> — TF.js モデル学習・推論もローカルで実行</div>
    <button id="verify-privacy" style="background:transparent;border:1px solid rgba(200,169,110,0.3);color:#c8a96e;padding:0.3rem 0.75rem;font-size:0.7rem;cursor:pointer;font-family:inherit;letter-spacing:0.05em;transition:all 0.15s;">検証方法を見る ▼</button>
  </div>
  <div id="privacy-detail" style="display:none;background:#0a0a0c;border-left:3px solid #c8a96e;border-bottom:1px solid rgba(200,169,110,0.15);padding:1.25rem 1.75rem;font-size:0.78rem;color:rgba(237,237,232,0.75);line-height:1.7;">
    <p style="color:#c8a96e;font-size:0.7rem;letter-spacing:0.2em;margin-bottom:0.6rem;">VERIFY YOURSELF</p>
    <ol style="margin:0;padding-left:1.25rem;">
      <li>DevTools (F12) → Network タブを開く</li>
      <li>「Disable cache」をオン</li>
      <li>ページをリロード → CDN ライブラリの読込のみ確認できる</li>
      <li>データ投入・学習・予測中、追加の通信が <strong>一切発生しない</strong> ことを確認</li>
    </ol>
    <p style="margin-top:0.8rem;color:rgba(255,255,255,0.5);font-size:0.72rem;">TensorFlow.js は WebGL/CPU を使ってブラウザ内で完結学習します。モデル重み・入力データは外部送信されません。</p>
    <p style="margin-top:0.5rem;color:rgba(255,255,255,0.45);font-size:0.7rem;">※ TensorFlow.js / Chart.js は学習ボタンクリック時に CDN からダウンロードされます。データの送信ではありません。</p>
  </div>

  <!-- Hero -->
  <div style="position:relative;height:12rem;overflow:hidden;display:flex;align-items:center;justify-content:center;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#0c0c0e 0%,#0d0d1a 60%,#0c0c0e 100%);"></div>
    <div style="position:relative;z-index:1;text-align:center;padding:0 1.5rem;">
      <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;margin-bottom:0.85rem;text-transform:uppercase;">AI Anomaly Detection</p>
      <h1 style="font-size:clamp(1.5rem,4vw,2.1rem);font-weight:200;letter-spacing:0.15em;color:#edede8;">異常検知デモ</h1>
      <p style="color:rgba(237,237,232,0.5);font-size:0.78rem;margin-top:0.6rem;letter-spacing:0.05em;">TF.js による完全ブラウザ内AI学習 · オートエンコーダー · 再構成誤差</p>
    </div>
  </div>

  <!-- USE CASES -->
  <div style="max-width:1100px;margin:0 auto;padding:1rem 1rem 0;">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:0.75rem;">
      <div style="background:#111114;border:1px solid rgba(200,169,110,0.15);border-left:3px solid #c8a96e;padding:0.85rem 1.1rem;">
        <div style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.4rem;">USE CASE 1</div>
        <div style="color:#edede8;font-size:0.82rem;font-weight:500;margin-bottom:0.3rem;">予知保全</div>
        <div style="color:rgba(237,237,232,0.55);font-size:0.72rem;line-height:1.5;">振動・温度センサー逸脱を製品不良前に検知</div>
      </div>
      <div style="background:#111114;border:1px solid rgba(200,169,110,0.15);border-left:3px solid #c8a96e;padding:0.85rem 1.1rem;">
        <div style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.4rem;">USE CASE 2</div>
        <div style="color:#edede8;font-size:0.82rem;font-weight:500;margin-bottom:0.3rem;">不良流出防止</div>
        <div style="color:rgba(237,237,232,0.55);font-size:0.72rem;line-height:1.5;">外観検査前段で異常パターンを自動アラート</div>
      </div>
      <div style="background:#111114;border:1px solid rgba(200,169,110,0.15);border-left:3px solid #c8a96e;padding:0.85rem 1.1rem;">
        <div style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.4rem;">USE CASE 3</div>
        <div style="color:#edede8;font-size:0.82rem;font-weight:500;margin-bottom:0.3rem;">工程逸脱モニタリング</div>
        <div style="color:rgba(237,237,232,0.55);font-size:0.72rem;line-height:1.5;">プロセスパラメータの組合せ異常を捕捉</div>
      </div>
    </div>

    <!-- 5秒クイックスタート -->
    <div style="margin-top:1rem;background:linear-gradient(90deg,rgba(110,200,151,0.06) 0%,transparent 100%);border-left:3px solid #6ec897;padding:0.85rem 1.1rem;display:flex;flex-wrap:wrap;gap:1.25rem;align-items:center;">
      <div style="color:#6ec897;font-size:0.6rem;letter-spacing:0.3em;white-space:nowrap;">⚡ 5秒で試す</div>
      <div style="display:flex;gap:0.5rem;align-items:center;font-size:0.78rem;color:rgba(237,237,232,0.85);flex-wrap:wrap;">
        <span style="color:#c8a96e;font-weight:600;">①</span> 「サンプルデータを読み込む」をクリック
        <span style="color:rgba(255,255,255,0.3);">→</span>
        <span style="color:#c8a96e;font-weight:600;">②</span> 閾値スライダーを調整（任意）
        <span style="color:rgba(255,255,255,0.3);">→</span>
        <span style="color:#c8a96e;font-weight:600;">③</span> 「AI学習 & 異常検知」をクリック
      </div>
    </div>
  </div>

  <div style="max-width:1100px;margin:0 auto;padding:1.5rem 1rem 4rem;">

    <!-- 業界プリセットバー -->
    <div style="background:#0a0a0c;border:1px solid rgba(200,169,110,0.1);padding:0.7rem 1rem;display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;margin-bottom:0.6rem;">
      <span style="color:rgba(200,169,110,0.7);font-size:0.62rem;letter-spacing:0.2em;">PRESET</span>
      <button class="preset-btn" data-preset="auto" style="background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(237,237,232,0.7);padding:0.3rem 0.85rem;font-size:0.72rem;cursor:pointer;font-family:inherit;">🚗 自動車部品(振動)</button>
      <button class="preset-btn" data-preset="elec" style="background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(237,237,232,0.7);padding:0.3rem 0.85rem;font-size:0.72rem;cursor:pointer;font-family:inherit;">⚙ 電子機器(温度)</button>
      <button class="preset-btn" data-preset="food" style="background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(237,237,232,0.7);padding:0.3rem 0.85rem;font-size:0.72rem;cursor:pointer;font-family:inherit;">🥫 食品工場(殺菌)</button>
      <button id="btn-template-csv" style="background:transparent;border:1px solid rgba(110,200,151,0.3);color:rgba(110,200,151,0.85);padding:0.3rem 0.85rem;font-size:0.72rem;cursor:pointer;font-family:inherit;margin-left:auto;">📥 CSVテンプレートDL</button>
    </div>

    <!-- Config & Data -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;" id="ctrl-grid">

      <!-- Settings -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">SETTINGS</p>
        <div style="display:flex;flex-direction:column;gap:0.85rem;">
          <div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
              <label class="field-label">正常データ割合（先頭 X%）</label>
              <span id="train-pct-val" style="color:#c8a96e;font-size:0.75rem;">70%</span>
            </div>
            <input id="train-pct" type="range" min="30" max="90" step="5" value="70" class="slider">
            <p style="color:rgba(255,255,255,0.35);font-size:0.65rem;margin-top:0.3rem;">先頭のデータを「正常」として学習に使用します</p>
          </div>
          <div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
              <label class="field-label">エポック数</label>
              <span id="epochs-val" style="color:#c8a96e;font-size:0.75rem;">50</span>
            </div>
            <input id="epochs" type="range" min="10" max="200" step="10" value="50" class="slider">
          </div>
          <div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
              <label class="field-label">異常閾値 (μ + k·σ)</label>
              <span id="kappa-val" style="color:#c8a96e;font-size:0.75rem;">2.0</span>
            </div>
            <input id="kappa" type="range" min="1.0" max="3.0" step="0.1" value="2.0" class="slider">
            <p style="color:rgba(255,255,255,0.35);font-size:0.65rem;margin-top:0.3rem;">学習後もスライダーで閾値変更可（再学習不要）</p>
          </div>
          <div>
            <label style="display:flex;align-items:center;gap:0.4rem;color:rgba(255,255,255,0.55);font-size:0.7rem;cursor:pointer;">
              <input id="early-stop" type="checkbox" style="accent-color:#c8a96e;">
              早期停止（直近3エポック平均より改善しない場合）
            </label>
          </div>
        </div>
      </div>

      <!-- Data -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">DATA</p>
        <div style="display:flex;flex-direction:column;gap:0.65rem;">
          <p style="color:rgba(255,255,255,0.5);font-size:0.72rem;line-height:1.6;">
            CSV形式: <code style="background:#0a0a0c;padding:0.1em 0.4em;color:#c8a96e;">timestamp,sensor1,sensor2,sensor3</code><br>
            センサーは最大5列。1行目はヘッダー行として自動スキップ。
          </p>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
            <button id="btn-sample" class="m-btn-ghost">サンプルデータ生成</button>
            <label class="m-btn-ghost" style="cursor:pointer;">
              CSV アップロード
              <input id="csv-upload" type="file" accept=".csv,text/csv" style="display:none;">
            </label>
          </div>
          <div id="csv-progress" style="display:none;margin-top:0.4rem;">
            <div style="color:rgba(255,255,255,0.5);font-size:0.7rem;margin-bottom:0.3rem;">CSVを解析中...</div>
            <div style="width:100%;background:#1a1a1d;border-radius:9999px;height:6px;">
              <div id="csv-progress-bar" style="background:#c8a96e;height:6px;border-radius:9999px;transition:width 0.1s;width:0%;"></div>
            </div>
          </div>
          <div id="data-status" style="color:rgba(255,255,255,0.4);font-size:0.7rem;min-height:1.2em;"></div>
          <div id="tf-status" style="color:rgba(255,255,255,0.4);font-size:0.68rem;">学習ボタンクリックでAI起動準備</div>
          <div style="margin-bottom:0.5rem;">
            <div style="color:rgba(255,255,255,0.4);font-size:0.65rem;letter-spacing:0.15em;margin-bottom:0.5rem;">検知モデル</div>
            <div style="display:flex;flex-wrap:wrap;gap:1rem;">
              <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
                <input type="radio" name="det-model" value="autoencoder" id="model-ae" checked style="accent-color:#c8a96e;">
                <span style="font-size:0.78rem;color:rgba(237,237,232,0.75);">Autoencoder (TF.js)</span>
              </label>
              <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
                <input type="radio" name="det-model" value="iforest" id="model-if" style="accent-color:#c8a96e;">
                <span style="font-size:0.78rem;color:rgba(237,237,232,0.75);">Isolation Forest（高速）</span>
              </label>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
            <button id="btn-run" class="m-btn" disabled>AI学習 &amp; 異常検知</button>
            <span style="color:rgba(255,255,255,0.35);font-size:0.72rem;">Ctrl+Enter で実行</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Progress -->
    <div id="progress-section" style="display:none;background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-bottom:1rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;">TRAINING PROGRESS</p>
        <span id="progress-text" style="color:rgba(255,255,255,0.5);font-size:0.7rem;"></span>
      </div>
      <div style="background:#0a0a0c;height:6px;border-radius:3px;overflow:hidden;">
        <div id="progress-bar" style="background:#c8a96e;height:100%;width:0%;transition:width 0.1s linear;"></div>
      </div>
      <div style="margin-top:0.5rem;color:rgba(255,255,255,0.35);font-size:0.68rem;" id="loss-text"></div>
    </div>

    <!-- Live Stream Section -->
    <div id="stream-section" style="display:none;background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.5rem;margin-bottom:1rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:0.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;">LIVE STREAM SIMULATION</p>
        <div style="display:flex;gap:0.5rem;">
          <button id="btn-stream-start" class="m-btn-ghost">▶ 開始</button>
          <button id="btn-stream-stop" class="m-btn-ghost" disabled>⏹ 停止</button>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;flex-wrap:wrap;">
        <div style="flex:1;min-width:140px;">
          <label class="field-label" style="font-size:0.65rem;">サンプリング間隔</label>
          <input type="range" id="stream-interval" min="100" max="2000" step="100" value="500" style="width:100%;accent-color:#c8a96e;">
          <div style="color:#c8a96e;font-size:0.7rem;text-align:right;"><span id="stream-interval-val">500</span> ms</div>
        </div>
        <div style="flex:1;min-width:140px;">
          <label class="field-label" style="font-size:0.65rem;">異常注入確率</label>
          <input type="range" id="stream-anom-prob" min="0" max="30" step="1" value="5" style="width:100%;accent-color:#c8a96e;">
          <div style="color:#c8a96e;font-size:0.7rem;text-align:right;"><span id="stream-anom-prob-val">5</span>%</div>
        </div>
      </div>
      <div style="position:relative;height:240px;">
        <canvas id="stream-chart"></canvas>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:0.75rem;margin-top:1rem;" id="stream-metrics">
        <div style="background:#0a0a0c;padding:0.85rem 1rem;border:1px solid rgba(255,255,255,0.05);">
          <div style="color:rgba(255,255,255,0.4);font-size:0.6rem;letter-spacing:0.2em;">受信点</div>
          <div style="color:#edede8;font-size:1.2rem;font-weight:200;" id="stream-count">0</div>
        </div>
        <div style="background:#0a0a0c;padding:0.85rem 1rem;border:1px solid rgba(255,255,255,0.05);">
          <div style="color:rgba(255,255,255,0.4);font-size:0.6rem;letter-spacing:0.2em;">異常検知数</div>
          <div style="color:#e87070;font-size:1.2rem;font-weight:200;" id="stream-anom-count">0</div>
        </div>
        <div style="background:#0a0a0c;padding:0.85rem 1rem;border:1px solid rgba(255,255,255,0.05);">
          <div style="color:rgba(255,255,255,0.4);font-size:0.6rem;letter-spacing:0.2em;">最新ステータス</div>
          <div id="stream-status" style="color:#6ec86e;font-size:0.9rem;font-weight:300;">待機中</div>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="result-section" style="display:none;">

      <!-- Sensor chart -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.5rem;margin-bottom:1rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">SENSOR TIME-SERIES</p>
        <div style="position:relative;height:240px;">
          <canvas id="sensor-chart"></canvas>
        </div>
        <button id="btn-png-sensor" class="m-btn-ghost" style="margin-top:0.5rem;font-size:0.72rem;">📷 PNG保存</button>
      </div>

      <!-- Anomaly score chart -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.5rem;margin-bottom:1rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">ANOMALY SCORE（再構成誤差）</p>
        <div style="position:relative;height:200px;">
          <canvas id="score-chart"></canvas>
        </div>
        <button id="btn-png-score" class="m-btn-ghost" style="margin-top:0.5rem;font-size:0.72rem;">📷 PNG保存</button>
      </div>
      <div id="perf-stats" style="display:none;margin-top:0.5rem;font-size:0.72rem;color:rgba(255,255,255,0.4);font-family:ui-monospace,monospace;"></div>

      <!-- Summary metrics -->
      <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:1rem;" id="metrics-grid">
        <div class="metric-card">
          <div class="metric-label">異常点数</div>
          <div class="metric-value" id="anomaly-count" style="color:#e87070;">—</div>
          <div class="metric-sub">閾値超えサンプル数</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">異常率</div>
          <div class="metric-value" id="anomaly-rate">—</div>
          <div class="metric-sub">全サンプルに対する割合</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">最大スコア</div>
          <div class="metric-value" id="max-score">—</div>
          <div class="metric-sub">最大再構成誤差</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">平均誤差</div>
          <div class="metric-value" id="mean-score">—</div>
          <div class="metric-sub">学習データ平均</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">閾値</div>
          <div class="metric-value" id="threshold-val">—</div>
          <div class="metric-sub">μ + k·σ</div>
        </div>
      </div>

      <!-- Actions -->
      <div style="display:flex;gap:0.6rem;flex-wrap:wrap;margin-top:1.25rem;justify-content:flex-end;">
        <button id="btn-download" class="m-btn-ghost">結果をCSVでダウンロード</button>
        <button id="btn-reset" class="m-btn-ghost">リセット</button>
      </div>

      <!-- NEXT ACTIONS -->
      <div id="action-hints" style="background:linear-gradient(135deg,rgba(200,169,110,0.05) 0%,rgba(110,200,151,0.05) 100%);border-left:3px solid #6ec897;padding:1.25rem 1.5rem;margin-top:1.5rem;">
        <div style="color:#6ec897;font-size:0.62rem;letter-spacing:0.3em;margin-bottom:0.75rem;">✓ NEXT ACTIONS — 現場で次にすべきこと</div>
        <ol style="margin:0;padding-left:1.5rem;color:rgba(237,237,232,0.85);font-size:0.85rem;line-height:1.8;">
          <li>検出された異常時刻のロット履歴・4M変化点を照合し、要因絞込み</li>
          <li>センサー閾値（μ+kσ）の再設定を検討（誤検出多→k上げ／見逃し→下げ）</li>
          <li>予兆段階での設備点検計画を策定し、予知保全を運用化</li>
        </ol>
      </div>

    </div>

    <!-- 関連ツール -->
    <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.07);">
      <div style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.3em;margin-bottom:1rem;">▸ 他のツールも組み合わせる</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:0.85rem;margin-bottom:1.5rem;">
