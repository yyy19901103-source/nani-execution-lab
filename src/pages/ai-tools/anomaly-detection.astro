    // ---- Isolation Forest (pure JS, no TF.js needed) ----
    class IsolationForest {
      constructor(nTrees, subsampleSize) {
        this.nTrees = nTrees || 50;
        this.subsampleSize = subsampleSize || 64;
        this.trees = [];
        this._cn = 1;
      }

      buildTree(data, depth, maxDepth) {
        if (data.length <= 1 || depth >= maxDepth) {
          return { isLeaf: true, size: data.length };
        }
        const nFeatures = data[0].length;
        const feat = Math.floor(Math.random() * nFeatures);
        const vals = data.map(d => d[feat]);
        const min = Math.min.apply(null, vals);
        const max = Math.max.apply(null, vals);
        if (min === max) return { isLeaf: true, size: data.length };
        const split = min + Math.random() * (max - min);
        const left = data.filter(d => d[feat] < split);
        const right = data.filter(d => d[feat] >= split);
        return {
          isLeaf: false, feat, split,
          left: this.buildTree(left, depth + 1, maxDepth),
          right: this.buildTree(right, depth + 1, maxDepth)
        };
      }

      pathLength(node, point, depth) {
        if (node.isLeaf) return depth + this._cFunc(node.size);
        return point[node.feat] < node.split
          ? this.pathLength(node.left, point, depth + 1)
          : this.pathLength(node.right, point, depth + 1);
      }

      _cFunc(n) {
        if (n <= 1) return 0;
        return 2 * (Math.log(n - 1) + 0.5772156649) - 2 * (n - 1) / n;
      }

      fit(data) {
        const maxDepth = Math.ceil(Math.log2(this.subsampleSize));
        this.trees = [];
        const sz = Math.min(this.subsampleSize, data.length);
        for (let i = 0; i < this.nTrees; i++) {
          const indices = [];
          const pool = data.length;
          for (let j = 0; j < sz; j++) indices.push(Math.floor(Math.random() * pool));
          const sample = indices.map(idx => data[idx]);
          this.trees.push(this.buildTree(sample, 0, maxDepth));
        }
        this._cn = this._cFunc(sz);
      }

      scorePoint(point) {
        if (this.trees.length === 0) return 0;
        const avgPath = this.trees.reduce((s, t) => s + this.pathLength(t, point, 0), 0) / this.trees.length;
        return Math.pow(2, -avgPath / this._cn);
      }

      predict(data, threshold) {
        threshold = threshold || 0.6;
        return data.map(d => {
          const score = this.scorePoint(d);
          return { score, isAnomaly: score >= threshold };
        });
      }
    }

