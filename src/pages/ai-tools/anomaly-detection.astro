          resizeDelay: 100,
          maintainAspectRatio: false,
          animation: false,
          animations: { colors: false, x: false },
          transitions: { active: { animation: { duration: 0 } } },
          plugins: {
            decimation: { enabled: true, algorithm: 'lttb', samples: 200, threshold: 300 },
            legend: { labels: { color: 'rgba(237,237,232,0.6)', font: { size: 10 }, boxWidth: 14 } },
            tooltip: { backgroundColor: '#111114', titleColor: '#c8a96e', bodyColor: '#edede8' }
          },
          scales: {
            x: { ticks: { color: 'rgba(255,255,255,0.35)', font: { size: 9 }, maxTicksLimit: 10 }, grid: { color: 'rgba(255,255,255,0.04)' } },
            y: { ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } }
          }
        }
      });
    }

    async function streamStep() {
      try {
        if (!streamModel || !streamStats) return;
        const anomalyProb = parseInt(streamAnomProbEl.value, 10) / 100;
        const isAnomaly = Math.random() < anomalyProb;
        const point = generateStreamPoint(streamCount, isAnomaly);

        const inputArr = sensorKeys.map(k => point[k] != null ? point[k] : 0);
        const normalized = inputArr.map((v, i) => {
          const range = streamStats.maxs[i] - streamStats.mins[i];
          return range === 0 ? 0 : (v - streamStats.mins[i]) / range;
        });

        const xT = tf.tensor2d([normalized]);
        const recon = streamModel.predict(xT);
        const errT = tf.mean(tf.square(tf.sub(xT, recon)), 1);
        const errArr = await errT.array();
        const error = errArr[0];
        xT.dispose(); recon.dispose(); errT.dispose();

        const detected = error > streamThreshold;
        if (detected) streamAnomCount++;
        streamCount++;

        streamData.push({ ...point, error, detected });
        if (streamData.length > 100) streamData.shift();

        // Update chart
        ensureStreamChart();
        if (streamChart) {
          streamChart.data.labels = streamData.map(d => d.t);
          streamChart.data.datasets[0].data = streamData.map(d => d.error);
          streamChart.data.datasets[1].data = streamData.map(() => streamThreshold);
          streamChart.update('none');
        }

        // Update metrics
        document.getElementById('stream-count').textContent = streamCount;
        document.getElementById('stream-anom-count').textContent = streamAnomCount;
        const statusEl2 = document.getElementById('stream-status');
        if (statusEl2) {
          if (detected) {
            statusEl2.textContent = '⚠ 異常検知';
            statusEl2.style.color = '#e87070';
          } else {
            statusEl2.textContent = '✓ 正常';
            statusEl2.style.color = '#6ec86e';
          }
        }
      } catch (e) {
        console.error('stream step', e);
      }
    }

    document.getElementById('btn-stream-start')?.addEventListener('click', () => {
      try {
        if (!streamModel) {
          alert('先にAI学習を実行してください');
          return;
        }
        const interval = parseInt(streamIntervalEl.value, 10);
        if (streamTimer) clearInterval(streamTimer);
        streamTimer = setInterval(streamStep, interval);
        document.getElementById('btn-stream-start').disabled = true;
        document.getElementById('btn-stream-stop').disabled = false;
      } catch (e) { console.error(e); alert('開始失敗: ' + e.message); }
    });

    document.getElementById('btn-stream-stop')?.addEventListener('click', () => {
      if (streamTimer) { clearInterval(streamTimer); streamTimer = null; }
      document.getElementById('btn-stream-start').disabled = false;
      document.getElementById('btn-stream-stop').disabled = true;
    });

    // ---- Reset ----
    document.getElementById('btn-reset').addEventListener('click', () => {
      lastErrors = null;
      lastNormalErrors = null;
      lastTrainSplit = 0;
      if (sensorChart) { sensorChart.destroy(); sensorChart = null; }
      if (scoreChart) { scoreChart.destroy(); scoreChart = null; }
      // Stop streaming
      if (streamTimer) { clearInterval(streamTimer); streamTimer = null; }
      if (streamChart) { streamChart.destroy(); streamChart = null; }
      if (streamModel) { try { streamModel.dispose(); } catch (_) {} streamModel = null; }
      streamStats = null; streamThreshold = null;
      streamData = []; streamCount = 0; streamAnomCount = 0;
      const ssec = document.getElementById('stream-section');
      if (ssec) ssec.style.display = 'none';
      const sc = document.getElementById('stream-count'); if (sc) sc.textContent = '0';
      const sac = document.getElementById('stream-anom-count'); if (sac) sac.textContent = '0';
      const sst = document.getElementById('stream-status'); if (sst) { sst.textContent = '待機中'; sst.style.color = '#6ec86e'; }
      const sbs = document.getElementById('btn-stream-start'); if (sbs) sbs.disabled = false;
      const sbsp = document.getElementById('btn-stream-stop'); if (sbsp) sbsp.disabled = true;
      resultSection.style.display = 'none';
      progressSection.style.display = 'none';
      document.getElementById('progress-bar').style.width = '0%';
      document.getElementById('progress-text').textContent = '';
      document.getElementById('loss-text').textContent = '';
      statusEl.textContent = 'リセット完了';
    });
  </script>

  <section style="max-width:1100px;margin:0 auto;padding:3rem 1rem 5rem;">
    <h2 style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;text-transform:uppercase;margin-bottom:2rem;">このツールについて</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem;">
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.05);padding:1.5rem;">
        <div style="color:#c8a96e;font-size:0.82rem;font-weight:500;margin-bottom:0.85rem;">🤖 Autoencoder</div>
        <p style="color:rgba(255,255,255,0.5);font-size:0.8rem;line-height:1.7;margin:0;">ニューラルネットワークで「正常データのパターン」を学習し、そこから大きく外れたデータを異常と判定。複雑な相関関係を捉えられるが、学習に時間がかかる。TF.js使用。</p>
      </div>
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.05);padding:1.5rem;">
        <div style="color:#c8a96e;font-size:0.82rem;font-weight:500;margin-bottom:0.85rem;">🌲 Isolation Forest</div>
        <p style="color:rgba(255,255,255,0.5);font-size:0.8rem;line-height:1.7;margin:0;">「異常なデータは少数の分岐で孤立しやすい」という性質を利用。ランダムな木構造でデータを分割し、孤立しやすさで異常スコアを算出。学習不要で超高速。</p>
      </div>
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.05);padding:1.5rem;">
        <div style="color:#c8a96e;font-size:0.82rem;font-weight:500;margin-bottom:0.85rem;">📊 しきい値の意味</div>
        <p style="color:rgba(255,255,255,0.5);font-size:0.8rem;line-height:1.7;margin:0;"><strong style="color:rgba(237,237,232,0.75);">低め（1.5σ）</strong>: 敏感に検知。誤検知が増える。<strong style="color:rgba(237,237,232,0.75);">標準（2.0σ）</strong>: バランス型。<strong style="color:rgba(237,237,232,0.75);">高め（3.0σ）</strong>: 確実な異常のみ。製造ラインでは用途に応じて調整。</p>
      </div>
    </div>
  </section>

