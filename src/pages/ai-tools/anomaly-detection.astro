    // ---- Autoencoder ----
    async function buildAutoencoder(inputDim) {
      const model = tf.sequential();
      model.add(tf.layers.dense({ units: 8, activation: 'relu', inputShape: [inputDim] }));
      model.add(tf.layers.dense({ units: 4, activation: 'relu' }));
      model.add(tf.layers.dense({ units: 8, activation: 'relu' }));
      model.add(tf.layers.dense({ units: inputDim, activation: 'linear' }));
      model.compile({ optimizer: tf.train.adam(0.01), loss: 'meanSquaredError' });
      return model;
    }

    function updateProgress(epoch, totalEpochs, loss) {
      const pct = ((epoch + 1) / totalEpochs * 100).toFixed(0);
      document.getElementById('progress-bar').style.width = pct + '%';
      document.getElementById('progress-text').textContent = 'Epoch ' + (epoch + 1) + ' / ' + totalEpochs;
      document.getElementById('loss-text').textContent = 'Loss: ' + (loss ? loss.toFixed(6) : '—');
    }

    async function trainAndDetect(normalData, allData, epochs, kappa, useEarlyStop) {
      const inputDim = normalData[0].length;
      const model = await buildAutoencoder(inputDim);

      // Dynamic batch size based on data volume
      const n = normalData.length;
      const batchSize = n < 50 ? 16 : (n < 200 ? 32 : 64);

      const xNormal = tf.tensor2d(normalData);
      const lossHistory = [];
      let stopped = false;

      await model.fit(xNormal, xNormal, {
        epochs,
        batchSize,
        shuffle: true,
        callbacks: {
          onEpochEnd: (e, logs) => {
            updateProgress(e, epochs, logs.loss);
            lossHistory.push(logs.loss);
            if (useEarlyStop && lossHistory.length >= 4) {
              const recent3 = lossHistory.slice(-4, -1);
              const avg = recent3.reduce((a, b) => a + b, 0) / 3;
              if (logs.loss >= avg) {
                stopped = true;
                model.stopTraining = true;
              }
            }
          }
        }
      });

      const xAll = tf.tensor2d(allData);
      const reconstructed = model.predict(xAll);
      const errors = tf.mean(tf.square(tf.sub(xAll, reconstructed)), 1);
      const errorsArr = await errors.array();

      // Threshold: mean + kappa·σ of normal data errors
      const normalErrors = errorsArr.slice(0, normalData.length);
      const mean = normalErrors.reduce((a, b) => a + b, 0) / normalErrors.length;
      const std = Math.sqrt(normalErrors.reduce((s, e) => s + (e - mean) * (e - mean), 0) / normalErrors.length);
      const threshold = mean + kappa * std;

      xNormal.dispose();
      xAll.dispose();
      reconstructed.dispose();
      errors.dispose();
      // NOTE: do NOT dispose model — kept for streaming inference

      return { errors: errorsArr, threshold, mean, std, normalErrors, stopped, model };
    }

    function recomputeThreshold() {
      if (!lastNormalErrors || !lastErrors) return;
      const kappa = parseFloat(document.getElementById('kappa').value);
      const mean = lastNormalErrors.reduce((a, b) => a + b, 0) / lastNormalErrors.length;
      const std = Math.sqrt(lastNormalErrors.reduce((s, e) => s + (e - mean) * (e - mean), 0) / lastNormalErrors.length);
      const threshold = mean + kappa * std;
      // Update score chart (bar colors + threshold line)
      if (scoreChart) {
        scoreChart.data.datasets[0].backgroundColor = lastErrors.map(e => e > threshold ? 'rgba(232,112,112,0.85)' : 'rgba(200,169,110,0.5)');
        scoreChart.data.datasets[1].data = Array(lastErrors.length).fill(threshold);
        scoreChart.update('none');
      }
      const anomalyCount = lastErrors.filter(e => e > threshold).length;
      document.getElementById('anomaly-count').textContent = anomalyCount;
      document.getElementById('anomaly-rate').textContent = (anomalyCount / lastErrors.length * 100).toFixed(1) + '%';
      document.getElementById('threshold-val').textContent = threshold.toFixed(4);
    }

    // ---- Normalize helper ----
    function normalize(matrix) {
      const cols = matrix[0].length;
      const mins = Array(cols).fill(Infinity);
      const maxs = Array(cols).fill(-Infinity);
      for (const row of matrix) {
        for (let j = 0; j < cols; j++) {
          if (row[j] < mins[j]) mins[j] = row[j];
          if (row[j] > maxs[j]) maxs[j] = row[j];
        }
      }
      const normalized = matrix.map(row => row.map((v, j) => {
        const range = maxs[j] - mins[j];
        return range === 0 ? 0 : (v - mins[j]) / range;
      }));
      return { normalized, mins, maxs };
    }

    // ---- Run ----
    document.getElementById('btn-run').addEventListener('click', async () => {
      if (!currentData) return;

      btnRun.disabled = true;
      const detModel = document.querySelector('input[name="det-model"]:checked')?.value || 'autoencoder';

      // Lazy-load Chart.js always; TF.js only for autoencoder
      if (!chartLoaded) {
        try { await loadChartJs(); } catch (err) {
          tfStatusEl.textContent = '✗ Chart.js の読込に失敗しました';
          tfStatusEl.style.color = '#e87070';
          btnRun.disabled = false;
          return;
        }
      }

      if (detModel === 'autoencoder' && (!tfLoaded || !chartLoaded)) {
        tfStatusEl.textContent = '⚙ TensorFlow.js 起動中... (初回のみ・通常2-3秒)';
        tfStatusEl.style.color = 'rgba(255,255,255,0.55)';
        try {
          await Promise.all([loadTfJs(), loadChartJs()]);
        } catch (err) {
          tfStatusEl.textContent = '✗ ' + (err.message || 'ライブラリの読込に失敗しました');
          tfStatusEl.style.color = '#e87070';
          btnRun.disabled = false;
          return;
        }
      }

      progressSection.style.display = 'block';
      resultSection.style.display = 'none';
      const _t0 = performance.now();

      const trainPct = parseInt(document.getElementById('train-pct').value, 10) / 100;
      const epochs = parseInt(document.getElementById('epochs').value, 10);
      const kappa = parseFloat(document.getElementById('kappa').value);
      const useEarlyStop = document.getElementById('early-stop').checked;
      const n = currentData.length;
      const nTrain = Math.max(5, Math.floor(n * trainPct));

      // Build matrix from sensor keys
      const allMatrix = currentData.map(row => sensorKeys.map(k => row[k] || 0));
      const normResult = normalize(allMatrix);
      const normalizedMatrix = normResult.normalized;
      const normalData = normalizedMatrix.slice(0, nTrain);
      // Save stats for streaming
      streamStats = { mins: normResult.mins, maxs: normResult.maxs };

      // ---- Isolation Forest path ----
      if (detModel === 'iforest') {
        try {
          tfStatusEl.textContent = '⚙ Isolation Forest 実行中...';
          tfStatusEl.style.color = 'rgba(255,255,255,0.55)';
          document.getElementById('progress-bar').style.width = '50%';
          document.getElementById('progress-text').textContent = 'Isolation Forest 学習中…';
          // Give UI a chance to update
          await new Promise(r => setTimeout(r, 10));

          const iforest = new IsolationForest(100, Math.min(64, nTrain));
          iforest.fit(normalData);
          const iForestThreshold = 0.55 + (kappa - 2.0) * 0.05; // map kappa to IF threshold
          const results = iforest.predict(normalizedMatrix, iForestThreshold);
          const errors = results.map(r => r.score);
          const normalErrors = errors.slice(0, nTrain);
          const mean = normalErrors.reduce((a, b) => a + b, 0) / normalErrors.length;
          const std = Math.sqrt(normalErrors.reduce((s, e) => s + (e - mean) ** 2, 0) / normalErrors.length);
          const threshold = mean + kappa * std;

          document.getElementById('progress-bar').style.width = '100%';
          document.getElementById('progress-text').textContent = '完了';
          document.getElementById('loss-text').textContent = `Isolation Forest (nTrees=100) | 閾値: ${threshold.toFixed(4)}`;

          lastErrors = errors;
          lastNormalErrors = normalErrors;
          lastTrainSplit = nTrain;
          streamModel = null; // IF doesn't support streaming mode
          tfStatusEl.textContent = '✓ Isolation Forest 完了';
          tfStatusEl.style.color = '#c8a96e';

          // Render charts (reuse existing chart rendering code)
          const labels = currentData.map(d => d.t.toString());
          const sensorColors = ['#c8a96e', '#7eb8c8', '#a8c87e'];

