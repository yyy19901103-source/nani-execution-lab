---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="異常検知デモ（AIオートエンコーダー）" description="TensorFlow.js オートエンコーダーによる工場センサー異常検知。完全ブラウザ内AI学習。再構成誤差で異常点を自動判定。">

  <!-- Security Banner -->
  <div style="background:rgba(200,169,110,0.08);border-left:3px solid #c8a96e;padding:0.85rem 1.25rem;font-size:0.78rem;color:#edede8;letter-spacing:0.03em;display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;justify-content:space-between;">
    <div>🔒 <strong>機密保護: 全処理ブラウザ完結</strong> — TF.js モデル学習・推論もローカルで実行</div>
    <button id="verify-privacy" style="background:transparent;border:1px solid rgba(200,169,110,0.3);color:#c8a96e;padding:0.3rem 0.75rem;font-size:0.7rem;cursor:pointer;font-family:inherit;letter-spacing:0.05em;transition:all 0.15s;">検証方法を見る ▼</button>
  </div>
  <div id="privacy-detail" style="display:none;background:#0a0a0c;border-left:3px solid #c8a96e;border-bottom:1px solid rgba(200,169,110,0.15);padding:1.25rem 1.75rem;font-size:0.78rem;color:rgba(237,237,232,0.75);line-height:1.7;">
    <p style="color:#c8a96e;font-size:0.7rem;letter-spacing:0.2em;margin-bottom:0.6rem;">VERIFY YOURSELF</p>
    <ol style="margin:0;padding-left:1.25rem;">
      <li>DevTools (F12) → Network タブを開く</li>
      <li>「Disable cache」をオン</li>
      <li>ページをリロード → CDN ライブラリの読込のみ確認できる</li>
      <li>データ投入・学習・予測中、追加の通信が <strong>一切発生しない</strong> ことを確認</li>
    </ol>
    <p style="margin-top:0.8rem;color:rgba(255,255,255,0.5);font-size:0.72rem;">TensorFlow.js は WebGL/CPU を使ってブラウザ内で完結学習します。モデル重み・入力データは外部送信されません。</p>
  </div>

  <!-- Hero -->
  <div style="position:relative;height:12rem;overflow:hidden;display:flex;align-items:center;justify-content:center;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#0c0c0e 0%,#0d0d1a 60%,#0c0c0e 100%);"></div>
    <div style="position:relative;z-index:1;text-align:center;padding:0 1.5rem;">
      <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;margin-bottom:0.85rem;text-transform:uppercase;">AI Anomaly Detection</p>
      <h1 style="font-size:clamp(1.5rem,4vw,2.1rem);font-weight:200;letter-spacing:0.15em;color:#edede8;">異常検知デモ</h1>
      <p style="color:rgba(237,237,232,0.5);font-size:0.78rem;margin-top:0.6rem;letter-spacing:0.05em;">TF.js による完全ブラウザ内AI学習 · オートエンコーダー · 再構成誤差</p>
    </div>
  </div>

  <div style="max-width:1100px;margin:0 auto;padding:1.5rem 1rem 4rem;">

    <!-- Config & Data -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;" id="ctrl-grid">

      <!-- Settings -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">SETTINGS</p>
        <div style="display:flex;flex-direction:column;gap:0.85rem;">
          <div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
              <label class="field-label">正常データ割合（先頭 X%）</label>
              <span id="train-pct-val" style="color:#c8a96e;font-size:0.75rem;">70%</span>
            </div>
            <input id="train-pct" type="range" min="30" max="90" step="5" value="70" class="slider">
            <p style="color:rgba(255,255,255,0.35);font-size:0.65rem;margin-top:0.3rem;">先頭のデータを「正常」として学習に使用します</p>
          </div>
          <div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
              <label class="field-label">エポック数</label>
              <span id="epochs-val" style="color:#c8a96e;font-size:0.75rem;">50</span>
            </div>
            <input id="epochs" type="range" min="10" max="200" step="10" value="50" class="slider">
          </div>
          <div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
              <label class="field-label">異常閾値 (μ + k·σ)</label>
              <span id="kappa-val" style="color:#c8a96e;font-size:0.75rem;">2.0</span>
            </div>
            <input id="kappa" type="range" min="1.0" max="3.0" step="0.1" value="2.0" class="slider">
            <p style="color:rgba(255,255,255,0.35);font-size:0.65rem;margin-top:0.3rem;">学習後もスライダーで閾値変更可（再学習不要）</p>
          </div>
          <div>
            <label style="display:flex;align-items:center;gap:0.4rem;color:rgba(255,255,255,0.55);font-size:0.7rem;cursor:pointer;">
              <input id="early-stop" type="checkbox" style="accent-color:#c8a96e;">
              早期停止（直近3エポック平均より改善しない場合）
            </label>
          </div>
        </div>
      </div>

      <!-- Data -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">DATA</p>
        <div style="display:flex;flex-direction:column;gap:0.65rem;">
          <p style="color:rgba(255,255,255,0.5);font-size:0.72rem;line-height:1.6;">
            CSV形式: <code style="background:#0a0a0c;padding:0.1em 0.4em;color:#c8a96e;">timestamp,sensor1,sensor2,sensor3</code><br>
            センサーは最大5列。1行目はヘッダー行として自動スキップ。
          </p>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
            <button id="btn-sample" class="m-btn-ghost">サンプルデータ生成</button>
            <label class="m-btn-ghost" style="cursor:pointer;">
              CSV アップロード
              <input id="csv-upload" type="file" accept=".csv,text/csv" style="display:none;">
            </label>
          </div>
          <div id="data-status" style="color:rgba(255,255,255,0.4);font-size:0.7rem;min-height:1.2em;"></div>
          <div id="tf-status" style="color:rgba(255,255,255,0.4);font-size:0.68rem;">TensorFlow.js 読込中…</div>
          <button id="btn-run" class="m-btn" disabled>AI学習 &amp; 異常検知</button>
        </div>
      </div>

    </div>

    <!-- Progress -->
    <div id="progress-section" style="display:none;background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-bottom:1rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;">TRAINING PROGRESS</p>
        <span id="progress-text" style="color:rgba(255,255,255,0.5);font-size:0.7rem;"></span>
      </div>
      <div style="background:#0a0a0c;height:6px;border-radius:3px;overflow:hidden;">
        <div id="progress-bar" style="background:#c8a96e;height:100%;width:0%;transition:width 0.1s linear;"></div>
      </div>
      <div style="margin-top:0.5rem;color:rgba(255,255,255,0.35);font-size:0.68rem;" id="loss-text"></div>
    </div>

    <!-- Results -->
    <div id="result-section" style="display:none;">

      <!-- Sensor chart -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.5rem;margin-bottom:1rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">SENSOR TIME-SERIES</p>
        <div style="position:relative;height:240px;">
          <canvas id="sensor-chart"></canvas>
        </div>
      </div>

      <!-- Anomaly score chart -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.5rem;margin-bottom:1rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">ANOMALY SCORE（再構成誤差）</p>
        <div style="position:relative;height:200px;">
          <canvas id="score-chart"></canvas>
        </div>
      </div>

      <!-- Summary metrics -->
      <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:1rem;" id="metrics-grid">
        <div class="metric-card">
          <div class="metric-label">異常点数</div>
          <div class="metric-value" id="anomaly-count" style="color:#e87070;">—</div>
          <div class="metric-sub">閾値超えサンプル数</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">異常率</div>
          <div class="metric-value" id="anomaly-rate">—</div>
          <div class="metric-sub">全サンプルに対する割合</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">最大スコア</div>
          <div class="metric-value" id="max-score">—</div>
          <div class="metric-sub">最大再構成誤差</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">平均誤差</div>
          <div class="metric-value" id="mean-score">—</div>
          <div class="metric-sub">学習データ平均</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">閾値</div>
          <div class="metric-value" id="threshold-val">—</div>
          <div class="metric-sub">μ + k·σ</div>
        </div>
      </div>

      <!-- Actions -->
      <div style="display:flex;gap:0.6rem;flex-wrap:wrap;margin-top:1.25rem;justify-content:flex-end;">
        <button id="btn-download" class="m-btn-ghost">結果をCSVでダウンロード</button>
        <button id="btn-reset" class="m-btn-ghost">リセット</button>
      </div>

    </div>

  </div>

  <style>
    .m-btn, .m-btn-ghost {
      background:#0a0a0c;color:#edede8;border:1px solid rgba(255,255,255,0.1);
      padding:0.42rem 0.75rem;font-size:0.72rem;cursor:pointer;font-family:inherit;letter-spacing:0.05em;transition:all 0.15s;
    }
    .m-btn-ghost:hover { border-color:#c8a96e;color:#c8a96e; }
    .m-btn { background:#c8a96e;color:#0c0c0e;border-color:#c8a96e;font-weight:600; }
    .m-btn:hover:not(:disabled) { background:#d4b87b; }
    .m-btn:disabled { opacity:0.4;cursor:not-allowed; }
    .field-label { display:block;color:rgba(255,255,255,0.55);font-size:0.68rem;letter-spacing:0.08em; }
    .slider { width:100%;accent-color:#c8a96e;cursor:pointer; }
    .metric-card { background:#0f0f12;border:1px solid rgba(255,255,255,0.07);padding:1.25rem;text-align:center; }
    .metric-label { color:#c8a96e;font-size:0.6rem;letter-spacing:0.35em;margin-bottom:0.5rem; }
    .metric-value { color:#edede8;font-size:1.6rem;font-weight:200;letter-spacing:0.05em;margin-bottom:0.3rem; }
    .metric-sub { color:rgba(255,255,255,0.4);font-size:0.65rem; }
    @media(max-width:1000px){
      #metrics-grid { grid-template-columns:repeat(2,1fr) !important; }
    }
    @media(max-width:700px){
      #ctrl-grid { grid-template-columns:1fr !important; }
      #metrics-grid { grid-template-columns:1fr !important; }
    }
  </style>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@4.17.0/dist/tf.min.js"></script>

  <script is:inline>
    // ---- Privacy verify toggle ----
    document.getElementById('verify-privacy')?.addEventListener('click', () => {
      const d = document.getElementById('privacy-detail');
      d.style.display = d.style.display === 'none' ? 'block' : 'none';
    });

    // ---- TF.js readiness ----
    const tfStatusEl = document.getElementById('tf-status');
    const btnRun = document.getElementById('btn-run');
    tfStatusEl.textContent = '⚙ TensorFlow.js 読込中...';

    async function checkTf() {
      if (typeof tf !== 'undefined') {
        try {
          await tf.setBackend('webgl');
        } catch (e) {
          try { await tf.setBackend('cpu'); } catch (_) {}
        }
        await tf.ready();
        const backend = tf.getBackend();
        tfStatusEl.textContent = '✓ TensorFlow.js v' + tf.version.tfjs + ' 準備完了 (Backend: ' + (backend === 'webgl' ? 'WebGL' : 'CPU') + ')';
        tfStatusEl.style.color = '#c8a96e';
        if (currentData) btnRun.disabled = false;
      } else {
        setTimeout(checkTf, 300);
      }
    }
    checkTf();

    // ---- Sample data generator ----
    function generateSampleData() {
      const n = 100;
      const data = [];
      for (let i = 0; i < n; i++) {
        let anomaly = (i >= 30 && i <= 33) || (i >= 65 && i <= 67) || i === 85;
        data.push({
          t: i,
          v1: 50 + 5 * Math.sin(i * 0.3) + (anomaly ? 25 : 0) + (Math.random() - 0.5) * 3,
          v2: 30 + 3 * Math.cos(i * 0.2) + (anomaly ? -15 : 0) + (Math.random() - 0.5) * 2,
          v3: 20 + 2 * Math.sin(i * 0.5) + (anomaly ? 20 : 0) + (Math.random() - 0.5) * 1.5
        });
      }
      return data;
    }

    // ---- State ----
    let currentData = null;  // array of {t, v1, v2, v3, ...}
    let sensorKeys = ['v1', 'v2', 'v3'];
    let sensorLabels = ['Sensor 1', 'Sensor 2', 'Sensor 3'];
    let sensorChart = null;
    let scoreChart = null;
    let lastErrors = null;
    let lastNormalErrors = null;
    let lastTrainSplit = 0;

    const statusEl = document.getElementById('data-status');
    const progressSection = document.getElementById('progress-section');
    const resultSection = document.getElementById('result-section');

    // ---- Sliders ----
    document.getElementById('train-pct').addEventListener('input', function() {
      document.getElementById('train-pct-val').textContent = this.value + '%';
    });
    document.getElementById('epochs').addEventListener('input', function() {
      document.getElementById('epochs-val').textContent = this.value;
    });
    document.getElementById('kappa').addEventListener('input', function() {
      document.getElementById('kappa-val').textContent = parseFloat(this.value).toFixed(1);
      // Recompute threshold without retraining
      if (lastErrors && lastNormalErrors) recomputeThreshold();
    });

    // ---- Sample load ----
    document.getElementById('btn-sample').addEventListener('click', () => {
      currentData = generateSampleData();
      sensorKeys = ['v1', 'v2', 'v3'];
      sensorLabels = ['Sensor 1', 'Sensor 2', 'Sensor 3'];
      statusEl.textContent = 'サンプルデータ生成完了: ' + currentData.length + ' サンプル（3特徴量）異常3箇所注入済み';
      if (typeof tf !== 'undefined') btnRun.disabled = false;
    });

    // ---- CSV upload ----
    document.getElementById('csv-upload').addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function(ev) {
        const text = ev.target.result;
        const lines = text.trim().split(/\r?\n/).filter(l => l.trim());
        if (lines.length < 2) { statusEl.textContent = 'エラー: データ行が不足しています'; return; }

        // Check if first row is header
        const firstParts = lines[0].split(',').map(s => s.trim());
        let startIdx = 0;
        let headerNames = null;
        if (isNaN(parseFloat(firstParts[1]))) {
          startIdx = 1;
          // Skip first column (timestamp), keep next up to 5 as sensor names
          headerNames = firstParts.slice(1, 6);
        }

        const rows = [];
        let cols = 0;
        for (let i = startIdx; i < lines.length; i++) {
          const parts = lines[i].split(',').map(s => s.trim());
          if (parts.length < 2) continue;
          const t = i - startIdx;
          const vals = {};
          const numCols = Math.min(parts.length - 1, 5);
          cols = Math.max(cols, numCols);
          for (let j = 0; j < numCols; j++) {
            vals['v' + (j + 1)] = parseFloat(parts[j + 1]);
          }
          rows.push({ t, ...vals });
        }

        if (rows.length < 10) {
          statusEl.textContent = 'エラー: データが少なすぎます（最低10行必要）';
          return;
        }

        sensorKeys = Array.from({length: cols}, (_, i) => 'v' + (i + 1));
        if (headerNames && headerNames.length >= cols) {
          sensorLabels = headerNames.slice(0, cols);
        } else {
          sensorLabels = Array.from({length: cols}, (_, i) => 'Sensor ' + (i + 1));
        }
        currentData = rows;
        statusEl.textContent = 'CSV読込完了: ' + rows.length + ' サンプル・' + cols + ' 特徴量 (' + sensorLabels.join(' / ') + ')';
        if (typeof tf !== 'undefined') btnRun.disabled = false;
      };
      reader.readAsText(file);
    });

    // ---- Autoencoder ----
    async function buildAutoencoder(inputDim) {
      const model = tf.sequential();
      model.add(tf.layers.dense({ units: 8, activation: 'relu', inputShape: [inputDim] }));
      model.add(tf.layers.dense({ units: 4, activation: 'relu' }));
      model.add(tf.layers.dense({ units: 8, activation: 'relu' }));
      model.add(tf.layers.dense({ units: inputDim, activation: 'linear' }));
      model.compile({ optimizer: tf.train.adam(0.01), loss: 'meanSquaredError' });
      return model;
    }

    function updateProgress(epoch, totalEpochs, loss) {
      const pct = ((epoch + 1) / totalEpochs * 100).toFixed(0);
      document.getElementById('progress-bar').style.width = pct + '%';
      document.getElementById('progress-text').textContent = 'Epoch ' + (epoch + 1) + ' / ' + totalEpochs;
      document.getElementById('loss-text').textContent = 'Loss: ' + (loss ? loss.toFixed(6) : '—');
    }

    async function trainAndDetect(normalData, allData, epochs, kappa, useEarlyStop) {
      const inputDim = normalData[0].length;
      const model = await buildAutoencoder(inputDim);

      // Dynamic batch size based on data volume
      const n = normalData.length;
      const batchSize = n < 50 ? 16 : (n < 200 ? 32 : 64);

      const xNormal = tf.tensor2d(normalData);
      const lossHistory = [];
      let stopped = false;

      await model.fit(xNormal, xNormal, {
        epochs,
        batchSize,
        shuffle: true,
        callbacks: {
          onEpochEnd: (e, logs) => {
            updateProgress(e, epochs, logs.loss);
            lossHistory.push(logs.loss);
            if (useEarlyStop && lossHistory.length >= 4) {
              const recent3 = lossHistory.slice(-4, -1);
              const avg = recent3.reduce((a, b) => a + b, 0) / 3;
              if (logs.loss >= avg) {
                stopped = true;
                model.stopTraining = true;
              }
            }
          }
        }
      });

      const xAll = tf.tensor2d(allData);
      const reconstructed = model.predict(xAll);
      const errors = tf.mean(tf.square(tf.sub(xAll, reconstructed)), 1);
      const errorsArr = await errors.array();

      // Threshold: mean + kappa·σ of normal data errors
      const normalErrors = errorsArr.slice(0, normalData.length);
      const mean = normalErrors.reduce((a, b) => a + b, 0) / normalErrors.length;
      const std = Math.sqrt(normalErrors.reduce((s, e) => s + (e - mean) * (e - mean), 0) / normalErrors.length);
      const threshold = mean + kappa * std;

      xNormal.dispose();
      xAll.dispose();
      reconstructed.dispose();
      errors.dispose();
      model.dispose();

      return { errors: errorsArr, threshold, mean, std, normalErrors, stopped };
    }

    function recomputeThreshold() {
      if (!lastNormalErrors || !lastErrors) return;
      const kappa = parseFloat(document.getElementById('kappa').value);
      const mean = lastNormalErrors.reduce((a, b) => a + b, 0) / lastNormalErrors.length;
      const std = Math.sqrt(lastNormalErrors.reduce((s, e) => s + (e - mean) * (e - mean), 0) / lastNormalErrors.length);
      const threshold = mean + kappa * std;
      // Update score chart (bar colors + threshold line)
      if (scoreChart) {
        scoreChart.data.datasets[0].backgroundColor = lastErrors.map(e => e > threshold ? 'rgba(232,112,112,0.85)' : 'rgba(200,169,110,0.5)');
        scoreChart.data.datasets[1].data = Array(lastErrors.length).fill(threshold);
        scoreChart.update('none');
      }
      const anomalyCount = lastErrors.filter(e => e > threshold).length;
      document.getElementById('anomaly-count').textContent = anomalyCount;
      document.getElementById('anomaly-rate').textContent = (anomalyCount / lastErrors.length * 100).toFixed(1) + '%';
      document.getElementById('threshold-val').textContent = threshold.toFixed(4);
    }

    // ---- Normalize helper ----
    function normalize(matrix) {
      const cols = matrix[0].length;
      const mins = Array(cols).fill(Infinity);
      const maxs = Array(cols).fill(-Infinity);
      for (const row of matrix) {
        for (let j = 0; j < cols; j++) {
          if (row[j] < mins[j]) mins[j] = row[j];
          if (row[j] > maxs[j]) maxs[j] = row[j];
        }
      }
      return matrix.map(row => row.map((v, j) => {
        const range = maxs[j] - mins[j];
        return range === 0 ? 0 : (v - mins[j]) / range;
      }));
    }

    // ---- Run ----
    document.getElementById('btn-run').addEventListener('click', async () => {
      if (!currentData || typeof tf === 'undefined') return;

      btnRun.disabled = true;
      progressSection.style.display = 'block';
      resultSection.style.display = 'none';

      const trainPct = parseInt(document.getElementById('train-pct').value, 10) / 100;
      const epochs = parseInt(document.getElementById('epochs').value, 10);
      const kappa = parseFloat(document.getElementById('kappa').value);
      const useEarlyStop = document.getElementById('early-stop').checked;
      const n = currentData.length;
      const nTrain = Math.max(5, Math.floor(n * trainPct));

      // Build matrix from sensor keys
      const allMatrix = currentData.map(row => sensorKeys.map(k => row[k] || 0));
      const normalizedMatrix = normalize(allMatrix);
      const normalData = normalizedMatrix.slice(0, nTrain);

      try {
        const { errors, threshold, mean: meanErr, normalErrors, stopped } = await trainAndDetect(normalData, normalizedMatrix, epochs, kappa, useEarlyStop);
        lastErrors = errors;
        lastNormalErrors = normalErrors;
        lastTrainSplit = nTrain;

        // Sensor chart
        const labels = currentData.map(d => d.t.toString());
        const sensorColors = ['#c8a96e', '#7eb8c8', '#a8c87e'];

        // Vertical line plugin for train/test boundary
        const trainBoundaryPlugin = {
          id: 'trainBoundary',
          afterDraw(chart) {
            const xScale = chart.scales.x;
            const yScale = chart.scales.y;
            if (!xScale || !yScale || lastTrainSplit <= 0) return;
            const xPos = xScale.getPixelForValue(lastTrainSplit - 1);
            const ctx = chart.ctx;
            ctx.save();
            ctx.strokeStyle = 'rgba(232,112,112,0.6)';
            ctx.lineWidth = 1;
            ctx.setLineDash([4, 3]);
            ctx.beginPath();
            ctx.moveTo(xPos, yScale.top);
            ctx.lineTo(xPos, yScale.bottom);
            ctx.stroke();
            ctx.setLineDash([]);
            ctx.fillStyle = 'rgba(232,112,112,0.85)';
            ctx.font = '10px sans-serif';
            ctx.fillText('train | eval', xPos + 4, yScale.top + 12);
            ctx.restore();
          }
        };

        if (sensorChart) sensorChart.destroy();
        const sCtx = document.getElementById('sensor-chart').getContext('2d');
        sensorChart = new Chart(sCtx, {
          type: 'line',
          plugins: [trainBoundaryPlugin],
          data: {
            labels,
            datasets: sensorKeys.map((k, i) => ({
              label: sensorLabels[i] || ('Sensor ' + (i + 1)),
              data: currentData.map(d => d[k]),
              borderColor: sensorColors[i % sensorColors.length],
              backgroundColor: 'transparent',
              borderWidth: 1.5,
              pointRadius: 0,
              tension: 0.3
            }))
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { labels: { color: 'rgba(237,237,232,0.6)', font: { size: 11 }, boxWidth: 14 } },
              tooltip: { backgroundColor: '#111114', borderColor: 'rgba(255,255,255,0.07)', borderWidth: 1, titleColor: '#c8a96e', bodyColor: '#edede8' }
            },
            scales: {
              x: { ticks: { color: 'rgba(255,255,255,0.35)', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
              y: { ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 11 } }, grid: { color: 'rgba(255,255,255,0.04)' } }
            }
          }
        });

        // Anomaly score chart - color bars by anomaly
        const anomalies = errors.map(e => e > threshold);
        const barColors = errors.map(e => e > threshold ? 'rgba(232,112,112,0.85)' : 'rgba(200,169,110,0.5)');

        if (scoreChart) scoreChart.destroy();
        const aCtx = document.getElementById('score-chart').getContext('2d');
        scoreChart = new Chart(aCtx, {
          type: 'bar',
          data: {
            labels,
            datasets: [
              {
                label: '異常スコア',
                data: errors,
                backgroundColor: barColors,
                borderColor: 'transparent',
                borderWidth: 0
              },
              {
                label: '閾値 (μ+' + kappa.toFixed(1) + 'σ)',
                data: Array(n).fill(threshold),
                type: 'line',
                borderColor: '#e87070',
                backgroundColor: 'transparent',
                borderWidth: 1.5,
                borderDash: [5, 4],
                pointRadius: 0
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { labels: { color: 'rgba(237,237,232,0.6)', font: { size: 11 }, boxWidth: 14 } },
              tooltip: {
                backgroundColor: '#111114', borderColor: 'rgba(255,255,255,0.07)', borderWidth: 1, titleColor: '#c8a96e', bodyColor: '#edede8',
                callbacks: {
                  label: function(ctx) {
                    if (ctx.dataset.type === 'line') return '閾値: ' + threshold.toFixed(4);
                    const isAnom = ctx.raw > threshold;
                    return 'スコア: ' + ctx.raw.toFixed(4) + (isAnom ? ' ⚠ 異常' : '');
                  }
                }
              }
            },
            scales: {
              x: { ticks: { color: 'rgba(255,255,255,0.35)', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
              y: { ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 11 } }, grid: { color: 'rgba(255,255,255,0.04)' } }
            }
          }
        });

        // Summary
        const anomalyCount = anomalies.filter(Boolean).length;
        const maxScore = Math.max(...errors);
        document.getElementById('anomaly-count').textContent = anomalyCount;
        document.getElementById('anomaly-rate').textContent = (anomalyCount / n * 100).toFixed(1) + '%';
        document.getElementById('max-score').textContent = maxScore.toFixed(4);
        document.getElementById('mean-score').textContent = meanErr.toFixed(4);
        document.getElementById('threshold-val').textContent = threshold.toFixed(4);

        if (stopped) {
          document.getElementById('loss-text').textContent += ' (早期停止)';
        }

        resultSection.style.display = 'block';
        resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

      } catch (err) {
        statusEl.textContent = 'エラー: ' + (err.message || '学習に失敗しました');
        console.error(err);
      } finally {
        btnRun.disabled = false;
      }
    });

    // ---- CSV Download ----
    document.getElementById('btn-download').addEventListener('click', () => {
      if (!lastErrors || !currentData) return;
      const kappa = parseFloat(document.getElementById('kappa').value);
      const mean = lastNormalErrors.reduce((a, b) => a + b, 0) / lastNormalErrors.length;
      const std = Math.sqrt(lastNormalErrors.reduce((s, e) => s + (e - mean) * (e - mean), 0) / lastNormalErrors.length);
      const threshold = mean + kappa * std;
      const header = ['timestamp', ...sensorLabels, 'reconstruction_error', 'is_anomaly'].join(',');
      const lines = [header];
      for (let i = 0; i < currentData.length; i++) {
        const row = currentData[i];
        const vals = sensorKeys.map(k => row[k] != null ? row[k] : '');
        const err = lastErrors[i];
        lines.push([row.t, ...vals, err.toFixed(6), err > threshold ? '1' : '0'].join(','));
      }
      const blob = new Blob([lines.join('\n')], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'anomaly_detection_result.csv';
      a.click();
      URL.revokeObjectURL(url);
    });

    // ---- Reset ----
    document.getElementById('btn-reset').addEventListener('click', () => {
      lastErrors = null;
      lastNormalErrors = null;
      lastTrainSplit = 0;
      if (sensorChart) { sensorChart.destroy(); sensorChart = null; }
      if (scoreChart) { scoreChart.destroy(); scoreChart = null; }
      resultSection.style.display = 'none';
      progressSection.style.display = 'none';
      document.getElementById('progress-bar').style.width = '0%';
      document.getElementById('progress-text').textContent = '';
      document.getElementById('loss-text').textContent = '';
      statusEl.textContent = 'リセット完了';
    });
  </script>

</BaseLayout>
