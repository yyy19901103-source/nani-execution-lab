              datasets: [
                { label: '異常スコア (IF)', data: errors, backgroundColor: barColors2, borderWidth: 0 },
                { label: '閾値', data: Array(n).fill(threshold), type: 'line', borderColor: '#e87070', backgroundColor: 'transparent', borderWidth: 1.5, borderDash: [5, 4], pointRadius: 0 }
