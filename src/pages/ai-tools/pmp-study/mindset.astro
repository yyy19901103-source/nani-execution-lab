---
import '../../../styles/pmp-mobile.css';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import mindsetData from '../../../data/pmp/mindset.json';
import pmbok7Data from '../../../data/pmp/pmbok7-principles.json';
import domainsData from '../../../data/pmp/pmbok7-domains.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="PMBOK 7 公式12原則 + PMP Mindset 8原則 - PMP学習アプリ"
  description="PMBOK 第7版の公式12原則（Stewardship/Team/Stakeholder/Value/Systems Thinking/Leadership/Tailoring/Quality/Complexity/Risk/Adaptability/Change）+ 試験判断軸 PMP Mindset 8原則を併載。"
>
  <div style="background:#0a0a0c;border-bottom:1px solid rgba(255,255,255,0.07);padding:0.7rem 1rem;">
    <div style="max-width:900px;margin:0 auto;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
      <a href={`${base}/ai-tools/pmp-study/`} style="color:rgba(237,237,232,0.6);font-size:0.75rem;text-decoration:none;letter-spacing:0.05em;">← ダッシュボード</a>
      <h1 style="color:#edede8;font-size:0.95rem;font-weight:300;letter-spacing:0.15em;margin:0;">原則 — PMBOK 7 & Mindset</h1>
    </div>
  </div>

  <div style="max-width:900px;margin:0 auto;padding:1.5rem 1rem 4rem;">

    {/* タブ */}
    <div style="display:flex;gap:0.4rem;margin-bottom:1.25rem;border-bottom:1px solid rgba(255,255,255,0.07);flex-wrap:wrap;">
      <button class="tab-btn active" data-tab="pmbok7" style="background:transparent;border:none;border-bottom:2px solid #c8a96e;color:#c8a96e;padding:0.6rem 0.9rem;font-size:0.78rem;font-family:inherit;cursor:pointer;letter-spacing:0.05em;">
        ✅ 12原則
      </button>
      <button class="tab-btn" data-tab="domains" style="background:transparent;border:none;border-bottom:2px solid transparent;color:rgba(237,237,232,0.5);padding:0.6rem 0.9rem;font-size:0.78rem;font-family:inherit;cursor:pointer;letter-spacing:0.05em;">
        ✅ 8パフォーマンスドメイン
      </button>
      <button class="tab-btn" data-tab="mindset" style="background:transparent;border:none;border-bottom:2px solid transparent;color:rgba(237,237,232,0.5);padding:0.6rem 0.9rem;font-size:0.78rem;font-family:inherit;cursor:pointer;letter-spacing:0.05em;">
        🧭 Mindset 8（試験軸）
      </button>
      <button class="tab-btn" data-tab="mapping" style="background:transparent;border:none;border-bottom:2px solid transparent;color:rgba(237,237,232,0.5);padding:0.6rem 0.9rem;font-size:0.78rem;font-family:inherit;cursor:pointer;letter-spacing:0.05em;">
        🔗 マッピング
      </button>
    </div>

    {/* PMBOK 7 タブ */}
    <div id="tab-pmbok7" class="tab-pane">
      <div style="background:rgba(110,200,151,0.06);border-left:3px solid #6ec897;padding:0.85rem 1.1rem;margin-bottom:1.25rem;font-size:0.78rem;color:rgba(237,237,232,0.85);line-height:1.7;">
        ✅ <strong style="color:#6ec897;">PMI 公開資料との照合済み</strong>（2026-05-13）。出典: PMI 公式 PDF + 公開二次資料3点。詳細は <a href={`${base}/ai-tools/pmp-study/audit`} style="color:#6ec897;text-decoration:underline;">監査レポート</a> 参照。
      </div>
      <p style="color:rgba(237,237,232,0.85);font-size:0.85rem;line-height:1.8;margin-bottom:1.5rem;">{pmbok7Data.note}</p>

      {pmbok7Data.principles.map((p, i) => (
        <details open={i < 3} style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-bottom:0.75rem;">
          <summary style="cursor:pointer;list-style:none;">
            <div style="display:flex;gap:0.75rem;align-items:baseline;">
              <span style="color:#c8a96e;font-size:0.7rem;letter-spacing:0.2em;">#{i + 1}</span>
              <h2 style="color:#edede8;font-size:1.05rem;font-weight:300;letter-spacing:0.05em;margin:0;flex:1;">{p.labelJa} <span style="color:rgba(237,237,232,0.5);font-size:0.78rem;font-weight:300;">/ {p.labelEn}</span></h2>
              <span style="color:rgba(237,237,232,0.4);font-size:0.7rem;">▼</span>
            </div>
            <p style="color:rgba(237,237,232,0.75);font-size:0.85rem;line-height:1.7;margin:0.6rem 0 0 1.5rem;">{p.summary}</p>
          </summary>
          <div style="margin-top:1rem;padding-left:1.5rem;border-left:2px solid rgba(200,169,110,0.2);">
            <p style="color:rgba(237,237,232,0.85);font-size:0.85rem;line-height:1.85;">{p.expanded}</p>
          </div>
        </details>
      ))}
    </div>

    {/* 8パフォーマンスドメイン タブ */}
    <div id="tab-domains" class="tab-pane" style="display:none;">
      <div style="background:rgba(110,200,151,0.06);border-left:3px solid #6ec897;padding:0.85rem 1.1rem;margin-bottom:1.25rem;font-size:0.78rem;color:rgba(237,237,232,0.85);line-height:1.7;">
        ✅ <strong style="color:#6ec897;">PMI 公開資料との照合済み</strong>（2026-05-13 2nd round）。PMBOK 6 (2017) の 10 Knowledge Areas を置き換えた新フレームワーク。<a href={`${base}/ai-tools/pmp-study/audit`} style="color:#6ec897;text-decoration:underline;">監査レポート</a> 参照。
      </div>

      <div style="background:#0f0f12;border:1px solid rgba(200,169,110,0.25);padding:1.25rem 1.5rem;margin-bottom:1.25rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:0.75rem;">PARADIGM SHIFT</p>
        <ul style="margin:0;padding-left:1.5rem;color:rgba(237,237,232,0.85);font-size:0.82rem;line-height:1.85;">
          {domainsData.comparisonWithLegacy.shift.map((s: string) => <li>{s}</li>)}
        </ul>
      </div>

      {domainsData.domains.map((d: any, i: number) => (
        <details open={i < 3} style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-bottom:0.75rem;">
          <summary style="cursor:pointer;list-style:none;">
            <div style="display:flex;gap:0.75rem;align-items:baseline;">
              <span style="color:#c8a96e;font-size:0.7rem;letter-spacing:0.2em;">#{i + 1}</span>
              <h2 style="color:#edede8;font-size:1.05rem;font-weight:300;letter-spacing:0.05em;margin:0;flex:1;">{d.labelJa} <span style="color:rgba(237,237,232,0.5);font-size:0.78rem;font-weight:300;">/ {d.labelEn}</span></h2>
              <span style="color:rgba(237,237,232,0.4);font-size:0.7rem;">▼</span>
            </div>
            <p style="color:rgba(237,237,232,0.75);font-size:0.85rem;line-height:1.7;margin:0.6rem 0 0 1.5rem;">{d.summary}</p>
          </summary>
          <div style="margin-top:1rem;padding-left:1.5rem;border-left:2px solid rgba(110,200,151,0.2);">
            <p style="color:#6ec897;font-size:0.65rem;letter-spacing:0.25em;margin-bottom:0.5rem;">期待される成果</p>
            <ul style="margin:0 0 1rem 0;padding-left:1.25rem;color:rgba(237,237,232,0.8);font-size:0.8rem;line-height:1.75;">
              {d.outcomes.map((o: string) => <li>{o}</li>)}
            </ul>
            {d.relatedChapters.length > 0 && (
              <div>
                <p style="color:rgba(237,237,232,0.5);font-size:0.7rem;letter-spacing:0.1em;margin-bottom:0.4rem;">本アプリの関連章:</p>
                <div style="display:flex;flex-wrap:wrap;gap:0.4rem;">
                  {d.relatedChapters.map((ch: string) => (
                    <a href={`${base}/ai-tools/pmp-study/study/${ch}`} style="background:rgba(200,169,110,0.06);border:1px solid rgba(200,169,110,0.25);color:#c8a96e;padding:0.2rem 0.55rem;font-size:0.7rem;text-decoration:none;">章 {ch}</a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </details>
      ))}
    </div>

    {/* Mindset タブ */}
    <div id="tab-mindset" class="tab-pane" style="display:none;">
      <div style="background:rgba(232,180,110,0.06);border-left:3px solid #e8b46e;padding:0.85rem 1.1rem;margin-bottom:1.25rem;font-size:0.78rem;color:rgba(237,237,232,0.85);line-height:1.7;">
        ⚠ <strong style="color:#e8b46e;">これは試験判断軸の整理</strong>であり、PMBOK 7 公式12原則とは別物です。問題演習で迷ったときの選択肢絞り込みフレームとして使用してください。
      </div>

      <div style="background:#111114;border:1px solid rgba(200,169,110,0.2);padding:1.5rem 1.75rem;margin-bottom:1.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:0.5rem;">CORE CONCEPT</p>
        <p style="color:rgba(237,237,232,0.9);font-size:0.9rem;line-height:1.8;">{mindsetData.description}</p>
      </div>

      {mindsetData.principles.map((p, i) => (
        <details open={i === 0} style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-bottom:0.75rem;">
          <summary style="cursor:pointer;list-style:none;">
            <div style="display:flex;gap:0.75rem;align-items:baseline;">
              <span style="color:#c8a96e;font-size:0.7rem;letter-spacing:0.2em;">#{i + 1}</span>
              <h2 style="color:#edede8;font-size:1.1rem;font-weight:300;letter-spacing:0.1em;margin:0;flex:1;">{p.label}</h2>
              <span style="color:rgba(237,237,232,0.4);font-size:0.7rem;">▼</span>
            </div>
            <p style="color:rgba(237,237,232,0.75);font-size:0.85rem;line-height:1.7;margin:0.6rem 0 0 1.5rem;">{p.summary}</p>
          </summary>
          <div style="margin-top:1rem;padding-left:1.5rem;border-left:2px solid rgba(200,169,110,0.2);">
            <p style="color:rgba(237,237,232,0.85);font-size:0.85rem;line-height:1.85;margin-bottom:1rem;">{p.explanation}</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1rem;">
              <div>
                <p style="color:#6ec897;font-size:0.65rem;letter-spacing:0.2em;margin-bottom:0.5rem;">✓ 正解パターン</p>
                <ul style="margin:0;padding-left:1.25rem;color:rgba(237,237,232,0.75);font-size:0.78rem;line-height:1.7;">
                  {p.examPatterns.map(ep => <li>{ep}</li>)}
                </ul>
              </div>
              <div>
                <p style="color:#e86e6e;font-size:0.65rem;letter-spacing:0.2em;margin-bottom:0.5rem;">✗ 誤答パターン</p>
                <ul style="margin:0;padding-left:1.25rem;color:rgba(237,237,232,0.75);font-size:0.78rem;line-height:1.7;">
                  {p.antipatterns.map(ap => <li>{ap}</li>)}
                </ul>
              </div>
            </div>
          </div>
        </details>
      ))}

      <div style="background:#0f0f12;border:1px solid rgba(110,200,151,0.25);padding:1.5rem 1.75rem;margin-top:1.5rem;">
        <p style="color:#6ec897;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">DECISION FLOWCHART · 判断フロー</p>
        <p style="color:rgba(237,237,232,0.75);font-size:0.82rem;line-height:1.7;margin-bottom:1rem;">問題に迷ったら以下の順で選択肢を絞り込み:</p>
        <ol style="margin:0;padding-left:1.5rem;color:rgba(237,237,232,0.85);font-size:0.85rem;line-height:1.9;">
          {mindsetData.decisionFlowchart.map(s => <li>{s.replace(/^\d+\.\s/, '')}</li>)}
        </ol>
      </div>

      <div style="background:#0a0a0c;border:1px solid rgba(255,255,255,0.07);padding:1.5rem 1.75rem;margin-top:1.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">TRAP WORDS · ワナの言葉</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">
          <div>
            <p style="color:#e86e6e;font-size:0.7rem;letter-spacing:0.1em;margin-bottom:0.5rem;">⚠ ほぼ誤答</p>
            <div style="display:flex;flex-wrap:wrap;gap:0.3rem;">
              {mindsetData.trapWords["ほぼ誤答のキーワード"].map(w => (
                <span style="background:rgba(232,110,110,0.06);border:1px solid rgba(232,110,110,0.25);color:#e86e6e;padding:0.2rem 0.5rem;font-size:0.7rem;">「{w}」</span>
              ))}
            </div>
          </div>
          <div>
            <p style="color:#6ec897;font-size:0.7rem;letter-spacing:0.1em;margin-bottom:0.5rem;">✓ ほぼ正解</p>
            <div style="display:flex;flex-wrap:wrap;gap:0.3rem;">
              {mindsetData.trapWords["ほぼ正解のキーワード"].map(w => (
                <span style="background:rgba(110,200,151,0.06);border:1px solid rgba(110,200,151,0.25);color:#6ec897;padding:0.2rem 0.5rem;font-size:0.7rem;">「{w}」</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* マッピング タブ */}
    <div id="tab-mapping" class="tab-pane" style="display:none;">
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-bottom:1rem;font-size:0.85rem;color:rgba(237,237,232,0.85);line-height:1.8;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:0.75rem;">RELATION</p>
        {pmbok7Data.relationToMindset.description}
      </div>

      <table style="width:100%;border-collapse:collapse;font-size:0.82rem;background:#111114;border:1px solid rgba(255,255,255,0.07);">
        <thead>
          <tr>
            <th style="text-align:left;color:#c8a96e;border-bottom:1px solid rgba(200,169,110,0.3);padding:0.7rem 1rem;letter-spacing:0.05em;">PMP Mindset 8原則</th>
            <th style="text-align:left;color:#6ec897;border-bottom:1px solid rgba(110,200,151,0.3);padding:0.7rem 1rem;letter-spacing:0.05em;">対応する PMBOK 7 公式12原則</th>
          </tr>
        </thead>
        <tbody>
          {pmbok7Data.relationToMindset.mappingTable.map((m: any) => (
            <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
              <td style="padding:0.7rem 1rem;color:rgba(237,237,232,0.85);">{m.mindset}</td>
              <td style="padding:0.7rem 1rem;">
                <div style="display:flex;flex-wrap:wrap;gap:0.3rem;">
                  {m.pmbok7.map((id: string) => {
                    const p = pmbok7Data.principles.find(pp => pp.id === id);
                    return p ? (
                      <span style="background:rgba(110,200,151,0.08);border:1px solid rgba(110,200,151,0.25);color:#6ec897;padding:0.15rem 0.5rem;font-size:0.7rem;">{p.labelJa}</span>
                    ) : null;
                  })}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

  </div>

  <script>
    const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const panes = document.querySelectorAll<HTMLElement>('.tab-pane');
    tabs.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab!;
        tabs.forEach(b => {
          b.style.borderBottomColor = 'transparent';
          b.style.color = 'rgba(237,237,232,0.5)';
        });
        btn.style.borderBottomColor = '#c8a96e';
        btn.style.color = '#c8a96e';
        panes.forEach(p => {
          p.style.display = p.id === `tab-${target}` ? '' : 'none';
        });
      });
    });
    localStorage.setItem('pmp-mindset-viewed', new Date().toISOString());
  </script>

</BaseLayout>
