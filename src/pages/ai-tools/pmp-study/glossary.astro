---
import '../../../styles/pmp-mobile.css';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import glossaryData from '../../../data/pmp/glossary.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const terms = glossaryData.terms;
const categories = glossaryData.categories;
---

<BaseLayout
  title="PMP用語集 (120語) - PMP学習アプリ"
  description="PMP試験頻出120用語の解説。カテゴリ別・章別に整理。EVM・リスク・スケジュール・品質・調達・アジャイル・リーダーシップ等を網羅。"
>
  <div style="background:#0a0a0c;border-bottom:1px solid rgba(255,255,255,0.07);padding:0.7rem 1rem;">
    <div style="max-width:1000px;margin:0 auto;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
      <a href={`${base}/ai-tools/pmp-study/`} style="color:rgba(237,237,232,0.6);font-size:0.75rem;text-decoration:none;letter-spacing:0.05em;">← ダッシュボード</a>
      <h1 style="color:#edede8;font-size:0.95rem;font-weight:300;letter-spacing:0.15em;margin:0;flex:1;">PMP用語集 · {terms.length} 語</h1>
      <input id="search" type="search" placeholder="🔎 検索..." style="background:#0a0a0c;color:#edede8;border:1px solid rgba(255,255,255,0.15);padding:0.35rem 0.7rem;font-size:0.78rem;font-family:inherit;width:200px;" />
    </div>
  </div>

  <div style="max-width:1000px;margin:0 auto;padding:1.25rem 1rem 4rem;">

    {/* カテゴリフィルタ */}
    <div style="background:#0a0a0c;border:1px solid rgba(200,169,110,0.1);padding:0.7rem 1rem;display:flex;flex-wrap:wrap;gap:0.4rem;align-items:center;margin-bottom:1rem;">
      <span style="color:rgba(200,169,110,0.7);font-size:0.62rem;letter-spacing:0.2em;">CATEGORY</span>
      <button class="cat-btn active" data-cat="all" style="background:rgba(200,169,110,0.15);border:1px solid #c8a96e;color:#c8a96e;padding:0.25rem 0.7rem;font-size:0.7rem;cursor:pointer;font-family:inherit;">全て</button>
      {categories.map(c => (
        <button class="cat-btn" data-cat={c} style="background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(237,237,232,0.7);padding:0.25rem 0.7rem;font-size:0.7rem;cursor:pointer;font-family:inherit;">{c}</button>
      ))}
    </div>

    <div id="glossary-list" style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:0.5rem 0;">
      {terms.map((t, i) => (
        <div class="glo-item" data-cat={t.category} data-search={`${t.term} ${t.termJa} ${t.definition}`.toLowerCase()} style="padding:0.85rem 1.5rem;border-bottom:1px solid rgba(255,255,255,0.04);">
          <div style="display:flex;gap:0.6rem;flex-wrap:wrap;align-items:baseline;margin-bottom:0.35rem;">
            <span style="color:#c8a96e;font-weight:600;font-size:0.88rem;">{t.term}</span>
            <span style="color:rgba(237,237,232,0.7);font-size:0.8rem;">{t.termJa}</span>
            <span style="background:rgba(200,169,110,0.06);color:rgba(200,169,110,0.85);padding:0.1rem 0.4rem;font-size:0.6rem;letter-spacing:0.05em;">{t.category}</span>
          </div>
          <p style="color:rgba(237,237,232,0.85);font-size:0.8rem;line-height:1.7;margin-bottom:0.35rem;">{t.definition}</p>
          {t.relatedChapter && (
            <a href={`${base}/ai-tools/pmp-study/study/${t.relatedChapter}`} style="color:rgba(110,200,151,0.85);font-size:0.7rem;text-decoration:none;border-bottom:1px solid rgba(110,200,151,0.25);">関連章 {t.relatedChapter} →</a>
          )}
        </div>
      ))}
    </div>

    <p id="empty" style="display:none;color:rgba(237,237,232,0.5);text-align:center;padding:2rem;font-size:0.85rem;">該当する用語がありません。</p>
  </div>

  <script>
    let activeCat = 'all';
    let searchTerm = '';

    function apply() {
      const items = document.querySelectorAll<HTMLElement>('.glo-item');
      let visible = 0;
      items.forEach(it => {
        const cat = it.dataset.cat!;
        const sd = it.dataset.search!;
        const catMatch = activeCat === 'all' || cat === activeCat;
        const searchMatch = !searchTerm || sd.includes(searchTerm);
        const show = catMatch && searchMatch;
        it.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      const empty = document.getElementById('empty');
      if (empty) empty.style.display = visible === 0 ? 'block' : 'none';

      // mark viewed
      localStorage.setItem('pmp-glossary-viewed', new Date().toISOString());
    }

    document.querySelectorAll<HTMLButtonElement>('.cat-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll<HTMLButtonElement>('.cat-btn').forEach(b => {
          b.style.background = 'transparent';
          b.style.borderColor = 'rgba(255,255,255,0.15)';
          b.style.color = 'rgba(237,237,232,0.7)';
        });
        btn.style.background = 'rgba(200,169,110,0.15)';
        btn.style.borderColor = '#c8a96e';
        btn.style.color = '#c8a96e';
        activeCat = btn.dataset.cat!;
        apply();
      });
    });

    const searchEl = document.getElementById('search') as HTMLInputElement | null;
    searchEl?.addEventListener('input', () => {
      searchTerm = searchEl.value.toLowerCase().trim();
      apply();
    });

    // mark viewed on page load
    localStorage.setItem('pmp-glossary-viewed', new Date().toISOString());
  </script>

</BaseLayout>
