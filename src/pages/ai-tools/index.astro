---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tools = [
  {
    name: '生産スケジュール最適化',
    icon: '📅',
    desc: '遺伝的アルゴリズムにより製造ラインの生産順序を最適化。段取り時間・納期・設備稼働率を同時考慮します。',
    href: `${base}/ai-tools/production-schedule/`,
    tag: '遺伝的アルゴリズム'
  },
  {
    name: '工程ボトルネック分析',
    icon: '🔍',
    desc: "Little's Lawに基づく工程ボトルネック特定。WIP・サイクルタイム・スループットの関係を可視化します。",
    href: `${base}/ai-tools/bottleneck/`,
    tag: "Little's Law"
  },
  {
    name: '需要予測',
    icon: '📈',
    desc: 'Holt-Winters 指数平滑法により季節性・トレンドを考慮した需要予測を実施。将来12ヶ月の予測値を算出します。',
    href: `${base}/ai-tools/demand-forecast/`,
    tag: 'Holt-Winters'
  },
  {
    name: '異常検知デモ',
    icon: '🚨',
    desc: 'TensorFlow.js Autoencoderにより製造データの異常パターンをリアルタイム検知。正常範囲からの逸脱を可視化します。',
    href: `${base}/ai-tools/anomaly-detection/`,
    tag: 'TensorFlow.js'
  },
  {
    name: '品質予測',
    icon: '⭐',
    desc: 'TensorFlow.js Dense Neural Networkがプロセスパラメータ（温度・圧力・速度・湿度）から品質スコアを予測します。',
    href: `${base}/ai-tools/quality-prediction/`,
    tag: 'TensorFlow.js'
  },
  {
    name: 'SPC管理図',
    icon: '📊',
    desc: 'X̄-R / X-MR管理図を自動生成。Western Electricルールで管理外れを検出。Cp/Cpk算出も対応。',
    href: `${base}/ai-tools/spc-chart/`,
    tag: 'SPC · 統計的工程管理'
  }
];

const etoTools = [
  {
    name: 'ETO類似案件見積り',
    icon: '🎯',
    desc: '過去案件マスタから k-NN コサイン類似度で類似Top3を抽出し、加重平均で工数・コスト・LTを予測。産業機械/プラント/特装車両プリセット内蔵。',
    href: `${base}/ai-tools/eto-similar-quote/`,
    tag: 'k-NN · 類似度検索',
    when: '営業・受注前の概算見積'
  },
  {
    name: 'プロジェクト納期リスク・モンテカルロ',
    icon: '🎲',
    desc: 'WBS+3点見積りから1万回モンテカルロでP50/P80/P95納期を算出。クリティカル度ランキングでバッファ配置・重点監視タスクを判断。',
    href: `${base}/ai-tools/project-monte-carlo/`,
    tag: 'Monte Carlo · CPM',
    when: 'PM・受注後の納期コミット'
  },
  {
    name: 'ETO Job Shopスケジューラ',
    icon: '🛠',
    desc: 'ジョブ毎に異なる工程経路にディスパッチングルール(EDD/SPT/CR)を適用してスケジューリング。ガントチャート・機械稼働率・3ルール比較。',
    href: `${base}/ai-tools/eto-job-shop/`,
    tag: 'Job Shop · Dispatching',
    when: '生管・受注後の生産計画'
  }
];

const faqs = [
  {
    q: '実際の工場データを入力しても大丈夫ですか？',
    a: 'はい。データはブラウザ外に出ません。TensorFlow.jsや遺伝的アルゴリズムなどすべての計算はあなたのデバイス上で実行されます。ページを閉じると入力データは消去されます。'
  },
  {
    q: 'TensorFlow.jsとは何ですか？',
    a: 'GoogleのオープンソースMLライブラリTensorFlowをブラウザ対応にしたものです。ニューラルネットワークのモデル学習・推論がサーバーなしでローカル完結します。WebGL（GPU）またはCPUで動作します。'
  },
  {
    q: '精度はどの程度ですか？',
    a: 'これらのツールはデモ・方向性確認・概算算出を目的として設計しています。サンプルデータや簡易モデルを使用しているため、実際の生産ラインへの本番導入前には専門家レビューと本格的なデータ検証を推奨します。'
  },
  {
    q: '動作環境は？',
    a: 'モダンブラウザ (Chrome/Edge/Firefox/Safari 最新版)。スマートフォンでも動作しますが、TensorFlow.js 系（異常検知・品質予測）はPC/タブレット推奨です。'
  },
  {
    q: 'ツール間でデータは共有されますか？',
    a: 'いいえ。各ツールはページ単位で独立しており、別ツールに移動するとデータはクリアされます。LocalStorageも使用していません。'
  },
  {
    q: 'ETO（一品一様製造）でも使えますか？',
    a: 'はい。ETO製造業向け専用ツールを3本用意しています：①類似案件見積り(コサイン類似度+k-NN)、②納期モンテカルロ(P50/P80/P95算出)、③Job Shopスケジューラ(EDD/SPT/CR比較)。量産用ツール(需要予測・SPC等)はETOには適さないため、ETO向けセクションのツールをご利用ください。産業機械・プラント設備・特装車両プリセット内蔵。'
  },
  {
    q: 'データが少ない（過去案件 10件程度）でもAIは効きますか？',
    a: '効きます。ETO類似案件見積り(k-NN)はデータ量より特徴量設計の質が重要で、10件程度でも実用的に動作します。一方、量産系のニューラルネットワーク(品質予測)は少なくとも50件以上のデータを推奨します。「データが少ないからAIは無理」と諦めず、まず現状データで類似度検索ツールから始めるのが推奨ルートです。'
  },
  {
    q: 'モンテカルロ・シミュレーションのP50/P80/P95はどう使い分けますか？',
    a: 'P50=社内目標日(中央値・努力目標)、P80=顧客コミット日(納期確約として最推奨)、P95=最終死守ライン(契約書・違約金条項用)。営業確約には P80 を使い、P80-P50 差分を「不確実性バッファ」としてプロジェクト末尾(チェイン末尾)に集中配置するのがCCPM運用の基本です。'
  }
];
---

<BaseLayout
  title="AI Tools — 機密保護型製造DX分析"
  description="TensorFlow.js・遺伝的アルゴリズム・統計モデルをブラウザ内で完結。工場データを外部送信ゼロで品質予測・ボトルネック分析・需要予測・異常検知を実施します。"
>

  <!-- 機密保護説明セクション -->
  <div style="background:#060e06;border-bottom:1px solid rgba(100,200,100,0.2);padding:2.5rem 1.5rem;">
    <div style="max-width:900px;margin:0 auto;text-align:center;">
      <div style="font-size:2rem;margin-bottom:1rem;">🔒</div>
      <h2 style="color:#6ec86e;font-size:1.1rem;font-weight:400;letter-spacing:0.15em;margin-bottom:1.5rem;">すべてのデータはあなたのブラウザ内でのみ処理されます</h2>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;margin-bottom:1.75rem;text-align:left;">
        <div style="background:rgba(100,200,100,0.06);border:1px solid rgba(100,200,100,0.15);padding:1rem 1.25rem;">
          <p style="color:#6ec86e;font-size:0.65rem;letter-spacing:0.25em;margin-bottom:0.4rem;">外部サーバーへのデータ送信</p>
          <p style="color:#edede8;font-size:1.25rem;font-weight:300;">ゼロ</p>
        </div>
        <div style="background:rgba(100,200,100,0.06);border:1px solid rgba(100,200,100,0.15);padding:1rem 1.25rem;">
          <p style="color:#6ec86e;font-size:0.65rem;letter-spacing:0.25em;margin-bottom:0.4rem;">機密データの漏洩リスク</p>
          <p style="color:#edede8;font-size:1.25rem;font-weight:300;">ゼロ</p>
        </div>
        <div style="background:rgba(100,200,100,0.06);border:1px solid rgba(100,200,100,0.15);padding:1rem 1.25rem;">
          <p style="color:#6ec86e;font-size:0.65rem;letter-spacing:0.25em;margin-bottom:0.4rem;">インターネット接続が必要なもの</p>
          <p style="color:#edede8;font-size:0.9rem;font-weight:300;">ライブラリの読み込みのみ</p>
        </div>
      </div>

      <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.75rem;text-align:left;max-width:680px;margin:0 auto;">
        <p style="color:rgba(255,255,255,0.45);font-size:0.65rem;letter-spacing:0.25em;margin-bottom:0.75rem;">技術的根拠</p>
        <p style="color:rgba(255,255,255,0.65);font-size:0.82rem;line-height:1.7;">
          <strong style="color:#edede8;">TensorFlow.js</strong> / <strong style="color:#edede8;">遺伝的アルゴリズム</strong> / <strong style="color:#edede8;">統計モデル</strong> を
          すべてブラウザ内 JavaScript で実行しています。<br>
          モデルの学習・推論・データ処理はあなたのデバイスのCPU/GPUで完結します。
        </p>
      </div>
    </div>
  </div>

  <!-- ヒーロー -->
  <div style="position:relative;height:16rem;overflow:hidden;display:flex;align-items:center;justify-content:center;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#0c0c0e 0%,#0d1020 60%,#0c0c0e 100%);"></div>
    <div style="position:absolute;inset:0;opacity:0.04;background-image:repeating-linear-gradient(0deg,transparent,transparent 40px,rgba(200,169,110,0.5) 40px,rgba(200,169,110,0.5) 41px),repeating-linear-gradient(90deg,transparent,transparent 40px,rgba(200,169,110,0.5) 40px,rgba(200,169,110,0.5) 41px);"></div>
    <div style="position:relative;z-index:1;text-align:center;padding:0 1.5rem;">
      <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;margin-bottom:1rem;text-transform:uppercase;">AI Tools Hub</p>
      <h1 style="font-size:clamp(1.75rem,5vw,2.75rem);font-weight:200;letter-spacing:0.15em;color:#edede8;margin-bottom:1rem;">AI Tools</h1>
      <p style="color:#edede8;font-size:1rem;font-weight:300;margin-bottom:0.4rem;">製造現場のAI活用、今日から始める</p>
      <p style="color:rgba(255,255,255,0.55);font-size:0.78rem;font-weight:300;">全6ツール・完全無料・データ社外送信ゼロ・登録不要</p>
    </div>
  </div>

  <!-- こんな方に -->
  <div style="background:#0a0a0c;border-bottom:1px solid rgba(200,169,110,0.1);padding:1.75rem 1.5rem;">
    <div style="max-width:1100px;margin:0 auto;">
      <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.3em;margin-bottom:1rem;text-align:center;">FOR PRODUCTION ENGINEERS</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:0.85rem;">
        <div style="background:#111114;border:1px solid rgba(200,169,110,0.15);border-left:3px solid #c8a96e;padding:0.95rem 1.15rem;">
          <div style="font-size:1.4rem;margin-bottom:0.35rem;">🏭</div>
          <div style="color:#edede8;font-size:0.85rem;font-weight:500;margin-bottom:0.25rem;">工場・ライン管理者</div>
          <div style="color:rgba(237,237,232,0.55);font-size:0.72rem;line-height:1.5;">生産計画・稼働率改善・納期管理</div>
        </div>
        <div style="background:#111114;border:1px solid rgba(200,169,110,0.15);border-left:3px solid #c8a96e;padding:0.95rem 1.15rem;">
          <div style="font-size:1.4rem;margin-bottom:0.35rem;">📊</div>
          <div style="color:#edede8;font-size:0.85rem;font-weight:500;margin-bottom:0.25rem;">生産技術・品質保証</div>
          <div style="color:rgba(237,237,232,0.55);font-size:0.72rem;line-height:1.5;">不良予測・SPC・工程能力評価</div>
        </div>
        <div style="background:#111114;border:1px solid rgba(200,169,110,0.15);border-left:3px solid #c8a96e;padding:0.95rem 1.15rem;">
          <div style="font-size:1.4rem;margin-bottom:0.35rem;">🔧</div>
          <div style="color:#edede8;font-size:0.85rem;font-weight:500;margin-bottom:0.25rem;">設備保全・カイゼン推進</div>
          <div style="color:rgba(237,237,232,0.55);font-size:0.72rem;line-height:1.5;">予知保全・異常検知・改善優先順位</div>
        </div>
      </div>
    </div>
  </div>

  <!-- 業界別ロードマップ -->
  <div style="background:#0c0c0e;padding:2rem 1.5rem;border-bottom:1px solid rgba(255,255,255,0.05);">
    <div style="max-width:1100px;margin:0 auto;">
      <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.3em;margin-bottom:0.5rem;text-align:center;">INDUSTRY ROADMAP — 業界別おすすめスタート</p>
      <p style="color:rgba(237,237,232,0.5);font-size:0.75rem;margin-bottom:1.25rem;text-align:center;">あなたの業界で、最初に試すべき3ツール</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;">
        <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.15rem 1.35rem;">
          <div style="color:#edede8;font-size:0.92rem;font-weight:500;margin-bottom:0.55rem;">🚗 自動車部品</div>
          <ol style="margin:0;padding-left:1.2rem;color:rgba(237,237,232,0.7);font-size:0.78rem;line-height:1.85;">
            <li>SPC管理図 (Cpk/IATF対応)</li>
            <li>工程ボトルネック分析</li>
            <li>異常検知 (予知保全)</li>
          </ol>
        </div>
        <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.15rem 1.35rem;">
          <div style="color:#edede8;font-size:0.92rem;font-weight:500;margin-bottom:0.55rem;">⚙ 電子機器</div>
          <ol style="margin:0;padding-left:1.2rem;color:rgba(237,237,232,0.7);font-size:0.78rem;line-height:1.85;">
            <li>品質予測 (DoE補助)</li>
            <li>生産スケジュール最適化</li>
            <li>異常検知 (SMT工程)</li>
          </ol>
        </div>
        <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.15rem 1.35rem;">
          <div style="color:#edede8;font-size:0.92rem;font-weight:500;margin-bottom:0.55rem;">🥫 食品工場</div>
          <ol style="margin:0;padding-left:1.2rem;color:rgba(237,237,232,0.7);font-size:0.78rem;line-height:1.85;">
            <li>需要予測 (季節性対応)</li>
            <li>SPC管理図 (HACCP補助)</li>
            <li>工程ボトルネック分析</li>
          </ol>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:1280px;margin:0 auto;padding:3rem 1.5rem 6rem;">

    <!-- クイックスタート -->
    <div style="background:#0a0a0c;border:1px solid rgba(200,169,110,0.15);padding:1.5rem 1.75rem;margin-bottom:2.5rem;">
      <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.3em;margin-bottom:1rem;">QUICK START / 使い方</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;">
        <div>
          <p style="color:#c8a96e;font-size:0.85rem;font-weight:500;margin-bottom:0.4rem;">① ツールを開く</p>
          <p style="color:rgba(255,255,255,0.55);font-size:0.78rem;line-height:1.6;">下から興味あるツールをクリック</p>
        </div>
        <div>
          <p style="color:#c8a96e;font-size:0.85rem;font-weight:500;margin-bottom:0.4rem;">② サンプル試行</p>
          <p style="color:rgba(255,255,255,0.55);font-size:0.78rem;line-height:1.6;">「サンプルデータを読み込む」で即体験</p>
        </div>
        <div>
          <p style="color:#c8a96e;font-size:0.85rem;font-weight:500;margin-bottom:0.4rem;">③ 自データ投入</p>
          <p style="color:rgba(255,255,255,0.55);font-size:0.78rem;line-height:1.6;">CSVアップロードで実データ分析</p>
        </div>
        <div>
          <p style="color:#c8a96e;font-size:0.85rem;font-weight:500;margin-bottom:0.4rem;">④ 結果保存</p>
          <p style="color:rgba(255,255,255,0.55);font-size:0.78rem;line-height:1.6;">「結果をCSVでダウンロード」</p>
        </div>
      </div>
    </div>

    <!-- 量産・繰り返し製造 セクションラベル -->
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;">
      <span style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;white-space:nowrap;">▸ 量産・繰り返し製造</span>
      <span style="flex:1;height:1px;background:rgba(255,255,255,0.07);"></span>
      <span style="color:rgba(255,255,255,0.4);font-size:0.7rem;">{tools.length} ツール</span>
    </div>

    <!-- 量産系ツールカードグリッド -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.25rem;margin-bottom:3.5rem;">
      {tools.map(t => (
        <a href={t.href} class="tool-card">
          <div style="display:flex;align-items:flex-start;gap:0.9rem;margin-bottom:1rem;">
            <div style="font-size:2rem;line-height:1;">{t.icon}</div>
            <div style="flex:1;">
              <p style="color:#6ec86e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.3rem;">{t.tag}</p>
              <h3 style="color:#edede8;font-size:1rem;font-weight:400;letter-spacing:0.04em;">{t.name}</h3>
            </div>
          </div>
          <p style="color:rgba(255,255,255,0.55);font-size:0.82rem;line-height:1.6;">{t.desc}</p>
          <div style="margin-top:1.25rem;color:#c8a96e;font-size:0.72rem;letter-spacing:0.25em;">
            使ってみる →
          </div>
        </a>
      ))}
    </div>

    <!-- ETO・一品一様製造 セクションラベル -->
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;">
      <span style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;white-space:nowrap;">▸ ETO・一品一様製造</span>
      <span style="flex:1;height:1px;background:rgba(255,255,255,0.07);"></span>
      <span style="color:rgba(255,255,255,0.4);font-size:0.7rem;">{etoTools.length} ツール</span>
    </div>
    <p style="color:rgba(255,255,255,0.55);font-size:0.82rem;line-height:1.7;margin-bottom:1.5rem;max-width:780px;">
      産業機械・プラント設備・特装車両など <strong style="color:#edede8;">受注設計生産</strong> 向け。過去案件の類似度ベース見積り・モンテカルロでの納期確度算出・Job Shop スケジューリングで、見積精度・納期確度・生産効率を実務レベルで改善します。
    </p>

    <!-- ETOツールカードグリッド -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.25rem;margin-bottom:4rem;">
      {etoTools.map(t => (
        <a href={t.href} class="tool-card eto-card">
          <div style="position:absolute;top:0.85rem;right:0.85rem;background:rgba(200,169,110,0.15);border:1px solid rgba(200,169,110,0.35);color:#c8a96e;font-size:0.58rem;letter-spacing:0.2em;padding:0.18rem 0.55rem;border-radius:2px;">ETO</div>
          <div style="display:flex;align-items:flex-start;gap:0.9rem;margin-bottom:1rem;">
            <div style="font-size:2rem;line-height:1;">{t.icon}</div>
            <div style="flex:1;">
              <p style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.3rem;">{t.tag}</p>
              <h3 style="color:#edede8;font-size:1rem;font-weight:400;letter-spacing:0.04em;">{t.name}</h3>
            </div>
          </div>
          <p style="color:rgba(255,255,255,0.55);font-size:0.82rem;line-height:1.6;">{t.desc}</p>
          <div style="margin-top:1rem;padding-top:0.85rem;border-top:1px solid rgba(255,255,255,0.07);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:rgba(110,200,151,0.85);font-size:0.6rem;letter-spacing:0.2em;">USE</span>
            <span style="color:rgba(237,237,232,0.7);font-size:0.74rem;">{t.when}</span>
          </div>
          <div style="margin-top:0.75rem;color:#c8a96e;font-size:0.72rem;letter-spacing:0.25em;">
            使ってみる →
          </div>
        </a>
      ))}
    </div>

    <!-- FAQ -->
    <div style="border-top:1px solid rgba(255,255,255,0.07);padding-top:3rem;">
      <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:2rem;text-align:center;">FAQ</p>
      <div style="max-width:800px;margin:0 auto;display:flex;flex-direction:column;gap:1rem;">
        {faqs.map((item, i) => (
          <div class="faq-item">
            <button class="faq-q" data-idx={i}>
              <span style="color:#c8a96e;margin-right:0.75rem;font-size:0.9rem;">Q</span>
              {item.q}
              <span class="faq-arrow" style="margin-left:auto;color:rgba(255,255,255,0.35);transition:transform 0.2s;">▼</span>
            </button>
            <div class="faq-a" style="display:none;">
              <div style="padding:1rem 1.25rem;color:rgba(255,255,255,0.65);font-size:0.82rem;line-height:1.7;border-top:1px solid rgba(255,255,255,0.07);">
                <span style="color:#6ec86e;margin-right:0.5rem;font-size:0.9rem;">A</span>
                {item.a}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>

  <style>
    .tool-card {
      display: block;
      background: #111114;
      border: 1px solid rgba(255,255,255,0.07);
      padding: 1.5rem;
      text-decoration: none;
      transition: all 0.2s;
      position: relative;
      overflow: hidden;
    }
    .tool-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(100,200,100,0.05), transparent 60%);
      opacity: 0;
      transition: opacity 0.2s;
      pointer-events: none;
    }
    .tool-card:hover {
      border-color: rgba(100,200,100,0.35);
      transform: translateY(-2px);
    }
    .tool-card:hover::before { opacity: 1; }
    .faq-item {
      background: #111114;
      border: 1px solid rgba(255,255,255,0.07);
      overflow: hidden;
    }
    .faq-q {
      width: 100%;
      display: flex;
      align-items: center;
      padding: 1rem 1.25rem;
      background: none;
      border: none;
      color: #edede8;
      font-size: 0.85rem;
      font-family: inherit;
      letter-spacing: 0.03em;
      cursor: pointer;
      text-align: left;
      gap: 0;
      transition: color 0.15s;
    }
    .faq-q:hover { color: #c8a96e; }
    .faq-q.open .faq-arrow { transform: rotate(180deg); }
  </style>

  <script is:inline>
    document.querySelectorAll('.faq-q').forEach(btn => {
      btn.addEventListener('click', () => {
        const parent = btn.closest('.faq-item');
        const ans = parent.querySelector('.faq-a');
        const isOpen = ans.style.display !== 'none';
        ans.style.display = isOpen ? 'none' : 'block';
        btn.classList.toggle('open', !isOpen);
      });
    });
  </script>

</BaseLayout>
