---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="仕様書リスク候補抽出" description="ETO（一品一様製造）向け、社内Excel仕様書からリスク候補をブラウザ完結で抽出。BM25+リスク辞書のハイブリッド検索・人レビュー学習・別Excel出力。データ社外送信ゼロ。産業機械/プラント設備/特装車両プリセット内蔵。">

  <!-- 機密保護バナー -->
  <div style="background:rgba(200,169,110,0.08);border-left:3px solid #c8a96e;padding:0.85rem 1.25rem;font-size:0.78rem;color:#edede8;letter-spacing:0.03em;display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;justify-content:space-between;">
    <div>🔒 <strong>機密保護: 全処理ブラウザ完結</strong> — 社内Excel・仕様文・レビュー結果は外部送信されません</div>
    <button id="verify-privacy" style="background:transparent;border:1px solid rgba(200,169,110,0.3);color:#c8a96e;padding:0.3rem 0.75rem;font-size:0.7rem;cursor:pointer;font-family:inherit;letter-spacing:0.05em;">検証方法を見る ▼</button>
  </div>
  <div id="privacy-detail" style="display:none;background:#0a0a0c;border-left:3px solid #c8a96e;padding:1.25rem 1.75rem;font-size:0.78rem;color:rgba(237,237,232,0.75);line-height:1.7;">
    <p style="color:#c8a96e;font-size:0.7rem;letter-spacing:0.2em;margin-bottom:0.6rem;">VERIFY YOURSELF</p>
    <ol style="margin:0;padding-left:1.25rem;">
      <li>ブラウザの DevTools を開く（F12 / Ctrl+Shift+I）</li>
      <li><code style="background:#111114;padding:0.1em 0.4em;color:#c8a96e;">Network</code> タブを選択</li>
      <li>このページで Excel を読み込み・抽出を実行</li>
      <li>新規ネットワーク通信が <strong>発生しないこと</strong> を確認</li>
    </ol>
    <p style="margin-top:0.8rem;color:rgba(255,255,255,0.5);font-size:0.72rem;">通信は SheetJS CDN ライブラリの初回読込のみ。Excel・仕様文は完全ローカル処理です。</p>
  </div>

  <!-- ヒーロー -->
  <div style="position:relative;height:12rem;overflow:hidden;display:flex;align-items:center;justify-content:center;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#0c0c0e 0%,#0d1a12 60%,#0c0c0e 100%);"></div>
    <div style="position:relative;z-index:1;text-align:center;padding:0 1.5rem;">
      <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;margin-bottom:0.85rem;text-transform:uppercase;">BM25 · Risk Dictionary · Browser-Local</p>
      <h1 style="font-size:clamp(1.5rem,4vw,2.1rem);font-weight:200;letter-spacing:0.15em;color:#edede8;">仕様書リスク候補抽出</h1>
    </div>
  </div>

  <!-- USE CASES -->
  <div style="max-width:1100px;margin:0 auto;padding:1rem 1rem 0;">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:0.75rem;">
      <div style="background:#111114;border:1px solid rgba(200,169,110,0.15);border-left:3px solid #c8a96e;padding:0.85rem 1.1rem;">
        <div style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.4rem;">USE CASE 1</div>
        <div style="color:#edede8;font-size:0.82rem;font-weight:500;margin-bottom:0.3rem;">受注前の見積もりリスク洗い出し</div>
        <div style="color:rgba(237,237,232,0.55);font-size:0.72rem;line-height:1.5;">RFQ要求仕様書から見積もり工数を狂わせる危険語を抽出</div>
      </div>
      <div style="background:#111114;border:1px solid rgba(200,169,110,0.15);border-left:3px solid #c8a96e;padding:0.85rem 1.1rem;">
        <div style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.4rem;">USE CASE 2</div>
        <div style="color:#edede8;font-size:0.82rem;font-weight:500;margin-bottom:0.3rem;">仕様書レビュー会議の事前準備</div>
        <div style="color:rgba(237,237,232,0.55);font-size:0.72rem;line-height:1.5;">過去類似要求と過去ハマりポイントを横断検索して論点抽出</div>
      </div>
      <div style="background:#111114;border:1px solid rgba(200,169,110,0.15);border-left:3px solid #c8a96e;padding:0.85rem 1.1rem;">
        <div style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.4rem;">USE CASE 3</div>
        <div style="color:#edede8;font-size:0.82rem;font-weight:500;margin-bottom:0.3rem;">設計変更影響の早期察知</div>
        <div style="color:rgba(237,237,232,0.55);font-size:0.72rem;line-height:1.5;">変更要求の中の「特殊」「初」「未」を一気に検出</div>
      </div>
    </div>

    <!-- 5秒クイックスタート -->
    <div style="margin-top:1rem;background:linear-gradient(90deg,rgba(110,200,151,0.06) 0%,transparent 100%);border-left:3px solid #6ec897;padding:0.85rem 1.1rem;display:flex;flex-wrap:wrap;gap:1.25rem;align-items:center;">
      <div style="color:#6ec897;font-size:0.6rem;letter-spacing:0.3em;white-space:nowrap;">⚡ 5秒で試す</div>
      <div style="display:flex;gap:0.5rem;align-items:center;font-size:0.78rem;color:rgba(237,237,232,0.85);flex-wrap:wrap;">
        <span style="color:#c8a96e;font-weight:600;">①</span> 業界プリセット選択
        <span style="color:rgba(255,255,255,0.3);">→</span>
        <span style="color:#c8a96e;font-weight:600;">②</span> サンプル仕様書をロード or Excelアップロード
        <span style="color:rgba(255,255,255,0.3);">→</span>
        <span style="color:#c8a96e;font-weight:600;">③</span> 「リスク抽出 ▶」をクリック
      </div>
    </div>
  </div>

  <div style="max-width:1100px;margin:0 auto;padding:1.5rem 1rem 4rem;">

    <!-- 業界プリセット -->
    <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:0.85rem 1.1rem;display:flex;flex-wrap:wrap;gap:0.65rem;align-items:center;margin-bottom:1rem;">
      <span style="color:rgba(255,255,255,0.4);font-size:0.65rem;letter-spacing:0.2em;">PRESET</span>
      <button class="preset-btn" data-preset="industrial" style="background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(237,237,232,0.7);padding:0.3rem 0.85rem;font-size:0.72rem;cursor:pointer;font-family:inherit;">🏭 産業機械</button>
      <button class="preset-btn" data-preset="plant" style="background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(237,237,232,0.7);padding:0.3rem 0.85rem;font-size:0.72rem;cursor:pointer;font-family:inherit;">⚗ プラント設備</button>
      <button class="preset-btn" data-preset="vehicle" style="background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(237,237,232,0.7);padding:0.3rem 0.85rem;font-size:0.72rem;cursor:pointer;font-family:inherit;">🚒 特装車両</button>
      <span style="color:rgba(255,255,255,0.3);font-size:0.7rem;flex:1;">業界別リスク辞書 + サンプル仕様書を一括ロード</span>
    </div>

    <!-- ステップ1: 入力 -->
    <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-bottom:1rem;">
      <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">STEP 1 — 仕様書読込</p>
      <div style="display:flex;flex-wrap:wrap;gap:0.85rem;align-items:center;margin-bottom:0.85rem;">
        <button id="btn-load-sample" class="m-btn-ghost">📄 サンプル仕様書をロード</button>
        <label class="m-btn-ghost" style="cursor:pointer;">
          📂 Excel(.xlsx/.xls) をアップロード
          <input id="excel-upload" type="file" accept=".xlsx,.xls" style="display:none;">
        </label>
        <button id="btn-template" class="m-btn-ghost" style="font-size:0.7rem;">⬇ Excelテンプレート</button>
        <span style="color:rgba(255,255,255,0.3);font-size:0.7rem;flex:1;">入力原本は上書きされません。結果は別Excelで出力します。</span>
      </div>
      <div id="file-progress" style="display:none;margin-top:0.5rem;">
        <div style="color:rgba(255,255,255,0.5);font-size:0.7rem;margin-bottom:0.3rem;">Excel解析中...</div>
        <div style="width:100%;background:#1a1a1d;border-radius:9999px;height:6px;">
          <div id="file-progress-bar" style="background:#c8a96e;height:6px;border-radius:9999px;transition:width 0.1s;width:0%;"></div>
        </div>
      </div>
      <div id="file-info" style="display:none;color:rgba(237,237,232,0.7);font-size:0.78rem;padding:0.65rem 0.85rem;background:#0a0a0c;border:1px solid rgba(200,169,110,0.15);"></div>
    </div>

    <!-- ステップ2: シート選択・列マッピング -->
    <div id="mapping-section" style="display:none;background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-bottom:1rem;">
      <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;margin-bottom:1rem;">STEP 2 — シート選択 & 列マッピング</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:0.85rem;margin-bottom:0.85rem;">
        <div>
          <label class="field-label">シート</label>
          <select id="sheet-select" class="field-input"></select>
        </div>
        <div>
          <label class="field-label">要求仕様文の列<span style="color:#c8a96e;">*</span></label>
          <select id="col-spec" class="field-input"></select>
          <div style="color:rgba(255,255,255,0.3);font-size:0.66rem;margin-top:0.25rem;">仕様/要求/Requirement系の列名を自動推定</div>
        </div>
        <div>
          <label class="field-label">章番号 列（任意）</label>
          <select id="col-chapter" class="field-input"></select>
        </div>
        <div>
          <label class="field-label">仕様種別 列（任意）</label>
          <select id="col-type" class="field-input"></select>
        </div>
        <div>
          <label class="field-label">所掌 列（任意）</label>
          <select id="col-owner" class="field-input"></select>
        </div>
      </div>
      <div id="preview-area" style="margin-top:0.85rem;"></div>
    </div>

    <!-- ステップ3: 実行 -->
    <div id="execute-section" style="display:none;display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;">
      <button id="btn-extract" class="m-btn">リスク抽出 ▶</button>
      <span style="color:rgba(255,255,255,0.35);font-size:0.72rem;">Ctrl+Enter で実行</span>
      <button id="btn-reset" class="m-btn-ghost">リセット</button>
    </div>

    <!-- 結果エリア -->
    <div id="result-area" style="display:none;">

      <!-- 統計サマリ -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:0.75rem;margin-bottom:1.25rem;">
        <div class="metric-card">
          <div class="metric-label">入力要求数</div>
          <div class="metric-value" id="m-total">-</div>
        </div>
        <div class="metric-card highlight">
          <div class="metric-label">⚠ 重大リスク</div>
          <div class="metric-value gold" id="m-high">-</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">注意</div>
          <div class="metric-value" id="m-mid">-</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">参考</div>
          <div class="metric-value" id="m-low">-</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">処理時間</div>
          <div class="metric-value" id="m-time">-</div>
        </div>
      </div>

      <!-- リスク候補テーブル -->
      <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-bottom:1rem;overflow-x:auto;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:0.5rem;">
          <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;">RISK CANDIDATES</p>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
            <select id="filter-level" class="field-input" style="width:auto;font-size:0.74rem;padding:0.3rem 0.6rem;">
              <option value="all">全件</option>
              <option value="high">⚠ 重大のみ</option>
              <option value="mid">注意以上</option>
            </select>
            <button id="btn-export" class="m-btn-ghost" style="font-size:0.72rem;">⬇ Excel出力</button>
          </div>
        </div>
        <table style="width:100%;border-collapse:collapse;font-size:0.78rem;">
          <thead>
            <tr>
              <th class="th" style="width:3em;">行</th>
              <th class="th">要求仕様文 / リスク候補</th>
              <th class="th" style="width:7em;">信頼度</th>
              <th class="th" style="width:9em;">レビュー</th>
            </tr>
          </thead>
          <tbody id="risk-tbody"></tbody>
        </table>
      </div>

      <!-- NEXT ACTIONS -->
      <div style="background:linear-gradient(135deg,rgba(200,169,110,0.05) 0%,rgba(110,200,151,0.05) 100%);border-left:3px solid #6ec897;padding:1.25rem 1.5rem;">
        <div style="color:#6ec897;font-size:0.62rem;letter-spacing:0.3em;margin-bottom:0.75rem;">✓ NEXT ACTIONS</div>
        <ol style="margin:0;padding-left:1.5rem;color:rgba(237,237,232,0.85);font-size:0.85rem;line-height:1.8;">
          <li>⚠ 重大リスクは仕様書レビュー会議の <strong>必須論点</strong> に上げる。RFQ確定前に顧客と握る</li>
          <li>レビュー結果を「採用/不採用/修正」で記録 → 次回以降の見積もり精度が累積で向上</li>
          <li>結果Excelの「処理内容」シートで、抽出根拠（一致辞書語・BM25スコア）を読み取り判断トレースを残す</li>
        </ol>
      </div>
    </div>

    <!-- 学習・モデル版管理パネル（レビュー1件以上で表示） -->
    <div id="learning-panel" style="display:none;background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.25rem 1.5rem;margin-top:1.5rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:0.5rem;">
        <p style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.35em;">▸ 学習・新旧モデル比較（第5〜第6段階）</p>
        <span style="color:rgba(255,255,255,0.4);font-size:0.7rem;">レビューが累積するほど精度が上がります</span>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:0.75rem;margin-bottom:1rem;">
        <div class="metric-card">
          <div class="metric-label">蓄積レビュー</div>
          <div class="metric-value" id="stat-reviews">0</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">✓ 採用</div>
          <div class="metric-value" id="stat-adopt" style="color:#6ec897;">0</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">✎ 修正採用</div>
          <div class="metric-value" id="stat-modify" style="color:#c8a96e;">0</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">✗ 不採用</div>
          <div class="metric-value" id="stat-reject" style="color:#ff8888;">0</div>
        </div>
        <div class="metric-card highlight">
          <div class="metric-label">重大候補の人手承認率</div>
          <div class="metric-value gold" id="stat-recall">0%</div>
          <div style="color:rgba(255,255,255,0.35);font-size:0.6rem;margin-top:0.2rem;">重大判定中で採用/修正された割合</div>
        </div>
      </div>
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;">
        <button id="btn-train" class="m-btn" style="font-size:0.74rem;padding:0.45rem 1.1rem;">🧠 学習実行 → 新モデル候補生成</button>
        <button id="btn-clear-reviews" class="m-btn-ghost" style="font-size:0.7rem;padding:0.4rem 0.95rem;">レビュー履歴クリア</button>
      </div>
      <div id="compare-result"></div>
    </div>

    <!-- 操作ログ -->
    <details style="margin-top:1.25rem;background:#0a0a0c;border:1px solid rgba(255,255,255,0.05);">
      <summary style="cursor:pointer;color:rgba(255,255,255,0.5);font-size:0.72rem;letter-spacing:0.2em;padding:0.65rem 0.95rem;outline:none;">▸ 操作ログ（直近30件）</summary>
      <pre id="op-log-body" style="margin:0;padding:0.6rem 0.95rem 0.95rem;font-size:0.7rem;line-height:1.55;color:rgba(255,255,255,0.5);font-family:'SF Mono','Consolas',monospace;white-space:pre-wrap;max-height:300px;overflow-y:auto;"></pre>
    </details>

    <!-- ETO 関連ツール + 関連事例 -->
    <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.07);">
      <div style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.3em;margin-bottom:1rem;">▸ 他のETOツールも併せて使う</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:0.85rem;margin-bottom:1.5rem;">
        <a href={`${base}/ai-tools/eto-similar-quote/`} style="display:block;background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1rem 1.1rem;text-decoration:none;">
          <div style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.4rem;">受注前 営業</div>
          <div style="color:#edede8;font-size:0.88rem;margin-bottom:0.3rem;">🎯 ETO類似案件見積り</div>
          <div style="color:rgba(255,255,255,0.5);font-size:0.72rem;line-height:1.5;">8特徴量から類似Top3抽出・工数/コスト/LT予測</div>
        </a>
        <a href={`${base}/ai-tools/project-monte-carlo/`} style="display:block;background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1rem 1.1rem;text-decoration:none;">
          <div style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.4rem;">受注後 PM</div>
          <div style="color:#edede8;font-size:0.88rem;margin-bottom:0.3rem;">🎲 プロジェクト納期モンテカルロ</div>
          <div style="color:rgba(255,255,255,0.5);font-size:0.72rem;line-height:1.5;">WBS+3点見積りからP50/P80/P95算出</div>
        </a>
        <a href={`${base}/ai-tools/eto-job-shop/`} style="display:block;background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1rem 1.1rem;text-decoration:none;">
          <div style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.25em;margin-bottom:0.4rem;">受注後 生管</div>
          <div style="color:#edede8;font-size:0.88rem;margin-bottom:0.3rem;">🛠 ETO Job Shopスケジューラ</div>
          <div style="color:rgba(255,255,255,0.5);font-size:0.72rem;line-height:1.5;">EDD/SPT/CR比較で工程経路の最適投入順</div>
        </a>
      </div>
      <a href={`${base}/cases/eto-ai-utilization/`} style="display:block;background:#0f0f12;border:1px solid rgba(110,200,151,0.2);padding:1rem 1.25rem;text-decoration:none;">
        <div style="color:#6ec897;font-size:0.62rem;letter-spacing:0.3em;margin-bottom:0.4rem;">📖 関連事例</div>
        <div style="color:#edede8;font-size:0.85rem;">一品一様製造（ETO）のAI活用 — 類似度見積り・モンテカルロ・Job Shop最適化の実務適用記録 →</div>
      </a>
    </div>

    <!-- アルゴリズム解説 -->
    <section style="max-width:880px;margin:3rem auto 0;padding:0;">
      <h2 style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:1.5rem;">このツールについて</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:0.85rem;">
        <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);padding:1.1rem 1.25rem;">
          <div style="color:#c8a96e;font-size:0.85rem;font-weight:500;margin-bottom:0.4rem;">🔍 BM25 検索</div>
          <p style="color:rgba(255,255,255,0.55);font-size:0.78rem;line-height:1.65;">Okapi BM25 アルゴリズム。TF-IDFを発展させた検索エンジン式の関連度計算。日本語はbigram(隣接2文字)+ASCII単語のハイブリッドトークナイザで処理。</p>
        </div>
