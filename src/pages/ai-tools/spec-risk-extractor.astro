        { '項目':'注意件数', '値': currentResults.filter(r => r.level==='mid').length },
        { '項目':'参考件数', '値': currentResults.filter(r => r.level==='low').length },
        { '項目':'検索アルゴリズム', '値': 'BM25 + リスク辞書ハイブリッド (MVP第1+第2段階)' },
        { '項目':'データ送信先', '値': 'なし（ブラウザ完結）' },
      ];
      const ws2 = XLSX.utils.json_to_sheet(procData);
      ws2['!cols'] = [{wch:25},{wch:60}];
      XLSX.utils.book_append_sheet(wb, ws2, '処理内容');

      // シート3: 列対応
      const colSpec = document.getElementById('col-spec').value;
      const colCh   = document.getElementById('col-chapter').value;
      const colTy   = document.getElementById('col-type').value;
