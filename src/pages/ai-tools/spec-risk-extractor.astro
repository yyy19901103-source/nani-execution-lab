    function getEffectiveDict(presetId) {
      const base = RISK_DICT[presetId];
      const ext = extendedDicts[presetId] || { high:[], mid:[], low:[] };
      return {
        name: base.name,
        high: [...base.high, ...(ext.high||[])],
        mid:  [...base.mid,  ...(ext.mid ||[])],
        low:  [...base.low,  ...(ext.low ||[])],
      };
    }

    // ===== 第5段階: レビュー保存（CODEX指摘 Major対応: upsert で重複蓄積を防ぐ） =====
    const reviewModified = {}; // idx -> 修正後仕様テキスト
    let lastReviewIdByCandidate = {}; // candidateKey -> 最後に書いたreviewのid

    function candidateKey(r) {
      // 安定論理キー: preset + rowNum + spec の簡易ハッシュ
      const h = simpleHash(r.spec || '');
      return `${currentPreset}|${r.rowNum}|${h}`;
    }
    function simpleHash(s) {
      let h = 0;
      for (let i = 0; i < s.length; i++) { h = ((h << 5) - h + s.charCodeAt(i)) | 0; }
      return h.toString(36);
    }

    // 起動時に既存レビューから lastReviewIdByCandidate を再構築
    async function rebuildReviewIndex() {
      try {
        const all = await dbGetAll('reviews');
        const seen = {};
        for (const rec of all) {
          // 同じ key で複数あれば最新（updatedAt or ts 最大）を採用
          const key = `${rec.preset}|${rec.rowNum}|${simpleHash(rec.spec||'')}`;
          if (!seen[key] || (rec.updatedAt || rec.ts || '') > (seen[key].updatedAt || seen[key].ts || '')) {
            seen[key] = rec;
          }
        }
        lastReviewIdByCandidate = {};
        for (const k in seen) lastReviewIdByCandidate[k] = seen[k].id;
      } catch (err) { console.warn(err); }
    }

    document.addEventListener('change', async (e) => {
      const sel = e.target.closest('.review-select');
      if (sel) {
        const idx = parseInt(sel.dataset.idx, 10);
        const r = currentResults.find(x => x.idx === idx);
        if (!r) return;
        const decision = sel.value;
        reviewState[idx] = decision;
        const modifyArea = document.getElementById(`modify-area-${idx}`);
        if (modifyArea) modifyArea.style.display = decision === 'modify' ? 'block' : 'none';
        if (!decision) return;
        await persistReview(r, decision);
      }
      const ta = e.target.closest('.modify-textarea');
      if (ta) {
        const idx = parseInt(ta.dataset.idx, 10);
        reviewModified[idx] = ta.value;
        const r = currentResults.find(x => x.idx === idx);
        if (r && reviewState[idx] === 'modify') {
          await persistReview(r, 'modify');
        }
      }
    });

    async function persistReview(r, decision) {
      try {
        const key = candidateKey(r);
        const now = new Date().toISOString();
        const record = {
          ts: now,
          updatedAt: now,
          preset: currentPreset,
          rowNum: r.rowNum,
          dictVersion: activeDictVersion || 'base',
          spec: r.spec,
          modifiedSpec: decision === 'modify' ? (reviewModified[r.idx] || '') : '',
          chapter: r.chapter,
          specType: r.specType,
          owner: r.owner,
          level: r.level,
          confidence: r.confidence,
          hits: r.allHits.map(h => h.word),
          decision,
        };
        // 既存IDがあれば上書き（upsert）
        if (lastReviewIdByCandidate[key] != null) {
          record.id = lastReviewIdByCandidate[key];
        }
        const newId = await dbPut('reviews', record);
        lastReviewIdByCandidate[key] = newId;
        log('review_save', `key=${key.substring(0,30)} ${decision}${decision==='modify'?' +mod':''} id=${newId}`);
        await refreshLearningStats();
      } catch (err) { console.warn(err); }
    }

    // ===== 第5段階: 学習統計表示・評価指標 =====
    async function refreshLearningStats() {
      const reviews = await dbGetAll('reviews');
      const elN  = document.getElementById('stat-reviews');
      const elAd = document.getElementById('stat-adopt');
      const elMd = document.getElementById('stat-modify');
      const elRj = document.getElementById('stat-reject');
      const elRc = document.getElementById('stat-recall');
      if (!elN) return;
      const adopt   = reviews.filter(r => r.decision === 'adopt').length;
      const modify  = reviews.filter(r => r.decision === 'modify').length;
      const reject  = reviews.filter(r => r.decision === 'reject').length;
      // 「対象候補の人手承認率」（CODEX指摘 Major: Recall という名前は誤りだったため修正・Phase2で「対象」に改称）
      // 重大判定された候補のうち、レビューで「採用 or 修正採用」された割合 = 辞書精度の見方
      const highReviews = reviews.filter(r => r.level === 'high');
      const highAccepted = highReviews.filter(r => r.decision === 'adopt' || r.decision === 'modify').length;
      const acceptRate = highReviews.length > 0 ? Math.round(highAccepted / highReviews.length * 100) : 0;
      elN.textContent  = reviews.length;
      elAd.textContent = adopt;
      elMd.textContent = modify;
      elRj.textContent = reject;
      elRc.textContent = `${acceptRate}%`;
      const panel = document.getElementById('learning-panel');
      if (panel && reviews.length > 0) panel.style.display = 'block';
    }

    // ===== 第6段階: 学習実行（CODEX指摘 Critical#2: 実際に extendedDicts を更新する） =====
    document.addEventListener('click', async (e) => {
      if (e.target && e.target.id === 'btn-train') {
        const reviews = await dbGetAll('reviews');
        if (reviews.length < 3) { alert('レビュー件数が少なすぎます（3件以上推奨）'); return; }
        log('train_start', `reviews=${reviews.length}`);
        // 採用された hits の頻度カウント
        const wordStats = {};
        for (const r of reviews) {
          for (const w of (r.hits||[])) {
            if (!wordStats[w]) wordStats[w] = { adopt:0, modify:0, reject:0, preset:r.preset };
            wordStats[w][r.decision] = (wordStats[w][r.decision]||0)+1;
          }
        }
        // 辞書を実更新する
        const newExt = JSON.parse(JSON.stringify(extendedDicts));
        let strengthened = 0, weakened = 0;
        for (const w in wordStats) {
          const s = wordStats[w];
          const total = s.adopt + s.modify + s.reject;
          if (total < 2) continue;
          const adoptRate = (s.adopt + 0.5*s.modify) / total;
          if (!newExt[s.preset]) newExt[s.preset] = { high:[], mid:[], low:[], suppressed:[] };
          if (!newExt[s.preset].suppressed) newExt[s.preset].suppressed = [];

          // 既存辞書のどのレベルに該当するか
          const baseDict = RISK_DICT[s.preset];
          let foundLevel = null;
          for (const lvl of ['high','mid','low']) {
            if (baseDict[lvl].some(en => en.word === w)) { foundLevel = lvl; break; }
          }

          if (adoptRate >= 0.8 && total >= 3) {
            // 強化: 既存辞書に無い新語なら 'high' として追加。あればそのまま（重み再強化はsuppressed解除のみ）
            if (!foundLevel) {
              if (!newExt[s.preset].high.some(en => en.word === w)) {
                newExt[s.preset].high.push({
                  word: w,
                  why: `レビュー学習（採用率${Math.round(adoptRate*100)}%・${total}件のレビューに基づき強化）`
                });
                strengthened++;
              }
            }
            // suppressed から外す（誤って弱化されていた場合の復活）
            const sIdx = newExt[s.preset].suppressed.indexOf(w);
            if (sIdx >= 0) { newExt[s.preset].suppressed.splice(sIdx, 1); strengthened++; }
          }
          if (adoptRate <= 0.2 && total >= 3) {
            // 弱化: suppressed リストに追加（本抽出で hit から除外される）
            if (!newExt[s.preset].suppressed.includes(w)) {
              newExt[s.preset].suppressed.push(w);
              weakened++;
            }
          }
        }
        // 新バージョン作成
        const newVer = 'v-' + new Date().toISOString().replace(/[:.]/g,'-');
        await dbPut('dictVersions', {
          version: newVer,
          baseAt: new Date().toISOString(),
          extended: newExt,
          stats: { reviewsUsed: reviews.length, strengthened, weakened },
        });
        log('train_done', `version=${newVer} +${strengthened} -${weakened}`);
        // 旧モデルとの新旧比較
        await runComparison(newVer);
      }
      if (e.target && e.target.id === 'btn-adopt-new') {
        const newVer = e.target.dataset.version;
        if (!newVer) return;
        await dbPut('modelMeta', { key:'active', version:newVer });
        activeDictVersion = newVer;
        const v = (await dbGetAll('dictVersions')).find(x => x.version === newVer);
        if (v) extendedDicts = v.extended || {};
        log('model_switch', newVer);
        document.getElementById('compare-result').innerHTML = `<div style="color:#6ec897;font-size:0.78rem;padding:0.5rem 0.85rem;background:rgba(110,200,151,0.08);border:1px solid rgba(110,200,151,0.3);">✓ 新モデル <strong>${newVer}</strong> を採用しました。次回デビクラ抽出から有効。</div>`;
      }
      if (e.target && e.target.id === 'btn-revert') {
        await dbPut('modelMeta', { key:'active', version:'base' });
        activeDictVersion = 'base';
        extendedDicts = {};
        log('model_revert', 'base');
        document.getElementById('compare-result').innerHTML = `<div style="color:rgba(255,255,255,0.7);font-size:0.78rem;padding:0.5rem 0.85rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);">↺ ベース辞書に戻しました（学習効果は無効化）。</div>`;
      }
      if (e.target && e.target.id === 'btn-clear-reviews') {
        if (!confirm('レビュー履歴を全削除します。よろしいですか？')) return;
        await dbClear('reviews');
        log('reviews_cleared', '');
        await refreshLearningStats();
        alert('レビュー履歴を全削除しました');
      }
    });

    // ===== 第6段階: 新旧モデル比較 =====
    async function runComparison(newVer) {
      if (currentResults.length === 0) {
        document.getElementById('compare-result').innerHTML = '<div style="color:rgba(255,255,255,0.5);font-size:0.78rem;">先にデビクラ抽出を実行してください（同じ仕様書で旧/新モデルを比較）</div>';
        return;
      }
      // 旧モデル(=現在のcurrentResults)と新モデル(extendedDicts更新後)を比較
      const oldHigh = currentResults.filter(r => r.level === 'high').map(r => r.idx);
      const oldTop10 = currentResults.slice(0, 10).map(r => r.idx);
      // 新辞書で再抽出
      const versions = await dbGetAll('dictVersions');
      const newV = versions.find(v => v.version === newVer);
      const savedExt = JSON.parse(JSON.stringify(extendedDicts));
      extendedDicts = newV.extended || {};
      const tempResults = await recomputeResults(); // CODEX対応: await + extractCandidates 共通化済み
      extendedDicts = savedExt;
      const newHigh = tempResults.filter(r => r.level === 'high').map(r => r.idx);
      const newTop10 = tempResults.slice(0, 10).map(r => r.idx);
      const top10Match = oldTop10.filter(i => newTop10.includes(i)).length;
      const highMatch  = oldHigh.filter(i => newHigh.includes(i)).length;
      // CODEX指摘 Major対応: 「重大候補の承認率」は誤称（実装は対象判定 idx の重複率）→ 「対象候補一致率」に正しく改名
      const highMatchRate = oldHigh.length > 0 ? Math.round(highMatch/oldHigh.length*100) : 100;
      const html = `
        <div style="background:#0f0f12;border:1px solid rgba(200,169,110,0.2);padding:1rem 1.25rem;">
          <div style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.3em;margin-bottom:0.75rem;">▸ 新旧モデル比較結果</div>
          <table style="width:100%;font-size:0.78rem;">
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">新バージョン</td><td style="padding:0.25rem;color:#edede8;">${newVer}</td></tr>
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">学習レビュー数</td><td style="padding:0.25rem;color:#edede8;">${newV.stats.reviewsUsed}件</td></tr>
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">辞書語 強化候補</td><td style="padding:0.25rem;color:#6ec897;">+${newV.stats.strengthened}語</td></tr>
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">辞書語 弱化候補</td><td style="padding:0.25rem;color:rgba(255,80,80,0.85);">-${newV.stats.weakened}語</td></tr>
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">「対象」候補一致率（旧∩新／旧）</td><td style="padding:0.25rem;color:#c8a96e;font-weight:600;">${highMatchRate}% (${highMatch}/${oldHigh.length})</td></tr>
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">Top10一致率</td><td style="padding:0.25rem;color:#edede8;">${oldTop10.length>0?Math.round(top10Match/oldTop10.length*100):0}% (${top10Match}/${oldTop10.length})</td></tr>
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">新モデル候補数</td><td style="padding:0.25rem;color:rgba(255,255,255,0.6);">${tempResults.length}件 (重大${newHigh.length}件)</td></tr>
          </table>
          <div style="display:flex;gap:0.5rem;margin-top:0.85rem;">
            <button id="btn-adopt-new" data-version="${newVer}" class="m-btn" style="font-size:0.74rem;padding:0.4rem 1rem;">✓ 新モデルを採用</button>
            <button id="btn-revert" class="m-btn-ghost" style="font-size:0.74rem;padding:0.4rem 1rem;">↺ ベースに戻す</button>
          </div>
        </div>`;
      document.getElementById('compare-result').innerHTML = html;
      log('compare_done', `match=${highMatchRate}% top10=${oldTop10.length>0?Math.round(top10Match/oldTop10.length*100):0}%`);
    }

    // CODEX指摘 Major対応: 比較再計算も extractCandidates() を使い本抽出と完全一致
    async function recomputeResults() {
      const colSpec = document.getElementById('col-spec').value;
      if (!colSpec) return [];
      const dict = getEffectiveDict(currentPreset);
      const suppressedSet = new Set((extendedDicts[currentPreset]?.suppressed || []));
      // 過去レビューはキャッシュ（旧/新で同じ集合を使う）
      const past = await dbGetAll('reviews').catch(() => []);
      return await extractCandidates(currentRows, colSpec, dict, suppressedSet, {
        pastReviews: past,
        checkAbort: false,
        yieldUI: false,
        includeHighlight: false,
      });
    }

    // ===== 第7段階: ESCで実際に中断（CODEX指摘 Major: 表示と挙動が一致してなかったので修正） =====
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        if (!extractAborted) {
          extractAborted = true;
          log('escape_pressed', '中断要求');
        }
      }
    });

    // ===== 学習データインポート（既存のデビクラ判定済みExcelを reviews ストアに一括投入） =====
    document.getElementById('learning-upload').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) { return; }
      const status = document.getElementById('learning-status');
      status.textContent = '解析中...';
      status.style.color = '#c8a96e';
      try {
        const buf = await file.arrayBuffer();
        const wb = XLSX.read(buf, { type:'array' });
        // 「正解データ」または「学習データ」シートを優先、なければ先頭シート
        const preferredSheets = ['正解データ', '学習データ', '判定済', 'デビクラ', 'training', 'learning'];
        let sheetName = wb.SheetNames[0];
        for (const ps of preferredSheets) {
          const found = wb.SheetNames.find(n => n.includes(ps));
          if (found) { sheetName = found; break; }
        }
        const ws = wb.Sheets[sheetName];
        const rows = XLSX.utils.sheet_to_json(ws, { defval:'' });
        if (rows.length === 0) throw new Error('シート「' + sheetName + '」に行が無い');

        // 列を自動推定
        const cols = Object.keys(rows[0]);
        const lc = cols.map(c => String(c).toLowerCase());
        const find = (kws) => {
          for (const kw of kws) {
            const idx = lc.findIndex(c => c.includes(kw.toLowerCase()));
            if (idx >= 0) return cols[idx];
          }
          return '';
        };
        const m = {
          spec:     find(['要求仕様','仕様文','要求事項','requirement','spec']),
          devicra:  find(['デビクラ','deviation','判定','正解']),
          category: find(['カテゴリー','カテゴリ','category']),
          project:  find(['project','プロジェクト','案件名']),
          rfq:      find(['引合','rfq']),
          impact:   find(['e&c&lt','e&c','影響']),
          doc:      find(['ドキュメント','document','図書']),
          chapter:  find(['章番号','章','chapter']),
          owner:    find(['所掌','担当','owner']),
        };
        if (!m.spec) throw new Error('「要求仕様」列が見つかりません');
        if (!m.devicra) throw new Error('「デビクラ」列が見つかりません（対象/要確認/対象外 のいずれか）');

        // デビクラ判定 → decision/level マッピング
        // 対象 → adopt + high  /  要確認 → modify + mid  /  対象外 → reject + low
        let imported = 0, skipped = 0;
        for (const r of rows) {
          const spec = String(r[m.spec]||'').trim();
          if (!spec) { skipped++; continue; }
          const devRaw = String(r[m.devicra]||'').trim();
          let decision = '', level = 'mid';
          if (devRaw === '対象')        { decision = 'adopt';  level = 'high'; }
          else if (devRaw === '要確認') { decision = 'modify'; level = 'mid';  }
          else if (devRaw === '対象外') { decision = 'reject'; level = 'low';  }
          else if (devRaw)              { decision = 'modify'; level = 'mid';  } // 未知ラベル → 要確認扱い
          else { skipped++; continue; }

          const rowNum = imported + 2;
          // CODEX 4巡目 Major対応: 通常レビュー保存と同じ candidateKey() ロジックで upsert する
          //   通常: `${preset}|${rowNum}|${simpleHash(spec)}`
          //   旧Bug: imported プレフィックス付きで別キー → 同一Excel再取込で重複蓄積していた
          const key = `${currentPreset}|${rowNum}|${simpleHash(spec)}`;
          const now = new Date().toISOString();
          // Phase 3: impact 列の文字列を正規化（"E,C" "E/C" "E C" "E、C" 等を ['E','C'] に）
          const impactRaw = m.impact ? String(r[m.impact]||'') : '';
          const impactArr = parseImpactString(impactRaw);
          const record = {
            ts: now,
            updatedAt: now,
            preset: currentPreset,
            rowNum,
            dictVersion: activeDictVersion || 'base',
            spec,
            modifiedSpec: '',
            chapter: m.chapter ? String(r[m.chapter]||'') : '',
            specType: m.category ? String(r[m.category]||'') : '',
            owner: m.owner ? String(r[m.owner]||'') : '',
            project: m.project ? String(r[m.project]||'') : '',
            rfq: m.rfq ? String(r[m.rfq]||'') : '',
            impactRaw,           // 元文字列も監査用に保持
            impact: impactArr,   // 正規化済み配列 ['E','C','LT']
            doc: m.doc ? String(r[m.doc]||'') : '',
            devicraRaw: devRaw,
            level,
            confidence: decision === 'adopt' ? 90 : (decision === 'modify' ? 60 : 30),
            hits: [],
            decision,
            source: 'imported',
          };
          if (lastReviewIdByCandidate[key] != null) record.id = lastReviewIdByCandidate[key];
          const newId = await dbPut('reviews', record);
          lastReviewIdByCandidate[key] = newId;
          imported++;
        }
        status.textContent = `✓ ${imported}件取り込み (シート「${sheetName}」 / スキップ${skipped}件 / preset=${currentPreset})`;
        status.style.color = '#6ec897';
        log('learning_import', `imported=${imported} skipped=${skipped} sheet=${sheetName}`);
        await refreshLearningStats();
      } catch (err) {
        status.textContent = '❌ 取込エラー: ' + err.message;
        status.style.color = '#ff8888';
        console.warn(err);
      }
      e.target.value = '';
    });

    // ============================================================
    // モデル共有: エクスポート/インポート（チーム配布用）
    // ============================================================
    //   形式: { type:'spec-risk-extractor-model', version, exportedAt,
    //          activeDictVersion, dictVersions[], reviews[], stats }
    //   インポートモード:
    //     merge   = 既存と統合（candidateKey/version で upsert・推奨）
    //     replace = 既存全削除して読込（取り消し不可）
    const MODEL_EXPORT_VERSION = '1.0';
    function setShareStatus(text, color) {
      const el = document.getElementById('model-share-status');
      if (!el) return;
      el.textContent = text;
      el.style.color = color || 'rgba(255,255,255,0.5)';
    }

    document.getElementById('btn-export-model').addEventListener('click', async () => {
      try {
        setShareStatus('書き出し中...', '#c8a96e');
        const dictVersions = await dbGetAll('dictVersions');
        const reviews      = await dbGetAll('reviews');
        const modelMeta    = await dbGetAll('modelMeta');
        const activeMeta   = modelMeta.find(m => m.key === 'active');
        const payload = {
          type: 'spec-risk-extractor-model',
          version: MODEL_EXPORT_VERSION,
          exportedAt: new Date().toISOString(),
          activeDictVersion: activeMeta?.version || activeDictVersion || 'base',
          dictVersions,
          reviews,
          stats: {
            dictVersions: dictVersions.length,
            reviews: reviews.length,
            adopt:  reviews.filter(r => r.decision === 'adopt').length,
            modify: reviews.filter(r => r.decision === 'modify').length,
            reject: reviews.filter(r => r.decision === 'reject').length,
          },
        };
        const blob = new Blob([JSON.stringify(payload, null, 2)], { type:'application/json' });
        const url  = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `spec-risk-model-${new Date().toISOString().slice(0,10)}.json`;
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
        setTimeout(() => URL.revokeObjectURL(url), 1000);
        setShareStatus(`✓ 書き出し完了 (辞書${payload.stats.dictVersions}版・レビュー${payload.stats.reviews}件)`, '#6ec897');
        log('model_export', `dictVersions=${payload.stats.dictVersions} reviews=${payload.stats.reviews}`);
      } catch (err) {
        setShareStatus('❌ 書き出しエラー: ' + err.message, '#ff8888');
        console.warn(err);
      }
    });

    document.getElementById('model-import-upload').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const mode = document.getElementById('model-import-mode').value || 'merge';
      try {
        setShareStatus(`取り込み中（${mode}）...`, '#c8a96e');
        const text = await file.text();
        const payload = JSON.parse(text);
        if (payload.type !== 'spec-risk-extractor-model') {
          throw new Error(`不正なファイル形式: type=${payload.type || '不明'}`);
        }
        if (mode === 'replace') {
          if (!confirm('既存の辞書バージョン・レビュー履歴を全削除して取り込みます。取り消しできません。よろしいですか？')) {
            setShareStatus('キャンセルしました', 'rgba(255,255,255,0.5)');
            e.target.value = '';
            return;
          }
          await dbClear('reviews');
          await dbClear('dictVersions');
          await dbClear('modelMeta');
          activeDictVersion = null;
          extendedDicts = {};
        }
        // dictVersions: version をキーにした upsert
        let dictUp = 0;
        for (const v of (payload.dictVersions || [])) {
          if (!v.version) continue;
          await dbPut('dictVersions', v);
          dictUp++;
        }
        // reviews: candidateKey で upsert（merge時のみ・replace時は新規挿入）
        let revUp = 0;
        for (const rec of (payload.reviews || [])) {
          if (!rec.spec) continue;
          if (mode === 'merge') {
            const key = `${rec.preset || currentPreset}|${rec.rowNum || 0}|${simpleHash(rec.spec)}`;
            if (lastReviewIdByCandidate[key] != null) {
              rec.id = lastReviewIdByCandidate[key];
            } else {
              delete rec.id;  // 新規追加（autoIncrement任せ）
            }
            const newId = await dbPut('reviews', rec);
            lastReviewIdByCandidate[key] = newId;
          } else {
            delete rec.id;
            await dbPut('reviews', rec);
          }
          revUp++;
        }
        // activeDictVersion 復元（明示指定あれば）
        if (payload.activeDictVersion && payload.activeDictVersion !== 'base') {
          await dbPut('modelMeta', { key:'active', version: payload.activeDictVersion });
        }
        await loadActiveModel();
        await rebuildReviewIndex();
        await refreshLearningStats();
        renderCustomWords();
        setShareStatus(`✓ 取り込み完了（${mode}） 辞書${dictUp}版・レビュー${revUp}件 / active=${activeDictVersion||'base'}`, '#6ec897');
        log('model_import', `mode=${mode} dictVersions=${dictUp} reviews=${revUp} active=${activeDictVersion||'base'}`);
      } catch (err) {
        setShareStatus('❌ 取り込みエラー: ' + err.message, '#ff8888');
        console.warn(err);
      }
      e.target.value = '';
    });

    // ============================================================
    // ===== AI類似検索 / PDF読込 / 過去事例DB管理 / Llama生成（Phase 2） =====
    // ============================================================

    // PDF.js worker 設定
    if (typeof pdfjsLib !== 'undefined') {
      pdfjsLib.GlobalWorkerOptions.workerSrc =
        'https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/build/pdf.worker.min.js';
    }

    // Embedding モデル（遅延初期化）
    let _embedder = null;
    async function getEmbedder() {
      if (_embedder) return _embedder;
      const pipeline = window._txPipeline;
      if (pipeline === null) throw new Error('Transformers.jsの読込に失敗しました。CDN障害またはCSP設定をご確認ください。');
      if (!pipeline) throw new Error('Transformers.jsをまだ読込中です。少し待ってから再試行してください。');
      setAIModelStatus('モデルをダウンロード中... (117MB・初回のみ)');
      _embedder = await pipeline('feature-extraction', 'Xenova/paraphrase-multilingual-MiniLM-L12-v2', {
        progress_callback: p => {
          if (p.status === 'downloading' && p.total) {
            const pct = Math.round(p.loaded / p.total * 100);
            setAIModelStatus(`ダウンロード中 ${pct}%... (${(p.loaded/1e6).toFixed(0)}/${(p.total/1e6).toFixed(0)}MB)`);
          } else if (p.status === 'ready') {
            setAIModelStatus('✓ モデル準備完了');
          }
        }
      });
      setAIModelStatus('✓ モデル準備完了');
      return _embedder;
    }

    function setAIModelStatus(msg) {
      const el = document.getElementById('ai-model-status');
      if (el) el.textContent = msg;
    }

    async function embedText(text) {
      const emb = await getEmbedder();
      const out = await emb(text, { pooling: 'mean', normalize: true });
      return Array.from(out.data);
    }

    function embeddingSim(a, b) {
      let dot = 0;
      for (let i = 0; i < a.length; i++) dot += a[i] * b[i];
      return dot; // normalize:true なので単位ベクトル済み
    }

    // ---- PDF テキスト抽出 ----
    async function extractPDFSentences(file, minLen = 12) {
      if (typeof pdfjsLib === 'undefined') throw new Error('PDF.jsが読込できていません');
      const buf = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: buf }).promise;
      const results = [];
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const content = await page.getTextContent();
        // hasEOL=true のアイテム後に改行を挿入して段組み・セル境界を保持
        const raw = content.items.map(it => it.str + (it.hasEOL ? '\n' : '')).join('');
        raw.split(/[。\n；;]/).forEach(s => {
          const t = s.trim().replace(/\s+/g, ' ');
          if (t.length >= minLen) results.push({ text: t, page: i });
        });
      }
      return results;
    }

    // ---- 過去事例DB CRUD ----
    async function addPastCase(specText, devicraText) {
      const embedding = await embedText(specText);
      await dbPut('pastCases', {
        specText, devicraText, embedding,
        preset: currentPreset,
        addedAt: new Date().toISOString(),
      });
    }

    async function deletePastCase(id) {
      const db = await openDB();
      return new Promise((res, rej) => {
        const tx = db.transaction('pastCases', 'readwrite');
        tx.objectStore('pastCases').delete(id);
        tx.oncomplete = res; tx.onerror = e => rej(e.target.error);
      });
    }

    async function refreshPastCasesUI() {
      const all = await dbGetAll('pastCases');
      const badge = document.getElementById('past-cases-count-badge');
      if (badge) badge.textContent = `${all.length}件登録済み`;
      const wrap = document.getElementById('past-cases-table-wrap');
      const list = document.getElementById('past-cases-list');
      if (!wrap || !list) return;
      wrap.style.display = all.length > 0 ? 'block' : 'none';
      list.innerHTML = all.length === 0 ? '' : all.map(c => `
        <div style="display:flex;gap:0.5rem;align-items:flex-start;padding:0.5rem 0.65rem;border-bottom:1px solid rgba(255,255,255,0.05);font-size:0.72rem;">
          <div style="flex:1;min-width:0;">
            <div style="color:#edede8;margin-bottom:0.2rem;word-break:break-all;">${c.specText}</div>
            <div style="color:#6ec897;font-size:0.68rem;word-break:break-all;">${c.devicraText}</div>
            <div style="color:rgba(255,255,255,0.25);font-size:0.63rem;margin-top:0.2rem;">${c.preset || ''} · ${(c.addedAt||'').slice(0,10)}</div>
          </div>
          <button class="btn-past-del" data-id="${c.id}"
            style="background:transparent;border:1px solid rgba(255,100,100,0.2);color:#ff8888;padding:0.15rem 0.45rem;font-size:0.63rem;cursor:pointer;font-family:inherit;flex-shrink:0;">削除</button>
        </div>
      `).join('');
    }

    // ---- 過去事例 PDF読込ハンドラ ----
    document.getElementById('past-pdf-upload').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const statusEl = document.getElementById('past-pdf-status');
      const wrapEl   = document.getElementById('past-pdf-sentences');
      const listEl   = document.getElementById('past-pdf-list');
      statusEl.textContent = 'PDF解析中...';
      try {
        const sentences = await extractPDFSentences(file);
        statusEl.textContent = `${sentences.length}文抽出 (${file.name})`;
        wrapEl.style.display = 'block';
        listEl.innerHTML = sentences.map((s, i) => `
          <div style="display:flex;gap:0.4rem;align-items:flex-start;padding:0.45rem 0.65rem;border-bottom:1px solid rgba(255,255,255,0.04);">
            <span style="color:rgba(255,255,255,0.25);font-size:0.62rem;flex-shrink:0;min-width:2em;">p${s.page}</span>
            <span style="flex:1;color:rgba(237,237,232,0.8);font-size:0.73rem;word-break:break-all;">${s.text}</span>
            <input type="text" class="field-input past-devicra-inline" data-spec="${s.text.replace(/"/g,'&quot;')}"
              placeholder="このデビクラを出した場合ここに入力"
              style="width:220px;font-size:0.7rem;padding:0.2rem 0.45rem;flex-shrink:0;">
            <button class="btn-past-inline-add" data-idx="${i}" style="background:rgba(110,200,151,0.1);border:1px solid rgba(110,200,151,0.3);color:#6ec897;padding:0.2rem 0.5rem;font-size:0.65rem;cursor:pointer;font-family:inherit;flex-shrink:0;white-space:nowrap;">登録</button>
          </div>
        `).join('');
      } catch (err) {
        statusEl.textContent = '❌ ' + err.message;
      }
      e.target.value = '';
    });

    // PDF行の「登録」ボタン
    document.addEventListener('click', async (e) => {
      const btn = e.target.closest('.btn-past-inline-add');
      if (!btn) return;
      const row = btn.closest('div');
      const input = row.querySelector('.past-devicra-inline');
      const specText    = input.dataset.spec;
      const devicraText = input.value.trim();
      if (!devicraText) { input.style.borderColor='#ff8888'; return; }
      btn.disabled = true; btn.textContent = '...';
      try {
        await addPastCase(specText, devicraText);
        btn.textContent = '✓'; btn.style.color = '#6ec897';
        input.value = ''; input.style.borderColor = '';
        await refreshPastCasesUI();
      } catch (err) {
        btn.textContent = '❌'; btn.disabled = false;
        alert(err.message);
      }
    });

    // 手動登録ボタン
    document.getElementById('btn-past-add').addEventListener('click', async () => {
      const specText    = document.getElementById('past-spec-input').value.trim();
      const devicraText = document.getElementById('past-devicra-input').value.trim();
      const st = document.getElementById('past-add-status');
      if (!specText)    { st.textContent = '⚠ 仕様文は必須です'; st.style.color='#ff8888'; return; }
      if (!devicraText) { st.textContent = '⚠ デビクラ文は必須です'; st.style.color='#ff8888'; return; }
      st.textContent = '登録中（Embedding生成）...'; st.style.color = 'rgba(255,255,255,0.5)';
      try {
        await addPastCase(specText, devicraText);
        document.getElementById('past-spec-input').value    = '';
        document.getElementById('past-devicra-input').value = '';
        st.textContent = '✓ 登録完了'; st.style.color = '#6ec897';
        await refreshPastCasesUI();
      } catch (err) {
        st.textContent = '❌ ' + err.message; st.style.color = '#ff8888';
      }
    });

    // 個別削除
    document.addEventListener('click', async (e) => {
      const btn = e.target.closest('.btn-past-del');
      if (!btn) return;
      await deletePastCase(Number(btn.dataset.id));
      await refreshPastCasesUI();
    });

    // 全件削除
    document.getElementById('btn-past-clear-all').addEventListener('click', async () => {
      if (!confirm('過去事例を全件削除しますか？（取り消し不可）')) return;
      const all = await dbGetAll('pastCases');
      for (const c of all) await deletePastCase(c.id);
      await refreshPastCasesUI();
    });

    // Embeddingモデル手動初期化ボタン
    document.getElementById('btn-ai-model-init').addEventListener('click', async () => {
      const btn = document.getElementById('btn-ai-model-init');
      btn.disabled = true;
      try { await getEmbedder(); }
      catch (err) { setAIModelStatus('❌ ' + err.message); }
      btn.disabled = false;
    });

    // ---- 新仕様書PDF アップロード（STEP 1） ----
    document.getElementById('pdf-upload').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const prog = document.getElementById('file-progress');
      const bar  = document.getElementById('file-progress-bar');
      prog.style.display = 'block';
      prog.querySelector('div').textContent = 'PDF解析中...';
      bar.style.width = '30%';
      try {
        const sentences = await extractPDFSentences(file);
        bar.style.width = '100%';
        currentRows = sentences.map((s, i) => ({ _pdfText: s.text, _page: s.page, rowNum: i + 1 }));
        showFileInfo(`PDF: ${file.name} / ${sentences.length}文 / ${(await (await fetch(URL.createObjectURL(file))).blob()).size ? '' : ''}${sentences.length}行読込完了`);
        // col-spec を _pdfText に固定マッピング
        document.querySelectorAll('.col-select').forEach(sel => {
          sel.innerHTML = '<option value="_pdfText">仕様文（PDF抽出）</option>';
        });
        document.getElementById('col-spec').value = '_pdfText';
        document.getElementById('mapping-section').style.display = 'block';
        document.getElementById('execute-section').style.display = 'flex';
        prog.style.display = 'none';
      } catch (err) {
        prog.style.display = 'none';
        alert('PDF読込エラー: ' + err.message);
      }
      e.target.value = '';
    });

    // ---- AI類似検索 実行 ----
    // ---- Llama 3.2 1B（WebLLM・Phase 2） ----
    let _llamaEngine = null;

    function setLlamaStatus(msg, color) {
      const el = document.getElementById('llama-status');
      if (el) { el.textContent = msg; if (color) el.style.color = color; }
    }

    async function checkWebGPU() {
      if (!navigator.gpu) return false;
      try { return !!(await navigator.gpu.requestAdapter()); }
      catch { return false; }
    }

    async function getLlamaEngine() {
      if (_llamaEngine) return _llamaEngine;
      const create = window._webllmCreate;
      if (create === null) throw new Error('WebLLM(esm.run)の読込に失敗しました。CDN障害・CSP・ネットワーク制限をご確認ください。');
      if (!create) throw new Error('WebLLMをまだ読込中です。少し待ってから再試行してください。');
      if (!await checkWebGPU()) throw new Error('WebGPU非対応ブラウザです。Chrome/Edge 113以降が必要です。');
      const wrap = document.getElementById('llama-dl-wrap');
      const bar  = document.getElementById('llama-dl-bar');
      if (wrap) wrap.style.display = 'block';
      _llamaEngine = await create('Llama-3.2-1B-Instruct-q4f16_1-MLC', {
        initProgressCallback: p => {
          setLlamaStatus(p.text || '読込中...');
          if (bar && p.progress) bar.style.width = Math.round(p.progress * 100) + '%';
        }
      });
      if (wrap) wrap.style.display = 'none';
      setLlamaStatus('✓ Llama 3.2 1B 準備完了', '#c8a96e');
      return _llamaEngine;
    }

    async function generateDevicra(specText, similarCases = []) {
      const engine = await getLlamaEngine();
      const ctxParts = similarCases.slice(0, 2).map(c =>
        `仕様例: ${c.specText}\nデビクラ例: ${c.devicraText}`
      ).join('\n\n');
      const sysMsg = 'あなたはETO製造業（一品一様製造）のデビクラ専門家です。デビクラとは「顧客に提示する懸念事項（Deviation & Clarification）」です。与えられた仕様文に対して、見積・設計・納期を狂わせる懸念事項を1〜2文で簡潔に日本語で述べてください。';
      const userMsg = ctxParts
        ? `【参考事例】\n${ctxParts}\n\n【新しい仕様文】「${specText}」\n\n【デビクラ（懸念事項）】`
        : `【仕様文】「${specText}」\n\n【デビクラ（懸念事項）】`;
      const reply = await engine.chat.completions.create({
        messages: [{ role:'system', content:sysMsg }, { role:'user', content:userMsg }],
        temperature: 0.3,
        max_tokens: 180,
      });
      return reply.choices[0].message.content.trim();
    }

    // モード切替UI
    document.querySelectorAll('input[name="ai-mode"]').forEach(radio => {
      radio.addEventListener('change', () => {
        const modeB = document.querySelector('input[name="ai-mode"]:checked').value === 'B';
        document.getElementById('llama-init-area').style.display = modeB ? 'block' : 'none';
      });
    });

    // Llamaモデル読込ボタン
    document.getElementById('btn-llama-init').addEventListener('click', async () => {
      const btn = document.getElementById('btn-llama-init');
      btn.disabled = true;
      setLlamaStatus('初期化中...', 'rgba(200,169,110,0.7)');
      try {
        await getLlamaEngine();
      } catch (err) {
        setLlamaStatus('❌ ' + err.message, '#ff8888');
      }
      btn.disabled = false;
    });

    // AI類似検索（モードA/B共通）
    document.getElementById('btn-ai-search').addEventListener('click', async () => {
      const modeB = document.querySelector('input[name="ai-mode"]:checked').value === 'B';
      const all = await dbGetAll('pastCases');
      if (currentResults.length === 0) {
        document.getElementById('ai-search-results').innerHTML =
          '<div style="color:#ff8888;font-size:0.78rem;padding:0.5rem;">先にデビクラ抽出を実行してください。</div>';
        return;
      }
      const threshold = parseFloat(document.getElementById('ai-threshold').value) || 0.75;
      const progressEl  = document.getElementById('ai-search-progress');
      const progressBar = document.getElementById('ai-progress-bar');
      const progressTxt = document.getElementById('ai-progress-text');
      const resultsEl   = document.getElementById('ai-search-results');
      progressEl.style.display = 'block';
      resultsEl.innerHTML = '';

      const validPast = all.filter(c =>
        Array.isArray(c.embedding) && c.embedding.length > 0 && c.preset === currentPreset
      );
      const total = currentResults.length;

      // モードBでLlamaが未初期化の場合は事前チェック
      if (modeB && !_llamaEngine) {
        progressTxt.textContent = 'Llamaモデルを初期化中...';
        try { await getLlamaEngine(); }
        catch (err) {
          progressEl.style.display = 'none';
          resultsEl.innerHTML = `<div style="color:#ff8888;font-size:0.78rem;padding:0.5rem;">❌ ${err.message}</div>`;
          return;
        }
      }

      // 各候補を処理
      const rows = [];
      for (let i = 0; i < currentResults.length; i++) {
        const r = currentResults[i];
        const phase = modeB ? `Embedding+生成中 ${i+1}/${total}` : `Embedding処理中 ${i+1}/${total}`;
        progressTxt.textContent = phase;
        progressBar.style.width = `${Math.round((i + 1) / total * 100)}%`;

        let qVec;
        try { qVec = await embedText(r.spec); }
        catch (err) { progressTxt.textContent = '❌ ' + err.message; progressEl.style.display='none'; return; }

        const matches = validPast
          .map(c => ({ ...c, sim: embeddingSim(qVec, c.embedding) }))
          .filter(c => c.sim >= threshold)
          .sort((a, b) => b.sim - a.sim)
          .slice(0, 3);

        let generated = null;
        if (modeB) {
          // 過去事例あり → 類似事例をコンテキストとして生成 / なし → コンテキストなしで生成
          progressTxt.textContent = `Llama生成中 ${i+1}/${total}...`;
          try { generated = await generateDevicra(r.spec, matches); }
          catch (err) { generated = '(生成エラー: ' + err.message + ')'; }
        }

        rows.push({ candidate: r, matches, generated });
        await new Promise(rb => setTimeout(rb, 0));
      }

      progressEl.style.display = 'none';

      const visibleRows = rows.filter(row =>
        row.matches.length > 0 || (modeB && row.generated)
      );

      if (visibleRows.length === 0) {
        resultsEl.innerHTML = `<div style="color:rgba(255,255,255,0.5);font-size:0.78rem;padding:0.5rem;">類似度 ${threshold} 以上の過去事例が見つかりませんでした。${modeB ? '' : '閾値を下げるか、モードBに切替えてください。'}</div>`;
        return;
      }

      resultsEl.innerHTML = visibleRows.map(({ candidate: r, matches, generated }) => `
        <div style="border:1px solid rgba(110,200,151,0.15);margin-bottom:0.75rem;background:#0a0a0c;">
          <div style="padding:0.6rem 0.85rem;background:rgba(110,200,151,0.05);border-bottom:1px solid rgba(110,200,151,0.1);">
            <span style="color:rgba(255,255,255,0.4);font-size:0.65rem;">行${r.rowNum} &nbsp;|&nbsp; </span>
            <span style="color:#edede8;font-size:0.78rem;">${r.spec}</span>
          </div>
          ${matches.map(m => `
            <div style="padding:0.55rem 0.85rem;border-bottom:1px solid rgba(255,255,255,0.04);">
              <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.3rem;flex-wrap:wrap;">
                <span style="background:rgba(110,200,151,0.15);color:#6ec897;font-size:0.68rem;padding:0.1rem 0.45rem;border-radius:2px;">類似度 ${m.sim.toFixed(2)}</span>
                <span style="color:rgba(255,255,255,0.35);font-size:0.65rem;">過去仕様文:</span>
                <span style="color:rgba(237,237,232,0.7);font-size:0.73rem;">${m.specText}</span>
              </div>
              <div style="display:flex;gap:0.5rem;align-items:flex-start;">
                <span style="color:#c8a96e;font-size:0.65rem;flex-shrink:0;margin-top:0.1rem;">過去デビクラ:</span>
                <span style="color:#c8a96e;font-size:0.76rem;font-weight:500;line-height:1.55;">${m.devicraText}</span>
              </div>
            </div>
          `).join('')}
          ${generated ? `
            <div style="padding:0.6rem 0.85rem;background:rgba(200,169,110,0.04);border-top:1px dashed rgba(200,169,110,0.18);">
              <div style="display:flex;gap:0.5rem;align-items:flex-start;">
                <span style="background:rgba(200,169,110,0.15);color:#c8a96e;font-size:0.65rem;padding:0.1rem 0.45rem;border-radius:2px;flex-shrink:0;">🦙 Llama生成</span>
                <span style="color:#c8a96e;font-size:0.77rem;font-weight:500;line-height:1.6;">${generated}</span>
              </div>
            </div>
          ` : ''}
        </div>
      `).join('');
    });

    // ===== 起動時: 学習DB・モデル版・レビューupsert索引を読み込む =====
    (async () => {
      try {
        await loadActiveModel();
        await rebuildReviewIndex();
        await refreshLearningStats();
        renderCustomWords();
        await refreshPastCasesUI();
        log('boot', `model=${activeDictVersion||'base'} reviews=${Object.keys(lastReviewIdByCandidate).length}`);
      } catch (err) { console.warn(err); }
    })();
  </script>

</BaseLayout>
