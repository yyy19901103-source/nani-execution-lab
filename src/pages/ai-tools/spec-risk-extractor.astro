  <script>
    // ============================================================
    // デビクラ辞書（業界別・対象/要確認/対象外の3段階）
    // ============================================================
    // CODEX 4巡目フィードバック: impact は配列で持つ（Set相当・OR集約）
    //   デビクラ種類 3軸:
    //     E  = 技術デビクラ（Engineering）   設計工数・公差・技術的成立性に関わる懸念
    //     C  = コストデビクラ（Cost）        部品・材料・認証・現地工事のコスト増懸念
    //     LT = リードタイムデビクラ（LeadTime） 認証取得期間・調達LT長・短納期要求の懸念
    //   各語の業務的意味から論理的に推定。空配列はデビクラ種類不明＝判定保留扱い
    const RISK_DICT = {
      industrial: {
        name: '産業機械',
        high: [
          { word:'特殊', why:'仕様詳細不明・標準外作業の指標', impact:['E','C','LT'] },
