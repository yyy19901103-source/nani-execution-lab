    // ============================================================
    // BM25 検索エンジン（純粋JS・日本語bigram対応）
    // ============================================================
    function tokenize(text) {
      if (!text) return [];
      const tokens = [];
      const cleaned = String(text).toLowerCase().replace(/\s+/g, ' ').trim();
      // ASCII単語抽出
      const asciiWords = cleaned.match(/[a-z0-9]+/g) || [];
      tokens.push(...asciiWords);
      // 日本語bigram抽出（CJK文字のみ対象）
      const jpOnly = cleaned.replace(/[a-z0-9\s\.,;:!?\-_/()「」『』、。]+/g, ' ');
      const segments = jpOnly.split(/\s+/).filter(s => s.length > 0);
      for (const seg of segments) {
        if (seg.length === 1) { tokens.push(seg); continue; }
        for (let i = 0; i < seg.length - 1; i++) {
          tokens.push(seg.substr(i, 2));
        }
      }
      return tokens;
    }

    class BM25 {
      constructor(k1=1.5, b=0.75) {
        this.k1 = k1; this.b = b;
        this.docs = []; this.docTokens = [];
        this.df = {}; this.avgdl = 0; this.N = 0;
      }
      fit(documents) {
        this.docs = documents;
        this.docTokens = documents.map(tokenize);
        this.N = this.docTokens.length;
        let totalLen = 0;
        this.df = {};
        for (const tokens of this.docTokens) {
          totalLen += tokens.length;
          const seen = new Set(tokens);
          for (const t of seen) this.df[t] = (this.df[t] || 0) + 1;
        }
        this.avgdl = this.N > 0 ? totalLen / this.N : 0;
      }
      idf(term) {
        const dft = this.df[term] || 0;
        return Math.log(1 + (this.N - dft + 0.5) / (dft + 0.5));
      }
      scoreDoc(queryTokens, docIdx) {
        const tokens = this.docTokens[docIdx];
        const dl = tokens.length;
        const tf = {};
        for (const t of tokens) tf[t] = (tf[t]||0)+1;
        let score = 0;
        for (const qt of queryTokens) {
          const f = tf[qt] || 0;
          if (f === 0) continue;
          const idf = this.idf(qt);
          const num = f * (this.k1 + 1);
          const den = f + this.k1 * (1 - this.b + this.b * dl / Math.max(this.avgdl, 1));
          score += idf * num / den;
        }
        return score;
      }
      search(query, topN=20) {
        const qTokens = tokenize(query);
        const scores = [];
        for (let i = 0; i < this.N; i++) {
          const s = this.scoreDoc(qTokens, i);
          if (s > 0) scores.push({ idx:i, score:s });
        }
        scores.sort((a,b) => b.score - a.score);
        return scores.slice(0, topN);
      }
    }

    // ============================================================
    // 状態管理
    // ============================================================
    let workbook = null;
    let currentRows = [];      // 元Excel全行
    let currentColumns = [];   // 列名一覧
    let currentPreset = 'industrial';
    let currentResults = [];   // 抽出結果
    let reviewState = {};      // {idx: 'adopt'|'reject'|'modify'}

    // ============================================================
    // PRESET 切り替え
    // ============================================================
    document.querySelectorAll('.preset-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentPreset = btn.dataset.preset;
      });
    });
    document.querySelector('.preset-btn[data-preset="industrial"]').classList.add('active');

    // ============================================================
    // サンプル仕様書ロード
    // ============================================================
    document.getElementById('btn-load-sample').addEventListener('click', () => {
      const sample = SAMPLE_SPECS[currentPreset];
      currentRows = sample.map((s, i) => ({
        '行': i + 2,
        '章番号': s.ch,
        '仕様種別': s.type,
        '要求仕様': s.spec,
      }));
      currentColumns = ['行', '章番号', '仕様種別', '要求仕様'];
      showFileInfo(`サンプル: ${RISK_DICT[currentPreset].name} 仕様書（${sample.length}行）読込完了`);
      setupMappingUI(['Sheet1'], { spec:'要求仕様', chapter:'章番号', type:'仕様種別', owner:'' });
      document.getElementById('mapping-section').style.display = 'block';
      document.getElementById('execute-section').style.display = 'flex';
    });

    // ============================================================
    // Excel アップロード
    // ============================================================
    document.getElementById('excel-upload').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const fp = document.getElementById('file-progress');
      const fpb = document.getElementById('file-progress-bar');
      fp.style.display = 'block'; fpb.style.width = '20%';
      try {
        const buf = await file.arrayBuffer();
        fpb.style.width = '60%';
        workbook = XLSX.read(buf, { type:'array' });
        fpb.style.width = '90%';
        const sheets = workbook.SheetNames;
        showFileInfo(`📂 ${file.name} (${(file.size/1024).toFixed(0)}KB) | シート ${sheets.length}枚: ${sheets.join(', ')}`);
        setupMappingUI(sheets);
        document.getElementById('mapping-section').style.display = 'block';
        document.getElementById('execute-section').style.display = 'flex';
        fpb.style.width = '100%';
        setTimeout(() => { fp.style.display = 'none'; }, 500);
      } catch (err) {
        alert('Excel読込エラー: ' + err.message);
        fp.style.display = 'none';
      }
      e.target.value = '';
    });

    function showFileInfo(text) {
      const fi = document.getElementById('file-info');
      fi.style.display = 'block';
      fi.textContent = text;
    }

    // ============================================================
    // シート選択 & 列マッピング UI
    // ============================================================
    function setupMappingUI(sheets, autoMap=null) {
      const ss = document.getElementById('sheet-select');
      ss.innerHTML = '';
      for (const s of sheets) {
        const opt = document.createElement('option');
        opt.value = s; opt.textContent = s;
        ss.appendChild(opt);
      }
      ss.onchange = () => loadSheetData();
      loadSheetData(autoMap);
    }

    function loadSheetData(autoMap=null) {
      if (workbook) {
        const ssVal = document.getElementById('sheet-select').value;
        const ws = workbook.Sheets[ssVal];
        currentRows = XLSX.utils.sheet_to_json(ws, { defval:'', header:'A' });
        // ヘッダ行抽出（1行目）
        if (currentRows.length === 0) { currentColumns = []; return; }
        const headers = currentRows[0];
        currentColumns = Object.values(headers).filter(v => v && String(v).trim());
        // ヘッダ行を除外して再構築
        currentRows = currentRows.slice(1).map((r, i) => {
          const obj = { _row: i + 2 };
          const keys = Object.keys(headers);
          for (const k of keys) obj[headers[k]] = r[k] !== undefined ? r[k] : '';
          return obj;
        });
      }
      populateColSelects(autoMap);
      renderPreview();
    }

    function populateColSelects(autoMap=null) {
      const cols = currentColumns;
      const auto = autoMap || autoDetectColumns(cols);
      const sels = [
        { id:'col-spec',    keys:['要求仕様','仕様文','要求事項','requirement','spec','specification','要求'], def:auto.spec },
        { id:'col-chapter', keys:['章番号','章','chapter','section','no'],                                       def:auto.chapter },
        { id:'col-type',    keys:['仕様種別','種別','type','カテゴリ','category'],                               def:auto.type },
        { id:'col-owner',   keys:['所掌','担当','owner','responsible'],                                          def:auto.owner },
      ];
      for (const s of sels) {
        const sel = document.getElementById(s.id);
        sel.innerHTML = '';
        const empty = document.createElement('option');
        empty.value = ''; empty.textContent = '— なし —';
        sel.appendChild(empty);
        for (const c of cols) {
          const opt = document.createElement('option');
          opt.value = c; opt.textContent = c;
          if (c === s.def) opt.selected = true;
          sel.appendChild(opt);
        }
      }
    }

    function autoDetectColumns(cols) {
      const lc = cols.map(c => String(c).toLowerCase());
      const find = (kws) => {
        for (const kw of kws) {
          const idx = lc.findIndex(c => c.includes(kw));
          if (idx >= 0) return cols[idx];
        }
        return '';
      };
      return {
        spec:    find(['要求仕様','仕様文','要求事項','requirement','spec','要求','仕様']),
        chapter: find(['章番号','章','chapter','section']),
        type:    find(['仕様種別','種別','type','category','カテゴリ']),
        owner:   find(['所掌','担当','owner']),
      };
    }

    function renderPreview() {
      const pa = document.getElementById('preview-area');
      const cs = document.getElementById('col-spec').value;
      if (!cs || currentRows.length === 0) { pa.innerHTML = ''; return; }
      const sample = currentRows.slice(0, 3);
      pa.innerHTML = `
        <div style="color:rgba(255,255,255,0.4);font-size:0.62rem;letter-spacing:0.2em;margin-bottom:0.4rem;">PREVIEW（先頭3行）</div>
        <div style="background:#0a0a0c;border:1px solid rgba(255,255,255,0.05);padding:0.65rem 0.85rem;font-size:0.74rem;line-height:1.6;color:rgba(237,237,232,0.7);">
          ${sample.map((r,i) => `<div style="margin-bottom:0.3rem;"><span style="color:#c8a96e;font-size:0.7rem;">${i+1}.</span> ${escapeHtml(String(r[cs]||'').substring(0,200))}</div>`).join('')}
        </div>`;
    }
    document.getElementById('col-spec').addEventListener('change', renderPreview);

    function escapeHtml(s) { return String(s).replace(/[&<>"']/g, m => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m])); }

    // ============================================================
    // リスク抽出メイン
    // ============================================================
    document.getElementById('btn-extract').addEventListener('click', () => {
      runExtraction();
    });
    document.getElementById('btn-reset').addEventListener('click', () => {
      currentResults = []; reviewState = {};
      document.getElementById('result-area').style.display = 'none';
      document.getElementById('mapping-section').style.display = 'none';
      document.getElementById('execute-section').style.display = 'none';
      document.getElementById('file-info').style.display = 'none';
      workbook = null; currentRows = []; currentColumns = [];
    });

    let extractAborted = false;
    async function runExtraction() {
      const colSpec = document.getElementById('col-spec').value;
      const colCh   = document.getElementById('col-chapter').value;
      const colTy   = document.getElementById('col-type').value;
      const colOw   = document.getElementById('col-owner').value;
      if (!colSpec) { alert('要求仕様文の列を指定してください'); return; }
      log('extract_start', `preset=${currentPreset} rows=${currentRows.length} dict=${activeDictVersion||'base'}`);

      // 大容量警告（ESC中断に対応）
      if (currentRows.length > 5000) {
        if (!confirm(`${currentRows.length}行は大容量です。処理を続けますか？（処理中はESCキーで中断できます）`)) {
          log('extract_canceled', '');
          return;
        }
      }
      extractAborted = false;
      const t0 = performance.now();

      // === 学習済み辞書を取得（CODEX指摘 Critical#2 への対応）===
      const dict = getEffectiveDict(currentPreset);
      const suppressedSet = new Set((extendedDicts[currentPreset]?.suppressed || []));
      const results = [];
      const docs = currentRows.map(r => String(r[colSpec]||''));

      // === BM25 インデックス構築 + 辞書語クエリで検索（CODEX指摘 Critical#1 への対応）===
      const bm25 = new BM25();
      bm25.fit(docs);
      const dictWords = [...dict.high, ...dict.mid, ...dict.low].filter(e => !suppressedSet.has(e.word)).map(e => e.word);
      const dictQuery = dictWords.join(' ');
      const bmHits = bm25.search(dictQuery, docs.length);
      const bmScoreByIdx = Object.fromEntries(bmHits.map(r => [r.idx, r.score]));
      const maxBM = Math.max(0.0001, ...bmHits.map(r => r.score));

      // 辞書全体のベクトル化（類似度比較の参照）
      const dictText = [...dict.high, ...dict.mid, ...dict.low].filter(e => !suppressedSet.has(e.word)).map(e => `${e.word} ${e.why}`).join(' ');
      const dictVec = vectorize(dictText);

      // 過去レビューDB（採用文ベクトル）— 採用された語パターンを学習材料に
      const pastReviews = await dbGetAll('reviews').catch(() => []);
      const adoptedReviewVecs = pastReviews.filter(r => r.decision === 'adopt' || r.decision === 'modify').map(r => ({
        v: vectorize((r.modifiedSpec || r.spec) || ''),
        decision: r.decision,
      }));
      const rejectedReviewVecs = pastReviews.filter(r => r.decision === 'reject').map(r => ({ v: vectorize(r.spec || ''), decision:'reject' }));

      // === メインループ（ESC中断対応・チャンク処理）===
      const CHUNK = 200;
      for (let i = 0; i < currentRows.length; i++) {
        if (extractAborted) { log('extract_aborted', `at row ${i}/${currentRows.length}`); break; }
        if (i > 0 && i % CHUNK === 0) {
          await new Promise(r => setTimeout(r, 0)); // yield UI
        }
        const row = currentRows[i];
        const text = String(row[colSpec]||'');
        if (!text.trim()) continue;

        // 1) 辞書ヒット検出（suppressed 除外）
        const hits = { high:[], mid:[], low:[] };
        for (const lvl of ['high','mid','low']) {
          for (const ent of dict[lvl]) {
            if (suppressedSet.has(ent.word)) continue;
            if (text.indexOf(ent.word) >= 0) hits[lvl].push(ent);
          }
        }
        const totalHits = hits.high.length + hits.mid.length + hits.low.length;

        // 2) BM25 スコア（正規化 0〜1）
        const bmScore = (bmScoreByIdx[i] || 0) / maxBM;

        // 3) ベクトル類似度（辞書ベクトルとのコサイン類似度）
        const docVec = vectorize(text);
        const vecSim = cosineSim(docVec, dictVec);

        // 4) 過去レビュー類似度（採用過去とどれだけ似ているか）
        let pastAdoptSim = 0, pastRejectSim = 0;
        for (const rv of adoptedReviewVecs) { const s = cosineSim(docVec, rv.v); if (s > pastAdoptSim) pastAdoptSim = s; }
        for (const rv of rejectedReviewVecs){ const s = cosineSim(docVec, rv.v); if (s > pastRejectSim) pastRejectSim = s; }

        // 候補化判定: 辞書/BM25/ベクトル/過去採用 のいずれかでスコアが立てば候補
        if (totalHits === 0 && bmScore < 0.30 && vecSim < 0.15 && pastAdoptSim < 0.5) continue;

        // 重大度判定
        let level = 'low';
        if (hits.high.length > 0) level = 'high';
        else if (hits.mid.length > 0) level = 'mid';
        else if (bmScore >= 0.55 || vecSim >= 0.25) level = 'mid'; // 辞書非ヒットでも検索強なら注意

        // 統合信頼度（CODEX指摘 Critical#1 + Suggestion対応：複数指標を可視化）
        const dictScore = Math.min(1, (hits.high.length*0.35 + hits.mid.length*0.18 + hits.low.length*0.08));
        const pastBonus = pastAdoptSim * 0.5 - pastRejectSim * 0.5;
        const totalScore =
          0.35 * dictScore +
          0.25 * bmScore +
          0.20 * vecSim +
          0.10 * Math.max(0, pastBonus) +
          0.10 * Math.min(1, totalHits/4);
        const confidence = Math.round(Math.max(0, Math.min(100, totalScore * 100)));

        const highlightedText = highlightHits(text, [...hits.high, ...hits.mid, ...hits.low]);

        results.push({
          idx: i, rowNum: row._row || i + 2,
          chapter: colCh ? String(row[colCh]||'') : '',
          specType: colTy ? String(row[colTy]||'') : '',
          owner: colOw ? String(row[colOw]||'') : '',
          spec: text, highlightedSpec: highlightedText,
          level, confidence, hits,
          allHits: [...hits.high, ...hits.mid, ...hits.low],
          bmScorePct: Math.round(bmScore * 100),
          vecSimPct: Math.round(vecSim * 100),
          dictScorePct: Math.round(dictScore * 100),
          pastAdoptSim: Math.round(pastAdoptSim * 100),
          pastRejectSim: Math.round(pastRejectSim * 100),
        });
      }

      // 重大度・信頼度降順でソート
      const lvlOrder = { high:0, mid:1, low:2 };
      results.sort((a,b) => lvlOrder[a.level] - lvlOrder[b.level] || b.confidence - a.confidence);

      currentResults = results;
      reviewState = {};

      const elapsed = performance.now() - t0;
      renderResults(elapsed);
      log('extract_done', `${results.length}件 / ${(elapsed).toFixed(0)}ms / dict=${activeDictVersion||'base'}`);
      await refreshLearningStats();
    }

    function highlightHits(text, hits) {
      let result = escapeHtml(text);
      // 長い語から先にハイライト（部分一致衝突避け）
      const sortedHits = [...hits].sort((a,b) => b.word.length - a.word.length);
      const seen = new Set();
      for (const h of sortedHits) {
        if (seen.has(h.word)) continue;
        seen.add(h.word);
        const re = new RegExp(h.word.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'), 'g');
        result = result.replace(re, `<span class="keyword-hit" title="${escapeHtml(h.why)}">${h.word}</span>`);
      }
      return result;
    }

    // ============================================================
    // 結果表示
    // ============================================================
    function renderResults(elapsedMs) {
      const total = currentRows.length;
      const high = currentResults.filter(r => r.level === 'high').length;
      const mid  = currentResults.filter(r => r.level === 'mid').length;
      const low  = currentResults.filter(r => r.level === 'low').length;
      document.getElementById('m-total').textContent = total;
      document.getElementById('m-high').textContent = high;
      document.getElementById('m-mid').textContent = mid;
      document.getElementById('m-low').textContent = low;
      document.getElementById('m-time').textContent = elapsedMs < 1000 ? Math.round(elapsedMs)+'ms' : (elapsedMs/1000).toFixed(2)+'s';

      renderTable();
      document.getElementById('result-area').style.display = 'block';
    }

    function renderTable() {
      const filter = document.getElementById('filter-level').value;
      const tbody = document.getElementById('risk-tbody');
      tbody.innerHTML = '';
      const frag = document.createDocumentFragment();
      const filtered = currentResults.filter(r => {
        if (filter === 'all') return true;
        if (filter === 'high') return r.level === 'high';
        if (filter === 'mid')  return r.level === 'high' || r.level === 'mid';
        return true;
      });
      if (filtered.length === 0) {
        const tr = document.createElement('tr');
        tr.innerHTML = `<td class="td" colspan="4" style="text-align:center;color:rgba(255,255,255,0.5);">該当するリスク候補はありません</td>`;
        frag.appendChild(tr);
      } else {
        filtered.forEach(r => frag.appendChild(buildRow(r)));
      }
      tbody.appendChild(frag);
    }

    function buildRow(r) {
      const tr = document.createElement('tr');
      tr.className = `risk-row ${r.level}`;
      const badge = r.level === 'high' ? '<span class="badge-high">⚠ 重大</span>' : r.level === 'mid' ? '<span class="badge-mid">注意</span>' : '<span class="badge-low">参考</span>';
      const meta = [];
      if (r.chapter)  meta.push(`<span style="color:rgba(255,255,255,0.4);font-size:0.7rem;">章:${escapeHtml(r.chapter)}</span>`);
      if (r.specType) meta.push(`<span style="color:rgba(255,255,255,0.4);font-size:0.7rem;">種別:${escapeHtml(r.specType)}</span>`);
      if (r.owner)    meta.push(`<span style="color:rgba(255,255,255,0.4);font-size:0.7rem;">所掌:${escapeHtml(r.owner)}</span>`);
      const reasons = r.allHits.length > 0
        ? r.allHits.map(h => `<li style="margin-bottom:0.15rem;"><strong style="color:#c8a96e;">${escapeHtml(h.word)}</strong>: <span style="color:rgba(255,255,255,0.6);">${escapeHtml(h.why)}</span></li>`).join('')
        : '<li style="color:rgba(255,255,255,0.5);">（辞書一致なし・BM25/類似度ヒット）</li>';
      // CODEX指摘 Suggestion: スコア内訳を可視化（辞書/BM25/ベクトル/過去レビュー）
      const scoreBadges = `
        <div style="display:flex;gap:0.35rem;flex-wrap:wrap;margin-top:0.5rem;font-size:0.62rem;">
          <span style="background:rgba(200,169,110,0.12);color:#c8a96e;border:1px solid rgba(200,169,110,0.25);padding:0.08rem 0.4rem;">辞書 ${r.dictScorePct}</span>
          <span style="background:rgba(110,180,200,0.10);color:#80c4d8;border:1px solid rgba(110,180,200,0.25);padding:0.08rem 0.4rem;">BM25 ${r.bmScorePct}</span>
          <span style="background:rgba(160,140,200,0.10);color:#a89cd0;border:1px solid rgba(160,140,200,0.25);padding:0.08rem 0.4rem;">類似度 ${r.vecSimPct}</span>
          ${r.pastAdoptSim > 30 ? `<span style="background:rgba(110,200,151,0.10);color:#6ec897;border:1px solid rgba(110,200,151,0.30);padding:0.08rem 0.4rem;">過去採用 ${r.pastAdoptSim}</span>` : ''}
          ${r.pastRejectSim > 30 ? `<span style="background:rgba(255,80,80,0.08);color:#ff8888;border:1px solid rgba(255,80,80,0.25);padding:0.08rem 0.4rem;">過去不採用 ${r.pastRejectSim}</span>` : ''}
        </div>`;
      const isModify = reviewState[r.idx] === 'modify';
      const modifiedVal = reviewModified[r.idx] || '';
      tr.innerHTML = `
        <td class="td" style="color:rgba(255,255,255,0.4);font-size:0.72rem;">${r.rowNum}</td>
        <td class="td">
          <div style="margin-bottom:0.4rem;">${badge}${meta.join(' / ')}</div>
          <div style="margin-bottom:0.5rem;line-height:1.6;">${r.highlightedSpec}</div>
          ${scoreBadges}
          <details style="font-size:0.72rem;margin-top:0.5rem;">
            <summary style="cursor:pointer;color:rgba(255,255,255,0.5);outline:none;">推定根拠を見る ▼</summary>
            <ul style="margin:0.4rem 0 0 0;padding-left:1.2rem;">${reasons}</ul>
          </details>
          <div id="modify-area-${r.idx}" style="display:${isModify?'block':'none'};margin-top:0.6rem;">
            <label style="color:rgba(255,255,255,0.5);font-size:0.66rem;letter-spacing:0.1em;display:block;margin-bottom:0.25rem;">修正後リスク内容（学習に保存）</label>
            <textarea class="modify-textarea" data-idx="${r.idx}" rows="2" style="width:100%;background:#0a0a0c;color:#edede8;border:1px solid rgba(200,169,110,0.3);padding:0.4rem 0.55rem;font-size:0.78rem;font-family:inherit;outline:none;line-height:1.5;">${escapeHtml(modifiedVal)}</textarea>
          </div>
        </td>
        <td class="td" style="text-align:center;">
          <div style="font-size:1rem;font-weight:600;color:${r.level==='high'?'#ff8888':r.level==='mid'?'#c8a96e':'#999'};">${r.confidence}</div>
          <div style="color:rgba(255,255,255,0.35);font-size:0.65rem;">/100</div>
        </td>
        <td class="td">
          <select class="review-select" data-idx="${r.idx}">
            <option value="">— 未レビュー —</option>
            <option value="adopt">✓ 採用</option>
            <option value="modify">修正して採用</option>
            <option value="reject">✗ 不採用</option>
          </select>
        </td>`;
      const sel = tr.querySelector('select.review-select');
      sel.value = reviewState[r.idx] || '';
      if (sel.value) sel.classList.add(sel.value);
      return tr;
    }

    document.getElementById('filter-level').addEventListener('change', renderTable);

    // ============================================================
    // Excel出力（別ファイル・原本を上書きしない）
    // ============================================================
    document.getElementById('btn-export').addEventListener('click', () => {
      if (currentResults.length === 0) { alert('抽出結果がありません'); return; }
      const wb = XLSX.utils.book_new();
      const dictName = RISK_DICT[currentPreset].name;

      // シート1: リスク候補
      const riskData = currentResults.map(r => ({
        '元行番号': r.rowNum,
        '章番号': r.chapter,
        '仕様種別': r.specType,
        '所掌': r.owner,
        '要求仕様文': r.spec,
        '重大度': r.level === 'high' ? '⚠ 重大' : r.level === 'mid' ? '注意' : '参考',
        '信頼度(0-100)': r.confidence,
        '一致リスク語': r.allHits.map(h => h.word).join(', '),
        '推定根拠': r.allHits.map(h => `${h.word}: ${h.why}`).join(' / '),
        'レビュー': reviewState[r.idx] === 'adopt' ? '採用' : reviewState[r.idx] === 'modify' ? '修正して採用' : reviewState[r.idx] === 'reject' ? '不採用' : '未レビュー',
        '修正後リスク内容': '',
        'コメント': '',
        '使用辞書': dictName,
