      const ws1 = XLSX.utils.json_to_sheet(riskData);
      // 列幅: 元行/章/種別/所掌/Proj/引合/E&C&LT入力/推定/E/C/LT/スコア/Doc/仕様文/判定/信頼度/一致語/根拠/レビュー/修正/コメント/辞書/日時 = 23列
