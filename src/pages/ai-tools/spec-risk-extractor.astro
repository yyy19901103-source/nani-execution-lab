      const mapData = [
        { '内部項目':'要求仕様文', '入力Excel列名':colSpec },
        { '内部項目':'章番号',   '入力Excel列名':colCh },
        { '内部項目':'仕様種別', '入力Excel列名':colTy },
        { '内部項目':'所掌',     '入力Excel列名':colOw },
      ];
      const ws3 = XLSX.utils.json_to_sheet(mapData);
      ws3['!cols'] = [{wch:20},{wch:30}];
      XLSX.utils.book_append_sheet(wb, ws3, '列対応');

      // シート4: リスク辞書（使用版）
      const dict = RISK_DICT[currentPreset];
      const dictData = [
        ...dict.high.map(e => ({ '重大度':'⚠ 重大','語':e.word,'判断材料(why)':e.why })),
        ...dict.mid .map(e => ({ '重大度':'注意',   '語':e.word,'判断材料(why)':e.why })),
        ...dict.low .map(e => ({ '重大度':'参考',   '語':e.word,'判断材料(why)':e.why })),
      ];
      const ws4 = XLSX.utils.json_to_sheet(dictData);
      ws4['!cols'] = [{wch:10},{wch:18},{wch:60}];
      XLSX.utils.book_append_sheet(wb, ws4, 'リスク辞書');

      const filename = `spec-risk-${currentPreset}-${new Date().toISOString().slice(0,10)}.xlsx`;
      XLSX.writeFile(wb, filename);
    });

    // ============================================================
    // CSVテンプレートDL
    // ============================================================
    document.getElementById('btn-template').addEventListener('click', () => {
      const wb = XLSX.utils.book_new();
