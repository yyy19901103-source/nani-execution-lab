    }

    // ===== 第5段階: IndexedDB ラッパー（CODEX指摘 Major: dbPromise キャッシュ + tx.oncomplete 待ち） =====
    const DB_NAME = 'spec-risk-db';
    const DB_VER = 1;
    let _dbPromise = null;  // open Promise 自体をキャッシュ → 同時呼び出しでも一本化
    function openDB() {
      if (_dbPromise) return _dbPromise;
      _dbPromise = new Promise((resolve, reject) => {
        const req = indexedDB.open(DB_NAME, DB_VER);
        req.onupgradeneeded = e => {
          const db = e.target.result;
          if (!db.objectStoreNames.contains('reviews'))     db.createObjectStore('reviews',     { keyPath:'id', autoIncrement:true });
          if (!db.objectStoreNames.contains('dictVersions'))db.createObjectStore('dictVersions',{ keyPath:'version' });
          if (!db.objectStoreNames.contains('modelMeta'))   db.createObjectStore('modelMeta',   { keyPath:'key' });
          if (!db.objectStoreNames.contains('learningQ'))   db.createObjectStore('learningQ',   { keyPath:'id', autoIncrement:true });
        };
        req.onsuccess = e => resolve(e.target.result);
        req.onerror   = e => { _dbPromise = null; reject(e.target.error); };
        req.onblocked = () => { /* 別タブで開きっぱなし等 */ };
      });
      return _dbPromise;
    }
    // tx.oncomplete を待つ（書き込み確定保証）
    function dbPut(store, value) {
      return openDB().then(db => new Promise((res, rej) => {
        const tx = db.transaction(store, 'readwrite');
        let result;
        const r = tx.objectStore(store).put(value);
        r.onsuccess = () => { result = r.result; };
        r.onerror   = () => rej(r.error);
        tx.oncomplete = () => res(result);
        tx.onabort    = () => rej(tx.error || new Error('tx aborted'));
        tx.onerror    = () => rej(tx.error);
      }));
    }
    function dbGetAll(store) {
      return openDB().then(db => new Promise((res, rej) => {
        const tx = db.transaction(store, 'readonly');
        const r = tx.objectStore(store).getAll();
        r.onsuccess = () => res(r.result || []);
        r.onerror   = () => rej(r.error);
        tx.onabort  = () => rej(tx.error || new Error('tx aborted'));
      }));
    }
    function dbClear(store) {
      return openDB().then(db => new Promise((res, rej) => {
        const tx = db.transaction(store, 'readwrite');
        tx.objectStore(store).clear();
        tx.oncomplete = () => res();
        tx.onabort    = () => rej(tx.error || new Error('tx aborted'));
        tx.onerror    = () => rej(tx.error);
      }));
    }

    // ===== 第3段階: 文章ベクトル類似度（bag-of-bigrams + コサイン類似度） =====
    function vectorize(text) {
      const tokens = tokenize(text);
      const v = {};
      for (const t of tokens) v[t] = (v[t]||0)+1;
      // L2正規化
      let norm = 0;
      for (const k in v) norm += v[k]*v[k];
      norm = Math.sqrt(norm) || 1;
      for (const k in v) v[k] /= norm;
      return v;
    }
    function cosineSim(va, vb) {
      let s = 0;
      for (const k in va) if (vb[k]) s += va[k]*vb[k];
      return s;
    }

    // ===== 第6段階: モデル版管理（辞書バージョン） =====
    let activeDictVersion = null;
    let extendedDicts = {}; // { presetId: { high:[+追加語], mid:[], low:[] } }

    async function loadActiveModel() {
      const meta = await dbGetAll('modelMeta');
      const active = meta.find(m => m.key === 'active');
      if (active) activeDictVersion = active.version;
      const all = await dbGetAll('dictVersions');
      for (const v of all) {
        if (v.version === activeDictVersion) {
          extendedDicts = v.extended || {};
          log('model_load', `version=${v.version}`);
          return;
        }
      }
    }

    function getEffectiveDict(presetId) {
      const base = RISK_DICT[presetId];
      const ext = extendedDicts[presetId] || { high:[], mid:[], low:[] };
      return {
        name: base.name,
        high: [...base.high, ...(ext.high||[])],
        mid:  [...base.mid,  ...(ext.mid ||[])],
        low:  [...base.low,  ...(ext.low ||[])],
      };
    }

    // ===== 第5段階: レビュー保存（CODEX指摘 Major対応: upsert で重複蓄積を防ぐ） =====
    const reviewModified = {}; // idx -> 修正後仕様テキスト
    let lastReviewIdByCandidate = {}; // candidateKey -> 最後に書いたreviewのid

    function candidateKey(r) {
      // 安定論理キー: preset + rowNum + spec の簡易ハッシュ
      const h = simpleHash(r.spec || '');
      return `${currentPreset}|${r.rowNum}|${h}`;
    }
    function simpleHash(s) {
      let h = 0;
      for (let i = 0; i < s.length; i++) { h = ((h << 5) - h + s.charCodeAt(i)) | 0; }
      return h.toString(36);
    }

    // 起動時に既存レビューから lastReviewIdByCandidate を再構築
    async function rebuildReviewIndex() {
      try {
        const all = await dbGetAll('reviews');
        const seen = {};
        for (const rec of all) {
          // 同じ key で複数あれば最新（updatedAt or ts 最大）を採用
          const key = `${rec.preset}|${rec.rowNum}|${simpleHash(rec.spec||'')}`;
          if (!seen[key] || (rec.updatedAt || rec.ts || '') > (seen[key].updatedAt || seen[key].ts || '')) {
            seen[key] = rec;
          }
        }
        lastReviewIdByCandidate = {};
        for (const k in seen) lastReviewIdByCandidate[k] = seen[k].id;
      } catch (err) { console.warn(err); }
    }

    document.addEventListener('change', async (e) => {
      const sel = e.target.closest('.review-select');
      if (sel) {
        const idx = parseInt(sel.dataset.idx, 10);
        const r = currentResults.find(x => x.idx === idx);
        if (!r) return;
        const decision = sel.value;
        reviewState[idx] = decision;
        const modifyArea = document.getElementById(`modify-area-${idx}`);
        if (modifyArea) modifyArea.style.display = decision === 'modify' ? 'block' : 'none';
        if (!decision) return;
        await persistReview(r, decision);
      }
      const ta = e.target.closest('.modify-textarea');
      if (ta) {
        const idx = parseInt(ta.dataset.idx, 10);
        reviewModified[idx] = ta.value;
        const r = currentResults.find(x => x.idx === idx);
        if (r && reviewState[idx] === 'modify') {
          await persistReview(r, 'modify');
        }
      }
    });

    async function persistReview(r, decision) {
      try {
        const key = candidateKey(r);
        const now = new Date().toISOString();
        const record = {
          ts: now,
          updatedAt: now,
          preset: currentPreset,
          rowNum: r.rowNum,
          dictVersion: activeDictVersion || 'base',
          spec: r.spec,
          modifiedSpec: decision === 'modify' ? (reviewModified[r.idx] || '') : '',
          chapter: r.chapter,
          specType: r.specType,
          owner: r.owner,
          level: r.level,
          confidence: r.confidence,
          hits: r.allHits.map(h => h.word),
          decision,
        };
        // 既存IDがあれば上書き（upsert）
        if (lastReviewIdByCandidate[key] != null) {
          record.id = lastReviewIdByCandidate[key];
        }
        const newId = await dbPut('reviews', record);
        lastReviewIdByCandidate[key] = newId;
        log('review_save', `key=${key.substring(0,30)} ${decision}${decision==='modify'?' +mod':''} id=${newId}`);
        await refreshLearningStats();
      } catch (err) { console.warn(err); }
    }

    // ===== 第5段階: 学習統計表示・評価指標 =====
    async function refreshLearningStats() {
      const reviews = await dbGetAll('reviews');
      const elN  = document.getElementById('stat-reviews');
      const elAd = document.getElementById('stat-adopt');
      const elMd = document.getElementById('stat-modify');
      const elRj = document.getElementById('stat-reject');
      const elRc = document.getElementById('stat-recall');
      if (!elN) return;
      const adopt   = reviews.filter(r => r.decision === 'adopt').length;
      const modify  = reviews.filter(r => r.decision === 'modify').length;
      const reject  = reviews.filter(r => r.decision === 'reject').length;
      // 「対象候補の人手承認率」（CODEX指摘 Major: Recall という名前は誤りだったため修正・Phase2で「対象」に改称）
      // 重大判定された候補のうち、レビューで「採用 or 修正採用」された割合 = 辞書精度の見方
      const highReviews = reviews.filter(r => r.level === 'high');
      const highAccepted = highReviews.filter(r => r.decision === 'adopt' || r.decision === 'modify').length;
      const acceptRate = highReviews.length > 0 ? Math.round(highAccepted / highReviews.length * 100) : 0;
      elN.textContent  = reviews.length;
      elAd.textContent = adopt;
      elMd.textContent = modify;
      elRj.textContent = reject;
      elRc.textContent = `${acceptRate}%`;
      const panel = document.getElementById('learning-panel');
      if (panel && reviews.length > 0) panel.style.display = 'block';
    }

    // ===== 第6段階: 学習実行（CODEX指摘 Critical#2: 実際に extendedDicts を更新する） =====
    document.addEventListener('click', async (e) => {
      if (e.target && e.target.id === 'btn-train') {
        const reviews = await dbGetAll('reviews');
        if (reviews.length < 3) { alert('レビュー件数が少なすぎます（3件以上推奨）'); return; }
        log('train_start', `reviews=${reviews.length}`);
        // 採用された hits の頻度カウント
        const wordStats = {};
        for (const r of reviews) {
          for (const w of (r.hits||[])) {
            if (!wordStats[w]) wordStats[w] = { adopt:0, modify:0, reject:0, preset:r.preset };
            wordStats[w][r.decision] = (wordStats[w][r.decision]||0)+1;
          }
        }
        // 辞書を実更新する
        const newExt = JSON.parse(JSON.stringify(extendedDicts));
        let strengthened = 0, weakened = 0;
        for (const w in wordStats) {
          const s = wordStats[w];
          const total = s.adopt + s.modify + s.reject;
          if (total < 2) continue;
          const adoptRate = (s.adopt + 0.5*s.modify) / total;
          if (!newExt[s.preset]) newExt[s.preset] = { high:[], mid:[], low:[], suppressed:[] };
          if (!newExt[s.preset].suppressed) newExt[s.preset].suppressed = [];

          // 既存辞書のどのレベルに該当するか
          const baseDict = RISK_DICT[s.preset];
          let foundLevel = null;
          for (const lvl of ['high','mid','low']) {
            if (baseDict[lvl].some(en => en.word === w)) { foundLevel = lvl; break; }
          }

          if (adoptRate >= 0.8 && total >= 3) {
            // 強化: 既存辞書に無い新語なら 'high' として追加。あればそのまま（重み再強化はsuppressed解除のみ）
            if (!foundLevel) {
              if (!newExt[s.preset].high.some(en => en.word === w)) {
                newExt[s.preset].high.push({
                  word: w,
                  why: `レビュー学習（採用率${Math.round(adoptRate*100)}%・${total}件のレビューに基づき強化）`
                });
                strengthened++;
              }
            }
            // suppressed から外す（誤って弱化されていた場合の復活）
            const sIdx = newExt[s.preset].suppressed.indexOf(w);
            if (sIdx >= 0) { newExt[s.preset].suppressed.splice(sIdx, 1); strengthened++; }
          }
          if (adoptRate <= 0.2 && total >= 3) {
            // 弱化: suppressed リストに追加（本抽出で hit から除外される）
            if (!newExt[s.preset].suppressed.includes(w)) {
              newExt[s.preset].suppressed.push(w);
              weakened++;
            }
          }
        }
        // 新バージョン作成
        const newVer = 'v-' + new Date().toISOString().replace(/[:.]/g,'-');
        await dbPut('dictVersions', {
          version: newVer,
          baseAt: new Date().toISOString(),
          extended: newExt,
          stats: { reviewsUsed: reviews.length, strengthened, weakened },
        });
        log('train_done', `version=${newVer} +${strengthened} -${weakened}`);
        // 旧モデルとの新旧比較
        await runComparison(newVer);
      }
      if (e.target && e.target.id === 'btn-adopt-new') {
        const newVer = e.target.dataset.version;
        if (!newVer) return;
        await dbPut('modelMeta', { key:'active', version:newVer });
        activeDictVersion = newVer;
        const v = (await dbGetAll('dictVersions')).find(x => x.version === newVer);
        if (v) extendedDicts = v.extended || {};
        log('model_switch', newVer);
        document.getElementById('compare-result').innerHTML = `<div style="color:#6ec897;font-size:0.78rem;padding:0.5rem 0.85rem;background:rgba(110,200,151,0.08);border:1px solid rgba(110,200,151,0.3);">✓ 新モデル <strong>${newVer}</strong> を採用しました。次回デビクラ抽出から有効。</div>`;
      }
      if (e.target && e.target.id === 'btn-revert') {
        await dbPut('modelMeta', { key:'active', version:'base' });
        activeDictVersion = 'base';
        extendedDicts = {};
        log('model_revert', 'base');
        document.getElementById('compare-result').innerHTML = `<div style="color:rgba(255,255,255,0.7);font-size:0.78rem;padding:0.5rem 0.85rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);">↺ ベース辞書に戻しました（学習効果は無効化）。</div>`;
      }
      if (e.target && e.target.id === 'btn-clear-reviews') {
        if (!confirm('レビュー履歴を全削除します。よろしいですか？')) return;
        await dbClear('reviews');
        log('reviews_cleared', '');
        await refreshLearningStats();
        alert('レビュー履歴を全削除しました');
      }
    });

    // ===== 第6段階: 新旧モデル比較 =====
    async function runComparison(newVer) {
      if (currentResults.length === 0) {
        document.getElementById('compare-result').innerHTML = '<div style="color:rgba(255,255,255,0.5);font-size:0.78rem;">先にデビクラ抽出を実行してください（同じ仕様書で旧/新モデルを比較）</div>';
        return;
      }
      // 旧モデル(=現在のcurrentResults)と新モデル(extendedDicts更新後)を比較
      const oldHigh = currentResults.filter(r => r.level === 'high').map(r => r.idx);
      const oldTop10 = currentResults.slice(0, 10).map(r => r.idx);
      // 新辞書で再抽出
      const versions = await dbGetAll('dictVersions');
      const newV = versions.find(v => v.version === newVer);
      const savedExt = JSON.parse(JSON.stringify(extendedDicts));
      extendedDicts = newV.extended || {};
      const tempResults = await recomputeResults(); // CODEX対応: await + extractCandidates 共通化済み
      extendedDicts = savedExt;
      const newHigh = tempResults.filter(r => r.level === 'high').map(r => r.idx);
      const newTop10 = tempResults.slice(0, 10).map(r => r.idx);
      const top10Match = oldTop10.filter(i => newTop10.includes(i)).length;
      const highMatch  = oldHigh.filter(i => newHigh.includes(i)).length;
      // CODEX指摘 Major対応: 「重大候補の承認率」は誤称（実装は対象判定 idx の重複率）→ 「対象候補一致率」に正しく改名
      const highMatchRate = oldHigh.length > 0 ? Math.round(highMatch/oldHigh.length*100) : 100;
      const html = `
        <div style="background:#0f0f12;border:1px solid rgba(200,169,110,0.2);padding:1rem 1.25rem;">
          <div style="color:#c8a96e;font-size:0.62rem;letter-spacing:0.3em;margin-bottom:0.75rem;">▸ 新旧モデル比較結果</div>
          <table style="width:100%;font-size:0.78rem;">
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">新バージョン</td><td style="padding:0.25rem;color:#edede8;">${newVer}</td></tr>
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">学習レビュー数</td><td style="padding:0.25rem;color:#edede8;">${newV.stats.reviewsUsed}件</td></tr>
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">辞書語 強化候補</td><td style="padding:0.25rem;color:#6ec897;">+${newV.stats.strengthened}語</td></tr>
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">辞書語 弱化候補</td><td style="padding:0.25rem;color:rgba(255,80,80,0.85);">-${newV.stats.weakened}語</td></tr>
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">「対象」候補一致率（旧∩新／旧）</td><td style="padding:0.25rem;color:#c8a96e;font-weight:600;">${highMatchRate}% (${highMatch}/${oldHigh.length})</td></tr>
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">Top10一致率</td><td style="padding:0.25rem;color:#edede8;">${oldTop10.length>0?Math.round(top10Match/oldTop10.length*100):0}% (${top10Match}/${oldTop10.length})</td></tr>
            <tr><td style="padding:0.25rem;color:rgba(255,255,255,0.55);">新モデル候補数</td><td style="padding:0.25rem;color:rgba(255,255,255,0.6);">${tempResults.length}件 (重大${newHigh.length}件)</td></tr>
          </table>
          <div style="display:flex;gap:0.5rem;margin-top:0.85rem;">
            <button id="btn-adopt-new" data-version="${newVer}" class="m-btn" style="font-size:0.74rem;padding:0.4rem 1rem;">✓ 新モデルを採用</button>
            <button id="btn-revert" class="m-btn-ghost" style="font-size:0.74rem;padding:0.4rem 1rem;">↺ ベースに戻す</button>
          </div>
        </div>`;
      document.getElementById('compare-result').innerHTML = html;
      log('compare_done', `match=${highMatchRate}% top10=${oldTop10.length>0?Math.round(top10Match/oldTop10.length*100):0}%`);
    }

    // CODEX指摘 Major対応: 比較再計算も extractCandidates() を使い本抽出と完全一致
    async function recomputeResults() {
      const colSpec = document.getElementById('col-spec').value;
      if (!colSpec) return [];
      const dict = getEffectiveDict(currentPreset);
      const suppressedSet = new Set((extendedDicts[currentPreset]?.suppressed || []));
      // 過去レビューはキャッシュ（旧/新で同じ集合を使う）
      const past = await dbGetAll('reviews').catch(() => []);
      return await extractCandidates(currentRows, colSpec, dict, suppressedSet, {
        pastReviews: past,
        checkAbort: false,
        yieldUI: false,
        includeHighlight: false,
      });
    }

    // ===== 第7段階: ESCで実際に中断（CODEX指摘 Major: 表示と挙動が一致してなかったので修正） =====
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        if (!extractAborted) {
          extractAborted = true;
          log('escape_pressed', '中断要求');
        }
      }
    });

    // ===== 学習データインポート（既存のデビクラ判定済みExcelを reviews ストアに一括投入） =====
    document.getElementById('learning-upload').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) { return; }
      const status = document.getElementById('learning-status');
      status.textContent = '解析中...';
      status.style.color = '#c8a96e';
      try {
        const buf = await file.arrayBuffer();
        const wb = XLSX.read(buf, { type:'array' });
        // 「正解データ」または「学習データ」シートを優先、なければ先頭シート
        const preferredSheets = ['正解データ', '学習データ', '判定済', 'デビクラ', 'training', 'learning'];
        let sheetName = wb.SheetNames[0];
        for (const ps of preferredSheets) {
          const found = wb.SheetNames.find(n => n.includes(ps));
          if (found) { sheetName = found; break; }
        }
        const ws = wb.Sheets[sheetName];
        const rows = XLSX.utils.sheet_to_json(ws, { defval:'' });
        if (rows.length === 0) throw new Error('シート「' + sheetName + '」に行が無い');

        // 列を自動推定
        const cols = Object.keys(rows[0]);
        const lc = cols.map(c => String(c).toLowerCase());
        const find = (kws) => {
          for (const kw of kws) {
            const idx = lc.findIndex(c => c.includes(kw.toLowerCase()));
            if (idx >= 0) return cols[idx];
          }
          return '';
        };
        const m = {
          spec:     find(['要求仕様','仕様文','要求事項','requirement','spec']),
          devicra:  find(['デビクラ','deviation','判定','正解']),
          category: find(['カテゴリー','カテゴリ','category']),
          project:  find(['project','プロジェクト','案件名']),
          rfq:      find(['引合','rfq']),
          impact:   find(['e&c&lt','e&c','影響']),
          doc:      find(['ドキュメント','document','図書']),
          chapter:  find(['章番号','章','chapter']),
          owner:    find(['所掌','担当','owner']),
        };
        if (!m.spec) throw new Error('「要求仕様」列が見つかりません');
        if (!m.devicra) throw new Error('「デビクラ」列が見つかりません（対象/要確認/対象外 のいずれか）');

        // デビクラ判定 → decision/level マッピング
        // 対象 → adopt + high  /  要確認 → modify + mid  /  対象外 → reject + low
        let imported = 0, skipped = 0;
        for (const r of rows) {
          const spec = String(r[m.spec]||'').trim();
          if (!spec) { skipped++; continue; }
          const devRaw = String(r[m.devicra]||'').trim();
          let decision = '', level = 'mid';
          if (devRaw === '対象')        { decision = 'adopt';  level = 'high'; }
          else if (devRaw === '要確認') { decision = 'modify'; level = 'mid';  }
          else if (devRaw === '対象外') { decision = 'reject'; level = 'low';  }
          else if (devRaw)              { decision = 'modify'; level = 'mid';  } // 未知ラベル → 要確認扱い
          else { skipped++; continue; }

          const rowNum = imported + 2;
          // CODEX 4巡目 Major対応: 通常レビュー保存と同じ candidateKey() ロジックで upsert する
          //   通常: `${preset}|${rowNum}|${simpleHash(spec)}`
          //   旧Bug: imported プレフィックス付きで別キー → 同一Excel再取込で重複蓄積していた
          const key = `${currentPreset}|${rowNum}|${simpleHash(spec)}`;
          const now = new Date().toISOString();
          const record = {
            ts: now,
            updatedAt: now,
            preset: currentPreset,
            rowNum,
            dictVersion: activeDictVersion || 'base',
            spec,
            modifiedSpec: '',
            chapter: m.chapter ? String(r[m.chapter]||'') : '',
            specType: m.category ? String(r[m.category]||'') : '',
            owner: m.owner ? String(r[m.owner]||'') : '',
            project: m.project ? String(r[m.project]||'') : '',
            rfq: m.rfq ? String(r[m.rfq]||'') : '',
            impact: m.impact ? String(r[m.impact]||'') : '',
            doc: m.doc ? String(r[m.doc]||'') : '',
            devicraRaw: devRaw,
            level,
            confidence: decision === 'adopt' ? 90 : (decision === 'modify' ? 60 : 30),
            hits: [],
            decision,
            source: 'imported',
          };
          if (lastReviewIdByCandidate[key] != null) record.id = lastReviewIdByCandidate[key];
          const newId = await dbPut('reviews', record);
          lastReviewIdByCandidate[key] = newId;
          imported++;
        }
        status.textContent = `✓ ${imported}件取り込み (シート「${sheetName}」 / スキップ${skipped}件 / preset=${currentPreset})`;
        status.style.color = '#6ec897';
        log('learning_import', `imported=${imported} skipped=${skipped} sheet=${sheetName}`);
        await refreshLearningStats();
      } catch (err) {
        status.textContent = '❌ 取込エラー: ' + err.message;
        status.style.color = '#ff8888';
        console.warn(err);
      }
      e.target.value = '';
    });

    // ===== 起動時: 学習DB・モデル版・レビューupsert索引を読み込む =====
    (async () => {
      try {
        await loadActiveModel();
        await rebuildReviewIndex();
        await refreshLearningStats();
        log('boot', `model=${activeDictVersion||'base'} reviews=${Object.keys(lastReviewIdByCandidate).length}`);
      } catch (err) { console.warn(err); }
    })();
  </script>

</BaseLayout>
