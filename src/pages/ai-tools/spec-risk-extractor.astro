    // ╔════════════════════════════════════════════════════════════╗
    // ║ 第3〜第7段階拡張（ベクトル検索/学習/新旧比較/評価/版管理）║
    // ╚════════════════════════════════════════════════════════════╝

    // ===== 第7段階: 操作ログ（IndexedDB+console） =====
    const opLog = [];
    function log(action, detail) {
      const entry = { ts: new Date().toISOString(), action, detail };
      opLog.push(entry);
      if (opLog.length > 200) opLog.shift();
      try { console.log('[spec-risk]', action, detail); } catch(_){}
      const elm = document.getElementById('op-log-body');
      if (elm) elm.textContent = opLog.slice(-30).reverse().map(e => `${e.ts.substring(11,19)} ${e.action}${e.detail?': '+e.detail:''}`).join('\n');
    }

    // ===== 第5段階: IndexedDB ラッパー（CODEX指摘 Major: dbPromise キャッシュ + tx.oncomplete 待ち） =====
    const DB_NAME = 'spec-risk-db';
    const DB_VER = 2; // v2: pastCases ObjectStore 追加
    let _dbPromise = null;  // open Promise 自体をキャッシュ → 同時呼び出しでも一本化
    function openDB() {
      if (_dbPromise) return _dbPromise;
      _dbPromise = new Promise((resolve, reject) => {
        const req = indexedDB.open(DB_NAME, DB_VER);
        req.onupgradeneeded = e => {
          const db = e.target.result;
          if (!db.objectStoreNames.contains('reviews'))     db.createObjectStore('reviews',     { keyPath:'id', autoIncrement:true });
          if (!db.objectStoreNames.contains('dictVersions'))db.createObjectStore('dictVersions',{ keyPath:'version' });
          if (!db.objectStoreNames.contains('modelMeta'))   db.createObjectStore('modelMeta',   { keyPath:'key' });
          if (!db.objectStoreNames.contains('learningQ'))   db.createObjectStore('learningQ',   { keyPath:'id', autoIncrement:true });
          if (!db.objectStoreNames.contains('pastCases'))   db.createObjectStore('pastCases',   { keyPath:'id', autoIncrement:true });
        };
        req.onsuccess = e => resolve(e.target.result);
        req.onerror   = e => { _dbPromise = null; reject(e.target.error); };
        req.onblocked = () => { /* 別タブで開きっぱなし等 */ };
      });
      return _dbPromise;
    }
    // tx.oncomplete を待つ（書き込み確定保証）
    function dbPut(store, value) {
      return openDB().then(db => new Promise((res, rej) => {
        const tx = db.transaction(store, 'readwrite');
        let result;
        const r = tx.objectStore(store).put(value);
        r.onsuccess = () => { result = r.result; };
        r.onerror   = () => rej(r.error);
        tx.oncomplete = () => res(result);
        tx.onabort    = () => rej(tx.error || new Error('tx aborted'));
        tx.onerror    = () => rej(tx.error);
      }));
    }
    function dbGetAll(store) {
      return openDB().then(db => new Promise((res, rej) => {
        const tx = db.transaction(store, 'readonly');
        const r = tx.objectStore(store).getAll();
        r.onsuccess = () => res(r.result || []);
        r.onerror   = () => rej(r.error);
        tx.onabort  = () => rej(tx.error || new Error('tx aborted'));
      }));
    }
    function dbClear(store) {
      return openDB().then(db => new Promise((res, rej) => {
        const tx = db.transaction(store, 'readwrite');
        tx.objectStore(store).clear();
        tx.oncomplete = () => res();
        tx.onabort    = () => rej(tx.error || new Error('tx aborted'));
        tx.onerror    = () => rej(tx.error);
      }));
    }

    // ===== Phase 3: E&C&LT デビクラ種類の文字列パーサー =====
    //   E = 技術（Engineering） / C = コスト（Cost） / LT = リードタイム（LeadTime）
    //   "E,C" / "E/C" / "E C" / "E、C" / "技術・コスト" / "Engineering, Cost" 等を ['E','C','LT'] に正規化
    //   未知トークンは捨てる。重複は除去。順序は ['E','C','LT'] 固定
    function parseImpactString(s) {
      if (!s) return [];
      const upper = String(s).toUpperCase();
      const flags = { E:false, C:false, LT:false };
      // LT を先に判定（'LT' を 'L' + 'T' と取られないため）
      if (/\bLT\b|LEAD\s*TIME|リードタイム|納期/.test(upper))           flags.LT = true;
      if (/\bE\b|ENGINEERING|TECHNICAL|技術|設計/.test(upper))           flags.E  = true;
      if (/\bC\b|COST|コスト|費用/.test(upper))                          flags.C  = true;
      const out = [];
      if (flags.E)  out.push('E');
      if (flags.C)  out.push('C');
      if (flags.LT) out.push('LT');
      return out;
    }

    // ===== 第3段階: 文章ベクトル類似度（bag-of-bigrams + コサイン類似度） =====
    function vectorize(text) {
      const tokens = tokenize(text);
      const v = {};
      for (const t of tokens) v[t] = (v[t]||0)+1;
      // L2正規化
      let norm = 0;
      for (const k in v) norm += v[k]*v[k];
      norm = Math.sqrt(norm) || 1;
      for (const k in v) v[k] /= norm;
      return v;
    }
    function cosineSim(va, vb) {
      let s = 0;
      for (const k in va) if (vb[k]) s += va[k]*vb[k];
      return s;
    }

    // ===== 第6段階: モデル版管理（辞書バージョン） =====
    let activeDictVersion = null;
    let extendedDicts = {}; // { presetId: { high:[+追加語], mid:[], low:[] } }

    async function loadActiveModel() {
      const meta = await dbGetAll('modelMeta');
      const active = meta.find(m => m.key === 'active');
      if (active) activeDictVersion = active.version;
      const all = await dbGetAll('dictVersions');
      for (const v of all) {
        if (v.version === activeDictVersion) {
          extendedDicts = v.extended || {};
          log('model_load', `version=${v.version}`);
          return;
        }
      }
    }

    // ===== カスタム辞書語管理 =====
    async function saveExtendedDicts() {
      // activeDictVersion がなければ自動で "custom-YYYY-MM-DD" を作成
      const ver = activeDictVersion || ('custom-' + new Date().toISOString().slice(0,10));
      await dbPut('dictVersions', {
        version: ver,
        baseAt: new Date().toISOString(),
        extended: extendedDicts,
        stats: {},
      });
      if (!activeDictVersion) {
        activeDictVersion = ver;
        await dbPut('modelMeta', { key:'active', version: ver });
      }
    }

    function renderCustomWords() {
      const ext = extendedDicts[currentPreset] || {};
      const levelLabel = { high:'対象', mid:'要確認', low:'対象外' };
      const levelColor = { high:'#6ec897', mid:'#c8a96e', low:'rgba(255,255,255,0.4)' };
      const words = [
        ...(ext.high||[]).filter(e => e._custom).map(e => ({...e, level:'high'})),
        ...(ext.mid ||[]).filter(e => e._custom).map(e => ({...e, level:'mid'})),
        ...(ext.low ||[]).filter(e => e._custom).map(e => ({...e, level:'low'})),
      ];
      const wrap  = document.getElementById('cdict-table-wrap');
      const tbody = document.getElementById('cdict-tbody');
      const cnt   = document.getElementById('cdict-count');
      if (!wrap || !tbody || !cnt) return;
      cnt.textContent = words.length;
      wrap.style.display = words.length > 0 ? 'block' : 'none';
      tbody.innerHTML = words.map(e => `
        <tr style="border-bottom:1px solid rgba(255,255,255,0.05);">
          <td style="padding:0.35rem 0.5rem;color:#edede8;font-weight:500;">${e.word}</td>
          <td style="padding:0.35rem 0.5rem;color:rgba(255,255,255,0.6);font-size:0.7rem;max-width:260px;word-break:break-all;">${e.why||''}</td>
          <td style="padding:0.35rem 0.5rem;color:${levelColor[e.level]};">${levelLabel[e.level]}</td>
          <td style="padding:0.35rem 0.5rem;color:rgba(255,255,255,0.5);">${Array.isArray(e.impact)?e.impact.join(','):''}</td>
          <td style="padding:0.35rem 0.5rem;text-align:right;">
            <button class="btn-cdict-del" data-word="${e.word}" data-level="${e.level}"
              style="background:transparent;border:1px solid rgba(255,100,100,0.25);color:#ff8888;padding:0.15rem 0.5rem;font-size:0.65rem;cursor:pointer;font-family:inherit;">削除</button>
          </td>
        </tr>
      `).join('');
    }

    document.getElementById('btn-cdict-add').addEventListener('click', async () => {
      const word = document.getElementById('cdict-word').value.trim();
      const st   = document.getElementById('cdict-status');
      if (!word) { st.textContent = '⚠ 「語」は必須です'; st.style.color='#ff8888'; return; }
      const why    = document.getElementById('cdict-why').value.trim();
      const level  = document.getElementById('cdict-level').value;
      const impact = [];
      if (document.getElementById('cdict-e').checked)  impact.push('E');
      if (document.getElementById('cdict-c').checked)  impact.push('C');
      if (document.getElementById('cdict-lt').checked) impact.push('LT');
      if (!extendedDicts[currentPreset]) extendedDicts[currentPreset] = { high:[], mid:[], low:[], suppressed:[] };
      const arr = extendedDicts[currentPreset][level] || [];
      if (arr.some(e => e.word === word)) {
        st.textContent = `⚠ 「${word}」は既に登録されています`;
        st.style.color = '#ff8888'; return;
      }
      arr.push({ word, why, impact, _custom: true });
      extendedDicts[currentPreset][level] = arr;
