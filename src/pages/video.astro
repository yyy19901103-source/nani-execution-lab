---
import BaseLayout from '../layouts/BaseLayout.astro';

// 動画を追加する場合: youtubeId または src (public/videos/ のパス) を指定
const videos: { title: string; description: string; youtubeId?: string; src?: string }[] = [];
---

<BaseLayout title="VIDEO" description="製造業DX・AI活用の解説動画・デモ動画。">
  <div style="padding-top:8rem;padding-bottom:3rem;max-width:1280px;margin:0 auto;padding-left:1.5rem;padding-right:1.5rem;">
    <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:1rem;">VIDEO</p>
    <h1 style="font-size:clamp(2rem,6vw,3.5rem);font-weight:100;letter-spacing:0.15em;color:#edede8;margin-bottom:1rem;">Video</h1>
    <p style="color:rgba(255,255,255,0.35);font-size:0.875rem;line-height:1.8;max-width:32rem;">
      システム解説・デモ動画・事例紹介を公開しています。
    </p>
  </div>

  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem 8rem;">
    {videos.length > 0 ? (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:2rem;">
        {videos.map(video => (
          <div style="border:1px solid rgba(255,255,255,0.07);background:#141418;overflow:hidden;">
            {video.youtubeId && (
              <div style="position:relative;aspect-ratio:16/9;">
                <iframe
                  src={`https://www.youtube.com/embed/${video.youtubeId}`}
                  title={video.title}
                  style="width:100%;height:100%;border:none;"
                  allowfullscreen
                ></iframe>
              </div>
            )}
            {video.src && !video.youtubeId && (
              <div style="position:relative;aspect-ratio:16/9;">
                <video src={video.src} controls style="width:100%;height:100%;" preload="metadata"></video>
              </div>
            )}
            <div style="padding:1.5rem;">
              <h3 style="font-size:0.95rem;font-weight:300;color:#edede8;margin-bottom:0.5rem;">{video.title}</h3>
              <p style="font-size:0.8rem;color:rgba(255,255,255,0.4);line-height:1.7;">{video.description}</p>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div style="border:1px solid rgba(255,255,255,0.04);padding:8rem 2rem;text-align:center;">
        <p style="color:rgba(255,255,255,0.15);font-size:0.8rem;letter-spacing:0.3em;margin-bottom:0.75rem;">COMING SOON</p>
        <p style="color:rgba(255,255,255,0.08);font-size:0.7rem;letter-spacing:0.1em;">システムデモ・解説動画など掲載予定</p>
      </div>
    )}
  </div>
</BaseLayout>
