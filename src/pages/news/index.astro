---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('news');
const sorted = items.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Gather unique categories
const allCategories = [...new Set(sorted.map(item => item.data.category).filter(Boolean))];
---

<BaseLayout title="NEWS" description="NaNi Execution Lab のお知らせ・最新情報。">

  <!-- Hero -->
  <div style="position:relative;height:18rem;overflow:hidden;margin-top:64px;">
    <img
      src="https://images.unsplash.com/photo-1504711434969-e33886168f5c?auto=format&fit=crop&w=1600&q=60"
      alt="NEWS"
      loading="lazy"
      style="width:100%;height:100%;object-fit:cover;opacity:0.2;"
    />
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom,#0c0c0e 0%,rgba(12,12,14,0.05) 45%,rgba(12,12,14,0.98) 100%);"></div>
    <div style="position:absolute;bottom:2.5rem;left:0;right:0;max-width:1100px;margin:0 auto;padding:0 1.5rem;">
      <div style="display:flex;align-items:center;gap:0.5rem;color:rgba(255,255,255,0.25);font-size:0.68rem;letter-spacing:0.12em;margin-bottom:0.75rem;">
        <a href={`${base}/`} style="transition:color 0.2s;" onmouseover="this.style.color='#c8a96e'" onmouseout="this.style.color='rgba(255,255,255,0.25)'">TOP</a>
        <span>›</span>
        <span style="color:rgba(255,255,255,0.45);">NEWS</span>
      </div>
      <h1 style="font-size:clamp(1.75rem,5vw,3rem);font-weight:100;letter-spacing:0.2em;color:#edede8;line-height:1.2;">News</h1>
      <p style="color:rgba(255,255,255,0.3);font-size:0.78rem;letter-spacing:0.06em;margin-top:0.5rem;">サイト更新・新規事例追加・イベント情報などをお知らせします</p>
    </div>
  </div>

  <!-- Main content -->
  <div style="max-width:1100px;margin:0 auto;padding:3rem 1.5rem 8rem;">

    <!-- Category filter -->
    {allCategories.length > 0 && (
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:3rem;" id="category-filters">
        <button
          data-category="all"
          class="cat-btn active"
          style="font-size:0.65rem;letter-spacing:0.15em;padding:0.3rem 0.875rem;border:1px solid rgba(200,169,110,0.4);color:#c8a96e;background:rgba(200,169,110,0.08);border-radius:2px;cursor:pointer;transition:all 0.2s;"
        >
          ALL
        </button>
        {allCategories.map(cat => (
          <button
            data-category={cat}
            class="cat-btn"
            style="font-size:0.65rem;letter-spacing:0.15em;padding:0.3rem 0.875rem;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.35);background:transparent;border-radius:2px;cursor:pointer;transition:all 0.2s;"
          >
            {cat}
          </button>
        ))}
      </div>
    )}

    <!-- Timeline -->
    <div style="max-width:52rem;position:relative;" id="news-timeline">
      <!-- Vertical line -->
      <div style="position:absolute;left:6.5rem;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,rgba(200,169,110,0.15),rgba(200,169,110,0.04));pointer-events:none;"></div>

      {sorted.length > 0 ? (
        sorted.map(item => {
          const formatted = new Date(item.data.date).toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' });
          const slug = item.id.replace(/\.md$/, '');
          return (
            <a
              href={`${base}/news/${slug}`}
              data-category={item.data.category ?? ''}
              class="timeline-item"
              style="display:flex;gap:0;align-items:flex-start;padding:1.375rem 0;border-bottom:1px solid rgba(255,255,255,0.04);text-decoration:none;transition:all 0.2s;position:relative;"
            >
              <!-- Date column -->
              <div style="flex-shrink:0;width:6.5rem;padding-right:1.5rem;text-align:right;">
                <div style="font-size:0.62rem;color:rgba(255,255,255,0.22);letter-spacing:0.04em;line-height:1.6;">{formatted}</div>
              </div>

              <!-- Timeline dot -->
              <div style="flex-shrink:0;width:0;position:relative;">
                <div class="timeline-dot" style="position:absolute;left:-4px;top:0.4rem;width:7px;height:7px;border-radius:50%;border:1px solid rgba(200,169,110,0.4);background:#0c0c0e;transition:all 0.2s;"></div>
              </div>

              <!-- Content -->
              <div style="flex:1;padding-left:1.75rem;">
                {item.data.category && (
                  <div style="display:inline-block;font-size:0.58rem;letter-spacing:0.18em;color:rgba(200,169,110,0.7);border:1px solid rgba(200,169,110,0.2);padding:0.1rem 0.5rem;border-radius:10px;margin-bottom:0.5rem;">{item.data.category}</div>
                )}
                <h3 class="news-title" style="font-size:0.88rem;font-weight:300;color:rgba(237,237,232,0.85);line-height:1.65;letter-spacing:0.02em;transition:color 0.2s;margin:0;">{item.data.title}</h3>
                {item.data.description && (
                  <p style="color:rgba(255,255,255,0.28);font-size:0.75rem;line-height:1.7;margin-top:0.375rem;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;">{item.data.description}</p>
                )}
              </div>

              <!-- Arrow -->
              <div class="news-arrow" style="flex-shrink:0;color:rgba(200,169,110,0.3);font-size:0.8rem;padding-left:1rem;padding-top:0.25rem;transition:all 0.2s;">→</div>
            </a>
          );
        })
      ) : (
        <p style="color:rgba(255,255,255,0.2);text-align:center;padding:6rem 0;font-size:0.875rem;letter-spacing:0.2em;">準備中</p>
      )}
    </div>

  </div>
</BaseLayout>

<style>
  .timeline-item:hover .news-title { color: #c8a96e !important; }
  .timeline-item:hover .timeline-dot {
    background: rgba(200,169,110,0.3) !important;
    border-color: #c8a96e !important;
    box-shadow: 0 0 6px rgba(200,169,110,0.3);
  }
  .timeline-item:hover .news-arrow {
    color: #c8a96e !important;
    transform: translateX(4px);
  }
  .cat-btn.active {
    border-color: rgba(200,169,110,0.4) !important;
    color: #c8a96e !important;
    background: rgba(200,169,110,0.08) !important;
  }
  .timeline-item.hidden { display: none; }
</style>

<script>
  // Category filter logic
  const filterBtns = document.querySelectorAll('.cat-btn');
  const timelineItems = document.querySelectorAll('.timeline-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const cat = (btn as HTMLElement).dataset.category ?? 'all';
      timelineItems.forEach(item => {
        const itemCat = (item as HTMLElement).dataset.category ?? '';
        if (cat === 'all' || itemCat === cat) {
          item.classList.remove('hidden');
        } else {
          item.classList.add('hidden');
        }
      });
    });
  });

  // Lazy image observer
  document.querySelectorAll('img[loading="lazy"]').forEach(img => {
    if ((img as HTMLImageElement).complete) {
      img.classList.add('loaded');
    } else {
      img.addEventListener('load', () => img.classList.add('loaded'));
    }
  });
</script>
