---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('news');
const sorted = items.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="NEWS" description="NaNi Execution Lab のお知らせ・最新情報。">
  <div style="padding-top:8rem;padding-bottom:3rem;max-width:1280px;margin:0 auto;padding-left:1.5rem;padding-right:1.5rem;">
    <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:1rem;">NEWS</p>
    <h1 style="font-size:clamp(2rem,6vw,3.5rem);font-weight:100;letter-spacing:0.15em;color:#edede8;margin-bottom:1rem;">News</h1>
    <p style="color:rgba(255,255,255,0.35);font-size:0.875rem;line-height:1.8;max-width:32rem;">
      サイト更新・新規事例追加・イベント情報などをお知らせします。
    </p>
  </div>

  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem 8rem;">
    <div style="max-width:48rem;">
      {sorted.length > 0 ? (
        sorted.map(item => (
          <BlogCard
            title={item.data.title}
            date={item.data.date}
            slug={item.id.replace(/\.md$/, '')}
            type="news"
            category={item.data.category}
          />
        ))
      ) : (
        <p style="color:rgba(255,255,255,0.2);text-align:center;padding:6rem 0;font-size:0.875rem;letter-spacing:0.2em;">準備中</p>
      )}
    </div>
  </div>
</BaseLayout>
