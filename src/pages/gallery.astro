---
import BaseLayout from '../layouts/BaseLayout.astro';

const images = [
  {
    src: 'https://images.unsplash.com/photo-1565514020179-026b92b84bb6?auto=format&fit=crop&w=800&q=80',
    alt: 'Factory automation robotic arms',
    caption: 'ロボットアーム自動化ライン',
    category: 'AUTOMATION',
    wide: true,
  },
  {
    src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80',
    alt: 'Data analytics dashboard',
    caption: 'データ分析ダッシュボード',
    category: 'DATA',
  },
  {
    src: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=800&q=80',
    alt: 'Smart manufacturing floor',
    caption: 'スマート製造ライン',
    category: 'MANUFACTURING',
  },
  {
    src: 'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=800&q=80',
    alt: 'Circuit board technology',
    caption: '制御基板・エッジデバイス',
    category: 'TECHNOLOGY',
  },
  {
    src: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=800&q=80',
    alt: 'Server room data center',
    caption: 'データセンター・クラウド基盤',
    category: 'INFRASTRUCTURE',
  },
  {
    src: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80',
    alt: 'Laptop with business analytics',
    caption: 'KPIモニタリング画面',
    category: 'ANALYTICS',
    wide: true,
  },
  {
    src: 'https://images.unsplash.com/photo-1596526131083-e8c633c948d2?auto=format&fit=crop&w=800&q=80',
    alt: 'Email automation workflow',
    caption: 'メール自動仕分けフロー',
    category: 'AUTOMATION',
  },
  {
    src: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=800&q=80',
    alt: 'Supply chain logistics',
    caption: 'サプライヤー管理・物流最適化',
    category: 'SUPPLY CHAIN',
  },
  {
    src: 'https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?auto=format&fit=crop&w=800&q=80',
    alt: 'Factory workers production line',
    caption: '生産ライン改善プロジェクト',
    category: 'MANUFACTURING',
  },
  {
    src: 'https://images.unsplash.com/photo-1677442135703-1787eea5ce01?auto=format&fit=crop&w=800&q=80',
    alt: 'AI visualization',
    caption: 'AI・機械学習モデル実装',
    category: 'AI',
  },
  {
    src: 'https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?auto=format&fit=crop&w=800&q=80',
    alt: 'Digital matrix code',
    caption: 'デジタルトランスフォーメーション',
    category: 'DX',
  },
  {
    src: 'https://images.unsplash.com/photo-1553413077-190dd305871c?auto=format&fit=crop&w=800&q=80',
    alt: 'Warehouse management',
    caption: '倉庫・在庫管理システム',
    category: 'LOGISTICS',
  },
];
---

<BaseLayout title="GALLERY" description="製造業DXの実装事例ギャラリー。ダッシュボード・システム構成図など。">
  <div style="padding-top:8rem;padding-bottom:3rem;max-width:1280px;margin:0 auto;padding-left:1.5rem;padding-right:1.5rem;">
    <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:1rem;">GALLERY</p>
    <h1 style="font-size:clamp(2rem,6vw,3.5rem);font-weight:100;letter-spacing:0.15em;color:#edede8;margin-bottom:1rem;">Gallery</h1>
    <p style="color:rgba(255,255,255,0.35);font-size:0.875rem;line-height:1.8;max-width:32rem;">
      製造DX・AI活用・業務自動化の現場から。実装シーン・データビジュアライゼーション・技術スタック。
    </p>
  </div>

  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem 8rem;">

    <!-- Hero image -->
    <div style="position:relative;height:32rem;overflow:hidden;margin-bottom:1px;border:1px solid rgba(255,255,255,0.07);" class="gallery-hero">
      <img
        src="https://images.unsplash.com/photo-1485827404703-89b55fcc595e?auto=format&fit=crop&w=1920&q=80"
        alt="Industrial automation robot"
        style="width:100%;height:100%;object-fit:cover;opacity:0.6;transition:all 0.7s;"
        class="gallery-hero-img"
        loading="eager"
      />
      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(12,12,14,0.85) 0%,transparent 60%);"></div>
      <div style="position:absolute;bottom:2.5rem;left:2.5rem;">
        <p style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.4em;margin-bottom:0.5rem;">FEATURED</p>
        <h2 style="font-size:clamp(1.25rem,3vw,1.75rem);font-weight:300;color:#edede8;letter-spacing:0.08em;">Industrial Automation & AI Integration</h2>
      </div>
    </div>

    <!-- Masonry-style grid -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,0.04);" class="gallery-grid">
      {images.map((img, i) => (
        <div
          style={`overflow:hidden;border:1px solid rgba(255,255,255,0.07);background:#141418;${img.wide ? 'grid-column:span 2;' : ''}`}
          class="gallery-item"
        >
          <div style="overflow:hidden;position:relative;">
            <img
              src={img.src}
              alt={img.alt}
              style="width:100%;height:15rem;object-fit:cover;opacity:0.65;transition:all 0.5s;"
              loading="lazy"
              class="gallery-img"
            />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(12,12,14,0.7) 0%,transparent 50%);opacity:0;transition:opacity 0.3s;" class="gallery-overlay"></div>
          </div>
          <div style="padding:1.25rem 1.5rem;">
            <p style="color:#c8a96e;font-size:0.6rem;letter-spacing:0.35em;margin-bottom:0.4rem;">{img.category}</p>
            <p style="color:rgba(255,255,255,0.55);font-size:0.8rem;line-height:1.6;">{img.caption}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom banner -->
    <div style="position:relative;height:20rem;overflow:hidden;margin-top:1px;border:1px solid rgba(255,255,255,0.07);" class="gallery-hero">
      <img
        src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&w=1920&q=80"
        alt="Data technology"
        style="width:100%;height:100%;object-fit:cover;opacity:0.3;transition:all 0.7s;"
        class="gallery-hero-img"
        loading="lazy"
      />
      <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(12,12,14,0.9) 0%,rgba(12,12,14,0.4) 100%);"></div>
      <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1rem;">
        <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.5em;">EXECUTION LAB</p>
        <p style="color:rgba(255,255,255,0.5);font-size:0.875rem;font-weight:300;letter-spacing:0.1em;">データが、現場を変える。</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .gallery-item:hover .gallery-img { opacity: 1 !important; transform: scale(1.04); }
  .gallery-item:hover .gallery-overlay { opacity: 1 !important; }
  .gallery-hero:hover .gallery-hero-img { opacity: 0.8 !important; transform: scale(1.02); }
  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: 1fr !important; }
    .gallery-grid > div[style*="span 2"] { grid-column: span 1 !important; }
  }
</style>
