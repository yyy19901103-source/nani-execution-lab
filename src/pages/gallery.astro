---
import BaseLayout from '../layouts/BaseLayout.astro';

// 画像を追加する場合: public/images/gallery/ に配置し、以下の配列に追加
const images: { src: string; alt: string; caption?: string }[] = [];
---

<BaseLayout title="GALLERY" description="製造業DXの実装事例ギャラリー。ダッシュボード・システム構成図など。">
  <div style="padding-top:8rem;padding-bottom:3rem;max-width:1280px;margin:0 auto;padding-left:1.5rem;padding-right:1.5rem;">
    <p style="color:#c8a96e;font-size:0.65rem;letter-spacing:0.4em;margin-bottom:1rem;">GALLERY</p>
    <h1 style="font-size:clamp(2rem,6vw,3.5rem);font-weight:100;letter-spacing:0.15em;color:#edede8;margin-bottom:1rem;">Gallery</h1>
    <p style="color:rgba(255,255,255,0.35);font-size:0.875rem;line-height:1.8;max-width:32rem;">
      ダッシュボード・システム構成図・実装画面のギャラリー。
    </p>
  </div>

  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem 8rem;">
    {images.length > 0 ? (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
        {images.map(img => (
          <div style="border:1px solid rgba(255,255,255,0.07);overflow:hidden;background:#141418;" class="gallery-item">
            <div style="overflow:hidden;">
              <img
                src={img.src}
                alt={img.alt}
                style="width:100%;height:14rem;object-fit:cover;opacity:0.75;transition:all 0.5s;"
                class="gallery-img"
                loading="lazy"
              />
            </div>
            {img.caption && (
              <div style="padding:1rem;">
                <p style="color:rgba(255,255,255,0.45);font-size:0.8rem;">{img.caption}</p>
              </div>
            )}
          </div>
        ))}
      </div>
    ) : (
      <div style="border:1px solid rgba(255,255,255,0.04);padding:8rem 2rem;text-align:center;">
        <p style="color:rgba(255,255,255,0.15);font-size:0.8rem;letter-spacing:0.3em;margin-bottom:0.75rem;">COMING SOON</p>
        <p style="color:rgba(255,255,255,0.08);font-size:0.7rem;letter-spacing:0.1em;">ダッシュボード・システム構成図など掲載予定</p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .gallery-item:hover .gallery-img {
    opacity: 1 !important;
    transform: scale(1.05);
  }
</style>
