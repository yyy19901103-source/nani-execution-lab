---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="まほうの庭 — Magic Garden"
  description="Claude AIと共同開発した放置育成ブラウザゲーム。キャラを育て、ステージを攻略しよう。"
>

  <!-- Hero -->
  <div style="position:relative;overflow:hidden;background:linear-gradient(135deg,#0d0d1a 0%,#0c0c0e 40%,#1a0d1a 100%);padding:5rem 1.5rem 3rem;text-align:center;margin-top:64px;border-bottom:1px solid rgba(200,169,110,0.1);">
    <div style="position:absolute;inset:0;opacity:0.06;background-image:url('https://images.unsplash.com/photo-1511512578047-dfb367046420?auto=format&fit=crop&w=1600&q=60');background-size:cover;background-position:center;"></div>
    <div style="position:relative;max-width:700px;margin:0 auto;">
      <div style="font-size:3rem;margin-bottom:0.75rem;">🌸</div>
      <div style="display:inline-block;padding:0.3rem 1rem;background:rgba(200,169,110,0.1);border:1px solid rgba(200,169,110,0.25);border-radius:20px;font-size:0.68rem;letter-spacing:0.2em;color:#c8a96e;margin-bottom:1.25rem;">CLAUDE AI × GAME DEV</div>
      <h1 style="font-size:clamp(1.75rem,4vw,2.75rem);font-weight:200;color:rgba(255,255,255,0.95);letter-spacing:0.08em;margin:0 0 0.75rem;">まほうの庭</h1>
      <p style="font-size:0.9rem;color:rgba(255,255,255,0.4);letter-spacing:0.1em;margin:0 0 0.5rem;">✿ Magic Garden ✿</p>
      <p style="font-size:0.85rem;color:rgba(255,255,255,0.45);line-height:1.8;max-width:500px;margin:1rem auto 2rem;">
        Claude AIと会話しながらゼロから構築した放置育成ゲーム。<br>
        キャラを育て、装備を集め、ステージを攻略しよう。
      </p>

      <!-- Stats bar -->
      <div style="display:flex;gap:2rem;justify-content:center;flex-wrap:wrap;margin-bottom:2rem;">
        {[
          { num: '3,468', label: 'Lines of JS' },
          { num: '917',   label: 'Lines of CSS' },
          { num: '11',    label: 'Characters' },
          { num: '5',     label: 'Chapters' },
        ].map(s => (
          <div style="text-align:center;">
            <div style="font-size:1.4rem;font-weight:200;color:#c8a96e;">{s.num}</div>
            <div style="font-size:0.6rem;letter-spacing:0.15em;color:rgba(255,255,255,0.3);">{s.label}</div>
          </div>
        ))}
      </div>

      <!-- CTAs -->
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a
          href="#play"
          style="padding:0.75rem 2rem;background:#c8a96e;color:#0c0c0e;font-size:0.8rem;letter-spacing:0.15em;font-weight:500;text-decoration:none;border-radius:4px;transition:opacity 0.2s;"
          onmouseover="this.style.opacity='0.85'"
          onmouseout="this.style.opacity='1'"
        >
          🎮 今すぐプレイ
        </a>
        <a
          href={`${base}/cases/magic-garden-game`}
          style="padding:0.75rem 2rem;background:transparent;border:1px solid rgba(200,169,110,0.4);color:#c8a96e;font-size:0.8rem;letter-spacing:0.15em;text-decoration:none;border-radius:4px;transition:all 0.2s;"
          onmouseover="this.style.background='rgba(200,169,110,0.08)'"
          onmouseout="this.style.background='transparent'"
        >
          📋 開発事例を読む
        </a>
      </div>
    </div>
  </div>

  <!-- Game embed section -->
  <div id="play" style="background:#08080a;padding:2.5rem 1.5rem 4rem;border-bottom:1px solid rgba(255,255,255,0.05);">
    <div style="max-width:480px;margin:0 auto;">

      <!-- Frame wrapper -->
      <div style="position:relative;background:#111;border:1px solid rgba(200,169,110,0.2);border-radius:12px;overflow:hidden;box-shadow:0 0 40px rgba(200,169,110,0.06);">

        <!-- Browser-like title bar -->
        <div style="background:#1a1a1e;padding:0.6rem 1rem;display:flex;align-items:center;gap:0.5rem;border-bottom:1px solid rgba(255,255,255,0.06);">
          <div style="display:flex;gap:0.4rem;">
            <div style="width:10px;height:10px;border-radius:50%;background:#ff5f57;"></div>
            <div style="width:10px;height:10px;border-radius:50%;background:#febc2e;"></div>
            <div style="width:10px;height:10px;border-radius:50%;background:#28c840;"></div>
          </div>
          <div style="flex:1;background:#0c0c0e;border-radius:4px;padding:0.2rem 0.75rem;font-size:0.65rem;color:rgba(255,255,255,0.3);letter-spacing:0.05em;text-align:center;">
            まほうの庭 ✿ Magic Garden
          </div>
        </div>

        <!-- iframe -->
        <iframe
          src={`${base}/game/index.html`}
          style="width:100%;height:640px;border:none;display:block;"
          title="まほうの庭 Magic Garden"
          allow="autoplay"
          loading="lazy"
        ></iframe>
      </div>

      <!-- Play tips -->
      <div style="margin-top:1.5rem;padding:1.25rem;background:#111114;border:1px solid rgba(255,255,255,0.06);border-radius:8px;">
        <p style="font-size:0.65rem;letter-spacing:0.15em;color:rgba(200,169,110,0.6);margin-bottom:0.875rem;">HOW TO PLAY</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;">
          {[
            { icon: '⚔️', text: '戦闘でキャラを強化' },
            { icon: '🎰', text: 'ガチャで新キャラ獲得' },
            { icon: '😴', text: '放置で資源を自動収集' },
            { icon: '🗺️', text: '5章・多数のステージ' },
          ].map(tip => (
            <div style="display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:rgba(255,255,255,0.45);">
              <span>{tip.icon}</span>
              <span>{tip.text}</span>
            </div>
          ))}
        </div>
        <p style="font-size:0.68rem;color:rgba(255,255,255,0.2);margin-top:0.875rem;line-height:1.6;">
          💾 セーブはブラウザのLocalStorageに自動保存されます。
        </p>
      </div>
    </div>
  </div>

  <!-- Tech highlights -->
  <div style="max-width:960px;margin:0 auto;padding:4rem 1.5rem 5rem;">
    <p style="font-size:0.65rem;letter-spacing:0.2em;color:rgba(200,169,110,0.6);text-align:center;margin-bottom:3rem;">TECHNOLOGY HIGHLIGHTS</p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.25rem;margin-bottom:3rem;">
      {[
        { icon:'⚡', title:'依存ゼロ', desc:'外部ライブラリなし。HTML/CSS/JSのみで完結。ビルドツール不要。' },
        { icon:'🧠', title:'AIペアプログラミング', desc:'Claude AIとの対話で設計→実装→デバッグ。コードの9割以上をAIが生成。' },
        { icon:'💾', title:'LocalStorage保存', desc:'サーバーレスで動作。Google Sheets連携でクラウド保存に拡張可能。' },
        { icon:'🎨', title:'CSS設計', desc:'917行のカスタムCSS。モバイル最適化・アニメーション・スプライト制御。' },
        { icon:'⚔️', title:'バトルエンジン', desc:'ターン制バトルシステム。属性相性・スキル・ボス戦を純粋JSで実装。' },
        { icon:'📦', title:'モジュール設計', desc:'6ファイル分離（game/main/storage/idle/data×2）。責務が明確な設計。' },
      ].map(item => (
        <div style="padding:1.25rem;background:#111114;border:1px solid rgba(255,255,255,0.06);border-radius:8px;">
          <div style="font-size:1.5rem;margin-bottom:0.625rem;">{item.icon}</div>
          <div style="font-size:0.85rem;font-weight:500;color:rgba(255,255,255,0.85);margin-bottom:0.5rem;">{item.title}</div>
          <div style="font-size:0.78rem;color:rgba(255,255,255,0.4);line-height:1.7;">{item.desc}</div>
        </div>
      ))}
    </div>

    <!-- CTA to case study -->
    <div style="text-align:center;padding:2.5rem;background:rgba(200,169,110,0.04);border:1px solid rgba(200,169,110,0.12);border-radius:8px;">
      <p style="color:rgba(255,255,255,0.5);font-size:0.85rem;margin-bottom:1.25rem;line-height:1.7;">
        このゲームがどのように作られたか —<br>Claude AIとの開発プロセス・技術判断・躓きポイントを詳しく解説しています。
      </p>
      <a
        href={`${base}/cases/magic-garden-game`}
        style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.75rem 2rem;background:rgba(200,169,110,0.08);border:1px solid rgba(200,169,110,0.3);border-radius:4px;text-decoration:none;color:#c8a96e;font-size:0.8rem;letter-spacing:0.12em;transition:all 0.2s;"
        onmouseover="this.style.background='rgba(200,169,110,0.15)'"
        onmouseout="this.style.background='rgba(200,169,110,0.08)'"
      >
        開発事例を読む →
      </a>
    </div>
  </div>

</BaseLayout>
