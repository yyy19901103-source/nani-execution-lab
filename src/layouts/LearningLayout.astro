---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';

export interface Props {
  title: string;
  currentSlug?: string;
}

const { title, currentSlug } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// 全learning記事を取得してナビゲーション構築
const allLearning = await getCollection('learning');

// Estimated study time per topic
const studyTime: Record<string, string> = {
  '01_business': '約60分',
  '02_eto_mto': '約90分',
  '03_biz_process': '約90分',
  '04_ecm': '約120分',
  '05_mfg_deployment': '約90分',
  '06_mfg_tech': '約90分',
  '07_quality_stats': '約120分',
  '08_equipment': '約90分',
  '09_procurement': '約60分',
  '10_record_design': '約90分',
  '11_it_infra': '約90分',
  '12_ai': '約120分',
  '13_poc': '約90分',
  '14_operations': '約60分',
  '15_standardization': '約60分',
  '16_kpi': '約90分',
};

const currentTime = currentSlug ? studyTime[currentSlug] : null;

// ナビグループ定義
const navGroups = [
  {
    label: '📋 全体スケジュール',
    phaseKey: 'schedule',
    items: allLearning.filter(e => e.id === '00_schedule'),
    color: '#888',
  },
  {
    label: 'Phase 1 — ビジネス基盤',
    subLabel: 'W1-4',
    phaseKey: 'phase1',
    color: '#4a9eff',
    items: allLearning.filter(e => [
      '01_business','02_eto_mto','03_biz_process','04_ecm'
    ].includes(e.id)).sort((a,b) => a.id.localeCompare(b.id)),
  },
  {
    label: 'Phase 2 — 製造技術基盤',
    subLabel: 'W5-9',
    phaseKey: 'phase2',
    color: '#4ec97a',
    items: allLearning.filter(e => [
      '05_mfg_deployment','06_mfg_tech','07_quality_stats','08_equipment','09_procurement'
    ].includes(e.id)).sort((a,b) => a.id.localeCompare(b.id)),
  },
  {
    label: 'Phase 3 — DX実装',
    subLabel: 'W10-12',
    phaseKey: 'phase3',
    color: '#e0a040',
    items: allLearning.filter(e => [
      '10_record_design','11_it_infra','12_ai','15_standardization'
    ].includes(e.id)).sort((a,b) => a.id.localeCompare(b.id)),
  },
  {
    label: 'Phase 4 — 統合・運用',
    subLabel: 'W13-16',
    phaseKey: 'phase4',
    color: '#c8a96e',
    items: allLearning.filter(e => [
      '13_poc','14_operations','16_kpi'
    ].includes(e.id)).sort((a,b) => a.id.localeCompare(b.id)),
  },
  {
    label: '📚 リファレンス',
    phaseKey: 'refs',
    color: '#888',
    items: allLearning.filter(e => ['99_frameworks','99_references'].includes(e.id))
      .sort((a,b) => a.id.localeCompare(b.id)),
  },
];

// Determine which phase group the current slug belongs to (for auto-expansion)
const currentGroupKey = navGroups.find(g => g.items.some(i => i.id === currentSlug))?.phaseKey || '';
---

<BaseLayout title={title}>
  <!-- Reading progress bar -->
  <div id="reading-progress-bar" style="position:fixed;top:0;left:0;width:0%;height:3px;background:linear-gradient(90deg,#c8a96e,#e0a040);z-index:200;transition:width 0.1s linear;pointer-events:none;"></div>

  <div style="min-height:100vh;padding-top:64px;background:#0c0c0e;">

    <!-- Page hero -->
    <div style="background:linear-gradient(135deg,#0f1420 0%,#0c0c0e 60%,#12100e 100%);border-bottom:1px solid rgba(200,169,110,0.15);padding:2.5rem 1.5rem 2rem;">
      <div style="max-width:1280px;margin:0 auto;">
        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
          <a href={`${base}/learning`} style="color:rgba(200,169,110,0.7);font-size:0.7rem;letter-spacing:0.15em;text-decoration:none;">LEARNING</a>
          <span style="color:rgba(255,255,255,0.2);font-size:0.7rem;">›</span>
          <span style="color:rgba(255,255,255,0.4);font-size:0.7rem;letter-spacing:0.1em;">{title}</span>
        </div>
        <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
          <h1 style="font-size:1.5rem;font-weight:300;color:rgba(255,255,255,0.9);letter-spacing:0.05em;margin:0;border-left:3px solid #c8a96e;padding-left:0.75rem;">{title}</h1>
          <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;">
            {currentTime && (
              <div style="display:flex;align-items:center;gap:0.5rem;padding:0.4rem 1rem;background:rgba(200,169,110,0.08);border:1px solid rgba(200,169,110,0.2);border-radius:20px;">
                <span style="font-size:0.75rem;color:rgba(200,169,110,0.7);">⏱</span>
                <span style="font-size:0.75rem;color:rgba(200,169,110,0.8);letter-spacing:0.05em;">学習時間目安：{currentTime}</span>
              </div>
            )}
            <button onclick="window.print()" style="display:flex;align-items:center;gap:0.4rem;padding:0.4rem 0.9rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.45);font-size:0.7rem;letter-spacing:0.1em;cursor:pointer;border-radius:20px;transition:all 0.2s;" onmouseover="this.style.borderColor='rgba(200,169,110,0.35)';this.style.color='rgba(200,169,110,0.8)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.12)';this.style.color='rgba(255,255,255,0.45)'">
              🖨️ 印刷・PDF保存
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile sidebar toggle button -->
    <div style="display:none;" id="mobile-controls" class="mobile-only" style="padding:0.75rem 1.5rem;background:#111114;border-bottom:1px solid rgba(255,255,255,0.06);">
      <button id="sidebar-toggle" style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 1rem;background:rgba(200,169,110,0.08);border:1px solid rgba(200,169,110,0.2);border-radius:6px;color:#c8a96e;font-size:0.75rem;letter-spacing:0.08em;cursor:pointer;">
        <span id="hamburger-icon">☰</span>
        <span>目次・ナビゲーション</span>
      </button>
    </div>

    <!-- Main layout -->
    <div style="max-width:1280px;margin:0 auto;padding:2rem 1.5rem;display:flex;gap:2rem;align-items:flex-start;">

      <!-- Sidebar -->
      <aside id="learning-sidebar" style="width:260px;flex-shrink:0;position:sticky;top:80px;max-height:calc(100vh - 96px);overflow-y:auto;">
        <div style="background:#111114;border:1px solid rgba(255,255,255,0.07);border-radius:8px;padding:1.25rem 0;">

          <!-- Table of Contents (auto-generated) -->
          <div id="toc-container" style="display:none;border-bottom:1px solid rgba(255,255,255,0.06);margin-bottom:0.5rem;padding-bottom:0.75rem;">
            <div style="padding:0.5rem 1.25rem;font-size:0.6rem;letter-spacing:0.15em;color:rgba(200,169,110,0.5);font-weight:500;text-transform:uppercase;display:flex;align-items:center;gap:0.5rem;">
              <span>このページの内容</span>
            </div>
            <div id="toc-list" style="padding:0 0.5rem;"></div>
          </div>

          {navGroups.map(group => (
            <div class="nav-group" style="margin-bottom:0.25rem;" data-phase={group.phaseKey}>
              <!-- Collapsible group header -->
              <button
                class="nav-group-toggle"
                data-phase={group.phaseKey}
                style={`width:100%;text-align:left;padding:0.5rem 1.25rem;font-size:0.62rem;letter-spacing:0.12em;color:${group.color || 'rgba(200,169,110,0.6)'};font-weight:500;text-transform:uppercase;background:none;border:none;cursor:pointer;display:flex;align-items:center;justify-content:space-between;transition:color 0.15s;`}
              >
                <span>{group.label}{group.subLabel ? ` （${group.subLabel}）` : ''}</span>
                <span class="toggle-arrow" style="font-size:0.55rem;opacity:0.5;transition:transform 0.2s;">▼</span>
              </button>
              <div class="nav-group-items" data-phase={group.phaseKey} style="overflow:hidden;">
                {group.items.map(item => {
                  const href = `${base}/learning/${item.id}`;
                  const isActive = currentSlug === item.id;
                  return (
                    <a
                      href={href}
                      style={`display:flex;align-items:center;padding:0.45rem 1.25rem 0.45rem 1.5rem;font-size:0.73rem;letter-spacing:0.04em;text-decoration:none;transition:all 0.15s;border-left:2px solid ${isActive ? (group.color || '#c8a96e') : 'transparent'};color:${isActive ? (group.color || '#c8a96e') : 'rgba(255,255,255,0.5)'};background:${isActive ? `${group.color || '#c8a96e'}0d` : 'transparent'};`}
                      class="nav-link"
                    >
                      <span style="flex:1;line-height:1.4;">{item.data.title}</span>
                      {isActive && <span style={`width:5px;height:5px;border-radius:50%;background:${group.color || '#c8a96e'};flex-shrink:0;`}></span>}
                    </a>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </aside>

      <!-- Content -->
      <main style="flex:1;min-width:0;">
        <article
          class="learning-content"
          style="background:#111114;border:1px solid rgba(255,255,255,0.07);border-radius:8px;padding:2.5rem;color:rgba(255,255,255,0.8);line-height:1.8;"
        >
          <slot />
        </article>

        <!-- Prev/Next nav -->
        <div id="prev-next-nav" style="margin-top:1.5rem;display:flex;gap:1rem;justify-content:space-between;" data-current={currentSlug}>
        </div>
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  /* Sidebar scrollbar */
  #learning-sidebar::-webkit-scrollbar { width: 4px; }
  #learning-sidebar::-webkit-scrollbar-track { background: transparent; }
  #learning-sidebar::-webkit-scrollbar-thumb { background: rgba(200,169,110,0.2); border-radius: 2px; }

  /* Nav link hover */
  .nav-link:hover {
    color: rgba(255,255,255,0.8) !important;
    background: rgba(255,255,255,0.03) !important;
  }
  .nav-group-toggle:hover {
    opacity: 0.9;
  }

  /* Markdown content styles */
  .learning-content h1 {
    font-size:1.75rem; font-weight:300; color:rgba(255,255,255,0.95);
    margin:0 0 1.5rem; letter-spacing:0.05em;
    border-bottom:2px solid rgba(200,169,110,0.3); padding-bottom:0.75rem;
    position: relative;
  }
  .learning-content h1::before {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 48px;
    height: 2px;
    background: #c8a96e;
  }
  .learning-content h2 {
    font-size:1.2rem; font-weight:400; color:rgba(200,169,110,0.9);
    margin:2.5rem 0 1rem; letter-spacing:0.08em;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(200,169,110,0.1);
  }
  .learning-content h3 { font-size:1rem; font-weight:500; color:rgba(255,255,255,0.85); margin:1.75rem 0 0.75rem; }
  .learning-content h4 { font-size:0.9rem; font-weight:500; color:rgba(255,255,255,0.75); margin:1.25rem 0 0.5rem; }
  .learning-content p { margin:0 0 1rem; color:rgba(255,255,255,0.7); }
  .learning-content ul, .learning-content ol { margin:0.5rem 0 1rem 1.5rem; color:rgba(255,255,255,0.7); }
  .learning-content li { margin-bottom:0.35rem; }

  /* Blockquote as callout box */
  .learning-content blockquote {
    border-left: 4px solid #c8a96e;
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    background: linear-gradient(135deg, rgba(200,169,110,0.07) 0%, rgba(200,169,110,0.03) 100%);
    color: rgba(255,255,255,0.75);
    font-style: normal;
    border-radius: 0 8px 8px 0;
    position: relative;
  }
  .learning-content blockquote::before {
    content: '📌';
    position: absolute;
    top: 0.8rem;
    right: 1rem;
    font-size: 0.9rem;
    opacity: 0.4;
  }

  /* Code blocks */
  .learning-content code {
    background: rgba(200,169,110,0.08);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-family: 'Fira Code', 'Cascadia Code', monospace;
    font-size: 0.85em;
    color: rgba(200,169,110,0.9);
    border: 1px solid rgba(200,169,110,0.15);
  }
  .learning-content pre {
    background: #080809;
    border: 1px solid rgba(255,255,255,0.08);
    border-top: 3px solid rgba(200,169,110,0.3);
    border-radius: 0 0 8px 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1rem 0 1.5rem;
    position: relative;
  }
  .learning-content pre::before {
    content: 'コード例';
    display: block;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: rgba(200,169,110,0.4);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .learning-content pre code {
    background: none;
    padding: 0;
    color: rgba(200,220,180,0.85);
    font-size: 0.82rem;
    line-height: 1.7;
    border: none;
  }

  /* Tables */
  .learning-content table { width:100%; border-collapse:collapse; margin:1rem 0 1.5rem; font-size:0.85rem; }
  .learning-content th { background:rgba(200,169,110,0.08); color:rgba(200,169,110,0.9); padding:0.6rem 1rem; text-align:left; font-weight:500; border:1px solid rgba(255,255,255,0.08); }
  .learning-content td { padding:0.55rem 1rem; color:rgba(255,255,255,0.65); border:1px solid rgba(255,255,255,0.06); vertical-align:top; }
  .learning-content tr:nth-child(even) td { background:rgba(255,255,255,0.02); }
  .learning-content a { color:rgba(200,169,110,0.85); text-decoration:underline; text-underline-offset:2px; }
  .learning-content a:hover { color:#c8a96e; }
  .learning-content strong { color:rgba(255,255,255,0.9); font-weight:600; }
  .learning-content hr { border:none; border-top:1px solid rgba(255,255,255,0.08); margin:2rem 0; }

  /* Checkbox list styling */
  .learning-content input[type="checkbox"] {
    accent-color: #c8a96e;
    margin-right: 0.5rem;
  }
  .learning-content li:has(input[type="checkbox"]) {
    list-style: none;
    margin-left: -1.5rem;
    padding: 0.2rem 0;
  }

  /* Mobile controls */
  .mobile-only {
    display: none !important;
  }

  /* Mobile: sidebar hidden by default, shown via toggle */
  @media (max-width: 1023px) {
    .mobile-only {
      display: block !important;
    }
    #mobile-controls {
      display: block !important;
      padding: 0.75rem 1.5rem;
      background: #111114;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    #learning-sidebar {
      display: none;
      width: 100%;
      position: static;
      max-height: none;
    }
    #learning-sidebar.open {
      display: block;
    }
  }

  /* Print styles */
  @media print {
    #learning-sidebar { display: none !important; }
    #reading-progress-bar { display: none !important; }
    header { display: none !important; }
    footer { display: none !important; }
    #mobile-controls { display: none !important; }
    #prev-next-nav { display: none !important; }

    .learning-content { max-width: 100% !important; padding: 0 !important; }

    body { background: white !important; color: #1a1a1a !important; }
    .learning-content { color: #1a1a1a !important; background: white !important; border: none !important; border-radius: 0 !important; }
    .learning-content h1 { color: #1a1a1a !important; border-bottom-color: #c8a96e !important; }
    .learning-content h2 { color: #8B6914 !important; border-bottom-color: #c8a96e !important; }
    .learning-content h3 { color: #333 !important; border-left-color: #c8a96e !important; }
    .learning-content p, .learning-content li, .learning-content td { color: #333 !important; }
    .learning-content code { background: #f5f5f5 !important; color: #8B6914 !important; border-color: #ddd !important; }
    .learning-content pre { background: #f8f8f8 !important; border-color: #ddd !important; border-top-color: #c8a96e !important; }
    .learning-content pre code { color: #333 !important; background: none !important; }
    .learning-content table { border-color: #ddd !important; }
    .learning-content th { background: #f0e8d0 !important; color: #8B6914 !important; border-color: #ddd !important; }
    .learning-content td { border-color: #eee !important; }
    .learning-content blockquote { border-left-color: #c8a96e !important; background: #fdf8ed !important; color: #555 !important; }
    .learning-content hr { border-color: #ddd !important; }
    .learning-content a { color: #8B6914 !important; }
    .learning-content strong { color: #1a1a1a !important; }

    h2, h3 { page-break-after: avoid; }
    pre, table, blockquote { page-break-inside: avoid; }

    main::before {
      content: 'NaNi Execution Lab — 製造DX学習ロードマップ';
      display: block;
      font-size: 10pt;
      color: #999;
      border-bottom: 1pt solid #ddd;
      padding-bottom: 6pt;
      margin-bottom: 16pt;
    }
  }

  /* TOC link styles */
  .toc-link {
    display: block;
    padding: 0.3rem 1.25rem;
    font-size: 0.68rem;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    letter-spacing: 0.03em;
    line-height: 1.4;
    transition: color 0.15s;
    border-left: 1px solid rgba(255,255,255,0.06);
    margin-left: 0.5rem;
  }
  .toc-link:hover {
    color: rgba(200,169,110,0.8);
    border-left-color: rgba(200,169,110,0.3);
  }
  .toc-link.active {
    color: rgba(200,169,110,0.9);
    border-left-color: #c8a96e;
  }
</style>

<script define:vars={{ currentSlug, currentGroupKey }}>
  // ============================================
  // 1. Reading progress bar
  // ============================================
  const progressBar = document.getElementById('reading-progress-bar');
  function updateReadingProgress() {
    const article = document.querySelector('.learning-content');
    if (!article || !progressBar) return;
    const rect = article.getBoundingClientRect();
    const articleHeight = article.offsetHeight;
    const scrolled = -rect.top;
    const pct = Math.min(100, Math.max(0, (scrolled / (articleHeight - window.innerHeight + 200)) * 100));
    progressBar.style.width = pct + '%';
  }
  window.addEventListener('scroll', updateReadingProgress, { passive: true });

  // ============================================
  // 2. Table of Contents auto-generation
  // ============================================
  function buildTOC() {
    const article = document.querySelector('.learning-content');
    const tocList = document.getElementById('toc-list');
    const tocContainer = document.getElementById('toc-container');
    if (!article || !tocList || !tocContainer) return;

    const headings = article.querySelectorAll('h2');
    if (headings.length < 2) return;

    tocContainer.style.display = 'block';
    headings.forEach((h, i) => {
      const id = `toc-heading-${i}`;
      h.id = id;
      const link = document.createElement('a');
      link.href = `#${id}`;
      link.className = 'toc-link';
      link.textContent = h.textContent || '';
      link.addEventListener('click', (e) => {
        e.preventDefault();
        h.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      tocList.appendChild(link);
    });

    // Highlight active TOC item on scroll
    const tocLinks = tocList.querySelectorAll('.toc-link');
    function updateActiveTOC() {
      let activeIdx = 0;
      headings.forEach((h, i) => {
        if (h.getBoundingClientRect().top < 100) activeIdx = i;
      });
      tocLinks.forEach((l, i) => {
        l.classList.toggle('active', i === activeIdx);
      });
    }
    window.addEventListener('scroll', updateActiveTOC, { passive: true });
  }
  buildTOC();

  // ============================================
  // 3. Mobile sidebar toggle
  // ============================================
  const sidebarToggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('learning-sidebar');
  const hamburger = document.getElementById('hamburger-icon');

  if (sidebarToggle && sidebar) {
    sidebarToggle.addEventListener('click', () => {
      const isOpen = sidebar.classList.toggle('open');
      if (hamburger) hamburger.textContent = isOpen ? '✕' : '☰';
    });
  }

  // ============================================
  // 4. Collapsible sidebar phase groups
  // ============================================
  const toggleBtns = document.querySelectorAll('.nav-group-toggle');

  function initGroupCollapse() {
    toggleBtns.forEach(btn => {
      const phaseKey = btn.getAttribute('data-phase');
      const itemsEl = document.querySelector(`.nav-group-items[data-phase="${phaseKey}"]`);
      const arrow = btn.querySelector('.toggle-arrow');
      if (!itemsEl) return;

      // Determine initial state: open if contains current slug or is schedule/refs
      const isCurrentGroup = phaseKey === currentGroupKey || phaseKey === 'schedule' || phaseKey === 'refs';
      const savedState = localStorage.getItem(`nav_group_${phaseKey}`);

      let isOpen = savedState !== null ? savedState === 'open' : isCurrentGroup;

      function applyState(open: boolean, animate: boolean) {
        if (open) {
          itemsEl.style.maxHeight = itemsEl.scrollHeight + 'px';
          if (arrow) (arrow as HTMLElement).style.transform = 'rotate(0deg)';
        } else {
          itemsEl.style.maxHeight = '0';
          if (arrow) (arrow as HTMLElement).style.transform = 'rotate(-90deg)';
        }
        if (animate) itemsEl.style.transition = 'max-height 0.25s ease';
      }

      // Set initial state without animation
      itemsEl.style.overflow = 'hidden';
      applyState(isOpen, false);

      btn.addEventListener('click', () => {
        isOpen = !isOpen;
        applyState(isOpen, true);
        localStorage.setItem(`nav_group_${phaseKey}`, isOpen ? 'open' : 'closed');
      });
    });
  }
  initGroupCollapse();

  // ============================================
  // 5. Prev/Next navigation
  // ============================================
  const navEl = document.getElementById('prev-next-nav');
  const current = navEl?.dataset.current;

  const order = [
    '00_schedule',
    '01_business','02_eto_mto','03_biz_process','04_ecm',
    '05_mfg_deployment','06_mfg_tech','07_quality_stats','08_equipment','09_procurement',
    '10_record_design','11_it_infra','12_ai','15_standardization',
    '13_poc','14_operations','16_kpi',
    '99_frameworks','99_references',
  ];

  if (navEl && current) {
    const idx = order.indexOf(current);
    const siteBase = window.location.pathname.replace(/\/learning\/.*$/, '');

    if (idx > 0) {
      const prev = order[idx - 1];
      const prevBtn = document.createElement('a');
      prevBtn.href = `${siteBase}/learning/${prev}`;
      prevBtn.style.cssText = 'flex:1;padding:0.875rem 1.25rem;background:#111114;border:1px solid rgba(255,255,255,0.07);border-radius:6px;text-decoration:none;color:rgba(255,255,255,0.55);font-size:0.8rem;letter-spacing:0.05em;transition:all 0.2s;display:flex;align-items:center;gap:0.5rem;';
      prevBtn.innerHTML = '← 前のテーマ';
      prevBtn.addEventListener('mouseenter', () => { prevBtn.style.borderColor = 'rgba(200,169,110,0.3)'; prevBtn.style.color = 'rgba(255,255,255,0.8)'; });
      prevBtn.addEventListener('mouseleave', () => { prevBtn.style.borderColor = 'rgba(255,255,255,0.07)'; prevBtn.style.color = 'rgba(255,255,255,0.55)'; });
      navEl.appendChild(prevBtn);
    } else {
      navEl.appendChild(document.createElement('div'));
    }

    if (idx < order.length - 1) {
      const next = order[idx + 1];
      const nextBtn = document.createElement('a');
      nextBtn.href = `${siteBase}/learning/${next}`;
      nextBtn.style.cssText = 'flex:1;padding:0.875rem 1.25rem;background:#111114;border:1px solid rgba(255,255,255,0.07);border-radius:6px;text-decoration:none;color:rgba(255,255,255,0.55);font-size:0.8rem;letter-spacing:0.05em;transition:all 0.2s;display:flex;align-items:center;gap:0.5rem;justify-content:flex-end;';
      nextBtn.innerHTML = '次のテーマ →';
      nextBtn.addEventListener('mouseenter', () => { nextBtn.style.borderColor = 'rgba(200,169,110,0.3)'; nextBtn.style.color = 'rgba(255,255,255,0.8)'; });
      nextBtn.addEventListener('mouseleave', () => { nextBtn.style.borderColor = 'rgba(255,255,255,0.07)'; nextBtn.style.color = 'rgba(255,255,255,0.55)'; });
      navEl.appendChild(nextBtn);
    }
  }

  // ============================================
  // 6. Mark page as visited
  // ============================================
  if (currentSlug) {
    localStorage.setItem(`learning_done_${currentSlug}`, '1');
  }
</script>
