---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'データでプロセスを再設計し、価値を生む自律型仕組みを実現する。製造業DX・AI活用の実行事例サイト。',
  ogImage,
} = Astro.props;

const siteName = 'NaNi Execution Lab';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0c0c0e" />
    <meta property="og:title" content={`${title} | ${siteName}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link rel="canonical" href={Astro.url.href} />
    <title>{title} | {siteName}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500&family=Inter:wght@300;400;500&display=optional"
      rel="stylesheet"
    />
    <style>
      .skip-link:focus { top: 0 !important; }
    </style>
  </head>
  <body class="min-h-screen flex flex-col" style="background:#0c0c0e;color:#edede8;">
    <a
      href="#main-content"
      class="skip-link"
      style="position:absolute;top:-100px;left:1rem;background:#c8a96e;color:#000;padding:0.5rem 1rem;font-size:0.8rem;letter-spacing:0.1em;border-radius:0 0 4px 4px;transition:top 0.2s;z-index:999;text-decoration:none;"
    >
      コンテンツへスキップ
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
