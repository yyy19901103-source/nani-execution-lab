---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  date: string;
  type: 'blog' | 'news';
  tags?: string[];
  category?: string;
  heroImage?: string;
}

const { title, description, date, type, tags = [], category, heroImage } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const formatted = new Date(date).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
const typeLabel = type === 'blog' ? 'BLOG' : 'NEWS';
const typePath  = `${base}/${type}`;

const defaultImages = {
  blog: 'https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?auto=format&fit=crop&w=1920&q=80',
  news: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1920&q=80',
};
const bgImage = heroImage ?? defaultImages[type];
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <div style="position:relative;height:22rem;overflow:hidden;margin-top:64px;">
    <img
      src={bgImage}
      alt={title}
      loading="lazy"
      style="width:100%;height:100%;object-fit:cover;opacity:0.18;"
    />
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom,#0c0c0e 0%,rgba(12,12,14,0.1) 40%,rgba(12,12,14,0.98) 100%);"></div>
    <!-- Breadcrumb overlay -->
    <div style="position:absolute;bottom:2.5rem;left:0;right:0;max-width:1100px;margin:0 auto;padding:0 1.5rem;">
      <div style="display:flex;align-items:center;gap:0.5rem;color:rgba(255,255,255,0.25);font-size:0.68rem;letter-spacing:0.12em;margin-bottom:0.75rem;">
        <a href={`${base}/`} style="transition:color 0.2s;hover:color:#c8a96e;">TOP</a>
        <span>›</span>
        <a href={typePath} style="transition:color 0.2s;">{typeLabel}</a>
        <span>›</span>
        <span style="color:rgba(255,255,255,0.45);">{title}</span>
      </div>
    </div>
  </div>

  <!-- Article container -->
  <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;">

    <!-- Article header -->
    <header style="max-width:46rem;padding:2.5rem 0 2rem;border-bottom:1px solid rgba(255,255,255,0.06);margin-bottom:0;">
      <div style="display:flex;align-items:center;gap:0.875rem;margin-bottom:1.25rem;flex-wrap:wrap;">
        <span style="font-size:0.62rem;letter-spacing:0.2em;color:#c8a96e;padding:0.2rem 0.75rem;border:1px solid rgba(200,169,110,0.3);border-radius:12px;">{category ?? typeLabel}</span>
        <span style="font-size:0.7rem;color:rgba(255,255,255,0.3);letter-spacing:0.06em;">{formatted}</span>
      </div>
      <h1 style="font-size:clamp(1.4rem,3.5vw,2.2rem);font-weight:300;letter-spacing:0.04em;color:#edede8;line-height:1.45;margin-bottom:1rem;">{title}</h1>
      {description && <p style="color:rgba(255,255,255,0.45);font-size:0.9rem;line-height:1.85;max-width:42rem;">{description}</p>}
      {tags.length > 0 && (
        <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:1rem;">
          {tags.map(tag => (
            <span style="font-size:0.62rem;color:rgba(255,255,255,0.28);border:1px solid rgba(255,255,255,0.09);padding:0.15rem 0.6rem;border-radius:2px;">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Share button row -->
    <div style="max-width:46rem;display:flex;justify-content:flex-end;padding:0.875rem 0;border-bottom:1px solid rgba(255,255,255,0.04);">
      <button
        id="share-btn"
        style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.35rem 0.875rem;background:transparent;border:1px solid rgba(255,255,255,0.1);border-radius:4px;color:rgba(255,255,255,0.3);font-size:0.68rem;letter-spacing:0.1em;cursor:pointer;transition:all 0.2s;"
        onmouseover="this.style.borderColor='rgba(200,169,110,0.4)';this.style.color='#c8a96e'"
        onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='rgba(255,255,255,0.3)'"
      >
        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
        </svg>
        <span id="share-label">URLをコピー</span>
      </button>
    </div>

    <!-- Main article body -->
    <article class="prose-custom" style="max-width:46rem;padding:2.5rem 0 3rem;">
      <slot />
    </article>

    <!-- Back navigation -->
    <div style="max-width:46rem;padding-bottom:6rem;border-top:1px solid rgba(255,255,255,0.06);padding-top:2rem;display:flex;justify-content:space-between;align-items:center;">
      <a
        href={typePath}
        style="display:inline-flex;align-items:center;gap:0.5rem;color:rgba(255,255,255,0.3);font-size:0.72rem;letter-spacing:0.15em;transition:color 0.2s;text-decoration:none;padding:0.625rem 1rem;border:1px solid rgba(255,255,255,0.08);border-radius:4px;"
        onmouseover="this.style.color='#c8a96e';this.style.borderColor='rgba(200,169,110,0.3)'"
        onmouseout="this.style.color='rgba(255,255,255,0.3)';this.style.borderColor='rgba(255,255,255,0.08)'"
      >
        ← {typeLabel}一覧へ戻る
      </a>
    </div>

    <!-- Slot for related posts (injected by [slug].astro) -->
    <slot name="related" />

  </div>

</BaseLayout>

<script>
  // Share / copy URL
  const btn = document.getElementById('share-btn');
  const label = document.getElementById('share-label');
  btn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      if (label) {
        label.textContent = 'コピーしました ✓';
        setTimeout(() => { label.textContent = 'URLをコピー'; }, 2500);
      }
    } catch {}
  });

  // Auto-add IDs and anchor links to h2/h3 in article
  const article = document.querySelector('article.prose-custom');
  if (article) {
    article.querySelectorAll('h2, h3').forEach(heading => {
      const text = heading.textContent?.trim() ?? '';
      const id = text.toLowerCase()
        .replace(/[^\w\u3040-\u309f\u30a0-\u30ff\u4e00-\u9faf\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/^-|-$/g, '');
      if (id && !heading.id) heading.id = id;

      // Add anchor link
      const anchor = document.createElement('a');
      anchor.href = `#${id}`;
      anchor.className = 'anchor-link';
      anchor.textContent = '#';
      anchor.style.cssText = 'opacity:0;margin-left:0.5rem;color:rgba(200,169,110,0.4);font-size:0.75em;transition:opacity 0.2s;text-decoration:none;vertical-align:middle;';
      heading.appendChild(anchor);
      heading.addEventListener('mouseenter', () => anchor.style.opacity = '1');
      heading.addEventListener('mouseleave', () => anchor.style.opacity = '0');
    });

    // Lazy image loading
    article.querySelectorAll('img[loading="lazy"]').forEach(img => {
      if ((img as HTMLImageElement).complete) {
        img.classList.add('loaded');
      } else {
        img.addEventListener('load', () => img.classList.add('loaded'));
      }
    });
  }
</script>
