{
  "version": "1.0.0",
  "totalTerms": 120,
  "categories": ["EVM", "Risk", "Schedule", "Quality", "Procurement", "Agile", "Leadership", "Stakeholder", "Scope", "Closure", "Governance", "Cost"],
  "terms": [
    { "term": "PV (Planned Value)", "termJa": "計画価値", "category": "EVM", "definition": "計画通り進めた場合、ある時点までに完了予定の作業の予算価値。BCWS（Budgeted Cost of Work Scheduled）とも呼ぶ。", "relatedChapter": "2.5", "tags": ["EVM"] },
    { "term": "EV (Earned Value)", "termJa": "出来高", "category": "EVM", "definition": "実際に完了した作業の予算価値。BCWP（Budgeted Cost of Work Performed）。EV < PV なら遅延、EV > PV なら前倒し。", "relatedChapter": "2.5", "tags": ["EVM"] },
    { "term": "AC (Actual Cost)", "termJa": "実コスト", "category": "EVM", "definition": "完了した作業に実際にかかったコスト。ACWP（Actual Cost of Work Performed）。", "relatedChapter": "2.5", "tags": ["EVM"] },
    { "term": "CV (Cost Variance)", "termJa": "コスト差異", "category": "EVM", "definition": "CV = EV − AC。プラスなら予算内、マイナスなら予算超過。", "relatedChapter": "2.5", "tags": ["EVM"] },
    { "term": "SV (Schedule Variance)", "termJa": "スケジュール差異", "category": "EVM", "definition": "SV = EV − PV。プラスなら前倒し、マイナスなら遅延。", "relatedChapter": "2.5", "tags": ["EVM"] },
    { "term": "CPI (Cost Performance Index)", "termJa": "コスト効率指数", "category": "EVM", "definition": "CPI = EV / AC。1.0で計画通り、1.0未満で予算超過、1.0超で予算節約。", "relatedChapter": "2.5", "tags": ["EVM"] },
    { "term": "SPI (Schedule Performance Index)", "termJa": "スケジュール効率指数", "category": "EVM", "definition": "SPI = EV / PV。1.0で計画通り、1.0未満で遅延、1.0超で前倒し。", "relatedChapter": "2.5", "tags": ["EVM"] },
    { "term": "EAC (Estimate At Completion)", "termJa": "完了時総コスト見積", "category": "EVM", "definition": "完了時の総コスト予測。典型ケースで EAC = BAC / CPI、非典型ケースで EAC = AC + (BAC − EV)。", "relatedChapter": "2.5", "tags": ["EVM", "Forecasting"] },
    { "term": "ETC (Estimate To Complete)", "termJa": "残作業コスト見積", "category": "EVM", "definition": "現時点から完了までに必要な追加コスト。ETC = EAC − AC。", "relatedChapter": "2.5", "tags": ["EVM"] },
    { "term": "BAC (Budget At Completion)", "termJa": "完了時総予算", "category": "EVM", "definition": "プロジェクト全体の承認済み予算。スコープベースラインに対する計画値。", "relatedChapter": "2.5", "tags": ["EVM"] },
    { "term": "VAC (Variance At Completion)", "termJa": "完了時差異", "category": "EVM", "definition": "VAC = BAC − EAC。プラスなら予算内完了見込み、マイナスなら超過見込み。", "relatedChapter": "2.5", "tags": ["EVM"] },
    { "term": "TCPI (To-Complete Performance Index)", "termJa": "残作業効率指数", "category": "EVM", "definition": "TCPI = (BAC − EV) / (BAC − AC)。完了予算維持のために残作業で必要な効率。1.0超なら警告。", "relatedChapter": "2.5", "tags": ["EVM"] },

    { "term": "Risk Avoid", "termJa": "回避", "category": "Risk", "definition": "リスク事象自体を発生させない対応戦略。例: 新技術採用を取りやめる。", "relatedChapter": "2.3", "tags": ["Risk Response"] },
    { "term": "Risk Transfer", "termJa": "転嫁", "category": "Risk", "definition": "リスクの責任を第三者に移す。例: 保険加入、外注。", "relatedChapter": "2.3", "tags": ["Risk Response"] },
    { "term": "Risk Mitigate", "termJa": "軽減", "category": "Risk", "definition": "リスクの発生確率または影響を低減する。例: 冗長化、PoC実施。", "relatedChapter": "2.3", "tags": ["Risk Response"] },
    { "term": "Risk Accept", "termJa": "受容", "category": "Risk", "definition": "リスクを認識した上で対応せず、発生したら対処する。能動的（コンティンジェンシー予備）と受動的がある。", "relatedChapter": "2.3", "tags": ["Risk Response"] },
    { "term": "Risk Exploit", "termJa": "活用", "category": "Risk", "definition": "プラスリスク（機会）を確実に実現させる積極的対応。", "relatedChapter": "2.3", "tags": ["Positive Risk"] },
    { "term": "Risk Enhance", "termJa": "強化", "category": "Risk", "definition": "機会の発生確率や影響を高める対応。", "relatedChapter": "2.3", "tags": ["Positive Risk"] },
    { "term": "Risk Share", "termJa": "共有", "category": "Risk", "definition": "機会の実現確率を高めるために第三者と協力する。", "relatedChapter": "2.3", "tags": ["Positive Risk"] },
    { "term": "Contingency Reserve", "termJa": "コンティンジェンシー予備", "category": "Risk", "definition": "識別済リスクへの予備費。PMが管理。コスト基線に含まれる。", "relatedChapter": "2.5", "tags": ["Risk", "Cost"] },
    { "term": "Management Reserve", "termJa": "マネジメント予備", "category": "Risk", "definition": "未知のリスク（unknown unknowns）への予備費。スポンサーが管理。コスト基線に含まれない。", "relatedChapter": "2.5", "tags": ["Risk", "Cost"] },
    { "term": "Risk Register", "termJa": "リスク登録簿", "category": "Risk", "definition": "識別されたリスク、その分析結果、対応戦略、所有者などを記録する文書。継続更新される。", "relatedChapter": "2.3", "tags": ["Risk Documentation"] },
    { "term": "PI Matrix (Probability-Impact Matrix)", "termJa": "確率影響マトリクス", "category": "Risk", "definition": "リスクを確率と影響で2軸プロットし優先度付けするツール。高×高がトップ優先。", "relatedChapter": "2.3", "tags": ["Risk Analysis"] },
    { "term": "EMV (Expected Monetary Value)", "termJa": "期待金額価値", "category": "Risk", "definition": "EMV = 発生確率 × 影響金額。意思決定ツリー分析で使用。", "relatedChapter": "2.3", "tags": ["Quantitative Risk"] },

    { "term": "CPM (Critical Path Method)", "termJa": "クリティカルパス法", "category": "Schedule", "definition": "プロジェクト最長経路を特定する手法。CPの遅延=プロジェクト遅延。", "relatedChapter": "2.6", "tags": ["Schedule"] },
    { "term": "Critical Path", "termJa": "クリティカルパス", "category": "Schedule", "definition": "プロジェクト全体のリードタイムを決定する一連のタスク。Total Float = 0。", "relatedChapter": "2.6", "tags": ["Schedule"] },
    { "term": "Float (Slack)", "termJa": "余裕時間", "category": "Schedule", "definition": "タスクが遅れても全体納期に影響しない期間。Total Float と Free Float の2種。", "relatedChapter": "2.6", "tags": ["Schedule"] },
    { "term": "PDM (Precedence Diagramming Method)", "termJa": "プレシデンス・ダイアグラム法", "category": "Schedule", "definition": "アクティビティをノード、依存関係を矢印で表現する手法（AON: Activity-on-Node）。", "relatedChapter": "2.6", "tags": ["Schedule"] },
    { "term": "FS / SS / FF / SF", "termJa": "依存関係タイプ", "category": "Schedule", "definition": "Finish-Start（最一般）/ Start-Start / Finish-Finish / Start-Finish（極稀）の4種。", "relatedChapter": "2.6", "tags": ["Dependency"] },
    { "term": "Fast Tracking", "termJa": "ファストトラック", "category": "Schedule", "definition": "クリティカルタスクの並行実行で工期短縮。コスト増なし、リスク増。", "relatedChapter": "2.6", "tags": ["Schedule Compression"] },
    { "term": "Crashing", "termJa": "クラッシング", "category": "Schedule", "definition": "クリティカルタスクへリソース追加で工期短縮。コスト増、リスク変化少。", "relatedChapter": "2.6", "tags": ["Schedule Compression"] },
    { "term": "Resource Leveling", "termJa": "リソース平準化", "category": "Schedule", "definition": "リソース制約のもとでスケジュール調整。納期延長を許容する。", "relatedChapter": "2.6", "tags": ["Resource"] },
    { "term": "Resource Smoothing", "termJa": "リソース平滑化", "category": "Schedule", "definition": "Free Float の範囲内でリソース変動を抑える。納期不変。", "relatedChapter": "2.6", "tags": ["Resource"] },
    { "term": "Critical Chain Method", "termJa": "クリティカルチェーン法", "category": "Schedule", "definition": "リソース制約を含めたCPの拡張。バッファ（プロジェクトバッファ・フィーディングバッファ）で保護。", "relatedChapter": "2.6", "tags": ["Schedule"] },

    { "term": "COQ (Cost of Quality)", "termJa": "品質コスト", "category": "Quality", "definition": "品質達成と品質欠陥に関連する全コスト。予防+評価+内部失敗+外部失敗の4カテゴリ。", "relatedChapter": "2.7", "tags": ["Quality Cost"] },
    { "term": "QC (Quality Control)", "termJa": "品質管理", "category": "Quality", "definition": "成果物の検査による品質確認。プロダクト指向。", "relatedChapter": "2.7", "tags": ["Quality"] },
    { "term": "QA (Quality Assurance)", "termJa": "品質保証", "category": "Quality", "definition": "プロセス監査・改善による品質保証。プロセス指向。", "relatedChapter": "2.7", "tags": ["Quality"] },
    { "term": "Pareto Chart", "termJa": "パレート図", "category": "Quality", "definition": "問題頻度の80/20分析を可視化。優先対処項目の特定に使う。", "relatedChapter": "2.7", "tags": ["Quality Tools"] },
    { "term": "Fishbone Diagram", "termJa": "特性要因図（石川/フィッシュボーン）", "category": "Quality", "definition": "原因（人・機械・材料・方法・測定・環境の6M）と結果の関係を可視化。RCAの代表ツール。", "relatedChapter": "2.7", "tags": ["RCA", "Quality Tools"] },
    { "term": "Control Chart", "termJa": "管理図", "category": "Quality", "definition": "プロセス変動を時系列で可視化し、管理限界線で異常を検出する。", "relatedChapter": "2.7", "tags": ["Quality Tools", "SPC"] },
    { "term": "7 Basic Quality Tools", "termJa": "QC七つ道具", "category": "Quality", "definition": "特性要因図・チェックシート・管理図・ヒストグラム・パレート図・散布図・フローチャート。", "relatedChapter": "2.7", "tags": ["Quality Tools"] },

    { "term": "FFP (Firm Fixed Price)", "termJa": "確定金額契約", "category": "Procurement", "definition": "固定価格契約。スコープ完全確定時に最適。リスクはベンダー側。", "relatedChapter": "2.11", "tags": ["Contract"] },
    { "term": "T&M (Time and Materials)", "termJa": "実費精算契約", "category": "Procurement", "definition": "時間と材料の実費に基づく契約。スコープ不確実時。リスクはバイヤー側。", "relatedChapter": "2.11", "tags": ["Contract"] },
    { "term": "CR (Cost Reimbursable)", "termJa": "コスト払い戻し契約", "category": "Procurement", "definition": "実コスト+報酬の契約。CPFF/CPIF/CPAF等のバリエーション。研究開発向け。", "relatedChapter": "2.11", "tags": ["Contract"] },
    { "term": "CPFF (Cost Plus Fixed Fee)", "termJa": "コスト+固定報酬", "category": "Procurement", "definition": "実コスト+事前合意の固定報酬。コスト増減で報酬不変。", "relatedChapter": "2.11", "tags": ["Contract"] },
    { "term": "CPIF (Cost Plus Incentive Fee)", "termJa": "コスト+インセンティブ報酬", "category": "Procurement", "definition": "実コスト+目標達成度に応じた報酬。コスト削減動機を作る。", "relatedChapter": "2.11", "tags": ["Contract"] },
    { "term": "FP-EPA (Fixed Price with Economic Price Adjustment)", "termJa": "経済価格調整付き固定価格", "category": "Procurement", "definition": "長期契約で物価変動を反映できる条項付き固定価格契約。", "relatedChapter": "2.11", "tags": ["Contract"] },
    { "term": "SOW (Statement of Work)", "termJa": "作業範囲記述書", "category": "Procurement", "definition": "調達対象の作業内容・成果物・受入基準を記述する文書。", "relatedChapter": "2.11", "tags": ["Procurement Documents"] },
    { "term": "RFP (Request for Proposal)", "termJa": "提案依頼書", "category": "Procurement", "definition": "ベンダーから提案を募集する文書。RFQ（見積依頼）・RFI（情報依頼）と区別。", "relatedChapter": "2.11", "tags": ["Procurement Documents"] },
    { "term": "BATNA (Best Alternative to Negotiated Agreement)", "termJa": "最善代替案", "category": "Procurement", "definition": "交渉決裂時の最良代替策。BATNA明確化が交渉力を決める。", "relatedChapter": "1.8", "tags": ["Negotiation"] },
    { "term": "Make-or-Buy", "termJa": "自製/購入判断", "category": "Procurement", "definition": "コア能力・コスト・キャパシティ・知財・リスクの多次元評価で内製か外注かを判断。", "relatedChapter": "2.11", "tags": ["Procurement"] },

    { "term": "Sprint", "termJa": "スプリント", "category": "Agile", "definition": "Scrumの固定タイムボックス（通常1-4週）。期間中スコープ変更不可。", "relatedChapter": "2.13", "tags": ["Scrum"] },
    { "term": "Backlog", "termJa": "バックログ", "category": "Agile", "definition": "プロダクト or スプリント向けの作業項目リスト。優先順位付きで管理。", "relatedChapter": "2.13", "tags": ["Scrum"] },
    { "term": "Velocity", "termJa": "ベロシティ", "category": "Agile", "definition": "1スプリントでチームが完了するストーリーポイント数。予測ツール、評価指標ではない。", "relatedChapter": "2.13", "tags": ["Scrum", "Metrics"] },
    { "term": "Story Points", "termJa": "ストーリーポイント", "category": "Agile", "definition": "相対的な作業量見積。フィボナッチ数列等を使う。時間でなく複雑性。", "relatedChapter": "2.13", "tags": ["Estimation"] },
    { "term": "DoD (Definition of Done)", "termJa": "完了の定義", "category": "Agile", "definition": "ストーリーが完了とみなされる条件のチェックリスト。チーム全員で合意。", "relatedChapter": "1.12", "tags": ["Scrum", "Quality"] },
    { "term": "DoR (Definition of Ready)", "termJa": "準備完了の定義", "category": "Agile", "definition": "ストーリーがスプリント着手可能とみなされる条件。INVEST基準など。", "relatedChapter": "1.12", "tags": ["Scrum"] },
    { "term": "Product Owner", "termJa": "プロダクトオーナー", "category": "Agile", "definition": "プロダクトバックログの優先順位決定権限を持つ役割。Whatを決める。", "relatedChapter": "2.13", "tags": ["Scrum"] },
    { "term": "Scrum Master", "termJa": "スクラムマスター", "category": "Agile", "definition": "Scrumプロセスの守護者・障害除去・コーチング。サーバントリーダー的。", "relatedChapter": "1.2", "tags": ["Scrum"] },
    { "term": "Retrospective", "termJa": "レトロスペクティブ", "category": "Agile", "definition": "スプリント末の振り返り会。プロセス改善のための学習機会。", "relatedChapter": "2.16", "tags": ["Scrum"] },
    { "term": "Burndown Chart", "termJa": "バーンダウンチャート", "category": "Agile", "definition": "残作業量の時系列推移。理想線と実績線の比較で進捗監視。", "relatedChapter": "2.5", "tags": ["Scrum", "Metrics"] },
    { "term": "Burnup Chart", "termJa": "バーンアップチャート", "category": "Agile", "definition": "完了作業量とスコープの時系列推移。スコープ変動の可視化に強い。", "relatedChapter": "2.5", "tags": ["Scrum", "Metrics"] },
    { "term": "MVP (Minimum Viable Product)", "termJa": "実用最小限の製品", "category": "Agile", "definition": "学習を最大化する最小限の成果物。早期フィードバック取得用。", "relatedChapter": "2.1", "tags": ["Lean"] },
    { "term": "WIP Limit", "termJa": "仕掛り制限", "category": "Agile", "definition": "同時進行中の作業数上限。Little's Lawによりリードタイム短縮に効く。", "relatedChapter": "2.1", "tags": ["Kanban"] },
    { "term": "Little's Law", "termJa": "リトルの法則", "category": "Agile", "definition": "L=λW。仕掛り数=到着率×リードタイム。フローシステムの基本法則。", "relatedChapter": "2.1", "tags": ["Kanban", "Flow"] },
    { "term": "Information Radiator", "termJa": "情報ラジエーター", "category": "Agile", "definition": "チームの状況を可視化する物理ボード等。受動的に情報共有を促す。", "relatedChapter": "2.2", "tags": ["Visualization"] },
    { "term": "Cumulative Flow Diagram", "termJa": "累積フロー図", "category": "Agile", "definition": "各ステータスの作業数を時系列で可視化。ボトルネック発見に有効。", "relatedChapter": "2.1", "tags": ["Kanban"] },

    { "term": "Servant Leadership", "termJa": "サーバントリーダーシップ", "category": "Leadership", "definition": "指示型でなく『支援・障害除去・自律性促進』に徹するリーダーシップ。アジャイル基本。", "relatedChapter": "1.2", "tags": ["Leadership"] },
    { "term": "Situational Leadership", "termJa": "状況対応型リーダーシップ", "category": "Leadership", "definition": "メンバー成熟度に応じて指示型/コーチ型/支援型/委任型を使い分ける。", "relatedChapter": "1.2", "tags": ["Leadership"] },
    { "term": "Emotional Intelligence (EQ)", "termJa": "感情知能", "category": "Leadership", "definition": "自己認識・自己調整・社会的認識・関係管理の4軸。リーダーシップに必須。", "relatedChapter": "1.14", "tags": ["EQ"] },
    { "term": "Tuckman Model", "termJa": "タックマンモデル", "category": "Leadership", "definition": "Forming→Storming→Norming→Performing→Adjourningのチーム発達5段階モデル。", "relatedChapter": "1.6", "tags": ["Team"] },
    { "term": "5 Conflict Modes (Thomas-Kilmann)", "termJa": "対立解決5モード", "category": "Leadership", "definition": "Withdraw/Smooth/Compromise/Force/Collaborate。Collaborate（協働）が最良ケースで多い。", "relatedChapter": "1.1", "tags": ["Conflict"] },
    { "term": "GROW Model", "termJa": "GROWモデル", "category": "Leadership", "definition": "Goal/Reality/Options/Will の4ステップ。コーチング・メンタリングの代表フレーム。", "relatedChapter": "1.13", "tags": ["Mentoring", "Coaching"] },
    { "term": "SBI Feedback", "termJa": "SBIフィードバック", "category": "Leadership", "definition": "Situation-Behavior-Impactの3要素で建設的フィードバックを与える手法。", "relatedChapter": "1.13", "tags": ["Feedback"] },
    { "term": "Active Listening", "termJa": "アクティブリスニング", "category": "Leadership", "definition": "傾聴+リフレクション+質問で相手の真意を引き出す技法。", "relatedChapter": "1.9", "tags": ["Communication"] },
    { "term": "Psychological Safety", "termJa": "心理的安全性", "category": "Leadership", "definition": "意見・質問・失敗報告ができる安心感。高パフォーマンスチームの最重要要因（Google調査）。", "relatedChapter": "1.6", "tags": ["Team"] },

    { "term": "Power/Interest Grid", "termJa": "影響度/関心グリッド", "category": "Stakeholder", "definition": "ステークホルダーを2軸4象限で分類するツール。Manage Closely/Keep Satisfied/Keep Informed/Monitor。", "relatedChapter": "1.9", "tags": ["Stakeholder"] },
    { "term": "Salience Model", "termJa": "サリエンスモデル", "category": "Stakeholder", "definition": "Power/Legitimacy/Urgencyの3軸で分類。Definitive Stakeholderが最優先。", "relatedChapter": "1.9", "tags": ["Stakeholder"] },
    { "term": "Stakeholder Engagement Matrix", "termJa": "ステークホルダーエンゲージメント評価マトリックス", "category": "Stakeholder", "definition": "現在/望ましいエンゲージメントレベル（Unaware/Resistant/Neutral/Supportive/Leading）を比較。", "relatedChapter": "2.4", "tags": ["Stakeholder"] },
    { "term": "RACI Matrix", "termJa": "RACIマトリクス", "category": "Stakeholder", "definition": "Responsible/Accountable/Consulted/Informed の役割割当表。", "relatedChapter": "1.4", "tags": ["Roles"] },
    { "term": "Stakeholder Register", "termJa": "ステークホルダーレジスタ", "category": "Stakeholder", "definition": "ステークホルダー一覧・連絡先・影響度・期待・関与状況を記録する文書。", "relatedChapter": "1.9", "tags": ["Stakeholder"] },

    { "term": "WBS (Work Breakdown Structure)", "termJa": "作業分解構成", "category": "Scope", "definition": "プロジェクト全体を階層分解した成果物指向の構造。100%ルールが原則。", "relatedChapter": "2.8", "tags": ["Scope"] },
    { "term": "100% Rule", "termJa": "100%ルール", "category": "Scope", "definition": "WBSの各レベルで子要素の合計が親の100%スコープをカバーする原則。", "relatedChapter": "2.8", "tags": ["WBS"] },
    { "term": "MoSCoW", "termJa": "MoSCoW優先度", "category": "Scope", "definition": "Must/Should/Could/Won't の4分類で要件優先度を付ける手法。", "relatedChapter": "2.8", "tags": ["Requirements"] },
    { "term": "Scope Creep", "termJa": "スコープクリープ", "category": "Scope", "definition": "正式変更管理を経ずにスコープが増大する現象。失敗要因の代表。", "relatedChapter": "2.8", "tags": ["Scope"] },
    { "term": "Validate Scope", "termJa": "スコープ検証", "category": "Scope", "definition": "顧客による成果物の正式受入プロセス。", "relatedChapter": "2.8", "tags": ["Scope"] },
